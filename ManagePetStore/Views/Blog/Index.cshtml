@model IEnumerable<ManagePetStore.Models.Blog>
@{
    Layout = "_PetStoreLayout";
    ViewData["Title"] = "Blog - Cẩm nang chăm sóc thú cưng";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int totalCount = ViewBag.TotalCount ?? 0;
    string? selectedCategory = ViewBag.SelectedCategory;
    string? searchKeyword = ViewBag.SearchKeyword;
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
}

@section Styles {
    <style>
        .blog-list-hero {
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
            padding: 64px 0 48px;
            color: #fff;
        }
        .blog-filter-pill {
            display: inline-block;
            padding: 6px 18px;
            border-radius: 20px;
            font-size: .85rem;
            font-weight: 600;
            text-decoration: none;
            transition: all .2s;
            border: 2px solid transparent;
        }
        .blog-filter-pill:not(.active) {
            background: #f8fafc; color: #475569; border-color: #e2e8f0;
        }
        .blog-filter-pill:not(.active):hover {
            border-color: #f97316; color: #f97316;
        }
        .blog-filter-pill.active {
            background: #f97316; color: #fff; border-color: #f97316;
        }
        .blog-grid-card {
            border-radius: 16px;
            overflow: hidden;
            background: #fff;
            box-shadow: 0 2px 12px rgba(0,0,0,.07);
            transition: transform .25s, box-shadow .25s;
            display: flex; flex-direction: column;
            text-decoration: none; color: inherit; height: 100%;
        }
        .blog-grid-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 30px rgba(0,0,0,.13);
        }
        .blog-grid-card img {
            width: 100%; height: 200px; object-fit: cover;
        }
        .blog-grid-card-body {
            padding: 20px; flex: 1; display: flex; flex-direction: column;
        }
        .blog-grid-card .cat-badge {
            display: inline-block;
            padding: 3px 10px; border-radius: 12px;
            font-size: .75rem; font-weight: 700;
            background: #fff7ed; color: #c2410c;
            margin-bottom: 10px;
        }
        .blog-grid-card h3 {
            font-size: 1rem; font-weight: 700; line-height: 1.45;
            margin-bottom: 10px; color: #1e293b;
            display: -webkit-box; -webkit-line-clamp: 2;
            -webkit-box-orient: vertical; overflow: hidden;
        }
        .blog-grid-card p {
            font-size: .88rem; color: #64748b; line-height: 1.6;
            display: -webkit-box; -webkit-line-clamp: 3;
            -webkit-box-orient: vertical; overflow: hidden;
            flex: 1;
        }
        .blog-grid-card .card-footer-meta {
            display: flex; justify-content: space-between; align-items: center;
            margin-top: 14px; padding-top: 12px;
            border-top: 1px solid #f1f5f9; font-size: .82rem; color: #94a3b8;
        }
        .blog-read-more {
            color: #f97316; font-weight: 600; font-size: .85rem;
            transition: gap .2s;
        }
        .featured-badge {
            position: absolute; top: 12px; left: 12px;
            background: #f97316; color: #fff;
            padding: 3px 10px; border-radius: 12px;
            font-size: .75rem; font-weight: 700;
        }
    </style>
}

<!-- Hero header -->
<div class="blog-list-hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <p class="text-warning fw-semibold small mb-2 text-uppercase letter-spacing-1">
                    📝 Blog &amp; Cẩm nang
                </p>
                <h1 class="fw-bold mb-3" style="font-size: clamp(1.6rem, 3vw, 2.4rem);">
                    Kiến thức chăm sóc thú cưng
                </h1>
                <p style="color: rgba(255,255,255,.7); line-height: 1.7;">
                    Tổng hợp @totalCount bài viết từ chuyên gia — Dinh dưỡng, Sức khỏe,
                    Huấn luyện và nhiều chủ đề thú vị khác.
                </p>
            </div>
            <div class="col-lg-6">
                <form asp-controller="Blog" asp-action="Index" method="get" class="d-flex gap-2 justify-content-lg-end">
                    @if (!string.IsNullOrEmpty(selectedCategory))
                    {
                        <input type="hidden" name="category" value="@selectedCategory" />
                    }
                    <input type="text" name="search" value="@searchKeyword"
                           placeholder="Tìm kiếm bài viết..."
                           class="form-control" style="max-width:300px;border-radius:12px;" />
                    <button type="submit" class="btn btn-warning fw-semibold px-4">
                        <i class="bi bi-search"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<section class="ps-section">
    <div class="container">
        <!-- Bộ lọc thể loại -->
        @if (categories.Any())
        {
            <div class="d-flex flex-wrap gap-2 mb-5">
                <a href="/Blog" class="blog-filter-pill @(string.IsNullOrEmpty(selectedCategory) ? "active" : "")">
                    Tất cả
                </a>
                @foreach (var cat in categories)
                {
                    <a href="/Blog?category=@Uri.EscapeDataString(cat)@(!string.IsNullOrEmpty(searchKeyword) ? "&search=" + Uri.EscapeDataString(searchKeyword) : "")"
                       class="blog-filter-pill @(selectedCategory == cat ? "active" : "")">
                        @cat
                    </a>
                }
            </div>
        }

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-journal-x" style="font-size:4rem;color:#cbd5e1;"></i>
                <h4 class="mt-3 text-muted">Chưa có bài viết nào</h4>
                <p class="text-muted">
                    @if (!string.IsNullOrEmpty(searchKeyword))
                    {
                        <span>Không tìm thấy bài viết phù hợp với "<strong>@searchKeyword</strong>"</span>
                    }
                    else
                    {
                        <span>Hãy quay lại sau nhé!</span>
                    }
                </p>
                <a href="/Blog" class="btn btn-outline-primary mt-2">Xem tất cả bài viết</a>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var blog in Model)
                {
                    var excerptText = System.Text.RegularExpressions.Regex.Replace(blog.ContentBody, "<.*?>", "");
                    var excerpt = excerptText.Length > 120 ? excerptText[..120] + "..." : excerptText;

                    <div class="col-md-6 col-lg-4">
                        <a href="/Blog/@blog.Slug" class="blog-grid-card" style="position:relative;display:block;">
                            @if (blog.IsFeatured)
                            {
                                <span class="featured-badge">⭐ Nổi bật</span>
                            }
                            @if (!string.IsNullOrEmpty(blog.CoverImage))
                            {
                                <img src="@blog.CoverImage" alt="@blog.Title" loading="lazy" />
                            }
                            else
                            {
                                <div style="height:200px;background:linear-gradient(135deg,#f1f5f9,#e2e8f0);
                                            display:flex;align-items:center;justify-content:center;">
                                    <i class="bi bi-journal-text" style="font-size:3rem;color:#94a3b8;"></i>
                                </div>
                            }
                            <div class="blog-grid-card-body">
                                @if (!string.IsNullOrEmpty(blog.Category))
                                {
                                    <span class="cat-badge">@blog.Category</span>
                                }
                                <h3>@blog.Title</h3>
                                <p>@excerpt</p>
                                <div class="card-footer-meta">
                                    <span>@blog.CreatedAt.ToString("dd/MM/yyyy")</span>
                                    <span><i class="bi bi-eye me-1"></i>@blog.ViewCount.ToString("N0")</span>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>

            <!-- Phân trang -->
            @if (totalPages > 1)
            {
                <nav class="mt-5 d-flex justify-content-center">
                    <ul class="pagination">
                        <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                            <a class="page-link" href="/Blog?page=@(currentPage - 1)@(!string.IsNullOrEmpty(selectedCategory) ? "&category=" + Uri.EscapeDataString(selectedCategory) : "")">«</a>
                        </li>
                        @for (int p = 1; p <= totalPages; p++)
                        {
                            <li class="page-item @(p == currentPage ? "active" : "")">
                                <a class="page-link" href="/Blog?page=@p@(!string.IsNullOrEmpty(selectedCategory) ? "&category=" + Uri.EscapeDataString(selectedCategory) : "")">@p</a>
                            </li>
                        }
                        <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                            <a class="page-link" href="/Blog?page=@(currentPage + 1)@(!string.IsNullOrEmpty(selectedCategory) ? "&category=" + Uri.EscapeDataString(selectedCategory) : "")">»</a>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</section>
