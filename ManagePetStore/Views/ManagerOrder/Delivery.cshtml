@model ManagePetStore.Models.ManagerModels.OrderManagementPageViewModel
@{
    Layout = "_ManagerLayout";
    ViewData["Title"] = "Giao hàng";
}

<style>
    .manager-order-shell {
        display: grid;
        gap: 20px;
    }

    .manager-tab-link {
        text-decoration: none;
    }

    .manager-status-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 0.8rem;
        font-weight: 700;
    }

    .manager-status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        display: inline-block;
    }

    .manager-status-pending { color: #f2780c; }
    .manager-status-pending .manager-status-dot { background: #f2780c; }
    .manager-status-approved { color: #0066ff; }
    .manager-status-approved .manager-status-dot { background: #0066ff; }
    .manager-status-delivering { color: #2563eb; }
    .manager-status-delivering .manager-status-dot { background: #2563eb; }
    .manager-status-completed { color: #2f9e58; }
    .manager-status-completed .manager-status-dot { background: #2f9e58; }
    .manager-status-rejected, .manager-status-cancelled { color: #dc2626; }
    .manager-status-rejected .manager-status-dot, .manager-status-cancelled .manager-status-dot { background: #dc2626; }

    .manager-inline-form {
        margin: 0;
    }

    .manager-empty-state {
        padding: 48px 24px;
        text-align: center;
        color: var(--admin-text-muted);
    }

    .manager-muted-text {
        color: var(--admin-text-muted);
        font-size: 0.85rem;
        line-height: 1.5;
    }

    .manager-progress-badge {
        display: inline-flex;
        align-items: center;
        padding: 8px 12px;
        border-radius: 10px;
        font-size: 0.8rem;
        font-weight: 600;
        background: #f8fafc;
        color: #475569;
    }

    .manager-progress-badge.completed {
        background: #ecfdf5;
        color: #047857;
    }

    .manager-filter-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
    }

    .manager-search-form {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .manager-search-box {
        position: relative;
        min-width: 320px;
    }

    .manager-search-box i {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--admin-text-muted);
    }

    .manager-search-input {
        width: 100%;
        height: 44px;
        border-radius: 14px;
        border: 1px solid var(--admin-border);
        padding: 0 14px 0 42px;
        background: #fff;
        font-family: var(--admin-font);
    }

    .manager-search-input:focus {
        outline: none;
        border-color: var(--admin-primary);
        box-shadow: 0 0 0 3px rgba(242, 120, 12, 0.12);
    }

    .manager-filter-btn,
    .manager-reset-btn {
        height: 44px;
        padding: 0 16px;
        border-radius: 12px;
        font-size: 0.85rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .manager-filter-btn {
        border: none;
        background: var(--admin-primary);
        color: #fff;
    }

    .manager-reset-btn {
        border: 1px solid var(--admin-border);
        background: #fff;
        color: var(--admin-text-dark);
    }

    .manager-pagination {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        flex-wrap: wrap;
    }

    .manager-page-link {
        min-width: 40px;
        height: 40px;
        padding: 0 14px;
        border-radius: 10px;
        border: 1px solid var(--admin-border);
        background: #fff;
        color: var(--admin-text-dark);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .manager-page-link.active {
        background: var(--admin-primary);
        color: #fff;
        border-color: var(--admin-primary);
    }

    .manager-page-link.disabled {
        pointer-events: none;
        opacity: 0.45;
    }

    .manager-result-meta {
        font-size: 0.85rem;
        color: var(--admin-text-muted);
        font-weight: 600;
    }
</style>

<div class="admin-title-row">
    <div>
        <h1>Giao hàng &amp; Theo dõi hoàn thành</h1>
        <p>Màn hình này chỉ cho phép bấm giao hàng cho đơn đã phê duyệt; khi customer xác nhận đã nhận hàng, trạng thái tại đây sẽ tự chuyển sang hoàn thành.</p>
    </div>
</div>

<div class="manager-order-shell">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: 12px; font-family: 'Outfit';">
            <strong>Thành công!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: 12px; font-family: 'Outfit';">
            <strong>Lỗi!</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="admin-table-filters" style="margin-bottom: 0;">
        <div class="admin-filter-pills">
            <a asp-action="Index" class="admin-filter-pill manager-tab-link @(Model.ActiveTab == "approval" ? "active" : "")">
                Duyệt / từ chối
            </a>
            <a asp-action="Delivery" class="admin-filter-pill manager-tab-link @(Model.ActiveTab == "delivery" ? "active" : "")">
                Giao hàng / hoàn thành
            </a>
        </div>
        <div class="admin-filter-pills">
            <a asp-action="Delivery"
               asp-route-searchTerm="@Model.SearchTerm"
               asp-route-statusFilter="approved"
               class="admin-filter-pill manager-tab-link @(Model.StatusFilter == "approved" ? "active" : "")">
                Đã phê duyệt (@Model.ApprovedCount)
            </a>
            <a asp-action="Delivery"
               asp-route-searchTerm="@Model.SearchTerm"
               asp-route-statusFilter="delivering"
               class="admin-filter-pill manager-tab-link @(Model.StatusFilter == "delivering" ? "active" : "")">
                Đang giao hàng (@Model.DeliveringCount)
            </a>
            <a asp-action="Delivery"
               asp-route-searchTerm="@Model.SearchTerm"
               asp-route-statusFilter="completed"
               class="admin-filter-pill manager-tab-link @(Model.StatusFilter == "completed" ? "active" : "")">
                Đã hoàn thành (@Model.CompletedCount)
            </a>
            <a asp-action="Delivery"
               asp-route-searchTerm="@Model.SearchTerm"
               asp-route-statusFilter="all"
               class="admin-filter-pill manager-tab-link @(Model.StatusFilter == "all" ? "active" : "")">
                Tất cả (@Model.TotalCount)
            </a>
        </div>
    </div>

    <div class="manager-filter-bar">
        <form asp-action="Delivery" method="get" class="manager-search-form">
            <input type="hidden" name="statusFilter" value="@Model.StatusFilter" />
            <div class="manager-search-box">
                <i class="bi bi-search"></i>
                <input type="text"
                       name="searchTerm"
                       value="@Model.SearchTerm"
                       class="manager-search-input"
                       placeholder="Tìm theo mã đơn, khách hàng, SĐT..." />
            </div>
            <button type="submit" class="manager-filter-btn">Lọc</button>
            @if (!string.IsNullOrWhiteSpace(Model.SearchTerm) || Model.StatusFilter != "all")
            {
                <a asp-action="Delivery" class="manager-reset-btn">Xóa lọc</a>
            }
        </form>

        <div class="manager-result-meta">
            Hiển thị @Model.Orders.Count / @Model.TotalFilteredItems đơn hàng
        </div>
    </div>

    <div class="admin-table-container">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Mã đơn</th>
                    <th>Khách hàng</th>
                    <th>Thời gian đặt</th>
                    <th>Tổng tiền</th>
                    <th>Thanh toán</th>
                    <th>Trạng thái</th>
                    <th>Tiến độ / thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Orders.Any())
                {
                    <tr>
                        <td colspan="7" class="manager-empty-state">Không có đơn nào trong màn giao hàng / hoàn thành.</td>
                    </tr>
                }
                @foreach (var order in Model.Orders)
                {
                    <tr>
                        <td>
                            <strong style="color: var(--admin-primary);">@order.DisplayOrderId</strong>
                        </td>
                        <td>
                            <div style="font-weight: 600;">@order.CustomerName</div>
                            <div class="manager-muted-text">SĐT: @(string.IsNullOrWhiteSpace(order.CustomerPhone) ? "Chưa có" : order.CustomerPhone)</div>
                        </td>
                        <td>
                            <span class="manager-muted-text">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
                        </td>
                        <td>
                            <strong>@order.Total.ToString("N0")đ</strong>
                        </td>
                        <td>
                            <span class="manager-muted-text">@order.PaymentMethod</span>
                        </td>
                        <td>
                            <span class="manager-status-pill manager-status-@order.StatusKey">
                                <span class="manager-status-dot"></span>
                                @order.StatusLabel
                            </span>
                        </td>
                        <td>
                            @if (order.CanShip)
                            {
                                <form asp-action="Ship" method="post" class="manager-inline-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="orderId" value="@order.OrderId" />
                                    <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                                    <input type="hidden" name="statusFilter" value="@Model.StatusFilter" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <button type="submit" class="admin-btn-primary" style="padding: 6px 16px; font-size: 0.8rem; border-radius: 8px; background-color: #2563eb; display:inline-flex;">
                                        Giao hàng
                                    </button>
                                </form>
                            }
                            else if (order.StatusKey == "delivering")
                            {
                                <span class="manager-progress-badge">Chờ customer xác nhận đã nhận hàng</span>
                            }
                            else
                            {
                                <span class="manager-progress-badge completed">Đơn đã hoàn thành</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="manager-pagination" aria-label="Phân trang giao hàng">
            <a asp-action="Delivery"
               asp-route-searchTerm="@Model.SearchTerm"
               asp-route-statusFilter="@Model.StatusFilter"
               asp-route-page="@(Model.Page - 1)"
               class="manager-page-link @(Model.HasPreviousPage ? "" : "disabled")">
                Trước
            </a>

            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <a asp-action="Delivery"
                   asp-route-searchTerm="@Model.SearchTerm"
                   asp-route-statusFilter="@Model.StatusFilter"
                   asp-route-page="@i"
                   class="manager-page-link @(i == Model.Page ? "active" : "")">
                    @i
                </a>
            }

            <a asp-action="Delivery"
               asp-route-searchTerm="@Model.SearchTerm"
               asp-route-statusFilter="@Model.StatusFilter"
               asp-route-page="@(Model.Page + 1)"
               class="manager-page-link @(Model.HasNextPage ? "" : "disabled")">
                Sau
            </a>
        </nav>
    }
</div>
