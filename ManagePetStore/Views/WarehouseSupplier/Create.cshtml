@model ManagePetStore.Models.Supplier
@{
    ViewData["Title"] = "Thêm Nhà Cung Cấp";
    Layout = "~/Views/Shared/_WarehouseLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <h2 class="mb-0 text-primary"><i class="fas fa-plus-circle text-primary me-2"></i>Thêm Nhà Cung Cấp</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0 mb-0 mt-2">
                    <li class="breadcrumb-item"><a asp-action="Index">Danh sách</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Thêm mới</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="card shadow border-0 rounded-3 max-w-800">
        <div class="card-body p-4">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label fw-bold">Tên nhà cung cấp <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="Nhập tên nhà cung cấp..." />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Phone" class="form-label fw-bold">Số điện thoại</label>
                        <input asp-for="Phone" class="form-control" placeholder="Nhập số điện thoại..." />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-bold">Email</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="Nhập email..." />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Danh mục cung cấp</label>
                        <select name="categoryIds" class="form-select" multiple asp-items="ViewBag.Categories" style="height: 100px;">
                        </select>
                        <div class="form-text text-muted">Giữ phím Ctrl (hoặc Cmd) để chọn nhiều danh mục.</div>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Address" class="form-label fw-bold">Địa chỉ</label>
                    <textarea asp-for="Address" class="form-control" rows="2" placeholder="Nhập địa chỉ..."></textarea>
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>

                <div class="mb-4 form-check form-switch">
                    <input class="form-check-input" type="checkbox" asp-for="IsActive" checked>
                    <label class="form-check-label" asp-for="IsActive">Đang hoạt động</label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i> Lưu thông tin</button>
                    <a asp-action="Index" class="btn btn-light border">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

