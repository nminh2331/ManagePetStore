@model ManagePetStore.Models.CustomerModels.ForgotPasswordViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quên mật khẩu - Pet Store</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body class="auth-body">
    <div class="auth-wrapper">
        <div class="auth-left">
            <div class="auth-left-content">
                <div class="auth-puppy-frame">
                    <img src="~/images/cute_puppy.png" alt="Pet Store Puppy" class="auth-puppy-img" />
                </div>
                <h2>Khôi phục <span>mật khẩu</span></h2>
                <p>Nhập email đăng ký tài khoản để nhận mã OTP xác thực.</p>
            </div>
        </div>

        <div class="auth-right">
            <div class="auth-form-container">
                <div class="auth-header">
                    <h1>Quên mật khẩu</h1>
                    <p>Vui lòng nhập Gmail bạn đã dùng để đăng ký tài khoản PetStore.</p>
                </div>

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="auth-alert auth-alert-danger" style="border-radius: 12px; margin-bottom: 20px;">
                        @TempData["ErrorMessage"]
                    </div>
                }

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="auth-alert auth-alert-danger">
                        <div asp-validation-summary="All" style="list-style-type: none; padding: 0; margin: 0;"></div>
                    </div>
                }

                <form asp-action="ForgotPassword" method="post">
                    @Html.AntiForgeryToken()

                    <div class="auth-input-group">
                        <label class="auth-input-label">Email đăng ký *</label>
                        <div class="auth-input-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                            <input type="email"
                                   name="email"
                                   class="auth-input-field"
                                   placeholder="example@petstore.com"
                                   value="@Model.Email"
                                   required
                                   autocomplete="email" />
                        </div>
                    </div>

                    <button type="submit" class="auth-btn-submit">
                         Xác Thực Gmail
                    </button>
                </form>

                <div class="auth-footer-link">
                    <a asp-action="Login">Quay lại đăng nhập</a>
                    &nbsp;|&nbsp;
                    <a asp-action="Register">Đăng ký tài khoản</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
