@model ManagePetStore.Models.CustomerModels.ForgotPasswordVerifyOtpViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Xác thực OTP - Quên mật khẩu</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body class="auth-body">
    <div class="auth-wrapper">
        <div class="auth-left">
            <div class="auth-left-content">
                <div class="auth-puppy-frame">
                    <img src="~/images/cute_puppy.png" alt="Pet Store Puppy" class="auth-puppy-img" />
                </div>
                <h2>Xác thực <span>Email</span></h2>
                <p>Nhập mã OTP đã gửi đến email của bạn để tiếp tục đặt lại mật khẩu.</p>
            </div>
        </div>

        <div class="auth-right" style="padding-top: 30px; padding-bottom: 30px;">
            <div class="auth-form-container">
                <div class="auth-header" style="margin-bottom: 25px;">
                    <h1>Nhập mã OTP</h1>
                    <p>Mã đã gửi đến: <strong>@Model.Email</strong></p>
                </div>

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="auth-alert auth-alert-danger" style="border-radius: 12px; margin-bottom: 20px;">
                        @TempData["ErrorMessage"]
                    </div>
                }

                @if (TempData["OtpSentMessage"] != null)
                {
                    <div class="auth-alert auth-alert-success" style="border-radius: 12px; margin-bottom: 20px;">
                        @TempData["OtpSentMessage"]
                    </div>
                }

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="auth-alert auth-alert-danger">
                        <div asp-validation-summary="All" style="list-style-type: none; padding: 0; margin: 0;"></div>
                    </div>
                }

                <form asp-action="ForgotPasswordVerifyOtp" method="post">
                    @Html.AntiForgeryToken()

                    <div class="auth-input-group">
                        <label class="auth-input-label">Mã OTP (6 số) *</label>
                        <div class="auth-input-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                            </svg>
                            <input type="text"
                                   name="otpCode"
                                   class="auth-input-field"
                                   placeholder="123456"
                                   maxlength="6"
                                   inputmode="numeric"
                                   pattern="[0-9]{6}"
                                   value="@Model.OtpCode"
                                   required
                                   style="letter-spacing: 6px; font-size: 20px; font-weight: 700; text-align: center;" />
                        </div>
                    </div>

                    <button type="submit" class="auth-btn-submit" style="margin-top: 15px;">
                        Xác nhận OTP
                    </button>
                </form>

                <form asp-action="ResendForgotPasswordOtp" method="post" style="margin-top: 12px;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn w-100 py-3" style="background: transparent; border: 2px solid #F2780C; color: #F2780C; font-weight: 600; border-radius: 12px;">
                        Gửi lại mã OTP
                    </button>
                </form>

                <div class="auth-footer-link">
                    <a asp-action="ForgotPassword">Quay lại nhập email</a>
                    &nbsp;|&nbsp;
                    <a asp-action="Login">Đăng nhập</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
