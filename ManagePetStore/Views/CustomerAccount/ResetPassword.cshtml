@model ManagePetStore.Models.CustomerModels.ResetPasswordViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đặt lại mật khẩu - Pet Store</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body class="auth-body">
    <div class="auth-wrapper">
        <div class="auth-left">
            <div class="auth-left-content">
                <div class="auth-puppy-frame">
                    <img src="~/images/cute_puppy.png" alt="Pet Store Puppy" class="auth-puppy-img" />
                </div>
                <h2>Đặt lại <span>mật khẩu</span></h2>
                <p>Tạo mật khẩu mới cho tài khoản <strong>@Model.Email</strong>.</p>
            </div>
        </div>

        <div class="auth-right">
            <div class="auth-form-container">
                <div class="auth-header">
                    <h1>Mật khẩu mới</h1>
                    <p>Nhập và xác nhận mật khẩu mới của bạn.</p>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="auth-alert auth-alert-danger">
                        <div asp-validation-summary="All" style="list-style-type: none; padding: 0; margin: 0;"></div>
                    </div>
                }

                <form asp-action="ResetPassword" method="post">
                    @Html.AntiForgeryToken()

                    <div class="auth-input-group">
                        <label class="auth-input-label">Mật khẩu mới *</label>
                        <div class="auth-input-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                            </svg>
                            <input type="password"
                                   name="newPassword"
                                   id="reset-new-password"
                                   class="auth-input-field"
                                   placeholder="........"
                                   required
                                   autocomplete="new-password" />
                            <button type="button" class="auth-password-toggle" onclick="togglePasswordVisibility('reset-new-password')">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" id="reset-new-password-eye">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                </svg>
                            </button>
                        </div>
                    </div>

                    <div class="auth-input-group">
                        <label class="auth-input-label">Xác nhận mật khẩu mới *</label>
                        <div class="auth-input-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                            </svg>
                            <input type="password"
                                   name="confirmNewPassword"
                                   id="reset-confirm-password"
                                   class="auth-input-field"
                                   placeholder="........"
                                   required
                                   autocomplete="new-password" />
                            <button type="button" class="auth-password-toggle" onclick="togglePasswordVisibility('reset-confirm-password')">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" id="reset-confirm-password-eye">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                </svg>
                            </button>
                        </div>
                    </div>

                    <button type="submit" class="auth-btn-submit">
                        Đổi mật khẩu
                    </button>
                </form>

                <div class="auth-footer-link">
                    <a asp-action="Login">Quay lại đăng nhập</a>
                </div>
            </div>
        </div>
    </div>

    <script>
        function togglePasswordVisibility(id) {
            var input = document.getElementById(id);
            var eyeIcon = document.getElementById(id + '-eye');
            if (input.type === "password") {
                input.type = "text";
                eyeIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.542 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />';
            } else {
                input.type = "password";
                eyeIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />';
            }
        }
    </script>
</body>
</html>

