@{
    ViewData["Title"] = "Trang Nhân Viên Thu Ngân";
}

<div class="container py-5" style="font-family: 'Outfit', sans-serif;">
    <div class="card border-0 shadow-sm p-5" style="border-radius: 20px; background: linear-gradient(135deg, #134e5e 0%, #71b280 100%); color: #ffffff;">
        <div class="row align-items-center">
            <div class="col-md-8">
                <span class="badge bg-warning text-dark mb-3 px-3 py-2" style="font-size: 0.8rem; font-weight: 600; border-radius: 20px;">PHÂN HỆ THU NGÂN</span>
                <h1 class="display-4 font-weight-bold" style="font-weight: 700;">Xin chào, @User.FindFirst("FullName")?.Value!</h1>
                <p class="lead" style="opacity: 0.9;">Bạn đang đăng nhập dưới quyền <strong>Cashier (Thu ngân)</strong>. Tại đây bạn có thể lập hóa đơn thanh toán cho khách hàng mua sản phẩm hoặc sử dụng dịch vụ tại Pet Store.</p>
                <hr class="my-4" style="background-color: rgba(255,255,255,0.2);">
                <div class="d-flex gap-3 flex-wrap">
                    <a href="/CustomerAccount/Profile" class="btn btn-warning px-4 py-2 text-dark font-weight-bold" style="border-radius: 10px; font-weight: 600;">
                        Xem Thông Tin Cá Nhân
                    </a>
                    <form asp-controller="CustomerAccount" asp-action="Logout" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-outline-light px-4 py-2" style="border-radius: 10px; font-weight: 600;">
                            Đăng xuất
                        </button>
                    </form>
                </div>
            </div>
            <div class="col-md-4 text-center d-none d-md-block">
                <svg xmlns="http://www.w3.org/2000/svg" width="180" height="180" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="opacity: 0.2;">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
        </div>
    </div>
</div>

