<!-- Chat Bubble Button -->
<div id="ps-chat-bubble" class="ps-chat-bubble" onclick="toggleChatPopup()">
    <i class="bi bi-chat-dots-fill"></i>
    <span class="ps-chat-badge d-none" id="chatNotificationBadge"></span>
</div>

<!-- Chat Popup Container -->
<div id="ps-chat-popup" class="ps-chat-popup d-none">
    <!-- Header -->
    <div class="ps-chat-header">
        <div class="d-flex align-items-center gap-2">
            <div class="ps-chat-header-avatar">
                <i class="bi bi-headset"></i>
            </div>
            <div>
                <div class="fw-bold fs-6">Hỗ trợ trực tuyến</div>
                <div class="ps-chat-status" id="chatSupportStatus">
                    <span class="status-dot online"></span> Sẵn sàng trợ giúp
                </div>
            </div>
        </div>
        <button type="button" class="btn-close btn-close-white" onclick="toggleChatPopup()" aria-label="Close"></button>
    </div>

    <!-- Body -->
    <div class="ps-chat-body" id="chatMessagesBody">
        <!-- Messages will be rendered here dynamically -->
        <div class="text-center text-muted my-5" id="chatLoadingSpinner">
            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
            <div class="mt-2 small">Đang tải lịch sử trò chuyện...</div>
        </div>
    </div>

    <!-- Footer / Input Form -->
    <div class="ps-chat-footer" id="chatInputArea">
        <form id="chatForm" onsubmit="sendChatMessage(event)" class="d-flex gap-2 w-100">
            <input type="text" id="chatMessageInput" class="form-control form-control-sm"
                   placeholder="Nhập tin nhắn..." autocomplete="off" required />
            <button type="submit" class="btn btn-primary btn-sm ps-chat-send-btn">
                <i class="bi bi-send-fill"></i>
            </button>
        </form>
    </div>
</div>

<!-- CSS cho Chat Bubble & Popup -->
<style>
    /* Chat Bubble Button */
    .ps-chat-bubble {
        position: fixed;
        bottom: 24px;
        right: 24px;
        width: 60px;
        height: 60px;
        background-color: #f97316;
        color: #fff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        box-shadow: 0 4px 16px rgba(249, 115, 22, 0.4);
        cursor: pointer;
        z-index: 1050;
        transition: transform 0.25s, background-color 0.25s;
    }
    .ps-chat-bubble:hover {
        transform: scale(1.08);
        background-color: #ea580c;
    }
    .ps-chat-badge {
        position: absolute;
        top: 2px;
        right: 2px;
        background-color: #ef4444;
        color: #fff;
        font-size: 10px;
        font-weight: 700;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid #fff;
    }

    /* Chat Popup Window */
    .ps-chat-popup {
        position: fixed;
        bottom: 96px;
        right: 24px;
        width: 360px;
        height: 480px;
        background-color: #fff;
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.15);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        z-index: 1050;
        border: 1px solid #f1f5f9;
        transition: all 0.3s ease;
    }
    
    .ps-chat-popup.d-none {
        display: none !important;
        opacity: 0;
        transform: translateY(20px);
    }

    /* Header */
    .ps-chat-header {
        background: linear-gradient(135deg, #f97316, #ea580c);
        color: #fff;
        padding: 14px 18px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .ps-chat-header-avatar {
        width: 36px;
        height: 36px;
        background-color: rgba(255,255,255,0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }
    .ps-chat-status {
        font-size: 11px;
        color: rgba(255,255,255,0.85);
        display: flex;
        align-items: center;
        gap: 4px;
        margin-top: 2px;
    }
    .status-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        display: inline-block;
    }
    .status-dot.online {
        background-color: #22c55e;
        box-shadow: 0 0 8px #22c55e;
    }
    .status-dot.waiting {
        background-color: #fbbf24;
    }

    /* Body */
    .ps-chat-body {
        flex: 1;
        padding: 16px;
        overflow-y: auto;
        background-color: #f8fafc;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    /* Message Item bubbles */
    .chat-msg-item {
        display: flex;
        flex-direction: column;
        max-width: 75%;
    }
    .chat-msg-item.self {
        align-self: flex-end;
    }
    .chat-msg-item.other {
        align-self: flex-start;
    }
    
    .chat-msg-bubble {
        padding: 10px 14px;
        border-radius: 14px;
        font-size: 13.5px;
        line-height: 1.45;
        word-break: break-word;
    }
    .chat-msg-item.self .chat-msg-bubble {
        background-color: #f97316;
        color: #fff;
        border-bottom-right-radius: 2px;
    }
    .chat-msg-item.other .chat-msg-bubble {
        background-color: #e2e8f0;
        color: #1e293b;
        border-bottom-left-radius: 2px;
    }
    .chat-msg-time {
        font-size: 10px;
        color: #94a3b8;
        margin-top: 4px;
        align-self: flex-end;
    }
    .chat-msg-item.other .chat-msg-time {
        align-self: flex-start;
    }

    /* System notifications inside chat body */
    .chat-system-notify {
        align-self: center;
        background-color: #f1f5f9;
        color: #64748b;
        font-size: 11px;
        padding: 4px 12px;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        text-align: center;
        max-width: 90%;
        margin: 4px 0;
    }

    /* Footer */
    .ps-chat-footer {
        padding: 12px;
        background-color: #fff;
        border-top: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
    }
    .ps-chat-send-btn {
        background-color: #f97316;
        border-color: #f97316;
        padding-left: 12px;
        padding-right: 12px;
    }
    .ps-chat-send-btn:hover {
        background-color: #ea580c;
        border-color: #ea580c;
    }

    /* Scrollbar */
    #chatMessagesBody::-webkit-scrollbar {
        width: 6px;
    }
    #chatMessagesBody::-webkit-scrollbar-track {
        background: #f1f5f9;
    }
    #chatMessagesBody::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 3px;
    }
</style>

<!-- Script logic cho Client (Customer) -->
<script>
    let chatConnection = null;
    let currentUserInfo = null;
    let isChatOpen = false;
    let hasLoadedHistory = false;

    function ensureSignalRLoaded(callback) {
        if (typeof signalR !== 'undefined') {
            callback();
            return;
        }
        // Thử tải từ nguồn local trước để đảm bảo mượt mà không phụ thuộc CDN bên ngoài
        const script = document.createElement('script');
        script.src = "/js/signalr.min.js";
        script.onload = () => {
            callback();
        };
        script.onerror = () => {
            console.warn("Không thể tải SignalR local, thử tải từ CDN dự phòng...");
            const cdnScript = document.createElement('script');
            cdnScript.src = "https://cdn.jsdelivr.net/npm/@@microsoft/signalr/dist/browser/signalr.min.js";

            cdnScript.onload = () => {
                callback();
            };
            cdnScript.onerror = () => {
                console.error("Không thể tải thư viện SignalR từ mọi nguồn.");
            };
            document.head.appendChild(cdnScript);
        };
        document.head.appendChild(script);
    }


    document.addEventListener("DOMContentLoaded", function () {
        // Lấy thông tin user hiện tại trước
        fetch('/api/ChatApi/me')
            .then(res => res.json())
            .then(data => {
                currentUserInfo = data;
                if (data.isAuthenticated) {
                    ensureSignalRLoaded(() => {
                        initSignalRChat(data.userId);
                    });
                }
            })
            .catch(err => console.error("Lỗi xác thực người dùng chat:", err));
    });



    // =========================================================================
    // KHỞI TẠO SIGNALR CONNECTION
    // =========================================================================
    function initSignalRChat(userId) {
        // Chỉ khách hàng (RoleId = 5) mới mở bong bóng chat. Manager và Admin sẽ dùng Dashboard khác
        if (currentUserInfo.roleId === 6 || currentUserInfo.roleId === 1) {
            // Ẩn hoàn toàn chat bubble đối với nhân viên (vì họ dùng dashboard riêng)
            const bubble = document.getElementById("ps-chat-bubble");
            if (bubble) bubble.classList.add("d-none");
            return;
        }

        // Tạo kết nối
        chatConnection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .withAutomaticReconnect()
            .build();

        // Lắng nghe ReceiveMessage
        chatConnection.on("ReceiveMessage", function (msg) {
            if (isChatOpen) {
                renderChatMessage(msg);
                scrollToBottom();
            } else {
                // Tăng số lượng tin nhắn thông báo chưa đọc ở bubble
                const badge = document.getElementById("chatNotificationBadge");
                badge.classList.remove("d-none");
                let count = parseInt(badge.textContent || "0") + 1;
                badge.textContent = count;
            }
        });

        // Lắng nghe thay đổi trạng thái
        chatConnection.on("SessionStatusChanged", function (statusInfo) {
            renderSystemMessage(statusInfo.message);
            updateStatusDot(statusInfo.status);
            scrollToBottom();
        });

        // Start connection
        chatConnection.start()
            .then(() => {
                // Gửi yêu cầu tham gia group của chính Customer này
                chatConnection.invoke("JoinGroup", userId)
                    .catch(err => console.error("Lỗi join SignalR Group:", err));
            })
            .catch(err => console.error("Lỗi khởi động SignalR Chat:", err));
    }

    // =========================================================================
    // MỞ/ĐÓNG POPUP CHAT
    // =========================================================================
    function toggleChatPopup() {
        const popup = document.getElementById("ps-chat-popup");
        isChatOpen = !isChatOpen;

        if (isChatOpen) {
            popup.classList.remove("d-none");
            // Clear thông báo badge đỏ ở bubble
            const badge = document.getElementById("chatNotificationBadge");
            badge.classList.add("d-none");
            badge.textContent = "";

            if (!currentUserInfo || !currentUserInfo.isAuthenticated) {
                // Hiển thị yêu cầu đăng nhập
                renderRequireLogin();
                return;
            }

            // Load lịch sử tin nhắn lần đầu mở ra
            if (!hasLoadedHistory) {
                loadChatHistory(currentUserInfo.userId);
            } else {
                scrollToBottom();
            }
        } else {
            popup.classList.add("d-none");
        }
    }

    // =========================================================================
    // LOAD LỊCH SỬ TIN NHẮN (API 50 TIN GẦN NHẤT)
    // =========================================================================
    function loadChatHistory(customerId) {
        const body = document.getElementById("chatMessagesBody");

        fetch(`/api/ChatApi/messages/${customerId}`)
            .then(res => {
                if (!res.ok) throw new Error("Không thể tải tin nhắn.");
                return res.json();
            })

            .then(messages => {
                // Xóa loading spinner
                body.innerHTML = "";
                hasLoadedHistory = true;

                if (messages.length === 0) {
                    renderSystemMessage("Hệ thống: Bắt đầu gửi tin nhắn để gặp hỗ trợ viên.");
                } else {
                    let lastSessionId = 0;
                    messages.forEach(m => {
                        // Thêm đường phân tách nhỏ nếu đổi phiên chat
                        if (lastSessionId !== 0 && lastSessionId !== m.sessionId) {
                            renderSystemMessage("--- Phiên trò chuyện trước ---");
                        }
                        lastSessionId = m.sessionId;

                        renderChatMessage({
                            senderId: m.senderId,
                            messageText: m.messageText,
                            sentAt: m.sentAt
                        });
                    });
                }
                scrollToBottom();
            })
            .catch(err => {
                body.innerHTML = `<div class="text-center text-danger my-5 small">${err.message}</div>`;
            });
    }

    // =========================================================================
    // GỬI TIN NHẮN QUA SIGNALR HUB
    // =========================================================================
    function sendChatMessage(event) {
        event.preventDefault();
        const input = document.getElementById("chatMessageInput");
        const text = input.value.trim();
        if (!text || !chatConnection) return;

        chatConnection.invoke("SendMessage", currentUserInfo.userId, text)
            .then(() => {
                input.value = "";
            })
            .catch(err => {
                console.error("Gửi tin nhắn thất bại:", err);
                renderSystemMessage("Lỗi: Không thể gửi tin nhắn.");
            });
    }

    // =========================================================================
    // UTILS - VẼ TIN NHẮN TRÊN UI
    // =========================================================================
    function renderChatMessage(msg) {
        const body = document.getElementById("chatMessagesBody");
        const isSelf = msg.senderId === currentUserInfo.userId;
        const msgClass = isSelf ? "self" : "other";

        const msgDiv = document.createElement("div");
        msgDiv.className = `chat-msg-item ${msgClass}`;

        const timeFormatted = new Date(msg.sentAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

        msgDiv.innerHTML = `
            <div class="chat-msg-bubble shadow-sm">${escapeHTML(msg.messageText)}</div>
            <div class="chat-msg-time">${timeFormatted}</div>
        `;

        body.appendChild(msgDiv);
    }

    function renderSystemMessage(text) {
        const body = document.getElementById("chatMessagesBody");
        const div = document.createElement("div");
        div.className = "chat-system-notify";
        div.textContent = text;
        body.appendChild(div);
    }

    function renderRequireLogin() {
        const body = document.getElementById("chatMessagesBody");
        body.innerHTML = `
            <div class="text-center my-auto p-4">
                <i class="bi bi-shield-lock-fill text-warning" style="font-size: 3rem;"></i>
                <h6 class="fw-bold mt-3">Yêu cầu đăng nhập</h6>
                <p class="text-muted small">Vui lòng đăng nhập tài khoản Khách hàng để bắt đầu chat trực tiếp với hỗ trợ viên.</p>
                <a href="/Customer/Account/Login" class="btn btn-warning btn-sm w-100 fw-semibold mt-2">Đăng nhập ngay</a>
            </div>
        `;
        // Ẩn khung input
        document.getElementById("chatInputArea").classList.add("d-none");
    }

    function updateStatusDot(status) {
        const dot = document.querySelector("#chatSupportStatus .status-dot");
        if (!dot) return;
        dot.className = "status-dot";
        if (status === "Waiting") {
            dot.classList.add("waiting");
        } else if (status === "Active") {
            dot.classList.add("online");
        }
    }

    function scrollToBottom() {
        const body = document.getElementById("chatMessagesBody");
        body.scrollTop = body.scrollHeight;
    }

    function escapeHTML(str) {
        return str.replace(/[&<>'"]/g, 
            tag => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[tag] || tag)
        );
    }
</script>
