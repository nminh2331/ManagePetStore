@model ManagePetStore.Areas.Customer.Models.CustomerNotificationMenuViewModel

@if (Model.IsCustomer)
{
    <div class="ps-notification" data-notification-root>
        @Html.AntiForgeryToken()
        <button class="ps-icon-btn" type="button" aria-label="Thông báo" aria-expanded="false" data-notification-toggle>
            <i class="bi bi-bell"></i>
            <span class="ps-badge ps-badge-red @(Model.UnreadCount == 0 ? "d-none" : "")" data-notification-count>@(Model.UnreadCount > 99 ? "99+" : Model.UnreadCount)</span>
        </button>
        <div class="ps-notification-menu" data-notification-menu hidden>
            <div class="ps-notification-head">
                <strong>Thông báo chăm sóc</strong>
                <div class="ps-notification-head-actions">
                    <button type="button" class="ps-notification-clear-all @(Model.Items.Count == 0 ? "d-none" : "")" data-notification-clear-all title="Xóa tất cả thông báo">Xóa tất cả</button>
                    <a href="/Customer/Notifications">Xem tất cả</a>
                </div>
            </div>
            <div class="ps-notification-list" data-notification-list>
                @if (Model.Items.Count == 0)
                {
                    <p class="ps-notification-empty" data-notification-empty>Chưa có thông báo mới.</p>
                }
                else
                {
                    @foreach (var item in Model.Items)
                    {
                        <div class="ps-notification-item-wrapper" data-notification-id="@item.NotificationId">
                            <a class="ps-notification-item @(!item.IsRead ? "is-unread" : "")" href="/Customer/Notifications/Open/@item.NotificationId">
                                <strong>@item.DisplayTitle</strong>
                                <span>@item.DisplayMessage</span>
                                <time>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</time>
                            </a>
                            <button type="button" class="ps-notification-delete-btn" data-notification-delete="@item.NotificationId" title="Xóa thông báo">&times;</button>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
    <div class="ps-care-toast" data-care-toast hidden>
        <i class="bi bi-bell-fill"></i>
        <div><strong data-care-toast-title></strong><span data-care-toast-message></span></div>
        <a data-care-toast-link href="#">Xem</a>
    </div>
}
