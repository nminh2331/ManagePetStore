<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PetStore</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/homepage.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/customer-notifications.css" asp-append-version="true" />
    <style>
        /* CSS cho phần Live Search Suggestions */
        .ps-search { position: relative; }
        .search-suggestions-box {
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.15);
            margin-top: 8px;
            z-index: 1050;
            overflow: hidden;
            border: 1px solid #eee;
        }
        .suggestion-item {
            display: flex;
            align-items: center;
            padding: 10px 15px;
            text-decoration: none;
            color: #333;
            border-bottom: 1px solid #f5f5f5;
            transition: background 0.2s;
        }
        .suggestion-item:hover { background: #f9fbf9; }
        .suggestion-img {
            width: 40px; height: 40px;
            border-radius: 6px;
            object-fit: cover;
            margin-right: 12px;
        }
        .suggestion-info { flex: 1; }
        .suggestion-title {
            font-size: 0.9rem; font-weight: 600;
            margin: 0 0 4px 0;
            display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;
        }
        .suggestion-price { font-size: 0.85rem; color: #10b981; font-weight: 700; margin: 0; }
        .suggestion-type {
            font-size: 0.7rem; background: #e8f5e9; color: #2d6a4f;
            padding: 2px 6px; border-radius: 4px; margin-left: 8px;
        }
        .search-view-all {
            display: block; text-align: center; padding: 10px;
            background: #f8faf9; color: #10b981; font-weight: 600;
            text-decoration: none; font-size: 0.9rem;
        }
        .search-view-all:hover { background: #e8f5e9; color: #2d6a4f; }
        .search-loading { padding: 15px; text-align: center; color: #777; font-size: 0.9rem; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="petstore-body">
    <!-- Header -->
    <header class="ps-header">
        <div class="container-fluid ps-header-inner">
            <a class="ps-logo" asp-area="" asp-controller="Home" asp-action="Index">
                <span class="ps-logo-icon"><i class="bi bi-cart3"></i></span>
                <span class="ps-logo-text">PetStore</span>
            </a>

            <!-- Chuyển form search về ProductController để dùng logic search mới (bỏ dấu, bắt lỗi khoảng trắng) -->
            <form class="ps-search" id="headerSearchForm" asp-area="" asp-controller="Product" asp-action="Index" method="get">
                <i class="bi bi-search"></i>
                <input type="text" id="headerSearchInput" name="search" value="@(ViewBag.SearchKeyword ?? ViewBag.Search)" placeholder="Tìm sản phẩm, dịch vụ cho thú cưng..." autocomplete="off" />
                @if (!string.IsNullOrEmpty(ViewBag.SelectedCategorySlug as string))
                {
                    <input type="hidden" name="category" value="@ViewBag.SelectedCategorySlug" />
                }
                
                <!-- Box Suggestions -->
                <div id="searchSuggestionsBox" class="search-suggestions-box d-none">
                    <div id="searchSuggestionsList"></div>
                    <a href="#" id="viewAllSearchBtn" class="search-view-all">Xem tất cả kết quả</a>
                </div>
            </form>

            <div class="ps-header-actions">
                <!-- Thêm link Sản phẩm chung cho mọi người -->
                <a class="ps-admin-link" asp-area="" asp-controller="Product" asp-action="Index" style="color: #10b981; font-weight: 700; white-space: nowrap; margin-right: 15px; text-decoration: none;">
                    <i class="bi bi-box-seam"></i> Sản phẩm
                </a>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a class="ps-admin-link" asp-area="Customer" asp-controller="Pet" asp-action="Index" style="color: #f97316; font-weight: 700; white-space: nowrap;">
                        <i class="bi bi-heart-fill"></i> Hồ sơ thú cưng
                    </a>
                    @if (User.FindFirst("RoleId")?.Value == "5")
                    {
                        <a class="ps-admin-link" href="/Customer/Account/Profile?tab=wallet" style="color: #0dcaf0; font-weight: 700; white-space: nowrap; margin-left: 15px;">
                            <i class="bi bi-wallet2"></i> Ví điện tử
                        </a>
                    }
                }

                @if (User.FindFirst("RoleId")?.Value == "2" || User.IsInRole("cashier"))
                {
                    <a class="ps-admin-link" asp-area="Cashier" asp-controller="ReturnRequest" asp-action="Index" style="color: #0dcaf0; font-weight: 700; white-space: nowrap; margin-left: 15px;">
                        <i class="bi bi-arrow-counterclockwise"></i> Trả hàng hoàn tiền
                    </a>
                    <a class="ps-admin-link" asp-area="Cashier" asp-controller="Order" asp-action="Create" style="color: #f97316; font-weight: 700; white-space: nowrap; margin-left: 15px;">
                        <i class="bi bi-shop"></i> Quầy thu ngân
                    </a>
                    <a class="ps-admin-link" asp-area="Cashier" asp-controller="Order" asp-action="CreateAtCounter" style="color: #10b981; font-weight: 700; white-space: nowrap; margin-left: 15px;">
                        <i class="bi bi-plus-circle"></i> Tạo đơn tại quầy
                    </a>
                }

                @if (User.IsInRole("admin"))
                {
                    <a class="ps-admin-link" asp-area="Admin" asp-controller="Home" asp-action="Index">Quản trị hệ thống</a>
                }
               

                <button class="ps-icon-btn" type="button" aria-label="Yêu thích"><i class="bi bi-heart"></i></button>

                @await Component.InvokeAsync("CartIcon")

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a class="ps-icon-btn" asp-area="Customer" asp-controller="Account" asp-action="Profile" aria-label="Tài khoản">
                        <i class="bi bi-person-circle"></i>
                    </a>
                    @await Component.InvokeAsync("CustomerNotification")
                    <span class="ps-greeting">Hi, @(User.FindFirst("FullName")?.Value ?? "Nguyễn Văn A")</span>
                    <form asp-area="Customer" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="ps-logout-btn">Đăng xuất</button>
                    </form>
                }
                else
                {
                    <a class="ps-icon-btn" asp-area="Customer" asp-controller="Account" asp-action="Login" aria-label="Tài khoản">
                        <i class="bi bi-person-circle"></i>
                    </a>
                    <button class="ps-icon-btn" type="button" aria-label="Thông báo">
                        <i class="bi bi-bell"></i>
                    </button>
                    <span class="ps-greeting">Hi, Khách</span>
                    <a asp-area="Customer" asp-controller="Account" asp-action="Login" class="ps-logout-btn text-decoration-none">Đăng nhập</a>
                }
            </div>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="ps-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <div class="ps-footer-brand">
                        <span class="ps-logo-icon"><i class="bi bi-cart3"></i></span>
                        <span class="ps-logo-text">PetStore</span>
                    </div>
                    <p class="ps-footer-desc">Hệ thống chăm sóc thú cưng toàn diện nhất. Spa, Hotel, Phụ kiện và thức ăn chính hãng.</p>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h6 class="ps-footer-title">Dịch vụ</h6>
                    <ul class="ps-footer-links">
                        <li><a href="#">Spa &amp; Grooming</a></li>
                        <li><a href="#" class="open-hotel-modal">Pet Hotel</a></li>
                        <li><a href="#">Phòng khám thú y</a></li>
                        <li><a href="#">Huấn luyện</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h6 class="ps-footer-title">Hỗ trợ</h6>
                    <ul class="ps-footer-links">
                        <li><a asp-area="Customer" asp-controller="Support" asp-action="Warranty">Chính sách đổi trả</a></li>
                        <li><a asp-area="Customer" asp-controller="Support" asp-action="Shipping">Vận chuyển</a></li>
                        <li><a asp-area="Customer" asp-controller="Support" asp-action="Faq">Câu hỏi thường gặp</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 col-md-6">
                    <h6 class="ps-footer-title">Liên hệ</h6>
                    <ul class="ps-footer-contact">
                        <li>Hotline: <strong>0862735289</strong></li>
                        <li>Email: <strong>hiephhhe171199@fpt.edu.vn</strong></li>
                    </ul>
                </div>
            </div>
            <div class="ps-footer-bottom">
                <p>&copy; 2024 PetStore AI. All rights reserved.</p>
            </div>
        </div>
    </footer>

    @await Html.PartialAsync("_HotelBookingModal")
    
    <!-- Local SignalR Library & Custom Chat Bubble -->
    <script src="~/js/signalr.min.js"></script>
    @await Html.PartialAsync("_ChatBubble")

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/homepage.js" asp-append-version="true"></script>
    <script src="~/js/customer-notifications.js" asp-append-version="true"></script>
    
    <!-- Script xử lý Live Search Suggestions -->
    <script>
        $(document).ready(function() {
            let debounceTimer;
            const $input = $('#headerSearchInput');
            const $box = $('#searchSuggestionsBox');
            const $list = $('#searchSuggestionsList');
            const $viewAllBtn = $('#viewAllSearchBtn');

            // Ẩn box khi click ra ngoài
            $(document).on('click', function(e) {
                if (!$(e.target).closest('.ps-search').length) {
                    $box.addClass('d-none');
                }
            });

            // Hiện lại box khi click vào ô input nếu có text
            $input.on('focus', function() {
                if ($input.val().trim().length >= 2) {
                    $box.removeClass('d-none');
                }
            });

            // Xử lý khi gõ
            $input.on('input', function() {
                const query = $(this).val().trim();
                
                clearTimeout(debounceTimer);
                
                if (query.length < 2) {
                    $box.addClass('d-none');
                    return;
                }

                $box.removeClass('d-none');
                $list.html('<div class="search-loading"><i class="fas fa-spinner fa-spin"></i> Đang tìm kiếm...</div>');
                $viewAllBtn.hide();

                // Đợi 300ms người dùng ngừng gõ mới gọi API (Debounce)
                debounceTimer = setTimeout(function() {
                    $.ajax({
                        url: '/Product/SearchSuggestions',
                        data: { q: query },
                        method: 'GET',
                        success: function(data) {
                            $list.empty();
                            if (data && data.length > 0) {
                                data.forEach(item => {
                                    // Hiển thị tuỳ theo Type. Sau này thêm "Service" hay "Room" thì vẫn xài đc
                                    let typeLabel = item.type === "Product" ? "Sản phẩm" : (item.type === "Service" ? "Dịch vụ" : item.type);
                                    
                                    let html = `
                                        <a href="${item.url}" class="suggestion-item">
                                            <img src="${item.imageUrl}" class="suggestion-img" alt="">
                                            <div class="suggestion-info">
                                                <h6 class="suggestion-title">${item.title}</h6>
                                                <p class="suggestion-price">${item.priceText} <span class="suggestion-type">${typeLabel}</span></p>
                                            </div>
                                        </a>
                                    `;
                                    $list.append(html);
                                });
                                $viewAllBtn.show();
                                $viewAllBtn.attr('href', '/Product/Index?search=' + encodeURIComponent(query));
                            } else {
                                $list.html('<div class="search-loading">Không tìm thấy kết quả phù hợp</div>');
                                $viewAllBtn.hide();
                            }
                        },
                        error: function() {
                            $list.html('<div class="search-loading">Có lỗi xảy ra khi tìm kiếm</div>');
                            $viewAllBtn.hide();
                        }
                    });
                }, 300);
            });
            
            // Fix icon submit form
            $('.ps-search .bi-search').on('click', function() {
                $('#headerSearchForm').submit();
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
