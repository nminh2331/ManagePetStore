@{
    var pets = ViewBag.HotelPets as IEnumerable<ManagePetStore.Controllers.PetOptionItem>;
    var roomTypes = ViewBag.HotelRoomTypes as IEnumerable<ManagePetStore.Controllers.RoomTypeOptionItem>;
    var discountPercent = ViewBag.HotelDiscountPercent is int value ? value : 0;
    var membershipTier = ViewBag.HotelMembershipTier as string ?? "Thành viên";
    var hasBookingOptions = pets?.Any() == true && roomTypes?.Any() == true;
    var isHomeBookingForm = pets != null && roomTypes != null;
}

<div class="hotel-modal-overlay" id="hotelModalOverlay">
    <div class="hotel-modal" role="dialog" aria-labelledby="hotelModalTitle" aria-modal="true">
        <div class="hotel-modal-header">
            <div class="hotel-modal-icon">
                <i class="bi bi-house-heart"></i>
            </div>
            <div class="hotel-modal-titles">
                <h2 id="hotelModalTitle">Đặt phòng Hotel</h2>
                <p>ĐẶT TRƯỚC PHÒNG LƯU TRÚ CHO THÚ CƯNG</p>
            </div>
            <button type="button" class="hotel-modal-close" id="closeHotelModal" aria-label="Đóng">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        @if (TempData["HotelError"] != null)
        {
            <div class="hotel-alert hotel-alert-error">
                <i class="bi bi-exclamation-circle"></i>
                <span>@TempData["HotelError"]</span>
            </div>
        }

        @if (User.Identity?.IsAuthenticated != true)
        {
            <div class="hotel-empty-state">
                <i class="bi bi-person-lock"></i>
                <p>Vui lòng đăng nhập để chọn thú cưng và đặt phòng Hotel.</p>
                <a asp-controller="CustomerAccount" asp-action="Login" class="hotel-submit-btn text-decoration-none">
                    Đăng nhập để đặt phòng
                </a>
            </div>
        }
        else if (!isHomeBookingForm)
        {
            <div class="hotel-empty-state">
                <i class="bi bi-house-heart"></i>
                <p>Vui lòng mở trang chủ để xem loại phòng và đặt lịch lưu trú.</p>
                <a asp-area="" asp-controller="Home" asp-action="Index" asp-route-hotel="book" class="hotel-submit-btn text-decoration-none">
                    Mở form đặt phòng
                </a>
            </div>
        }
        else
        {
            <form class="hotel-modal-form"
                  id="hotelBookingForm"
                  
                  asp-controller="CustomerHotelBooking"
                  asp-action="Book"
                  method="post"
                  data-discount-percent="@discountPercent">
                @Html.AntiForgeryToken()

                @if (!hasBookingOptions)
                {
                    <div class="hotel-alert hotel-alert-warning">
                        <i class="bi bi-info-circle"></i>
                        <span>
                            @if (pets?.Any() != true)
                            {
                                <text>Bạn cần có ít nhất một hồ sơ thú cưng đang hoạt động.</text>
                            }
                            else
                            {
                                <text>Hiện chưa có loại phòng Hotel nào sẵn sàng nhận đặt trước.</text>
                            }
                        </span>
                    </div>
                }

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="hotel-label" for="hotelPet"><i class="bi bi-heart"></i> CHỌN THÚ CƯNG</label>
                        <select class="hotel-select" id="hotelPet" name="PetId" required disabled="@(pets?.Any() != true ? "disabled" : null)">
                            @if (pets?.Any() == true)
                            {
                                <option value="">Chọn thú cưng</option>
                                @foreach (var pet in pets)
                                {
                                    <option value="@pet.Id">@pet.Name (@pet.Breed)</option>
                                }
                            }
                            else
                            {
                                <option value="">Chưa có hồ sơ thú cưng</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="hotel-label" for="hotelRoomType"><i class="bi bi-star"></i> LOẠI PHÒNG</label>
                        <select class="hotel-select" id="hotelRoomType" name="RoomTypeId" required disabled="@(roomTypes?.Any() != true ? "disabled" : null)">
                            @if (roomTypes?.Any() == true)
                            {
                                <option value="">Chọn loại phòng</option>
                                @foreach (var room in roomTypes)
                                {
                                    <option value="@room.Id" data-price="@room.DailyPrice">
                                        @room.Name - @room.DailyPrice.ToString("N0")đ/đêm
                                    </option>
                                }
                            }
                            else
                            {
                                <option value="">Chưa có phòng khả dụng</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="hotel-label" for="hotelCheckIn"><i class="bi bi-calendar3"></i> NGÀY NHẬN PHÒNG</label>
                        <div class="hotel-date-wrap">
                            <input type="date" class="hotel-date" id="hotelCheckIn" name="CheckInDate" required />
                            <i class="bi bi-calendar3"></i>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="hotel-label" for="hotelCheckOut"><i class="bi bi-calendar-check"></i> NGÀY TRẢ PHÒNG</label>
                        <div class="hotel-date-wrap">
                            <input type="date" class="hotel-date" id="hotelCheckOut" name="CheckOutDate" required />
                            <i class="bi bi-calendar3"></i>
                        </div>
                    </div>
                </div>

                <div class="hotel-date-help">
                    Đặt trước tối đa 365 ngày, mỗi lượt từ 1 đến 90 đêm.
                </div>

                <div class="hotel-summary">
                    <div class="hotel-summary-row">
                        <span>Ưu đãi thành viên</span>
                        <span class="hotel-discount">-@discountPercent%</span>
                    </div>
                    <div class="hotel-summary-row">
                        <span>Số đêm</span>
                        <strong id="hotelNights">1 đêm</strong>
                    </div>
                    <div class="hotel-summary-row hotel-total-row">
                        <span>TẠM TÍNH:</span>
                        <span class="hotel-total" id="hotelTotal">0đ</span>
                    </div>
                </div>

                @if (pets?.Any() != true)
                {
                    <a asp-controller="CustomerPet" asp-action="Index" class="hotel-secondary-link">
                        Tạo hồ sơ thú cưng trước
                    </a>
                }

                <button type="submit" class="hotel-submit-btn" disabled="@(!hasBookingOptions ? "disabled" : null)">
                    Xác nhận đặt phòng
                </button>
            </form>
        }
    </div>
</div>

