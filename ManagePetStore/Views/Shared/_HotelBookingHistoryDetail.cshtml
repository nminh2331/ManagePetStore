@model ManagePetStore.Models.HotelBookingHistoryDetailViewModel

@{
    var scheduledCheckIn = Model.ScheduledCheckInDate ?? Model.CheckInDate;
    var scheduledCheckOut = Model.ScheduledCheckOutDate ?? Model.CheckOutDate ?? scheduledCheckIn.AddDays(Math.Max(Model.StayDays, 1));
    var showTimeline = ViewData["ShowHotelTimeline"] as bool? ?? true;
    var roomServiceProfile = ManagePetStore.Models.HotelRoomTypeCatalog.GetServiceProfile(Model.RoomTypeCode);
    string FormatScheduledDateTime(DateTime value) => value.TimeOfDay == TimeSpan.Zero
        ? value.ToString("dd/MM/yyyy")
        : value.ToString("dd/MM/yyyy HH:mm");
}

<div class="hbh-summary-band">
    <div class="hbh-pet-summary">
        @if (!string.IsNullOrWhiteSpace(Model.PetImageUrl))
        {
            <img src="@Model.PetImageUrl" alt="Ảnh của @Model.PetName" class="hbh-pet-avatar" />
        }
        else
        {
            <span class="hbh-pet-avatar hbh-pet-avatar-placeholder"><i class="bi bi-heart-fill"></i></span>
        }
        <div>
            <span class="hbh-eyebrow">@Model.DisplayBookingId</span>
            <h2>@Model.PetName</h2>
            <p>@Model.PetSpecies · @(Model.PetBreed ?? "Chưa rõ giống") · @(Model.PetAge ?? "Chưa rõ tuổi")</p>
        </div>
    </div>
    <span class="hb-status hb-status-@Model.StatusKey">@Model.Status</span>
</div>

<div class="hbh-facts" aria-label="Thông tin lượt lưu trú">
    <div><span>Chuồng</span><strong>@Model.CageId</strong><small>@Model.RoomTypeName · @Model.RoomSize</small></div>
    <div>
        <span>@(Model.ActualCheckInAt.HasValue ? "Nhận thực tế" : "Nhận dự kiến")</span>
        <strong>@(Model.ActualCheckInAt?.ToString("dd/MM/yyyy HH:mm") ?? FormatScheduledDateTime(scheduledCheckIn))</strong>
        @if (Model.ActualCheckInAt.HasValue) { <small>Dự kiến: @FormatScheduledDateTime(scheduledCheckIn)</small> }
    </div>
    <div>
        <span>@(Model.ActualCheckOutAt.HasValue ? "Trả thực tế" : "Trả dự kiến")</span>
        <strong>@(Model.ActualCheckOutAt?.ToString("dd/MM/yyyy HH:mm") ?? FormatScheduledDateTime(scheduledCheckOut))</strong>
        @if (Model.ActualCheckOutAt.HasValue) { <small>Dự kiến: @FormatScheduledDateTime(scheduledCheckOut)</small> }
    </div>
    <div><span>Thời gian</span><strong>@Model.StayDays ngày</strong></div>
</div>

<div class="hbh-detail-grid">
    <div class="hbh-detail-main">
        @if (!string.IsNullOrWhiteSpace(Model.HealthAssessmentDecision))
        {
            var decisionLabel = Model.HealthAssessmentDecision switch
            {
                "Fit" => "Đủ điều kiện lưu trú",
                "Monitor" => "Đủ điều kiện, cần theo dõi",
                "Rejected" => "Không đủ điều kiện lưu trú",
                _ => Model.HealthAssessmentDecision
            };
            <section class="hbh-section">
                <div class="hbh-section-heading"><div><h3><i class="bi bi-clipboard2-pulse"></i> Kết luận tiếp nhận</h3></div></div>
                <dl class="hbh-data-list">
                    <div><dt>Kết luận</dt><dd>@decisionLabel</dd></div>
                    <div><dt>Sổ y tế</dt><dd>#@Model.HealthAssessmentMedicalRecordId</dd></div>
                    <div><dt>Nhân viên</dt><dd>@Model.HealthAssessedByName</dd></div>
                    <div><dt>Thời gian</dt><dd>@Model.HealthAssessedAt?.ToString("dd/MM/yyyy HH:mm")</dd></div>
                    <div><dt>Ghi chú</dt><dd>@(Model.HealthAssessmentNote ?? "Không có")</dd></div>
                </dl>
            </section>
        }

        <section class="hbh-section">
            <div class="hbh-section-heading"><div><h3><i class="bi bi-cup-straw"></i> Kế hoạch ăn</h3></div></div>
            <dl class="hbh-data-list">
                <div><dt>Gói thức ăn</dt><dd>@Model.FoodPlanName</dd></div>
                @if (!string.IsNullOrWhiteSpace(Model.FoodProductSku))
                {
                    <div><dt>Mã sản phẩm</dt><dd>SKU @Model.FoodProductSku</dd></div>
                }
                else
                {
                    <div><dt>Khẩu phần cũ</dt><dd>@Model.FoodPortionGrams g · @Model.FoodMealsPerDay bữa/ngày</dd></div>
                }
                <div><dt>Cân nặng tính giá</dt><dd>@(Model.FoodPetWeight.HasValue ? $"{Model.FoodPetWeight:0.##} kg" : "Chưa ghi nhận (dữ liệu cũ)")</dd></div>
                <div><dt>Giá thức ăn/ngày</dt><dd>@Model.FoodPricePerDay.ToString("N0")đ</dd></div>
                <div><dt>Hướng dẫn</dt><dd>@(Model.FeedingInstructions ?? "Không có")</dd></div>
                <div><dt>Dị ứng/lưu ý</dt><dd>@(Model.FoodAllergyNotes ?? "Không ghi nhận")</dd></div>
            </dl>
        </section>

        @if (showTimeline)
        {
        <section class="hbh-section">
            <div class="hbh-section-heading">
                <div>
                    <h3><i class="bi bi-clock-history"></i> Hoạt động trong lần lưu trú</h3>
                    <p>Các lần đặt, tiếp nhận, kiểm tra, chuyển chuồng và trả chuồng.</p>
                </div>
                <span>@Model.Timeline.Count hoạt động</span>
            </div>

            @if (Model.Timeline.Count == 0)
            {
                <div class="hbh-empty"><i class="bi bi-journal-text"></i> Chưa có hoạt động chi tiết được ghi nhận cho lượt này.</div>
            }
            else
            {
                <ol class="hbh-timeline">
                    @foreach (var item in Model.Timeline)
                    {
                        <li>
                            <span class="hbh-timeline-dot"><i class="bi bi-check2"></i></span>
                            <div class="hbh-timeline-content">
                                <time>@item.OccurredAt.ToString("dd/MM/yyyy HH:mm")</time>
                                <h4>@item.Title</h4>
                                <p>@item.Description</p>
                            </div>
                        </li>
                    }
                </ol>
            }
        </section>
        }

        <section class="hbh-section">
            <div class="hbh-section-heading">
                <div>
                    <h3><i class="bi bi-clipboard2-pulse"></i> Sức khỏe và y tế</h3>
                    <p>Các hồ sơ y tế được liên kết với đúng lần lưu trú.</p>
                </div>
                <span>@Model.MedicalRecords.Count hồ sơ</span>
            </div>

            @if (Model.MedicalRecords.Count == 0)
            {
                <div class="hbh-empty"><i class="bi bi-clipboard2"></i> Không có hồ sơ y tế phát sinh trong lượt lưu trú này.</div>
            }
            else
            {
                <div class="hbh-record-list">
                    @foreach (var record in Model.MedicalRecords)
                    {
                        <article class="hbh-record-row">
                            <div class="hbh-record-date">
                                <strong>@record.DateCreated.ToString("dd/MM")</strong>
                                <span>@record.DateCreated.ToString("HH:mm")</span>
                            </div>
                            <div>
                                <h4>@record.HealthStatus</h4>
                                <p>Cân nặng: @record.Weight.ToString("0.##") kg</p>
                                @if (!string.IsNullOrWhiteSpace(record.Symptoms))
                                {
                                    <p><strong>Triệu chứng:</strong> @record.Symptoms</p>
                                }
                                @if (!string.IsNullOrWhiteSpace(record.Treatment))
                                {
                                    <p><strong>Điều trị:</strong> @record.Treatment</p>
                                }
                                @if (!string.IsNullOrWhiteSpace(record.PhysicalCheck))
                                {
                                    <p><strong>Kiểm tra:</strong> @record.PhysicalCheck</p>
                                }
                                @if (!string.IsNullOrWhiteSpace(record.VaccinationStatus))
                                {
                                    <p><strong>Tiêm phòng:</strong> @record.VaccinationStatus</p>
                                }
                                @if (!string.IsNullOrWhiteSpace(record.ParasitePrevention))
                                {
                                    <p><strong>Phòng ký sinh:</strong> @record.ParasitePrevention</p>
                                }
                            </div>
                        </article>
                    }
                </div>
            }
        </section>

        <section class="hbh-section">
            <div class="hbh-section-heading">
                <div>
                    <h3><i class="bi bi-cup-straw"></i> Nhật ký chăm sóc</h3>
                    <p>Ăn uống, tình trạng và ghi chú của nhân viên chăm sóc.</p>
                </div>
                <span>@Model.CareLogs.Count nhật ký</span>
            </div>

            @if (Model.CareLogs.Count == 0)
            {
                <div class="hbh-empty"><i class="bi bi-cup"></i> Chưa có nhật ký chăm sóc được liên kết với lượt này.</div>
            }
            else
            {
                <div class="hbh-care-table-wrap">
                    <table class="hbh-care-table">
                        <thead><tr><th>Thời gian</th><th>Hoạt động</th><th>Tình trạng</th><th>Ăn uống</th><th>Nhân viên</th><th>Media</th></tr></thead>
                        <tbody>
                        @foreach (var log in Model.CareLogs)
                        {
                            <tr>
                                <td>@(log.OccurredAt?.ToString("dd/MM/yyyy HH:mm") ?? log.LegacyTime)</td>
                                <td><strong>@log.Title</strong><small class="hbh-care-type">@log.ActivityType</small></td>
                                <td>@log.Status</td>
                                <td>
                                    @log.FoodType
                                    @if (!string.IsNullOrWhiteSpace(log.Amount) && log.Amount != "Không áp dụng") { <small class="hbh-care-type">@log.Amount</small> }
                                    @if (log.IsExtraCharge) { <small class="hbh-care-type">Phụ phí: @log.ExtraChargeAmount.ToString("N0")đ</small> }
                                </td>
                                <td>@log.StaffName</td>
                                <td>
                                    @if (log.MediaType == "Video" && !string.IsNullOrWhiteSpace(log.MediaUrl))
                                    {
                                        <video class="hbh-care-video" controls preload="metadata"><source src="@log.MediaUrl" /></video>
                                    }
                                    else if (!string.IsNullOrWhiteSpace(log.MediaUrl ?? log.PhotoUrl))
                                    {
                                        var imageUrl = log.MediaUrl ?? log.PhotoUrl;
                                        <a href="@imageUrl" target="_blank" rel="noopener" class="hbh-care-photo-link"><img src="@imageUrl" alt="Ảnh nhật ký chăm sóc" class="hbh-care-photo" /></a>
                                    }
                                    else
                                    {
                                        <span>—</span>
                                    }
                                </td>
                            </tr>
                            @if (!string.IsNullOrWhiteSpace(log.Note))
                            {
                                <tr class="hbh-care-note"><td colspan="6"><strong>Ghi chú:</strong> @log.Note</td></tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </div>

    <aside class="hbh-detail-aside">
        <section class="hbh-section">
            <div class="hbh-section-heading"><div><h3><i class="bi bi-person"></i> Chủ nuôi</h3></div></div>
            <dl class="hbh-data-list">
                <div><dt>Họ tên</dt><dd>@Model.CustomerName</dd></div>
                <div><dt>Điện thoại</dt><dd>@Model.CustomerPhone</dd></div>
                <div><dt>Email</dt><dd>@(Model.CustomerEmail ?? "Chưa cập nhật")</dd></div>
            </dl>
        </section>

        <section class="hbh-section">
            <div class="hbh-section-heading"><div><h3><i class="bi bi-heart-pulse"></i> Thú cưng</h3></div></div>
            <dl class="hbh-data-list">
                <div><dt>Cân nặng hiện tại</dt><dd>@Model.PetWeight.ToString("0.##") kg</dd></div>
                <div><dt>Bệnh lý/Lưu ý</dt><dd>@(Model.PetPathology ?? "Không ghi nhận")</dd></div>
            </dl>
        </section>

        <section class="hbh-section">
            <div class="hbh-section-heading"><div><h3><i class="bi bi-house-check"></i> Tiện nghi và dịch vụ @roomServiceProfile.DisplayName</h3></div></div>
            <ul class="hbh-feature-list">
                <li class="@(Model.HasAc ? "available" : "")"><i class="bi bi-snow"></i> Điều hòa</li>
                <li class="@(Model.HasCamera ? "available" : "")"><i class="bi bi-camera-video"></i> Camera</li>
                @foreach (var service in roomServiceProfile.IncludedServices)
                {
                    <li class="available"><i class="bi bi-shield-check"></i> @service</li>
                }
            </ul>
            <small>Gói thức ăn được lựa chọn và tính riêng theo cân nặng của pet.</small>
        </section>

        <section class="hbh-section">
            <div class="hbh-section-heading"><div><h3><i class="bi bi-receipt"></i> Chi phí</h3></div></div>
            <dl class="hbh-price-list">
                <div><dt>Giá phòng/ngày</dt><dd>@Model.BaseDailyPrice.ToString("N0")đ</dd></div>
                <div><dt>Tạm tính</dt><dd>@Model.Subtotal.ToString("N0")đ</dd></div>
                @foreach (var addon in Model.Addons)
                {
                    <div><dt>@addon.Name</dt><dd>@addon.Price.ToString("N0")đ</dd></div>
                }
                <div><dt>Giảm giá</dt><dd>-@Model.Discount.ToString("N0")đ</dd></div>
                <div class="hbh-price-total"><dt>Tổng cộng</dt><dd>@Model.FinalAmount.ToString("N0")đ</dd></div>
            </dl>
        </section>
    </aside>
</div>
