@{
    ViewData["Title"] = "Tạo Phiếu Xuất Kho Nội Bộ";
    var products = ViewBag.Products as ManagePetStore.Models.ProductSummaryViewModel;
}

<div class="mb-4">
    <a asp-action="Index" class="text-decoration-none text-muted mb-2 d-inline-block">
        <i class="fas fa-arrow-left"></i> Quay lại lịch sử
    </a>
    <h2 class="fw-bold m-0" style="color: #333;">Tạo Phiếu Xuất Nội Bộ</h2>
    <p class="text-muted small mt-1 mb-0">Xuất sản phẩm cho mục đích sử dụng nội bộ (ví dụ: dùng cho Spa, Khách sạn).</p>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 12px; max-width: 600px;">
    <div class="card-body p-4">
        <form asp-action="CreateExport" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <div class="mb-3">
                <label for="Note" class="form-label fw-bold">Mục đích xuất (Ghi chú) <span class="text-danger">*</span></label>
                <input type="text" id="Note" name="Note" class="form-control" style="border-radius: 8px;" placeholder="Ví dụ: Xuất 2 chai sữa tắm cho phòng Spa..." required />
            </div>

            <div class="mb-3">
                <label for="ProductSku" class="form-label fw-bold">Sản phẩm <span class="text-danger">*</span></label>
                <select id="ProductSku" name="ProductSku" class="form-select" style="border-radius: 8px;" required>
                    <option value="">-- Chọn sản phẩm --</option>
                    @if (products != null && products.Products != null)
                    {
                        foreach (var p in products.Products)
                        {
                            <option value="@p.Sku">@p.Name (Tồn: @p.Stock)</option>
                        }
                    }
                </select>
            </div>
            
            <div class="mb-4">
                <label for="Quantity" class="form-label fw-bold">Số lượng xuất <span class="text-danger">*</span></label>
                <input type="number" id="Quantity" name="Quantity" min="1" class="form-control" style="border-radius: 8px;" required />
                <div class="form-text text-muted">Hệ thống sẽ tự động trừ vào các lô hàng cũ nhất (FIFO).</div>
            </div>
            
            <div class="text-end">
                <button type="submit" class="btn btn-warning fw-bold px-4 py-2 text-dark">
                    <i class="fas fa-file-export"></i> Tạo Phiếu Xuất
                </button>
            </div>
        </form>
    </div>
</div>
