@model ManagePetStore.Models.RoomViewModel

@{
    ViewData["Title"] = $"Chỉnh sửa chuồng {Model.RoomCode}";
}

<style>
    :root { --orange:#F97316; --orange-dk:#EA6C0A; --card-bg:#1E293B; --border:rgba(255,255,255,.08); }
    .form-card {
        background:linear-gradient(145deg,#1E293B,#0F172A);
        border:1px solid var(--border); border-radius:18px;
        padding:2rem 2.25rem; max-width:640px; margin:0 auto;
        box-shadow:0 16px 48px rgba(0,0,0,.35);
    }
    .form-card h2 { font-size:1.4rem; font-weight:700; color:#F1F5F9; margin-bottom:1.5rem; }
    .form-card h2 span { color:var(--orange); }
    .form-label { color:#CBD5E1; font-size:.85rem; font-weight:600; margin-bottom:.3rem; }
    .form-control, .form-select {
        background:#0F172A; border:1px solid rgba(255,255,255,.12);
        color:#F1F5F9; border-radius:10px; padding:.55rem .85rem; font-size:.9rem;
        transition:border-color .2s, box-shadow .2s;
    }
    .form-control:focus, .form-select:focus {
        background:#0F172A; color:#F1F5F9;
        border-color:var(--orange); box-shadow:0 0 0 3px rgba(249,115,22,.2);
    }
    .form-control::placeholder { color:#475569; }
    .form-select option { background:#1E293B; }
    .text-danger { font-size:.8rem; margin-top:.25rem; }
    .divider { border-color:var(--border); margin:1.5rem 0; }
    .btn-save {
        background:linear-gradient(135deg,var(--orange),var(--orange-dk));
        border:none; color:#fff; border-radius:10px; padding:.55rem 1.4rem;
        font-weight:600; font-size:.92rem; transition:transform .15s,box-shadow .15s;
        box-shadow:0 4px 14px rgba(249,115,22,.35);
    }
    .btn-save:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(249,115,22,.5); color:#fff; }
    .btn-cancel { border-radius:10px; padding:.55rem 1.2rem; font-size:.92rem; }
    .field-hint { font-size:.77rem; color:#64748B; margin-top:.2rem; }
    .id-chip {
        display:inline-flex; align-items:center; gap:.35rem;
        background:rgba(249,115,22,.12); border:1px solid rgba(249,115,22,.25);
        color:var(--orange); border-radius:8px; padding:.22rem .7rem; font-size:.78rem; font-weight:600;
        margin-bottom:1.25rem;
    }
</style>

<div class="container-fluid px-4 py-4">
    <div class="form-card">
        <h2><i class="fas fa-pen-to-square me-2" style="color:var(--orange)"></i>Chỉnh sửa <span>@Model.RoomCode</span></h2>
        <div class="id-chip"><i class="fas fa-hashtag"></i> ID: @Model.RoomId</div>

        <form asp-action="Edit" method="post" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="RoomId" />

            <%-- Validation summary --%>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 px-3 mb-3" style="font-size:.85rem; border-radius:10px; background:rgba(239,68,68,.12); border:1px solid rgba(239,68,68,.3); color:#FCA5A5;"></div>

            <%-- Mã chuồng --%>
            <div class="mb-3">
                <label asp-for="RoomCode" class="form-label">
                    Mã chuồng <span class="text-danger">*</span>
                </label>
                <input asp-for="RoomCode" class="form-control" placeholder="Ví dụ: A01, VIP-02..." />
                <span asp-validation-for="RoomCode" class="text-danger"></span>
            </div>

            <%-- Loại chuồng --%>
            <div class="mb-3">
                <label asp-for="RoomType" class="form-label">
                    Loại chuồng <span class="text-danger">*</span>
                </label>
                <select asp-for="RoomType" asp-items="ViewBag.RoomTypes" class="form-select">
                    <option value="">-- Chọn loại chuồng --</option>
                </select>
                <span asp-validation-for="RoomType" class="text-danger"></span>
            </div>

            <%-- Giá theo ngày --%>
            <div class="mb-3">
                <label asp-for="DailyRate" class="form-label">
                    Giá theo ngày (đ) <span class="text-danger">*</span>
                </label>
                <input asp-for="DailyRate" type="number" min="1000" step="1000"
                       class="form-control" placeholder="Ví dụ: 150000" />
                <span asp-validation-for="DailyRate" class="text-danger"></span>
                <div class="field-hint">Tối thiểu 1.000đ</div>
            </div>

            <%-- Trạng thái --%>
            <div class="mb-3">
                <label asp-for="Status" class="form-label">Trạng thái</label>
                <select asp-for="Status" asp-items="ViewBag.Statuses" class="form-select"></select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <%-- Kích thước --%>
            <div class="mb-4">
                <label asp-for="Dimensions" class="form-label">Kích thước <small class="text-secondary">(tuỳ chọn)</small></label>
                <input asp-for="Dimensions" class="form-control" placeholder="Ví dụ: 2m x 1.5m" />
                <span asp-validation-for="Dimensions" class="text-danger"></span>
            </div>

            <hr class="divider" />

            <div class="d-flex gap-2 justify-content-end">
                <a asp-action="Index" class="btn btn-secondary btn-cancel">
                    <i class="fas fa-arrow-left me-1"></i> Hủy
                </a>
                <button type="submit" class="btn btn-save">
                    <i class="fas fa-floppy-disk me-1"></i> Lưu thay đổi
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
