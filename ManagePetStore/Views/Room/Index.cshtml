@model ManagePetStore.Models.RoomListViewModel
@using ManagePetStore.Model

@{
    ViewData["Title"] = "Quản lý Chuồng & Phòng";

    string BadgeClass(string? s) => s switch
    {
        RoomStatus.Available   => "badge-available",
        RoomStatus.Occupied    => "badge-occupied",
        RoomStatus.Cleaning    => "badge-cleaning",
        RoomStatus.Maintenance => "badge-maintenance",
        _                      => "badge-secondary"
    };

    string BadgeLabel(string? s) => s switch
    {
        RoomStatus.Available   => "Trống",
        RoomStatus.Occupied    => "Đang dùng",
        RoomStatus.Cleaning    => "Đang dọn",
        RoomStatus.Maintenance => "Bảo trì",
        _                      => s ?? "—"
    };
}

<style>
    :root {
        --orange:      #F97316;
        --orange-dk:   #EA6C0A;
        --card-bg:     #1E293B;
        --card-deep:   #0F172A;
        --border:      rgba(255,255,255,.08);
        --text-dim:    #94A3B8;
    }
    /* header */
    .pg-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.75rem; flex-wrap:wrap; gap:.75rem; }
    .pg-header h1 { font-size:1.6rem; font-weight:700; color:#F1F5F9; margin:0; }
    .pg-header h1 span { color:var(--orange); }
    .btn-add {
        background:linear-gradient(135deg,var(--orange),var(--orange-dk));
        color:#fff; border:none; border-radius:10px; padding:.52rem 1.2rem;
        font-weight:600; font-size:.9rem; display:inline-flex; align-items:center; gap:.4rem;
        text-decoration:none; transition:transform .15s,box-shadow .15s;
        box-shadow:0 4px 14px rgba(249,115,22,.35);
    }
    .btn-add:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(249,115,22,.5); color:#fff; }
    /* toast */
    .toast-alert { border-radius:10px; font-size:.88rem; margin-bottom:1.25rem; }
    /* tabs */
    .status-tabs { display:flex; gap:.5rem; margin-bottom:1.75rem; flex-wrap:wrap; }
    .s-tab {
        padding:.42rem 1rem; border-radius:30px; font-size:.83rem; font-weight:600;
        text-decoration:none; color:var(--text-dim); background:rgba(255,255,255,.05);
        border:1px solid transparent; display:inline-flex; align-items:center; gap:.35rem; transition:all .2s;
    }
    .s-tab:hover { color:#F1F5F9; background:rgba(255,255,255,.1); }
    .s-tab.active { background:var(--orange); color:#fff; box-shadow:0 3px 10px rgba(249,115,22,.4); }
    .s-tab .n { background:rgba(0,0,0,.25); border-radius:20px; padding:1px 7px; font-size:.74rem; }
    /* grid */
    .room-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(265px,1fr)); gap:1.2rem; }
    /* card */
    .r-card {
        background:linear-gradient(145deg,var(--card-bg),var(--card-deep));
        border:1px solid var(--border); border-radius:16px;
        padding:1.3rem 1.2rem 1rem; display:flex; flex-direction:column; gap:.55rem;
        transition:transform .2s,box-shadow .2s,border-color .2s; position:relative; overflow:hidden;
    }
    .r-card::before {
        content:''; position:absolute; top:0; left:0; right:0; height:3px;
        background:linear-gradient(90deg,var(--orange),#FB923C); border-radius:16px 16px 0 0;
    }
    .r-card:hover { transform:translateY(-4px); box-shadow:0 12px 32px rgba(0,0,0,.45); border-color:rgba(249,115,22,.3); }
    .r-card-top { display:flex; justify-content:space-between; align-items:flex-start; }
    .r-card-code { font-size:1.22rem; font-weight:700; color:#F1F5F9; letter-spacing:.01em; }
    .r-card-meta { font-size:.82rem; color:var(--text-dim); display:flex; flex-direction:column; gap:.22rem; }
    .r-card-meta i { width:15px; color:#64748B; }
    .r-card-rate { font-size:1.05rem; font-weight:700; color:var(--orange); }
    /* badges */
    .sb { display:inline-block; padding:.26rem .72rem; border-radius:30px; font-size:.76rem; font-weight:700; letter-spacing:.03em; }
    .badge-available   { background:rgba(34,197,94,.15);  color:#22C55E; border:1px solid rgba(34,197,94,.25); }
    .badge-occupied    { background:rgba(239,68,68,.15);   color:#EF4444; border:1px solid rgba(239,68,68,.25); }
    .badge-cleaning    { background:rgba(234,179,8,.15);   color:#EAB308; border:1px solid rgba(234,179,8,.25); }
    .badge-maintenance { background:rgba(148,163,184,.15); color:#94A3B8; border:1px solid rgba(148,163,184,.25); }
    /* card footer */
    .c-footer { display:flex; align-items:center; gap:.45rem; margin-top:auto; padding-top:.7rem; border-top:1px solid var(--border); flex-wrap:wrap; }
    .qs-form select {
        background:#1E293B; color:#CBD5E1; border:1px solid rgba(255,255,255,.12);
        border-radius:8px; padding:.28rem .5rem; font-size:.79rem; cursor:pointer; outline:none; transition:border-color .2s;
    }
    .qs-form select:focus { border-color:var(--orange); }
    .ic-btn {
        width:33px; height:33px; border-radius:8px; border:1px solid rgba(255,255,255,.1);
        background:rgba(255,255,255,.04); color:var(--text-dim); display:inline-flex; align-items:center;
        justify-content:center; font-size:.84rem; text-decoration:none; cursor:pointer; transition:all .2s;
    }
    .ic-btn:hover { background:rgba(255,255,255,.1); color:#F1F5F9; }
    .ic-btn.del:hover { background:rgba(239,68,68,.15); border-color:rgba(239,68,68,.4); color:#EF4444; }
    /* empty */
    .empty-box { text-align:center; padding:4rem 2rem; color:#475569; }
    .empty-box i { font-size:3.5rem; margin-bottom:1rem; display:block; }
    /* modal */
    .modal-content { background:#1E293B; border:1px solid var(--border); border-radius:16px; }
    .modal-header  { border-bottom:1px solid var(--border); }
    .modal-footer  { border-top:1px solid var(--border); }
    .modal-title   { color:#F1F5F9; font-weight:700; }
    .modal-body    { color:var(--text-dim); }
</style>

<div class="container-fluid px-4 py-4">

    <%-- Header --%>
    <div class="pg-header">
        <h1><i class="fas fa-house-chimney me-2" style="color:var(--orange)"></i>Quản lý <span>Chuồng & Phòng</span></h1>
        <a asp-action="Create" class="btn-add">
            <i class="fas fa-plus"></i> Thêm chuồng mới
        </a>
    </div>

    <%-- Toast alerts --%>
    @if (TempData["Success"] is string ok)
    {
        <div class="alert alert-success alert-dismissible fade show toast-alert" role="alert">
            <i class="fas fa-circle-check me-2"></i>@ok
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] is string err)
    {
        <div class="alert alert-danger alert-dismissible fade show toast-alert" role="alert">
            <i class="fas fa-circle-xmark me-2"></i>@err
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <%-- Status Tabs --%>
    <div class="status-tabs">
        <a asp-action="Index" class="s-tab @(string.IsNullOrEmpty(Model.StatusFilter) ? "active" : "")">
            <i class="fas fa-border-all"></i> Tất cả <span class="n">@Model.TotalCount</span>
        </a>
        <a asp-action="Index" asp-route-statusFilter="@RoomStatus.Available"
           class="s-tab @(Model.StatusFilter == RoomStatus.Available ? "active" : "")">
            <i class="fas fa-circle-check"></i> Trống <span class="n">@Model.AvailableCount</span>
        </a>
        <a asp-action="Index" asp-route-statusFilter="@RoomStatus.Occupied"
           class="s-tab @(Model.StatusFilter == RoomStatus.Occupied ? "active" : "")">
            <i class="fas fa-paw"></i> Đang dùng <span class="n">@Model.OccupiedCount</span>
        </a>
        <a asp-action="Index" asp-route-statusFilter="@RoomStatus.Cleaning"
           class="s-tab @(Model.StatusFilter == RoomStatus.Cleaning ? "active" : "")">
            <i class="fas fa-broom"></i> Đang dọn <span class="n">@Model.CleaningCount</span>
        </a>
        <a asp-action="Index" asp-route-statusFilter="@RoomStatus.Maintenance"
           class="s-tab @(Model.StatusFilter == RoomStatus.Maintenance ? "active" : "")">
            <i class="fas fa-screwdriver-wrench"></i> Bảo trì <span class="n">@Model.MaintenanceCount</span>
        </a>
    </div>

    <%-- Card grid --%>
    @if (!Model.Rooms.Any())
    {
        <div class="empty-box">
            <i class="fas fa-box-open"></i>
            <p class="fs-5 fw-semibold text-secondary">Chưa có chuồng nào</p>
            <a asp-action="Create" class="btn-add mt-2">
                <i class="fas fa-plus"></i> Thêm chuồng đầu tiên
            </a>
        </div>
    }
    else
    {
        <div class="room-grid">
            @foreach (var room in Model.Rooms)
            {
                <div class="r-card">
                    <div class="r-card-top">
                        <span class="r-card-code">@room.RoomCode</span>
                        <span class="sb @BadgeClass(room.Status)">@BadgeLabel(room.Status)</span>
                    </div>

                    <div class="r-card-meta">
                        <span><i class="fas fa-tag"></i> @room.RoomType</span>
                        @if (!string.IsNullOrWhiteSpace(room.Dimensions))
                        {
                            <span><i class="fas fa-ruler-combined"></i> @room.Dimensions</span>
                        }
                    </div>

                    <div class="r-card-rate">
                        <i class="fas fa-coins me-1" style="font-size:.82rem"></i>
                        @room.DailyRate.ToString("N0")đ<small class="text-secondary fw-normal" style="font-size:.71rem">/ngày</small>
                    </div>

                    <div class="c-footer">
                        <%-- Quick status --%>
                        <form asp-action="UpdateStatus" method="post" class="qs-form d-flex align-items-center gap-1">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@room.RoomId" />
                            <select name="status" onchange="this.form.submit()" title="Đổi trạng thái nhanh">
                                <option value="@RoomStatus.Available"   selected="@(room.Status == RoomStatus.Available   ? "selected" : null)">Trống</option>
                                <option value="@RoomStatus.Occupied"    selected="@(room.Status == RoomStatus.Occupied    ? "selected" : null)">Đang dùng</option>
                                <option value="@RoomStatus.Cleaning"    selected="@(room.Status == RoomStatus.Cleaning    ? "selected" : null)">Đang dọn</option>
                                <option value="@RoomStatus.Maintenance" selected="@(room.Status == RoomStatus.Maintenance ? "selected" : null)">Bảo trì</option>
                            </select>
                        </form>

                        <div class="ms-auto d-flex gap-1">
                            <a asp-action="Edit" asp-route-id="@room.RoomId" class="ic-btn" title="Chỉnh sửa">
                                <i class="fas fa-pen"></i>
                            </a>
                            <button type="button" class="ic-btn del" title="Xóa"
                                    data-bs-toggle="modal" data-bs-target="#delModal"
                                    data-rid="@room.RoomId" data-rcode="@room.RoomCode">
                                <i class="fas fa-trash-can"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<%-- Delete confirm modal --%>
<div class="modal fade" id="delModal" tabindex="-1" aria-labelledby="delModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="delModalLabel">
                    <i class="fas fa-triangle-exclamation text-warning me-2"></i>Xác nhận xóa
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Bạn có chắc muốn xóa chuồng <strong id="delCode" class="text-white"></strong>?
                <br><small class="text-danger mt-1 d-block">Hành động này không thể hoàn tác.</small>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <form asp-action="Delete" method="post" id="delForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="delId" />
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash-can me-1"></i> Xóa
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('delModal').addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            document.getElementById('delId').value = btn.dataset.rid;
            document.getElementById('delCode').textContent = btn.dataset.rcode;
        });
    </script>
}
