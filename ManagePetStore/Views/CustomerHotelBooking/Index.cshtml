@model ManagePetStore.Models.CustomerModels.HotelBookingHistoryPageViewModel

@{
    Layout = "/Views/Shared/_PetStoreLayout.cshtml";
    ViewData["Title"] = "Lịch hẹn & Khách sạn";
}

@section Styles {
    <link rel="stylesheet" href="~/css/customer-pets.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/customer-hotel-bookings.css" asp-append-version="true" />
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="cp-toast success" id="cpToast">@TempData["SuccessMessage"]</div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="cp-toast error" id="cpToast">@TempData["ErrorMessage"]</div>
}

<div class="cp-dashboard">
    @await Html.PartialAsync("_CustomerSidebar", Model)

    <section class="cp-main">
        <div class="cp-main-header">
            <div>
                <h1 class="cp-main-title">Lịch hẹn &amp; Khách sạn</h1>
                <p class="cp-main-subtitle">Theo dõi các lịch lưu trú đã đặt trước cho thú cưng.</p>
            </div>
            <a asp-area="" asp-controller="Home" asp-action="Index" asp-route-hotel="book" class="cp-btn-add text-decoration-none">
                <i class="bi bi-plus-lg"></i> Đặt phòng mới
            </a>
        </div>

        @if (!Model.Bookings.Any())
        {
            <div class="cp-empty">
                <i class="bi bi-house-heart"></i>
                <p>Bạn chưa có lịch đặt Hotel nào.</p>
                <a asp-area="" asp-controller="Home" asp-action="Index" asp-route-hotel="book" class="hb-btn-primary">
                    Đặt phòng ngay
                </a>
            </div>
        }
        else
        {
            <div class="hb-list">
                @foreach (var booking in Model.Bookings)
                {
                    <article class="hb-card">
                        <div class="hb-card-icon">
                            <i class="bi bi-house-heart"></i>
                        </div>
                        <div class="hb-card-main">
                            <div class="hb-card-heading">
                                <div>
                                    <h2>@booking.PetName</h2>
                                    <p>@booking.RoomTypeName · Chuồng @booking.CageId</p>
                                </div>
                                <span class="hb-status hb-status-@booking.StatusKey">@booking.Status</span>
                            </div>
                            <div class="hb-details">
                                <div>
                                    <span>Nhận phòng</span>
                                    <strong>@booking.CheckInDate.ToString("dd/MM/yyyy")</strong>
                                </div>
                                <div>
                                    <span>Trả phòng</span>
                                    <strong>@booking.CheckOutDate.ToString("dd/MM/yyyy")</strong>
                                </div>
                                <div>
                                    <span>Thời gian</span>
                                    <strong>@booking.StayDays đêm</strong>
                                </div>
                                <div>
                                    <span>Tạm tính</span>
                                    <strong class="hb-price">@booking.FinalAmount.ToString("N0")đ</strong>
                                </div>
                            </div>
                        </div>
                        <div class="hb-card-action">
                            @if (booking.CanCancel)
                            {
                                <form asp-action="Cancel" method="post" onsubmit="return confirm('Bạn chắc chắn muốn hủy lịch đặt phòng này?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@booking.HotelBookingId" />
                                    <button type="submit" class="hb-btn-cancel">Hủy lịch</button>
                                </form>
                            }
                            else
                            {
                                <span class="hb-action-note">Không thể hủy online</span>
                            }
                        </div>
                    </article>
                }
            </div>
        }
    </section>
</div>

@section Scripts {
    <script>
        window.setTimeout(function () {
            document.getElementById('cpToast')?.remove();
        }, 4500);
    </script>
}
