@model IEnumerable<ManagePetStore.Models.Product>

@{
    ViewData["Title"] = "Danh sách Sản phẩm";
    int totalProducts   = ViewBag.TotalProducts  ?? 0;
    int lowStockCount   = ViewBag.LowStockCount  ?? 0;
    int outOfStockCount = ViewBag.OutOfStockCount ?? 0;
    decimal totalValue  = ViewBag.TotalValue      ?? 0m;
    int categoryCount   = ViewBag.CategoryCount   ?? 0;
}

<!-- ── Stat Cards ───────────────────────────────────────────── -->
<div class="row g-3 mb-4">
    <div class="col-6 col-xl-3">
        <div class="stat-card" style="--accent:#e65c00;">
            <div class="stat-icon" style="background:rgba(230,92,0,.12);">
                <i class="fas fa-box-open" style="color:#e65c00;"></i>
            </div>
            <div>
                <p class="stat-label">Tổng sản phẩm</p>
                <h3 class="stat-value">@totalProducts</h3>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="stat-card" style="--accent:#f59e0b;">
            <div class="stat-icon" style="background:rgba(245,158,11,.12);">
                <i class="fas fa-exclamation-triangle" style="color:#f59e0b;"></i>
            </div>
            <div>
                <p class="stat-label">Sắp hết hàng</p>
                <h3 class="stat-value">@lowStockCount</h3>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="stat-card" style="--accent:#ef4444;">
            <div class="stat-icon" style="background:rgba(239,68,68,.12);">
                <i class="fas fa-times-circle" style="color:#ef4444;"></i>
            </div>
            <div>
                <p class="stat-label">Hết hàng</p>
                <h3 class="stat-value">@outOfStockCount</h3>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="stat-card" style="--accent:#10b981;">
            <div class="stat-icon" style="background:rgba(16,185,129,.12);">
                <i class="fas fa-coins" style="color:#10b981;"></i>
            </div>
            <div>
                <p class="stat-label">Giá trị tồn kho</p>
                <h3 class="stat-value" style="font-size:1.1rem;">@string.Format("{0:N0} đ", totalValue)</h3>
            </div>
        </div>
    </div>
</div>

<!-- ── Header ─────────────────────────────────────────────── -->
<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
        <h2 class="fw-bold m-0" style="color:#333;">
            Quản lý danh sách Sản phẩm
        </h2>
        <p class="text-muted small mb-0 mt-1">Chỉnh sửa nhanh thông tin và kiểm soát sản phẩm ngừng kinh doanh.</p>
    </div>
    
    <div class="d-flex gap-3 align-items-center">
        <!-- Dropdown filter -->
        <div class="dropdown">
            <button class="btn btn-light dropdown-toggle d-flex align-items-center gap-2" type="button" id="filterDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="border-radius:20px; font-size:14px; font-weight:500; border:1px solid #ddd; background:#fff;">
                <i class="fas fa-eye text-muted"></i> 
                @{
                    string currentFilter = ViewBag.Filter ?? "active";
                    string filterLabel = currentFilter switch {
                        "all" => "Hiển thị tất cả sản phẩm",
                        "deleted" => "Sản phẩm đã xóa",
                        _ => "Chỉ sản phẩm đang kinh doanh"
                    };
                }
                @filterLabel
            </button>
            <ul class="dropdown-menu shadow-sm border-0" aria-labelledby="filterDropdown" style="border-radius:12px;">
                <li><a class="dropdown-item @(currentFilter == "active" ? "active" : "")" href="?filter=active&search=@ViewBag.Search">Chỉ sản phẩm đang kinh doanh</a></li>
                <li><a class="dropdown-item @(currentFilter == "all" ? "active" : "")" href="?filter=all&search=@ViewBag.Search">Hiển thị tất cả sản phẩm</a></li>
                <li><a class="dropdown-item @(currentFilter == "deleted" ? "active" : "")" href="?filter=deleted&search=@ViewBag.Search">Sản phẩm đã xóa</a></li>
            </ul>
        </div>

        <a asp-action="Create" class="btn btn-primary-custom btn-custom">
            <i class="fas fa-plus"></i> Thêm sản phẩm
        </a>
    </div>
</div>

<!-- ── Alert low-stock banner ─────────────────────────────── -->
@if (lowStockCount > 0 || outOfStockCount > 0)
{
    <div class="alert d-flex align-items-center gap-2 mb-3"
         style="background:#fff8f0;border:1px solid #f59e0b;border-radius:10px;color:#92400e;">
        <i class="fas fa-exclamation-triangle" style="color:#f59e0b;"></i>
        <span>
            Có <strong>@outOfStockCount</strong> sản phẩm <strong>hết hàng</strong> và
            <strong>@lowStockCount</strong> sản phẩm <strong>sắp hết</strong> cần nhập thêm.
        </span>
    </div>
}

<!-- ── Table ──────────────────────────────────────────────── -->
<div class="row g-4">
    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            var isDeletedCardStyle = item.IsDeleted ? "opacity: 0.7; background-color: #fcfcfc;" : "background-color: #fff;";
            var statusBadge = item.IsDeleted 
                ? "<span class='badge' style='background:#f3f4f6; color:#6b7280; padding:6px 12px; border-radius:16px; font-weight:600;'><i class='fas fa-ban me-1'></i> Ngừng kinh doanh</span>"
                : "<span class='badge' style='background:#dcfce7; color:#166534; padding:6px 12px; border-radius:16px; font-weight:600;'><i class='fas fa-check-circle me-1'></i> Đang kinh doanh</span>";

            <div class="col-12 col-xl-6">
                <div class="card h-100 border-0 shadow-sm" style="border-radius:16px; @isDeletedCardStyle border:1px solid #f0f0f0;">
                    <div class="card-body p-4 d-flex flex-column">
                        <!-- Top Row: SKU and Status -->
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <span class="text-muted fw-bold small" style="letter-spacing:0.5px;">MÃ SẢN PHẨM: @item.Sku</span>
                            <div class="d-flex align-items-center gap-2">
                                @Html.Raw(statusBadge)
                                <!-- Toggle Delete/Restore -->
                                @if (!item.IsDeleted) {
                                    <form asp-action="Delete" asp-route-id="@item.Sku" method="post" onsubmit="return confirm('Ngừng kinh doanh sản phẩm này?');" class="m-0">
                                        <button type="submit" class="btn btn-sm btn-light" style="border-radius:50%; width:34px; height:34px; color:#ef4444; border:1px solid #fee2e2;" title="Ngừng kinh doanh"><i class="fas fa-power-off"></i></button>
                                    </form>
                                } else {
                                    <form asp-action="Restore" asp-route-id="@item.Sku" method="post" onsubmit="return confirm('Mở lại kinh doanh sản phẩm này?');" class="m-0">
                                        <button type="submit" class="btn btn-sm btn-light" style="border-radius:50%; width:34px; height:34px; color:#10b981; border:1px solid #d1fae5;" title="Mở kinh doanh"><i class="fas fa-power-off"></i></button>
                                    </form>
                                }
                            </div>
                        </div>

                        <!-- Content Flex -->
                        <div class="d-flex gap-4 mb-4 flex-grow-1 flex-wrap flex-md-nowrap">
                            <!-- Image Space -->
                            <div class="flex-shrink-0">
                                @if (!string.IsNullOrEmpty(item.ImageUrl)) {
                                    <img src="@item.ImageUrl" style="width:130px; height:130px; object-fit:cover; border-radius:12px; border:1px solid #eee;" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                    <div style="display:none; width:130px; height:130px; border-radius:12px; background:#f8f9fa; align-items:center; justify-content:center; border:1px solid #eee;">
                                        <i class="fas fa-image text-muted" style="font-size:2.5rem; opacity:0.5;"></i>
                                    </div>
                                } else {
                                    <div style="width:130px; height:130px; border-radius:12px; background:#f8f9fa; display:flex; align-items:center; justify-content:center; border:1px solid #eee;">
                                        <i class="fas fa-image text-muted" style="font-size:2.5rem; opacity:0.5;"></i>
                                    </div>
                                }
                            </div>

                            <!-- Details Grid -->
                            <div class="flex-grow-1 w-100">
                                <div class="row g-3">
                                    <div class="col-12">
                                        <p class="text-muted small mb-1 fw-bold">Tên sản phẩm</p>
                                        <div class="fw-bold px-3 py-2 bg-light text-dark" style="border-radius:10px; font-size:1.1rem;">@item.Name</div>
                                    </div>
                                    <div class="col-md-6">
                                        <p class="text-muted small mb-1 fw-bold">Danh mục</p>
                                        <div class="fw-bold px-3 py-2 bg-light" style="border-radius:10px; color:#e65c00;">@(item.Category?.Name ?? "—")</div>
                                    </div>
                                    <div class="col-md-6">
                                        <p class="text-muted small mb-1 fw-bold">Tồn kho / Đơn vị</p>
                                        <div class="fw-bold px-3 py-2 bg-light" style="border-radius:10px;">@item.Stock @item.Unit</div>
                                    </div>
                                    <div class="col-md-6">
                                        <p class="text-muted small mb-1 fw-bold">Vị trí kệ</p>
                                        <div class="fw-bold px-3 py-2 bg-light" style="border-radius:10px;">@(string.IsNullOrEmpty(item.ShelfLocation) ? "—" : item.ShelfLocation)</div>
                                    </div>
                                    <div class="col-md-6">
                                        <p class="text-muted small mb-1 fw-bold">Giá bán</p>
                                        <div class="fw-bold px-3 py-2 bg-light" style="border-radius:10px;">@string.Format("{0:N0} đ", item.Price)</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Footer Actions -->
                        <div class="text-end pt-2">
                            <a asp-controller="WarehouseStockMovement" asp-action="CreateImport" asp-route-productSku="@item.Sku" class="btn text-primary fw-bold me-2" style="border-radius:20px; padding:8px 20px; border:1px solid #007bff;">
                                <i class="fas fa-file-import me-1"></i> Tạo đơn nhập
                            </a>
                            <a asp-controller="WarehouseInventoryBatch" asp-action="Index" asp-route-id="@item.Sku" class="btn text-dark fw-bold me-2" style="border-radius:20px; padding:8px 20px; background-color:#f8f9fa; border:1px solid #ddd;">
                                <i class="fas fa-boxes me-1"></i> Quản lý lô hàng
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Sku" class="btn text-white fw-bold" style="border-radius:20px; padding:8px 24px; background-color:#ff8c00;">
                                <i class="fas fa-edit me-1"></i> Chỉnh sửa
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <i class="fas fa-box-open text-muted" style="font-size:3rem;opacity:.3;"></i>
            <p class="mt-3 text-muted">Không có dữ liệu phù hợp.</p>
        </div>
    }
</div>

<style>
    .stat-card {
        background: #fff;
        border-radius: 14px;
        padding: 1.1rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        box-shadow: 0 2px 10px rgba(0,0,0,.06);
        border-left: 4px solid var(--accent);
        transition: transform .2s, box-shadow .2s;
    }
    .stat-card:hover { transform: translateY(-2px); box-shadow: 0 6px 18px rgba(0,0,0,.1); }
    .stat-icon {
        width: 48px; height: 48px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.3rem; flex-shrink: 0;
    }
    .stat-label { font-size: .78rem; color: #888; margin: 0; font-weight: 500; }
    .stat-value { font-size: 1.4rem; font-weight: 700; margin: 0; color: #222; }
</style>
