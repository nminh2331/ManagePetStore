 <!-- hà hoàng hiệp code -->

@model ManagePetStore.Controllers.ProductDetailViewModel
@{
    Layout = "_PetStoreLayout";
    ViewData["Title"] = Model.Name;
}

<section class="ps-product-detail">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: 12px; margin-bottom: 24px; border: none; background-color: #d1e7dd; color: #0f5132; padding: 16px; font-weight: 500;">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: 12px; margin-bottom: 24px; border: none; background-color: #f8d7da; color: #842029; padding: 16px; font-weight: 500;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        </div>
    }

    <style>
        .ps-back-btn {
            color: #6c757d;
            font-weight: 600;
            font-size: 1.1rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: color 0.2s ease;
        }
        .ps-back-btn:hover {
            color: #ea580c;
        }
    </style>
    
    <!-- Nút Quay lại trang Sản phẩm (giữ nguyên bộ filter nhờ sessionStorage) -->
    <div class="mb-3">
        <a id="btn-back-to-products"
           href="@Url.Action("Index", "Product")" 
           class="ps-back-btn">
            &larr; Quay lại
        </a>
    </div>

    <script>
        // Nếu người dùng vào từ trang sản phẩm, lưu URL đó lại (kể cả khi là khách)
        (function () {
            var referrer = document.referrer;
            var productListPath = '@Url.Action("Index", "Product")';

            if (referrer && referrer.includes(productListPath.split('?')[0])) {
                // Lưu URL bao gồm toàn bộ filter vào sessionStorage
                sessionStorage.setItem('productListUrl', referrer);
            }

            // Gán href cho nút quay lại
            var savedUrl = sessionStorage.getItem('productListUrl');
            var backBtn  = document.getElementById('btn-back-to-products');
            if (savedUrl && backBtn) {
                backBtn.href = savedUrl;
            }
        })();
    </script>

    <div class="ps-pd-grid">
        <div>
            <div class="ps-pd-main-image">
                <img id="pdMainImage" src="@Model.Images.FirstOrDefault()" alt="@Model.Name" />
            </div>
            <div class="ps-pd-thumbs">
                @for (var i = 0; i < Model.Images.Count; i++)
                {
                    <div class="ps-pd-thumb @(i == 0 ? "active" : "")" data-src="@Model.Images[i]">
                        <img src="@Model.Images[i]" alt="@Model.Name thumbnail @(i + 1)" />
                    </div>
                }
            </div>
        </div>

        <div>
            <div class="ps-pd-brand">
                @if (Model.Sku.StartsWith("SPA-SVC-"))
                {
                    @:DỊCH VỤ: @Model.Brand
                    @if (Model.InStock)
                    {
                        <span class="ps-pd-stock-badge" style="background: rgba(46, 196, 182, 0.1); color: #2ec4b6;"><i class="bi bi-check-circle-fill"></i> Sẵn sàng phục vụ</span>
                    }
                }
                else
                {
                    @:THƯƠNG HIỆU: @Model.Brand
                    @if (Model.InStock)
                    {
                        <span class="ps-pd-stock-badge"><i class="bi bi-check-circle-fill"></i> Còn hàng</span>
                    }
                }
            </div>

            <h1 class="ps-pd-title">@Model.FullTitle</h1>

            <div class="ps-pd-meta">
                <i class="bi bi-star-fill"></i> @Model.Rating.ToString("0.0") (@Model.ReviewCount đánh giá) | Đã bán @Model.SoldCount
            </div>

            <div class="ps-pd-price-box">
                <div class="ps-pd-price-row">
                    <span class="ps-pd-price">@Model.Price.ToString("N0")đ</span>
                    @if (Model.OriginalPrice > Model.Price)
                    {
                        <span class="ps-pd-original">@Model.OriginalPrice.ToString("N0")đ</span>
                        <span class="ps-pd-discount-badge">@Model.DiscountPercent%</span>
                    }
                </div>
                @if (Model.Savings > 0)
                {
                    <div class="ps-pd-savings">Tiết kiệm: @Model.Savings.ToString("N0")đ</div>
                }
            </div>

            @if (Model.Sku.StartsWith("SPA-SVC-"))
            {
                <div class="ps-pd-qty-row" style="margin-bottom: 16px;">
                    <span class="ps-pd-qty-label">Trạng thái:</span>
                    <span class="ps-pd-stock-text" style="color: #2ec4b6; font-weight: 600; margin-left: 0;">Dịch vụ luôn sẵn sàng phục vụ</span>
                    <span class="ps-pd-qty-value" id="pdQty" data-max="999" style="display: none;">1</span>
                </div>

                <div class="ps-pd-actions">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <button type="button" class="ps-pd-buy-now w-100" id="btnOpenBookingModal" style="background: #ff7815; color: #fff; border: none; border-radius: 12px; font-weight: 600; height: 48px; font-size: 1rem;">
                            Đặt dịch vụ
                        </button>
                    }
                    else
                    {
                        <a href="/Customer/Account/Login?returnUrl=@(Context.Request.Path + Context.Request.QueryString)" class="ps-pd-buy-now w-100 d-block text-center" style="border-radius: 12px; font-weight: 600; text-decoration: none; padding: 12px; background: #ff7815; color: #fff; line-height: 24px;">
                            Đặt dịch vụ
                        </a>
                    }
                </div>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <!-- BOOKING MODAL FOR SPA SERVICES -->
                    <div id="spaBookingModal" class="ps-booking-modal-overlay" style="display: none;">
                        <div class="ps-booking-modal-content">
                            <button type="button" class="ps-booking-modal-close" id="btnCloseBookingModal">&times;</button>
                            
                            <h3 style="font-size: 1.25rem; font-weight: 700; color: #ff7815; margin-bottom: 24px; display: flex; align-items: center; gap: 8px; text-transform: uppercase;">
                                <i class="bi bi-calendar3" style="color: #ffaa00; font-size: 1.35rem;"></i> ĐẶT LỊCH HẸN SPA TRỰC TUYẾN
                            </h3>
                            
                            <form asp-controller="Product" asp-action="BookSpaService" method="post" id="spaBookingForm">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="sku" value="@Model.Sku" />
                                
                                <!-- Customer Info Grid -->
                                <div class="row g-3 mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Họ và tên khách hàng</label>
                                        <input type="text" class="form-control" value="@ViewBag.LoggedInCustomer?.FullName" disabled />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Số điện thoại</label>
                                        <input type="text" class="form-control" value="@ViewBag.LoggedInCustomer?.Phone" disabled />
                                    </div>
                                </div>
                                
                                <!-- Pet Selection -->
                                <div class="mb-3 text-start">
                                    <label class="form-label">Chọn thú cưng của bạn *</label>
                                    <select name="petId" id="petSelect" class="form-select" required>
                                        <option value="" disabled selected>-- Chọn thú cưng --</option>
                                        @foreach (var pet in ViewBag.CustomerPets as List<Pet> ?? new List<Pet>())
                                        {
                                            <option value="@pet.PetId">@pet.Name (@pet.Species)</option>
                                        }
                                        <option value="0">+ Thêm thú cưng mới</option>
                                    </select>
                                </div>
                                
                                <!-- Dynamic Pet Info Preview Box -->
                                <div id="petInfoPreview" class="p-3 mb-3 text-start" style="display: none;">
                                    <h4 style="font-size: 0.85rem; font-weight: 700; color: #ff7815; margin-bottom: 8px;">Thông tin thú cưng:</h4>
                                    <div class="row g-2" style="font-size: 0.8rem;">
                                        <div class="col-6">Loài: <strong id="previewSpecies"></strong></div>
                                        <div class="col-6">Giống: <strong id="previewBreed"></strong></div>
                                        <div class="col-6">Tuổi: <strong id="previewAge"></strong></div>
                                        <div class="col-6">Cân nặng: <strong id="previewWeight"></strong> kg</div>
                                    </div>
                                </div>
                                
                                <!-- New Pet Registration Fields (hidden by default) -->
                                <div id="newPetFields" class="p-3 mb-3 text-start" style="display: none; background: #fdfdfd; border: 1px solid #ddd; border-radius: 10px;">
                                    <h4 style="font-size: 0.85rem; font-weight: 700; color: #555; margin-bottom: 12px;">Đăng ký thú cưng mới</h4>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label">Tên thú cưng *</label>
                                            <input type="text" name="newPetName" id="newPetName" class="form-control form-control-sm" placeholder="Nhập tên" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Loài *</label>
                                            <select name="newPetSpecies" id="newPetSpecies" class="form-select form-select-sm">
                                                <option value="Chó">Chó</option>
                                                <option value="Mèo">Mèo</option>
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Giống loại</label>
                                            <input type="text" name="newPetBreed" id="newPetBreed" class="form-control form-control-sm" placeholder="Ví dụ: Poodle, Ba Tư" />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label">Tuổi</label>
                                            <input type="text" name="newPetAge" id="newPetAge" class="form-control form-control-sm" placeholder="Ví dụ: 1 tuổi" />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label">Cân nặng (kg)</label>
                                            <input type="number" step="0.1" name="newPetWeight" id="newPetWeight" class="form-control form-control-sm" value="4.0" />
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Groomer Selection -->
                                <div class="mb-3 text-start">
                                    <label class="form-label">Chọn nhân viên mong muốn (Không bắt buộc)</label>
                                    <select name="groomerId" id="groomerSelect" class="form-select">
                                        <option value="0" selected>-- Hệ thống tự phân bổ (Hoặc chọn nhân viên mong muốn) --</option>
                                        @foreach (var gr in ViewBag.ActiveGroomers as List<User> ?? new List<User>())
                                        {
                                            <option value="@gr.UserId">@gr.FullName (Groomer Master)</option>
                                        }
                                    </select>
                                </div>
                                
                                <!-- Date Selection -->
                                <div class="mb-3 text-start">
                                    <label class="form-label">Chọn ngày đặt lịch *</label>
                                    <input type="date" name="bookingDate" id="bookingDate" class="form-control" min="@DateTime.Today.ToString("yyyy-MM-dd")" value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                                </div>
                                
                                <!-- Time Slot Selection Grid -->
                                <div class="mb-3 text-start">
                                    <label class="form-label">Chọn khung giờ làm việc *</label>
                                    <input type="hidden" name="bookingTime" id="selectedTimeSlot" required />
                                    
                                    <div class="ps-slot-grid-wrapper">
                                        <div class="ps-slot-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px;">
                                            @{
                                                var defaultTimeSlots = new string[] { "08:00", "09:00", "10:00", "11:00", "13:00", "14:00", "15:00", "16:00" };
                                                foreach (var slot in defaultTimeSlots)
                                                {
                                                    <button type="button" class="ps-slot-btn" data-time="@slot">
                                                        @slot
                                                    </button>
                                                }
                                            }
                                        </div>
                                        <p class="text-muted mt-2 mb-0" style="font-size: 0.72rem; text-align: center;">
                                            ⓘ Khung giờ mờ là nhân viên đã bận. Vui lòng đổi nhân viên hoặc ngày khác.
                                        </p>
                                    </div>
                                </div>
                                
                                <!-- Note -->
                                <div class="mb-4 text-start">
                                    <label class="form-label">Ghi chú yêu cầu thêm</label>
                                    <textarea name="note" class="form-control" rows="2" placeholder="Ví dụ: Thú cưng sợ nước, muốn cạo lông ngắn..."></textarea>
                                </div>
                                
                                <!-- Submit Button -->
                                <button type="submit" class="w-100" id="btnSubmitBooking">
                                    <i class="bi bi-calendar3"></i> XÁC NHẬN ĐẶT DỊCH VỤ
                                </button>
 
                                <!-- Trust Badges under button -->
                                <div class="ps-pd-trust">
                                    <div class="ps-pd-trust-item"><i class="bi bi-shield-check"></i> CHÍNH HÃNG 100%</div>
                                    <div class="ps-pd-trust-item"><i class="bi bi-truck"></i> GIAO NHANH 2H</div>
                                    <div class="ps-pd-trust-item"><i class="bi bi-arrow-repeat"></i> ĐỔI TRẢ 7 NGÀY</div>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- WARNING POPUP FOR PETS WITH NO MEDICAL HISTORY -->
                    <div id="medicalWarningModal" style="display: none; position: fixed; top: 24px; right: 24px; width: 450px; max-width: calc(100vw - 48px); background: #ffffff; border-radius: 20px; box-shadow: 0 15px 40px rgba(139, 69, 19, 0.18); border: 1px solid #FFEAD2; z-index: 10005; padding: 24px; animation: slideInRight 0.35s cubic-bezier(0.16, 1, 0.3, 1);">
                        <style>
                            @@keyframes slideInRight {
                                from {
                                    transform: translateX(120%);
                                    opacity: 0;
                                }
                                to {
                                    transform: translateX(0);
                                    opacity: 1;
                                }
                            }
                        </style>
                        <div style="display: flex; gap: 18px; align-items: flex-start; text-align: left;">
                            <div style="font-size: 2.5rem; color: #ffaa00; line-height: 1; flex-shrink: 0; margin-top: -2px;">
                                <i class="bi bi-exclamation-triangle-fill"></i>
                            </div>
                            <div style="flex: 1;">
                                <h3 style="font-size: 1.15rem; font-weight: 700; color: #ff7815; margin-top: 0; margin-bottom: 8px; text-transform: uppercase;">Khuyến nghị khám sức khỏe</h3>
                                <p style="font-size: 0.88rem; color: #555; line-height: 1.6; margin-bottom: 12px;">
                                    Thú cưng này chưa từng được khám sức khỏe tại cửa hàng (không có lịch sử sổ y tế). 
                                    <strong>Vui lòng mang bé đến cửa hàng để được bác sĩ khám và tạo sổ y tế trước khi đặt lịch dịch vụ Spa.</strong>
                                </p>
                                <p style="font-size: 0.78rem; color: #888; margin-bottom: 18px; line-height: 1.4;">
                                    * Các mặt hàng (sản phẩm, thức ăn, phụ kiện...) vẫn có thể mua sắm bình thường.
                                </p>
                                <div style="text-align: right;">
                                    <button type="button" class="btn btn-primary rounded-pill px-4 py-2" id="btnCloseWarningModal" style="background-color: #ff7815; border: none; font-weight: 600; color: white; font-size: 0.85rem; box-shadow: 0 4px 12px rgba(255, 120, 21, 0.25); transition: all 0.2s;">Tôi hiểu rồi</button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="ps-pd-qty-row">
                    <span class="ps-pd-qty-label">Số lượng:</span>
                    <div class="ps-pd-qty-control">
                        <button type="button" class="ps-pd-qty-btn" id="pdQtyMinus">−</button>
                        <span class="ps-pd-qty-value" id="pdQty" data-max="@Model.Stock">1</span>
                        <button type="button" class="ps-pd-qty-btn" id="pdQtyPlus">+</button>
                    </div>
                    <span class="ps-pd-stock-text">@Model.Stock sản phẩm có sẵn</span>
                </div>

                <div class="ps-pd-actions">
                    <form asp-area="Customer" asp-controller="Cart" asp-action="Add" method="post" class="ps-pd-add-cart-form" style="width: 100%;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="sku" value="@Model.Sku" />
                        <input type="hidden" name="quantity" id="pdQtyInput" value="1" />
                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                        <button type="submit" class="ps-pd-add-cart" style="width: 100%;" @(Model.InStock ? null : "disabled")>
                            <i class="bi bi-cart3"></i> Thêm vào giỏ
                        </button>
                    </form>
                    <button type="button" class="ps-pd-buy-now">Mua ngay</button>
                </div>
            }

            <div class="ps-pd-trust">
                <div class="ps-pd-trust-item"><i class="bi bi-shield-check"></i> CHÍNH HÃNG 100%</div>
                <div class="ps-pd-trust-item"><i class="bi bi-truck"></i> GIAO NHANH 2H</div>
                <div class="ps-pd-trust-item"><i class="bi bi-arrow-repeat"></i> ĐỔI TRẢ 7 NGÀY</div>
            </div>
        </div>
    </div>
</section>

<section class="ps-section mt-4 mb-5" style="max-width: 1200px; margin: 0 auto; padding: 0 32px;">
    <div style="background: #fff; border-radius: 16px; box-shadow: 0 4px 16px rgba(0,0,0,.06); overflow: hidden;">
        <div style="display: flex; border-bottom: 1px solid #eee; padding: 0 24px;">
            <div style="padding: 16px 24px; color: #ea580c; font-weight: 700; border-bottom: 2px solid #ea580c; cursor: pointer; font-size: 1rem;">
                @if (!Model.Sku.StartsWith("SPA-SVC-")) { <text>Mô tả sản phẩm</text> } else { <text>Chi tiết dịch vụ</text> }
            </div>
        </div>
        
        <div style="padding: 32px 32px;">
            <h3 style="font-size: 1.15rem; font-weight: 800; color: #111; margin-bottom: 16px; text-transform: uppercase; letter-spacing: 0.5px;">
                @Model.Name
            </h3>
            
            <div class="product-description-content" style="color: #555; line-height: 1.8; font-size: 0.95rem;">
                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    @Html.Raw(Model.Description.Replace("\r\n", "<br/>").Replace("\n", "<br/>"))
                }
                else
                {
                    <p style="color: #888; font-style: italic;">Đang cập nhật thông tin...</p>
                }
            </div>
        </div>
    </div>
</section>

@if (!Model.Sku.StartsWith("SPA-SVC-"))
{
    <!-- ======================== KHU VỰC ĐÁNH GIÁ SẢN PHẨM ======================== -->
    <section class="ps-section mt-4 mb-4" style="max-width: 1200px; margin: 0 auto; padding: 0 32px;">
        <style>
            .review-section-wrap { background: #fff; border-radius: 16px; box-shadow: 0 4px 16px rgba(0,0,0,.06); padding: 28px 32px; }
            .review-summary-row { display: flex; align-items: center; gap: 32px; padding-bottom: 24px; border-bottom: 1px solid #f0f0f0; margin-bottom: 24px; flex-wrap: wrap; }
            .review-big-score { font-size: 3.5rem; font-weight: 900; color: #111; line-height: 1; }
            .review-stars-row { display: flex; gap: 4px; }
            .review-star { font-size: 1.4rem; }
            .review-star.filled { color: #f59e0b; }
            .review-star.empty  { color: #d1d5db; }
            .review-star.half   { color: #f59e0b; }
            .review-count-label { font-size: 0.88rem; color: #6b7280; margin-top: 4px; }
            .review-list { display: flex; flex-direction: column; gap: 20px; }
            .review-card { background: #fafafa; border-radius: 12px; padding: 18px 22px; border: 1px solid #f0f0f0; }
            .review-card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; flex-wrap: wrap; gap: 8px; }
            .review-card-author { font-weight: 700; font-size: 0.95rem; color: #111; display: flex; align-items: center; gap: 8px; }
            .review-card-author .avatar { width: 32px; height: 32px; border-radius: 50%; background: linear-gradient(135deg, #ea580c, #f59e0b); color: #fff; font-weight: 800; font-size: 0.8rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
            .review-card-date { font-size: 0.8rem; color: #9ca3af; }
            .review-card-stars { display: flex; gap: 3px; margin-bottom: 8px; }
            .review-card-stars .rs { font-size: 1rem; color: #f59e0b; }
            .review-card-stars .rs.empty { color: #d1d5db; }
            .review-card-comment { color: #374151; font-size: 0.93rem; line-height: 1.7; }
            .review-empty-state { text-align: center; padding: 32px; color: #9ca3af; }
            .review-empty-state i { font-size: 2.5rem; color: #e5e7eb; display: block; margin-bottom: 12px; }
            /* Write review form */
            .write-review-wrap { margin-top: 28px; padding-top: 24px; border-top: 1px solid #f0f0f0; }
            .write-review-title { font-size: 1.05rem; font-weight: 800; color: #111; margin-bottom: 18px; }
            .star-picker { display: flex; gap: 8px; margin-bottom: 18px; cursor: pointer; }
            .star-picker i { font-size: 1.8rem; color: #d1d5db; transition: color 0.15s; }
            .star-picker i.active { color: #f59e0b; }
            .star-picker i:hover ~ i { color: #d1d5db; }
            .write-review-textarea { width: 100%; border: 1.5px solid #e5e7eb; border-radius: 10px; padding: 14px 16px; font-size: 0.93rem; color: #374151; resize: vertical; min-height: 100px; font-family: inherit; transition: border-color 0.2s; }
            .write-review-textarea:focus { outline: none; border-color: #ea580c; }
            .write-review-submit { margin-top: 12px; background: linear-gradient(135deg, #ea580c, #f59e0b); color: #fff; border: none; border-radius: 10px; padding: 12px 28px; font-weight: 700; font-size: 0.95rem; cursor: pointer; transition: opacity 0.2s, transform 0.15s; }
            .write-review-submit:hover { opacity: 0.9; transform: translateY(-1px); }
            .review-login-notice { background: #fff7ed; border: 1.5px solid #fed7aa; border-radius: 10px; padding: 14px 18px; color: #9a3412; font-size: 0.9rem; margin-top: 24px; }
        </style>

        <div class="review-section-wrap">
            <h2 style="font-size: 1.15rem; font-weight: 800; color: #111; margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
                <i class="bi bi-star-fill" style="color: #f59e0b;"></i> Đánh giá từ khách hàng
            </h2>

            @{
                var avgRating = Model.ReviewCount > 0 ? Model.Rating : 0.0;
                var fullStars = (int)Math.Floor(avgRating);
                var hasHalf = (avgRating - fullStars) >= 0.5;
            }

            <div class="row">
                <!-- Cột trái: Tóm tắt điểm & Form đánh giá -->
                <div class="col-md-4" style="border-right: 1px solid #f0f0f0; padding-right: 24px;">
                    <!-- Summary row -->
                    <div class="review-summary-row" style="padding-bottom: 20px; margin-bottom: 20px;">
                        <div style="display: flex; align-items: center; gap: 10px; flex-wrap: wrap;">
                            <div style="display: flex; gap: 3px;">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= fullStars)
                                    { <span class="review-star filled">★</span> }
                                    else if (i == fullStars + 1 && hasHalf)
                                    { <span class="review-star half">★</span> }
                                    else
                                    { <span class="review-star empty">☆</span> }
                                }
                            </div>
                            @if (Model.ReviewCount > 0)
                            {
                                <div style="width: 100%;">
                                    <span style="font-size: 1.1rem; font-weight: 800; color: #111;">@avgRating.ToString("0.0")</span>
                                    <span style="color: #9ca3af; font-size: 0.88rem;">/ 5 (@Model.ReviewCount đánh giá)</span>
                                </div>
                            }
                            else
                            {
                                <div style="width: 100%;"><span style="color: #9ca3af; font-size: 0.88rem;">Chưa có đánh giá nào</span></div>
                            }
                        </div>
                    </div>

                    <!-- Write review form or notice -->
                    @if (Model.CanReview)
                    {
                        <div class="write-review-wrap" style="margin-top: 0; padding-top: 0; border-top: none;">
                            <div class="write-review-title"><i class="bi bi-pencil-square me-2" style="color: #ea580c;"></i>Viết đánh giá của bạn</div>
                            <form asp-controller="Product" asp-action="SubmitProductReview" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productSku" value="@Model.Sku" />
                                <input type="hidden" name="rating" id="review-rating-input" value="5" />
                                <div class="star-picker" id="star-picker">
                                    <i class="bi bi-star-fill active" data-val="1"></i>
                                    <i class="bi bi-star-fill active" data-val="2"></i>
                                    <i class="bi bi-star-fill active" data-val="3"></i>
                                    <i class="bi bi-star-fill active" data-val="4"></i>
                                    <i class="bi bi-star-fill active" data-val="5"></i>
                                </div>
                                <textarea class="write-review-textarea" name="comment" placeholder="Chia sẻ cảm nhận của bạn về sản phẩm..." required maxlength="1000" style="min-height: 80px;"></textarea>
                                <div><button type="submit" class="write-review-submit" style="padding: 10px 20px; font-size: 0.9rem;"><i class="bi bi-send me-2"></i>Gửi đánh giá</button></div>
                            </form>
                        </div>
                    }
                    else if (!User.Identity?.IsAuthenticated ?? true)
                    {
                        <div class="review-login-notice" style="margin-top: 0;">
                            <i class="bi bi-info-circle me-2"></i>
                            <a asp-area="Customer" asp-controller="Account" asp-action="Login" style="color: #ea580c; font-weight: 700;">Đăng nhập</a> và mua sản phẩm này để gửi đánh giá.
                        </div>
                    }
                    else
                    {
                        <div class="review-login-notice" style="margin-top: 0; background: #f0fdf4; border-color: #bbf7d0; color: #166534;">
                            <i class="bi bi-bag-check me-2"></i>
                            Mua và nhận sản phẩm này để có thể gửi đánh giá.
                        </div>
                    }
                </div>

                <!-- Cột phải: Danh sách bình luận -->
                <div class="col-md-8" style="padding-left: 24px;">
                    <!-- Review list -->
                    @if (Model.Reviews.Any())
                    {
                        <div class="review-list">
                            @foreach (var rv in Model.Reviews)
                            {
                                <div class="review-card">
                                    <div class="review-card-header">
                                        <div class="review-card-author">
                                            <div class="avatar">@(rv.CustomerName.Length > 0 ? rv.CustomerName[0].ToString().ToUpper() : "K")</div>
                                            <span>@rv.CustomerName</span>
                                        </div>
                                        <span class="review-card-date">@rv.CreatedAt.ToString("dd/MM/yyyy")</span>
                                    </div>
                                    <div class="review-card-stars">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <span class="rs @(i <= rv.Rating ? "" : "empty")">★</span>
                                        }
                                    </div>
                                    <div class="review-card-comment">@rv.Comment</div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="review-empty-state">
                            <i class="bi bi-chat-square-text"></i>
                            <div style="font-weight: 600; color: #6b7280; margin-bottom: 4px;">Chưa có đánh giá nào</div>
                            <div style="font-size: 0.85rem;">Hãy là người đầu tiên đánh giá sản phẩm này!</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- JS: Star picker -->
    <script>
        (function () {
            var picker = document.getElementById('star-picker');
            var input = document.getElementById('review-rating-input');
            if (!picker || !input) return;
            var stars = picker.querySelectorAll('i');
            function setRating(val) {
                input.value = val;
                stars.forEach(function (s, idx) {
                    s.classList.toggle('active', idx < val);
                });
            }
            stars.forEach(function (star, idx) {
                star.addEventListener('click', function () { setRating(idx + 1); });
                star.addEventListener('mouseenter', function () {
                    stars.forEach(function (s, i) { s.classList.toggle('active', i <= idx); });
                });
            });
            picker.addEventListener('mouseleave', function () { setRating(parseInt(input.value)); });
        })();
    </script>
}

@if (!Model.Sku.StartsWith("SPA-SVC-"))
{
