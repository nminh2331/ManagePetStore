 <!-- hà hoàng hiệp code -->

@model ManagePetStore.Controllers.ProductDetailViewModel
@{
    Layout = "_PetStoreLayout";
    ViewData["Title"] = Model.Name;
}

<section class="ps-product-detail">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: 12px; margin-bottom: 24px; border: none; background-color: #d1e7dd; color: #0f5132; padding: 16px; font-weight: 500;">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: 12px; margin-bottom: 24px; border: none; background-color: #f8d7da; color: #842029; padding: 16px; font-weight: 500;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        </div>
    }
    <div class="ps-pd-grid">
        <div>
            <div class="ps-pd-main-image">
                <img id="pdMainImage" src="@Model.Images.FirstOrDefault()" alt="@Model.Name" />
            </div>
            <div class="ps-pd-thumbs">
                @for (var i = 0; i < Model.Images.Count; i++)
                {
                    <div class="ps-pd-thumb @(i == 0 ? "active" : "")" data-src="@Model.Images[i]">
                        <img src="@Model.Images[i]" alt="@Model.Name thumbnail @(i + 1)" />
                    </div>
                }
            </div>
        </div>

        <div>
            <div class="ps-pd-brand">
                @if (Model.Sku.StartsWith("SPA-SVC-"))
                {
                    @:DỊCH VỤ: @Model.Brand
                    @if (Model.InStock)
                    {
                        <span class="ps-pd-stock-badge" style="background: rgba(46, 196, 182, 0.1); color: #2ec4b6;"><i class="bi bi-check-circle-fill"></i> Sẵn sàng phục vụ</span>
                    }
                }
                else
                {
                    @:THƯƠNG HIỆU: @Model.Brand
                    @if (Model.InStock)
                    {
                        <span class="ps-pd-stock-badge"><i class="bi bi-check-circle-fill"></i> Còn hàng</span>
                    }
                }
            </div>

            <h1 class="ps-pd-title">@Model.FullTitle</h1>

            <div class="ps-pd-meta">
                <i class="bi bi-star-fill"></i> @Model.Rating.ToString("0.0") (@Model.ReviewCount đánh giá) | Đã bán @Model.SoldCount
            </div>

            <div class="ps-pd-price-box">
                <div class="ps-pd-price-row">
                    <span class="ps-pd-price">@Model.Price.ToString("N0")đ</span>
                    @if (Model.OriginalPrice > Model.Price)
                    {
                        <span class="ps-pd-original">@Model.OriginalPrice.ToString("N0")đ</span>
                        <span class="ps-pd-discount-badge">@Model.DiscountPercent%</span>
                    }
                </div>
                @if (Model.Savings > 0)
                {
                    <div class="ps-pd-savings">Tiết kiệm: @Model.Savings.ToString("N0")đ</div>
                }
            </div>

            <p class="ps-pd-desc">@Model.Description</p>

            <div class="ps-pd-features">
                @foreach (var feature in Model.Features)
                {
                    <div class="ps-pd-feature">
                        <span class="ps-pd-feature-icon"><i class="bi bi-check-lg"></i></span>
                        @feature
                    </div>
                }
            </div>

            @if (Model.Sku.StartsWith("SPA-SVC-"))
            {
                <div class="ps-pd-qty-row" style="margin-bottom: 16px;">
                    <span class="ps-pd-qty-label">Trạng thái:</span>
                    <span class="ps-pd-stock-text" style="color: #2ec4b6; font-weight: 600; margin-left: 0;">Dịch vụ luôn sẵn sàng phục vụ</span>
                    <span class="ps-pd-qty-value" id="pdQty" data-max="999" style="display: none;">1</span>
                </div>

                <div class="ps-pd-actions">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <button type="button" class="ps-pd-buy-now w-100" id="btnOpenBookingModal" style="background: #ff7815; color: #fff; border: none; border-radius: 12px; font-weight: 600; height: 48px; font-size: 1rem;">
                            Đặt dịch vụ
                        </button>
                    }
                    else
                    {
                        <a href="/Customer/Account/Login?returnUrl=@(Context.Request.Path + Context.Request.QueryString)" class="ps-pd-buy-now w-100 d-block text-center" style="border-radius: 12px; font-weight: 600; text-decoration: none; padding: 12px; background: #ff7815; color: #fff; line-height: 24px;">
                            Đặt dịch vụ
                        </a>
                    }
                </div>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <!-- BOOKING MODAL FOR SPA SERVICES -->
                    <div id="spaBookingModal" class="ps-booking-modal-overlay" style="display: none;">
                        <div class="ps-booking-modal-content">
                            <button type="button" class="ps-booking-modal-close" id="btnCloseBookingModal">&times;</button>
                            
                            <h3 style="font-size: 1.25rem; font-weight: 700; color: #ff7815; margin-bottom: 24px; display: flex; align-items: center; gap: 8px; text-transform: uppercase;">
                                <i class="bi bi-calendar3" style="color: #ffaa00; font-size: 1.35rem;"></i> ĐẶT LỊCH HẸN SPA TRỰC TUYẾN
                            </h3>
                            
                            <form asp-controller="Product" asp-action="BookSpaService" method="post" id="spaBookingForm">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="sku" value="@Model.Sku" />
                                
                                <!-- Customer Info Grid -->
                                <div class="row g-3 mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Họ và tên khách hàng</label>
                                        <input type="text" class="form-control" value="@ViewBag.LoggedInCustomer?.FullName" disabled />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Số điện thoại</label>
                                        <input type="text" class="form-control" value="@ViewBag.LoggedInCustomer?.Phone" disabled />
                                    </div>
                                </div>
                                
                                <!-- Pet Selection -->
                                <div class="mb-3 text-start">
                                    <label class="form-label">Chọn thú cưng của bạn *</label>
                                    <select name="petId" id="petSelect" class="form-select" required>
                                        <option value="" disabled selected>-- Chọn thú cưng --</option>
                                        @foreach (var pet in ViewBag.CustomerPets as List<Pet> ?? new List<Pet>())
                                        {
                                            <option value="@pet.PetId">@pet.Name (@pet.Species)</option>
                                        }
                                        <option value="0">+ Thêm thú cưng mới</option>
                                    </select>
                                </div>
                                
                                <!-- Dynamic Pet Info Preview Box -->
                                <div id="petInfoPreview" class="p-3 mb-3 text-start" style="display: none;">
                                    <h4 style="font-size: 0.85rem; font-weight: 700; color: #ff7815; margin-bottom: 8px;">Thông tin thú cưng:</h4>
                                    <div class="row g-2" style="font-size: 0.8rem;">
                                        <div class="col-6">Loài: <strong id="previewSpecies"></strong></div>
                                        <div class="col-6">Giống: <strong id="previewBreed"></strong></div>
                                        <div class="col-6">Tuổi: <strong id="previewAge"></strong></div>
                                        <div class="col-6">Cân nặng: <strong id="previewWeight"></strong> kg</div>
                                    </div>
                                </div>
                                
                                <!-- New Pet Registration Fields (hidden by default) -->
                                <div id="newPetFields" class="p-3 mb-3 text-start" style="display: none; background: #fdfdfd; border: 1px solid #ddd; border-radius: 10px;">
                                    <h4 style="font-size: 0.85rem; font-weight: 700; color: #555; margin-bottom: 12px;">Đăng ký thú cưng mới</h4>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label">Tên thú cưng *</label>
                                            <input type="text" name="newPetName" id="newPetName" class="form-control form-control-sm" placeholder="Nhập tên" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Loài *</label>
                                            <select name="newPetSpecies" id="newPetSpecies" class="form-select form-select-sm">
                                                <option value="Chó">Chó</option>
                                                <option value="Mèo">Mèo</option>
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Giống loại</label>
                                            <input type="text" name="newPetBreed" id="newPetBreed" class="form-control form-control-sm" placeholder="Ví dụ: Poodle, Ba Tư" />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label">Tuổi</label>
                                            <input type="text" name="newPetAge" id="newPetAge" class="form-control form-control-sm" placeholder="Ví dụ: 1 tuổi" />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label">Cân nặng (kg)</label>
                                            <input type="number" step="0.1" name="newPetWeight" id="newPetWeight" class="form-control form-control-sm" value="4.0" />
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Groomer Selection -->
                                <div class="mb-3 text-start">
                                    <label class="form-label">Chọn nhân viên mong muốn (Không bắt buộc)</label>
                                    <select name="groomerId" id="groomerSelect" class="form-select">
                                        <option value="0" selected>-- Hệ thống tự phân bổ (Hoặc chọn nhân viên mong muốn) --</option>
                                        @foreach (var gr in ViewBag.ActiveGroomers as List<User> ?? new List<User>())
                                        {
                                            <option value="@gr.UserId">@gr.FullName (Groomer Master)</option>
                                        }
                                    </select>
                                </div>
                                
                                <!-- Date Selection -->
                                <div class="mb-3 text-start">
                                    <label class="form-label">Chọn ngày đặt lịch *</label>
                                    <input type="date" name="bookingDate" id="bookingDate" class="form-control" min="@DateTime.Today.ToString("yyyy-MM-dd")" value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                                </div>
                                
                                <!-- Time Slot Selection Grid -->
                                <div class="mb-3 text-start">
                                    <label class="form-label">Chọn khung giờ làm việc *</label>
                                    <input type="hidden" name="bookingTime" id="selectedTimeSlot" required />
                                    
                                    <div class="ps-slot-grid-wrapper">
                                        <div class="ps-slot-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px;">
                                            @{
                                                var defaultTimeSlots = new string[] { "08:00", "09:00", "10:00", "11:00", "13:00", "14:00", "15:00", "16:00" };
                                                foreach (var slot in defaultTimeSlots)
                                                {
                                                    <button type="button" class="ps-slot-btn" data-time="@slot">
                                                        @slot
                                                    </button>
                                                }
                                            }
                                        </div>
                                        <p class="text-muted mt-2 mb-0" style="font-size: 0.72rem; text-align: center;">
                                            ⓘ Khung giờ mờ là nhân viên đã bận. Vui lòng đổi nhân viên hoặc ngày khác.
                                        </p>
                                    </div>
                                </div>
                                
                                <!-- Note -->
                                <div class="mb-4 text-start">
                                    <label class="form-label">Ghi chú yêu cầu thêm</label>
                                    <textarea name="note" class="form-control" rows="2" placeholder="Ví dụ: Thú cưng sợ nước, muốn cạo lông ngắn..."></textarea>
                                </div>
                                
                                <!-- Submit Button -->
                                <button type="submit" class="w-100" id="btnSubmitBooking">
                                    <i class="bi bi-calendar3"></i> XÁC NHẬN ĐẶT DỊCH VỤ
                                </button>
 
                                <!-- Trust Badges under button -->
                                <div class="ps-pd-trust">
                                    <div class="ps-pd-trust-item"><i class="bi bi-shield-check"></i> CHÍNH HÃNG 100%</div>
                                    <div class="ps-pd-trust-item"><i class="bi bi-truck"></i> GIAO NHANH 2H</div>
                                    <div class="ps-pd-trust-item"><i class="bi bi-arrow-repeat"></i> ĐỔI TRẢ 7 NGÀY</div>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- WARNING POPUP FOR PETS WITH NO MEDICAL HISTORY -->
                    <div id="medicalWarningModal" style="display: none; position: fixed; top: 24px; right: 24px; width: 450px; max-width: calc(100vw - 48px); background: #ffffff; border-radius: 20px; box-shadow: 0 15px 40px rgba(139, 69, 19, 0.18); border: 1px solid #FFEAD2; z-index: 10005; padding: 24px; animation: slideInRight 0.35s cubic-bezier(0.16, 1, 0.3, 1);">
                        <style>
                            @@keyframes slideInRight {
                                from {
                                    transform: translateX(120%);
                                    opacity: 0;
                                }
                                to {
                                    transform: translateX(0);
                                    opacity: 1;
                                }
                            }
                        </style>
                        <div style="display: flex; gap: 18px; align-items: flex-start; text-align: left;">
                            <div style="font-size: 2.5rem; color: #ffaa00; line-height: 1; flex-shrink: 0; margin-top: -2px;">
                                <i class="bi bi-exclamation-triangle-fill"></i>
                            </div>
                            <div style="flex: 1;">
                                <h3 style="font-size: 1.15rem; font-weight: 700; color: #ff7815; margin-top: 0; margin-bottom: 8px; text-transform: uppercase;">Khuyến nghị khám sức khỏe</h3>
                                <p style="font-size: 0.88rem; color: #555; line-height: 1.6; margin-bottom: 12px;">
                                    Thú cưng này chưa từng được khám sức khỏe tại cửa hàng (không có lịch sử sổ y tế). 
                                    <strong>Vui lòng mang bé đến cửa hàng để được bác sĩ khám và tạo sổ y tế trước khi đặt lịch dịch vụ Spa.</strong>
                                </p>
                                <p style="font-size: 0.78rem; color: #888; margin-bottom: 18px; line-height: 1.4;">
                                    * Các mặt hàng (sản phẩm, thức ăn, phụ kiện...) vẫn có thể mua sắm bình thường.
                                </p>
                                <div style="text-align: right;">
                                    <button type="button" class="btn btn-primary rounded-pill px-4 py-2" id="btnCloseWarningModal" style="background-color: #ff7815; border: none; font-weight: 600; color: white; font-size: 0.85rem; box-shadow: 0 4px 12px rgba(255, 120, 21, 0.25); transition: all 0.2s;">Tôi hiểu rồi</button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="ps-pd-qty-row">
                    <span class="ps-pd-qty-label">Số lượng:</span>
                    <div class="ps-pd-qty-control">
                        <button type="button" class="ps-pd-qty-btn" id="pdQtyMinus">−</button>
                        <span class="ps-pd-qty-value" id="pdQty" data-max="@Model.Stock">1</span>
                        <button type="button" class="ps-pd-qty-btn" id="pdQtyPlus">+</button>
                    </div>
                    <span class="ps-pd-stock-text">@Model.Stock sản phẩm có sẵn</span>
                </div>

                <div class="ps-pd-actions">
                    <form asp-area="Customer" asp-controller="Cart" asp-action="Add" method="post" class="ps-pd-add-cart-form" style="width: 100%;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="sku" value="@Model.Sku" />
                        <input type="hidden" name="quantity" id="pdQtyInput" value="1" />
                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                        <button type="submit" class="ps-pd-add-cart" style="width: 100%;" @(Model.InStock ? null : "disabled")>
                            <i class="bi bi-cart3"></i> Thêm vào giỏ
                        </button>
                    </form>
                    <button type="button" class="ps-pd-buy-now">Mua ngay</button>
                </div>
            }

            <div class="ps-pd-trust">
                <div class="ps-pd-trust-item"><i class="bi bi-shield-check"></i> CHÍNH HÃNG 100%</div>
                <div class="ps-pd-trust-item"><i class="bi bi-truck"></i> GIAO NHANH 2H</div>
                <div class="ps-pd-trust-item"><i class="bi bi-arrow-repeat"></i> ĐỔI TRẢ 7 NGÀY</div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{
        var serializedPets = "[]";
        if (ViewBag.CustomerPets != null)
        {
            var petsWithRecords = ViewBag.PetIdsWithRecords as HashSet<int> ?? new HashSet<int>();
            var petListData = (ViewBag.CustomerPets as List<Pet> ?? new List<Pet>())
                .Select(p => new { 
                    p.PetId, 
                    p.Name, 
                    Species = p.Species ?? "Chó", 
                    Breed = p.Breed ?? "Không rõ", 
                    Age = p.Age ?? "Chưa rõ", 
                    Weight = p.Weight,
                    HasMedicalRecord = petsWithRecords.Contains(p.PetId)
                });
            serializedPets = System.Text.Json.JsonSerializer.Serialize(petListData);
        }
    }
    
    <script>
        (function () {
            // 1. Swapping product images on thumbnail click
            var mainImage = document.getElementById('pdMainImage');
            var thumbs = document.querySelectorAll('.ps-pd-thumb');
            thumbs.forEach(function (thumb) {
                thumb.addEventListener('click', function () {
                    thumbs.forEach(t => t.classList.remove('active'));
                    this.classList.add('active');
                    if (mainImage) {
                        mainImage.src = this.getAttribute('data-src');
                    }
                });
            });

            // 2. Quantity selector logic (for normal products)
            var qtyMinus = document.getElementById('pdQtyMinus');
            var qtyPlus = document.getElementById('pdQtyPlus');
            var qtyValue = document.getElementById('pdQty');
            var qtyInput = document.getElementById('pdQtyInput');

            if (qtyValue) {
                var maxVal = parseInt(qtyValue.getAttribute('data-max')) || 99;
                
                if (qtyMinus) {
                    qtyMinus.addEventListener('click', function () {
                        var val = parseInt(qtyValue.textContent) || 1;
                        if (val > 1) {
                            val--;
                            qtyValue.textContent = val;
                            if (qtyInput) qtyInput.value = val;
                        }
                    });
                }

                if (qtyPlus) {
                    qtyPlus.addEventListener('click', function () {
                        var val = parseInt(qtyValue.textContent) || 1;
                        if (val < maxVal) {
                            val++;
                            qtyValue.textContent = val;
                            if (qtyInput) qtyInput.value = val;
                        }
                    });
                }
            }

            // 3. Spa service booking form interactive logic
            var customerPets = @Html.Raw(serializedPets);
            var petSelect = document.getElementById('petSelect');
            var petInfoPreview = document.getElementById('petInfoPreview');
            var newPetFields = document.getElementById('newPetFields');

            // Fields to toggle required status
            var newPetName = document.getElementById('newPetName');

            var warningModal = document.getElementById('medicalWarningModal');
            var btnCloseWarningModal = document.getElementById('btnCloseWarningModal');
            var btnSubmitBooking = document.getElementById('btnSubmitBooking');

            if (btnCloseWarningModal && warningModal) {
                btnCloseWarningModal.addEventListener('click', function () {
                    warningModal.style.display = 'none';
                });
            }

            function checkPetMedicalHistory(val) {
                if (!btnSubmitBooking) return;
                
                // Keep the button clickable HTML-wise so we can catch clicks and show the warning popup
                btnSubmitBooking.disabled = false;
                
                if (val === "0") {
                    btnSubmitBooking.style.opacity = '0.5';
                    btnSubmitBooking.style.cursor = 'not-allowed';
                    btnSubmitBooking.dataset.invalidPet = "true";
                } else if (val && val !== "") {
                    var selectedId = parseInt(val);
                    var pet = customerPets.find(p => p.PetId === selectedId);
                    if (pet && !pet.HasMedicalRecord) {
                        btnSubmitBooking.style.opacity = '0.5';
                        btnSubmitBooking.style.cursor = 'not-allowed';
                        btnSubmitBooking.dataset.invalidPet = "true";
                    } else {
                        btnSubmitBooking.style.opacity = '1';
                        btnSubmitBooking.style.cursor = 'pointer';
                        btnSubmitBooking.dataset.invalidPet = "false";
                        // Automatically hide warning popup if a valid pet is chosen
                        if (warningModal) warningModal.style.display = 'none';
                    }
                } else {
                    btnSubmitBooking.style.opacity = '0.5';
                    btnSubmitBooking.style.cursor = 'not-allowed';
                    btnSubmitBooking.dataset.invalidPet = "false";
                }
            }

            if (petSelect) {
                // Initial check on load
                checkPetMedicalHistory(petSelect.value);

                petSelect.addEventListener('change', function () {
                    var val = this.value;
                    checkPetMedicalHistory(val);
                    
                    if (val === "0") {
                        // Show new pet fields and require them
                        newPetFields.style.display = 'block';
                        if (newPetName) newPetName.setAttribute('required', 'required');
                        petInfoPreview.style.display = 'none';
                    } else if (val && val !== "") {
                        // Find the selected pet details in our serialized list
                        var selectedId = parseInt(val);
                        var pet = customerPets.find(p => p.PetId === selectedId);
                        
                        if (pet) {
                            document.getElementById('previewSpecies').textContent = pet.Species;
                            document.getElementById('previewBreed').textContent = pet.Breed;
                            document.getElementById('previewAge').textContent = pet.Age;
                            document.getElementById('previewWeight').textContent = pet.Weight;

                            petInfoPreview.style.display = 'block';
                        } else {
                            petInfoPreview.style.display = 'none';
                        }
                        newPetFields.style.display = 'none';
                        if (newPetName) newPetName.removeAttribute('required');
                    } else {
                        petInfoPreview.style.display = 'none';
                        newPetFields.style.display = 'none';
                        if (newPetName) newPetName.removeAttribute('required');
                    }
                });
            }

            // Time Slot grid selection
            var slotButtons = document.querySelectorAll('.ps-slot-btn');
            var selectedTimeInput = document.getElementById('selectedTimeSlot');

            slotButtons.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    if (this.classList.contains('disabled') || this.disabled) {
                        return;
                    }
                    slotButtons.forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    if (selectedTimeInput) {
                        selectedTimeInput.value = this.getAttribute('data-time');
                    }
                });
            });

            // Dynamic busy slots querying
            var groomerSelect = document.getElementById('groomerSelect');
            var bookingDateInput = document.getElementById('bookingDate');

            function updateAvailableTimeSlots() {
                var groomerId = groomerSelect ? groomerSelect.value : "0";
                var date = bookingDateInput ? bookingDateInput.value : "";

                if (!date) {
                    slotButtons.forEach(function (btn) {
                        btn.disabled = false;
                        btn.classList.remove('disabled', 'busy');
                        btn.classList.add('free');
                    });
                    return;
                }

                if (groomerId === "0" || !groomerId) {
                    // No preferred groomer, all slots free
                    slotButtons.forEach(function (btn) {
                        btn.disabled = false;
                        btn.classList.remove('disabled', 'busy');
                        btn.classList.add('free');
                    });
                    return;
                }

                fetch(`/Product/GetGroomerBookedSlots?groomerId=${groomerId}&date=${date}`)
                    .then(response => response.json())
                    .then(busySlots => {
                        slotButtons.forEach(function (btn) {
                            var time = btn.getAttribute('data-time');
                            btn.disabled = false; // Always clickable
                            btn.classList.remove('disabled', 'busy', 'free');
                            if (busySlots.includes(time)) {
                                btn.classList.add('busy');
                            } else {
                                btn.classList.add('free');
                            }
                        });
                    })
                    .catch(err => {
                        console.error("Error fetching groomer booked slots:", err);
                        slotButtons.forEach(function (btn) {
                            btn.disabled = false;
                            btn.classList.remove('disabled', 'busy');
                            btn.classList.add('free');
                        });
                    });
            }

            if (groomerSelect) {
                groomerSelect.addEventListener('change', updateAvailableTimeSlots);
            }
            if (bookingDateInput) {
                bookingDateInput.addEventListener('change', updateAvailableTimeSlots);
            }

            // Initial slot state loading
            if (groomerSelect && bookingDateInput) {
                updateAvailableTimeSlots();
            }

            // Form validation before submit
            var formEl = document.getElementById('spaBookingForm');
            if (formEl) {
                formEl.addEventListener('submit', function (e) {
                    if (btnSubmitBooking && btnSubmitBooking.dataset.invalidPet === "true") {
                        e.preventDefault();
                        if (warningModal) {
                            warningModal.style.display = 'block';
                        }
                        return;
                    }

                    if (selectedTimeInput && !selectedTimeInput.value) {
                        e.preventDefault();
                        alert('Vui lòng chọn khung giờ làm việc của nhân viên.');
                    }
                });
            }

            // Also check on click event directly to provide prompt visual response
            if (btnSubmitBooking) {
                btnSubmitBooking.addEventListener('click', function (e) {
                    if (btnSubmitBooking.dataset.invalidPet === "true") {
                        e.preventDefault();
                        if (warningModal) {
                            warningModal.style.display = 'block';
                        }
                    }
                });
            }

            // 4. Modal popup controls
            var modalOverlay = document.getElementById('spaBookingModal');
            var btnOpenModal = document.getElementById('btnOpenBookingModal');
            var btnCloseModal = document.getElementById('btnCloseBookingModal');

            if (btnOpenModal && modalOverlay) {
                btnOpenModal.addEventListener('click', function () {
                    modalOverlay.style.display = 'flex';
                    slotButtons.forEach(b => b.classList.remove('active'));
                    if (selectedTimeInput) selectedTimeInput.value = '';
                    if (petSelect) checkPetMedicalHistory(petSelect.value);
                    updateAvailableTimeSlots();
                });
            }

            if (btnCloseModal && modalOverlay) {
                btnCloseModal.addEventListener('click', function () {
                    modalOverlay.style.display = 'none';
                    if (warningModal) warningModal.style.display = 'none';
                });
            }

            if (modalOverlay) {
                modalOverlay.addEventListener('click', function (e) {
                    if (e.target === modalOverlay) {
                        modalOverlay.style.display = 'none';
                    }
                });
            }
        })();
    </script>
}
