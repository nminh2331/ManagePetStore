@model IEnumerable<ManagePetStore.Models.Product>
@{
    ViewData["Title"] = "Tất cả sản phẩm";
    Layout = "~/Views/Shared/_PetStoreLayout.cshtml";
    var categories   = ViewBag.Categories  as List<ManagePetStore.Models.ProductCategory> ?? new();
    var animalTypes  = ViewBag.AnimalTypes as List<string> ?? new();
    int currentPage  = ViewBag.Page        ?? 1;
    int totalPages   = ViewBag.TotalPages  ?? 1;
    int totalItems   = ViewBag.TotalItems  ?? 0;
    string curSort   = ViewBag.Sort        ?? "best_selling";
    string? curSearch       = ViewBag.Search;
    int?    curCategoryId   = ViewBag.CategoryId;
    string? curAnimalType   = ViewBag.AnimalType;
    int?    curSupplierId   = ViewBag.SupplierId;
    int?    curMinPrice     = ViewBag.MinPrice;
    int?    curMaxPrice     = ViewBag.MaxPrice;
    var suppliers    = ViewBag.Suppliers as List<ManagePetStore.Models.Supplier> ?? new();
    var categoryCounts = ViewBag.CategoryCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
    
    bool hasFilter = !string.IsNullOrEmpty(curSearch) || 
                     curCategoryId.HasValue || 
                     !string.IsNullOrEmpty(curAnimalType) || 
                     curSupplierId.HasValue || 
                     curMinPrice.HasValue || 
                     curMaxPrice.HasValue || 
                     curSort != "best_selling";
}

<style>
    :root {
        --primary: #ea580c;
        --primary-light: #f97316;
        --primary-fade: #fff3eb;
        --accent: #22c55e;
        --bg: #f5f6fa;
        --card-radius: 16px;
        --shadow: 0 4px 16px rgba(0,0,0,.06);
    }
    body { background: var(--bg); }

    /* ---- Search bar ---- */
    .search-wrap { position: relative; }
    .search-wrap input { border-radius: 50px; padding-left: 2.8rem; border: 2px solid #e0e0e0; transition: border .2s; }
    .search-wrap input:focus { border-color: var(--primary-light); box-shadow: 0 0 0 3px rgba(234,88,12,.15); }
    .search-wrap .search-icon { position:absolute; left:1rem; top:50%; transform:translateY(-50%); color:#aaa; }

    /* ---- Sidebar ---- */
    .sidebar-card { background:#fff; border-radius:var(--card-radius); box-shadow:var(--shadow); padding:1.2rem 1rem; margin-bottom:1.5rem; }
    .sidebar-card h6 { font-weight:800; color:#333; margin-bottom:.8rem; font-size:.95rem; text-transform:uppercase; letter-spacing:0.5px; }
    .filter-btn { display:block; width:100%; text-align:left; background:none; border:none; padding:.5rem .8rem; border-radius:10px; color:#555; font-size:.95rem; cursor:pointer; transition:all .2s; margin-bottom: 2px; }
    .filter-btn:hover, .filter-btn.active { background:var(--primary-fade); color:var(--primary); font-weight:700; }
    .filter-btn .count { float:right; background:#f0f0f0; border-radius:50px; padding:2px 8px; font-size:.75rem; color:#777; font-weight:600; }
    .filter-btn.active .count { background:var(--primary-fade); color:var(--primary); }

    /* ---- Sort bar ---- */
    .sort-wrap { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; background: #fff; padding: 12px 20px; border-radius: 12px; box-shadow: var(--shadow); }
    .sort-wrap .form-select { border-radius: 8px; border: 1px solid #ddd; padding-top: 6px; padding-bottom: 6px; font-size: .95rem; }
    
    /* ---- Product card ---- */
    .product-card { background:#fff; border-radius:var(--card-radius); box-shadow:var(--shadow); overflow:hidden; transition:transform .2s, box-shadow .2s; cursor:pointer; height:100%; display:flex; flex-direction:column; position: relative; border: 1px solid rgba(0,0,0,.03); }
    .product-card:hover { transform:translateY(-5px); box-shadow:0 12px 30px rgba(0,0,0,.1); }
    .product-card .img-wrap { position: relative; width: 100%; padding-top: 100%; background: #f9f9f9; }
    .product-card img { position: absolute; top:0; left:0; width:100%; height:100%; object-fit:cover; border-top-left-radius: var(--card-radius); border-top-right-radius: var(--card-radius); }
    
    .product-card .card-body { padding:1.2rem; flex:1; display:flex; flex-direction:column; }
    .product-card .p-name { font-weight:700; font-size:.95rem; color:#333; margin-bottom:.3rem; line-height:1.4; flex:1; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .product-card .p-unit { font-size: .8rem; color: #888; margin-bottom: .8rem; }
    .product-card .price-row { display: flex; align-items: flex-end; gap: 8px; margin-bottom: 1rem; }
    .product-card .p-price { font-size:1.15rem; font-weight:800; color:#111; }
    .product-card .btn-add { border-radius:10px; background:var(--primary); border:none; color:#fff; font-size:.9rem; font-weight:700; padding:.6rem 1rem; width:100%; transition:background .2s; }
    .product-card .btn-add:hover { background:var(--primary-light); }
    .out-of-stock .btn-add { background: #f0f0f0; color: #999; cursor: not-allowed; }
    
    /* ---- Badges & Heart ---- */
    .badge-new { position:absolute; top:12px; left:12px; background:var(--accent); color:#fff; border-radius:50px; font-size:.7rem; padding:.25rem .7rem; font-weight:700; z-index:2; }
    .badge-out { position:absolute; top:12px; left:12px; background:rgba(0,0,0,.7); color:#fff; border-radius:50px; font-size:.7rem; padding:.25rem .7rem; font-weight:700; z-index:2; }
    .heart-btn { position:absolute; top:12px; right:12px; background:rgba(255,255,255,.9); color:#aaa; border-radius:50px; width:32px; height:32px; display:flex; align-items:center; justify-content:center; box-shadow:0 2px 5px rgba(0,0,0,.1); z-index:2; transition: color .2s; }
    .heart-btn:hover { color: #ff4757; }

    /* ---- Pagination ---- */
    .page-link { border-radius:8px !important; margin:0 2px; color:var(--primary); }
    .page-item.active .page-link { background:var(--primary); border-color:var(--primary); }

    /* ---- Empty state ---- */
    .empty-state { text-align:center; padding:4rem 1rem; color:#aaa; }
    .empty-state i { font-size:4rem; margin-bottom:1rem; }

    /* ---- Sticky Sidebar ---- */
    .sticky-sidebar {
        position: sticky;
        top: 100px; /* Offset cho header */
        height: fit-content;
        max-height: calc(100vh - 120px);
        overflow-y: auto;
    }
    
    /* Ẩn scrollbar cho đẹp */
    .sticky-sidebar::-webkit-scrollbar { width: 4px; }
    .sticky-sidebar::-webkit-scrollbar-track { background: transparent; }
    .sticky-sidebar::-webkit-scrollbar-thumb { background: #ccc; border-radius: 10px; }
    .sticky-sidebar::-webkit-scrollbar-thumb:hover { background: #aaa; }
</style>

<div class="container-fluid py-4" style="max-width:1400px;">

    <!-- Page Header -->
    <div class="mb-4">
        <h1 class="fw-bold" style="color:var(--primary)">
            <i class="fas fa-store me-2"></i>Tất cả sản phẩm
        </h1>
        <p class="text-muted mb-0">
            Khám phá <strong>@totalItems</strong> sản phẩm dành cho thú cưng của bạn
        </p>
    </div>

    <div class="row g-4">

        <!-- ====== SIDEBAR ====== -->
        <div class="col-lg-2 col-md-3 sticky-sidebar">

            <!-- Loại thú cưng -->
            <div class="sidebar-card">
                <h6>LOẠI THÚ CƯNG</h6>
                <a class="filter-btn @(string.IsNullOrEmpty(curAnimalType) ? "active" : "")"
                   href="@Url.Action("Index","Product", new { search=curSearch, sort=curSort, categoryId=curCategoryId })">
                    🐾 Tất cả thú cưng
                </a>
                @foreach (var at in animalTypes)
                {
                    string icon = at.ToLower() switch {
                        "chó" => "🐕",
                        "mèo" => "🐈",
                        "chim" => "🐦",
                        "cá" => "🐟",
                        "chuột" => "🐁",
                        "thỏ" => "🐇",
                        _ => "🐾"
                    };
                    <a class="filter-btn @(curAnimalType == at ? "active" : "")"
                       href="@Url.Action("Index","Product", new { animalType=at, search=curSearch, sort=curSort, categoryId=curCategoryId })">
                        @icon @at
                    </a>
                }
            </div>

            <!-- Danh mục -->
            <div class="sidebar-card">
                <h6>DANH MỤC</h6>
                <a class="filter-btn @(curCategoryId == null ? "active" : "")"
                   href="@Url.Action("Index","Product", new { search=curSearch, sort=curSort, animalType=curAnimalType })">
                    Tất cả <span class="count">@totalItems</span>
                </a>
                @foreach (var cat in categories)
                {
                    <a class="filter-btn @(curCategoryId == cat.CategoryId ? "active" : "")"
                       href="@Url.Action("Index","Product", new { categoryId=cat.CategoryId, search=curSearch, sort=curSort, animalType=curAnimalType })">
                        @cat.Name <span class="count">@(categoryCounts.GetValueOrDefault(cat.CategoryId, 0))</span>
                    </a>
                }
            </div>

            <!-- Khoảng giá -->
            <div class="sidebar-card">
                <h6>KHOẢNG GIÁ</h6>
                <form method="get" action="@Url.Action("Index", "Product")">
                    @if (!string.IsNullOrEmpty(curSearch)) { <input type="hidden" name="search" value="@curSearch" /> }
                    @if (curCategoryId.HasValue) { <input type="hidden" name="categoryId" value="@curCategoryId" /> }
                    @if (!string.IsNullOrEmpty(curAnimalType)) { <input type="hidden" name="animalType" value="@curAnimalType" /> }
                    <input type="hidden" name="sort" value="@curSort" />
                    
                    <div class="d-flex align-items-center mb-3 gap-2 mt-2">
                        <input type="number" name="minPrice" class="form-control form-control-sm" placeholder="Từ" value="@curMinPrice" min="0" style="border-radius: 6px; text-align: center;"/>
                        <span style="color:#aaa;">-</span>
                        <input type="number" name="maxPrice" class="form-control form-control-sm" placeholder="Đến" value="@curMaxPrice" min="0" style="border-radius: 6px; text-align: center;"/>
                    </div>
                    <button type="submit" class="btn btn-sm w-100" style="background:var(--primary);color:#fff;border-radius:8px;font-weight:700;padding:8px 0;">Áp dụng</button>
                </form>
            </div>

            @if (hasFilter)
            {
                <a href="@Url.Action("Index", "Product")" class="btn w-100 mb-3" style="border: 1px solid var(--accent); color: var(--accent); font-weight: 600; border-radius: 8px;">
                    <i class="fas fa-undo me-1"></i> Xoá bộ lọc
                </a>
            }
        </div>

        <!-- ====== MAIN CONTENT ====== -->
        <div class="col-lg-10 col-md-9">

            <!-- Sort bar -->
            <div class="sort-wrap">
                <div class="d-flex align-items-center gap-2">
                    <span class="text-muted small">Sắp xếp:</span>
                    <form method="get" action="@Url.Action("Index", "Product")" id="sortForm">
                        @if (!string.IsNullOrEmpty(curSearch)) { <input type="hidden" name="search" value="@curSearch" /> }
                        @if (curCategoryId.HasValue) { <input type="hidden" name="categoryId" value="@curCategoryId" /> }
                        @if (!string.IsNullOrEmpty(curAnimalType)) { <input type="hidden" name="animalType" value="@curAnimalType" /> }
                        @if (curMinPrice.HasValue) { <input type="hidden" name="minPrice" value="@curMinPrice" /> }
                        @if (curMaxPrice.HasValue) { <input type="hidden" name="maxPrice" value="@curMaxPrice" /> }
                        <select name="sort" class="form-select form-select-sm" onchange="document.getElementById('sortForm').submit();" style="width: 160px; font-weight: 600;">
                            <option value="best_selling" selected="@(curSort == "best_selling" ? "selected" : null)">Phổ biến nhất</option>
                            <option value="newest" selected="@(curSort == "newest" ? "selected" : null)">Mới nhất</option>
                            <option value="price_asc" selected="@(curSort == "price_asc" ? "selected" : null)">Giá tăng dần</option>
                            <option value="price_desc" selected="@(curSort == "price_desc" ? "selected" : null)">Giá giảm dần</option>
                        </select>
                    </form>
                </div>
            </div>

            <!-- Product grid -->
            @if (!Model.Any())
            {
                <div class="empty-state">
                    <i class="fas fa-search-minus d-block"></i>
                    <h5>Không tìm thấy sản phẩm nào</h5>
                    <p>Thử tìm với từ khóa khác hoặc <a href="@Url.Action("Index","Product")" style="color:var(--primary);">xem tất cả sản phẩm</a></p>
                </div>
            }
            else
            {
                <div class="row row-cols-2 row-cols-sm-3 row-cols-xl-4 g-4">
                    @{
                        // Lấy top 4 SKU bán chạy để gắn badge Hot
                        var hotSkus = Model
                            .OrderByDescending(p => p.OrderItems.Sum(oi => (int?)oi.Quantity) ?? 0)
                            .Take(4)
                            .Select(p => p.Sku)
                            .ToHashSet();
                        // Gắn badge New cho 4 SKU mới nhất (theo SKU alphabet desc)
                        var newSkus = Model
                            .OrderByDescending(p => p.Sku)
                            .Take(4)
                            .Select(p => p.Sku)
                            .ToHashSet();
                    }
                    @foreach (var p in Model)
                    {
                        var isHot  = hotSkus.Contains(p.Sku) && (p.OrderItems?.Sum(oi => (int?)oi.Quantity) ?? 0) > 0;
                        var isNew  = newSkus.Contains(p.Sku);
                        var imgUrl = string.IsNullOrEmpty(p.ImageUrl)
                            ? "https://images.unsplash.com/photo-1589924691995-400dc9ecc119?w=400&h=400&fit=crop"
                            : p.ImageUrl;
                        <div class="col">
                            <div class="product-card @(p.Stock == 0 ? "out-of-stock" : "")">
                                <div class="img-wrap">
                                    <a href="@Url.Action("Details","Product", new { id = p.Sku })">
                                        <img src="@imgUrl" alt="@p.Name" loading="lazy" />
                                    </a>
                                    @if (p.Stock == 0) {
                                        <span class="badge-out">HẾT HÀNG</span>
                                    } else if (isNew) { 
                                        <span class="badge-new">Mới</span> 
                                    }
                                    <a href="#" class="heart-btn" title="Yêu thích"><i class="fas fa-heart"></i></a>
                                </div>
                                <div class="card-body">
                                    <a href="@Url.Action("Details","Product", new { id = p.Sku })"
                                       class="d-block p-name text-decoration-none">
                                        @p.Name
                                    </a>
                                    <div class="p-unit">@p.Unit</div>
                                    <div class="mt-auto">
                                        <div class="price-row">
                                            <div class="p-price">@p.Price.ToString("N0")đ</div>
                                        </div>
                                        @if (p.Stock > 0)
                                        {
                                            <form method="post" action="/Customer/Cart/Add" class="w-100">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="sku" value="@p.Sku" />
                                                <input type="hidden" name="quantity" value="1" />
                                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                                <button type="submit" class="btn-add">
                                                    Thêm vào giỏ
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <button class="btn-add w-100" disabled>Hết hàng</button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                @if (totalPages > 1)
                {
                    <nav class="mt-4 d-flex justify-content-center" aria-label="Pagination">
                        <ul class="pagination">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("Index","Product", new { page=currentPage-1, search=curSearch, categoryId=curCategoryId, animalType=curAnimalType, sort=curSort, supplierId=curSupplierId, minPrice=curMinPrice, maxPrice=curMaxPrice })">
                                    <i class="fas fa-chevron-left"></i>
                                </a>
                            </li>
                            @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" href="@Url.Action("Index","Product", new { page=i, search=curSearch, categoryId=curCategoryId, animalType=curAnimalType, sort=curSort, supplierId=curSupplierId, minPrice=curMinPrice, maxPrice=curMaxPrice })">@i</a>
                                </li>
                            }
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("Index","Product", new { page=currentPage+1, search=curSearch, categoryId=curCategoryId, animalType=curAnimalType, sort=curSort, supplierId=curSupplierId, minPrice=curMinPrice, maxPrice=curMaxPrice })">
                                    <i class="fas fa-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                }
            }
        </div>
    </div>
</div>
