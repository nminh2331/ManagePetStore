@section Scripts {
<script>
// ===== AUTO-DISMISS TOAST =====
setTimeout(() => {
    document.querySelectorAll('.toast-hotel .alert').forEach(el => {
        el.style.transition = 'opacity 0.5s';
        el.style.opacity = '0';
        setTimeout(() => el.closest('.toast-hotel')?.remove(), 500);
    });
}, 3500);

// ===== TAB SWITCHING =====
function switchTab(tabName, btn) {
    document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
    document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));
    document.getElementById('tabContent-' + tabName).classList.add('active');
    btn.classList.add('active');
}

// ===== CHECK-IN: LOOKUP CUSTOMER BY PHONE =====
let lookupTimer;
function lookupCustomer(phone) {
    clearTimeout(lookupTimer);
    const normalizedPhone = phone.replace(/\D/g, '');
    if (normalizedPhone.length < 10) {
        document.getElementById('existingPetGroup').style.display = 'none';
        document.getElementById('ci-customerName').value = '';
        document.getElementById('ci-existingPetHidden').value = '';
        return;
    }
    lookupTimer = setTimeout(() => {
        // Find from server-side customers list
        const customers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(customers.Select(c => new { c.CustomerId, c.FullName, c.Phone })));
        const found = customers.find(c => c.phone === normalizedPhone);
        if (found) {
            document.getElementById('ci-customerName').value = found.fullName;
            // Load their pets
            fetch('/SpaServices/GetHotelPetsByCustomer?customerId=' + found.customerId)
                .then(r => r.json())
                .then(pets => {
                    const sel = document.getElementById('ci-existingPet');
                    sel.innerHTML = '<option value="">— Tạo mới —</option>';
                    pets.forEach(p => {
                        const option = document.createElement('option');
                        option.value = p.petId;
                        option.textContent = `${p.name} (${p.species})`;
                        option.dataset.name = p.name;
                        option.dataset.species = p.species;
                        option.dataset.breed = p.breed;
                        option.dataset.age = p.age;
                        option.dataset.weight = p.weight;
                        option.dataset.pathology = p.pathology;
                        sel.appendChild(option);
                    });
                    document.getElementById('existingPetGroup').style.display = pets.length > 0 ? 'block' : 'none';
                });
        } else {
            document.getElementById('existingPetGroup').style.display = 'none';
            document.getElementById('ci-existingPetHidden').value = '';
        }
    }, 400);
}

function fillExistingPet(select) {
    const opt = select.options[select.selectedIndex];
    const hidden = document.getElementById('ci-existingPetHidden');
    if (!opt.value) {
        hidden.value = '';
        document.getElementById('petNewForm').style.opacity = '1';
        document.getElementById('petNewForm').style.pointerEvents = 'auto';
        return;
    }
    hidden.value = opt.value;
    document.getElementById('ci-petName').value = opt.dataset.name || '';
    document.getElementById('ci-species').value = opt.dataset.species || 'Chó';
    document.getElementById('ci-breed').value = opt.dataset.breed || '';
    document.getElementById('ci-age').value = opt.dataset.age || '';
    document.getElementById('ci-weight').value = opt.dataset.weight || '';
    document.getElementById('ci-pathology').value = opt.dataset.pathology || '';
    // Dim the pet form to show it's prefilled
    document.getElementById('petNewForm').style.opacity = '0.7';
    document.getElementById('petNewForm').style.pointerEvents = 'none';
}

// ===== HEALTH CHECK VALIDATION =====
function updateHealthStatus() {
    const status = document.getElementById('ci-healthStatus').value;
    const pathology = document.getElementById('ci-pathology');
    const message = document.getElementById('healthStatusMessage');

    pathology.setCustomValidity('');
    if (status === 'Monitor' && !pathology.value.trim()) {
        pathology.setCustomValidity('Vui lòng ghi rõ tình trạng cần theo dõi.');
    }

    if (status === 'Rejected') {
        message.style.display = 'flex';
        message.innerHTML = '<i class="fa-solid fa-ban"></i> Kết luận này sẽ bị hệ thống chặn, không thể nhận thú cưng vào chuồng.';
    } else {
        message.style.display = 'none';
        message.innerHTML = '';
    }
}

document.getElementById('ci-pathology').addEventListener('input', updateHealthStatus);

function validateStayDates() {
    const checkInInput = document.getElementById('ci-checkIn');
    const checkOutInput = document.getElementById('ci-checkOut');
    const checkIn = checkInInput.value;
    const checkOut = checkOutInput.value;

    checkInInput.setCustomValidity('');
    checkOutInput.setCustomValidity('');

    if (checkIn) {
        const checkInDate = new Date(checkIn);
        const now = new Date();
        if (checkInDate < new Date(now.getTime() - 24 * 60 * 60 * 1000) ||
            checkInDate > new Date(now.getTime() + 24 * 60 * 60 * 1000)) {
            checkInInput.setCustomValidity('Ngày nhận phải nằm trong vòng 24 giờ so với thời điểm hiện tại.');
        }
    }

    if (checkIn && checkOut) {
        const checkInDate = new Date(checkIn);
        const checkOutDate = new Date(checkOut);
        const stayDays = (checkOutDate - checkInDate) / (1000 * 60 * 60 * 24);

        if (checkOutDate <= checkInDate) {
            checkOutInput.setCustomValidity('Ngày trả dự kiến phải sau ngày nhận.');
        } else if (stayDays > 365) {
            checkOutInput.setCustomValidity('Thời gian lưu trú dự kiến không được vượt quá 365 ngày.');
        }
    }

    return checkInInput.validity.valid && checkOutInput.validity.valid;
}

document.getElementById('checkInForm').addEventListener('submit', event => {
    updateHealthStatus();
    validateStayDates();

    const healthStatus = document.getElementById('ci-healthStatus').value;

    if (healthStatus === 'Rejected') {
        event.preventDefault();
        alert('Thú cưng không đủ điều kiện lưu trú nên không thể nhận vào chuồng.');
        return;
    }

    if (!event.currentTarget.checkValidity()) {
        event.preventDefault();
        event.currentTarget.reportValidity();
    }
});

// ===== LOAD AVAILABLE CAGES =====
function loadAvailableCages(roomTypeId) {
    const sel = document.getElementById('ci-cage');
    sel.innerHTML = '<option value="">Đang tải...</option>';
    if (!roomTypeId) {
        sel.innerHTML = '<option value="">— Chọn loại chuồng trước —</option>';
        return;
    }
    fetch('/SpaServices/GetAvailableCages?roomTypeId=' + roomTypeId)
        .then(r => r.json())
        .then(cages => {
            if (!cages.length) {
                sel.innerHTML = '<option value="">Không có chuồng trống</option>';
                return;
            }
            sel.innerHTML = '<option value="">— Chọn chuồng —</option>';
            cages.forEach(c => {
                sel.innerHTML += `<option value="${c.cageId}">${c.cageId}</option>`;
            });
            calcStay();
        });
}

// ===== CALC STAY & PREVIEW PRICE =====
function calcStay() {
    const checkIn = document.getElementById('ci-checkIn').value;
    const checkOut = document.getElementById('ci-checkOut').value;
    const roomSel = document.getElementById('ci-roomType');
    const pricePreview = document.getElementById('pricePreview');
    const priceVal = document.getElementById('pricePreviewValue');
    const priceDet = document.getElementById('pricePreviewDetail');

    if (!checkIn || !checkOut || !roomSel.value) {
        pricePreview.style.display = 'none';
        return;
    }

    const opt = roomSel.options[roomSel.selectedIndex];
    const dailyPrice = parseFloat(opt?.dataset?.price || '0');
    const d1 = new Date(checkIn);
    const d2 = new Date(checkOut);
    if (!validateStayDates() || d2 <= d1) {
        pricePreview.style.display = 'none';
        return;
    }

    const diffDays = Math.max(1, Math.ceil((d2 - d1) / (1000 * 60 * 60 * 24)));

    const total = dailyPrice * diffDays;
    priceVal.textContent = total.toLocaleString('vi-VN') + 'đ';
    priceDet.textContent = `${diffDays} ngày × ${dailyPrice.toLocaleString('vi-VN')}đ/ngày`;
    pricePreview.style.display = 'block';
}

// ===== SET DEFAULT CHECK-IN DATE =====
document.addEventListener('DOMContentLoaded', () => {
    const now = new Date();
    now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
    document.getElementById('ci-checkIn').value = now.toISOString().slice(0, 16);
    document.getElementById('ci-checkIn').addEventListener('input', calcStay);
    document.getElementById('ci-checkOut').addEventListener('input', calcStay);
    validateStayDates();
});

// ===== TOGGLE ROOM TYPE =====
function toggleRoomType(id, checkbox) {
    fetch('/SpaServices/ToggleRoomType', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': getAntiForgeryToken() },
        body: 'id=' + id
    })
    .then(r => r.json())
    .then(data => {
        if (!data.success) {
            checkbox.checked = !checkbox.checked;
            alert('Lỗi: ' + data.message);
        }
    });
}

// ===== OPEN EDIT ROOM TYPE =====
function openEditRoomType(id, type, size, capacity, hourly, daily, hasAc, hasCam, hasFood) {
    document.getElementById('edit-rt-id').value = id;
    document.getElementById('edit-rt-type').value = type;
    document.getElementById('edit-rt-capacity').value = capacity;
    document.getElementById('edit-rt-daily').value = daily;
    document.getElementById('edit-rt-hourly').value = hourly;
    document.getElementById('edit-rt-ac').checked = hasAc === true || hasAc === 'true';
    document.getElementById('edit-rt-cam').checked = hasCam === true || hasCam === 'true';
    document.getElementById('edit-rt-food').checked = hasFood === true || hasFood === 'true';
    // Set size dropdown
    const sizeSel = document.getElementById('edit-rt-size');
    for (let i = 0; i < sizeSel.options.length; i++) {
        if (sizeSel.options[i].value === size) { sizeSel.selectedIndex = i; break; }
    }
    new bootstrap.Modal(document.getElementById('editRoomTypeModal')).show();
}

// ===== DELETE ROOM TYPE =====
function deleteRoomType(id, name) {
    if (!confirm(`Xóa loại chuồng "${name}"?\nNếu có chuồng đang dùng, hệ thống sẽ tự động chuyển sang Ngưng hoạt động.`)) return;
    fetch('/SpaServices/DeleteRoomType', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': getAntiForgeryToken() },
        body: 'id=' + id
    })
    .then(r => r.json())
    .then(data => {
        if (data.success) { location.reload(); }
        else { alert('Lỗi: ' + data.message); }
    });
}

// ===== OPEN EDIT CAGE =====
function openEditCage(cageId, roomTypeId, feedSchedule, portion) {
    document.getElementById('edit-cage-id').value = cageId;
    document.getElementById('edit-cage-feed').value = feedSchedule;
    document.getElementById('edit-cage-portion').value = portion;
    const rtSel = document.getElementById('edit-cage-roomtype');
    for (let i = 0; i < rtSel.options.length; i++) {
        if (parseInt(rtSel.options[i].value) === roomTypeId) { rtSel.selectedIndex = i; break; }
    }
    new bootstrap.Modal(document.getElementById('editCageModal')).show();
}

// ===== DELETE CAGE =====
function deleteCage(cageId) {
    if (!confirm(`Xóa chuồng "${cageId}"?`)) return;
    fetch('/SpaServices/DeleteCage', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': getAntiForgeryToken() },
        body: 'cageId=' + encodeURIComponent(cageId)
    })
    .then(r => r.json())
    .then(data => {
        if (data.success) { location.reload(); }
        else { alert('❌ ' + data.message); }
    });
}

// ===== CONFIRM CHECK-OUT =====
let checkoutBookingId = null;
function confirmCheckout(bookingId, petName, cageId) {
    checkoutBookingId = bookingId;
    document.getElementById('checkoutPetName').textContent = petName;
    document.getElementById('checkoutCageId').textContent = 'Chuồng ' + cageId;
    new bootstrap.Modal(document.getElementById('checkOutModal')).show();
}

document.getElementById('confirmCheckoutBtn').addEventListener('click', () => {
    if (!checkoutBookingId) return;
    fetch('/SpaServices/CheckOut', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': getAntiForgeryToken() },
        body: 'bookingId=' + checkoutBookingId
    })
    .then(r => r.json())
    .then(data => {
        if (data.success) { location.reload(); }
        else { alert('Lỗi: ' + data.message); }
    });
});

// ===== ANTI-FORGERY TOKEN HELPER =====
function getAntiForgeryToken() {
    return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
}
