@section Scripts {
    <script>
        var isOtpSent = false;

        function openModal() {
            // Reset form
            $('#createStaffForm')[0].reset();
            $('#createStaffForm input[name="password"]').val('123456');
            $('#staff-otp-group').hide();
            $('#staff-otp-code').val('');
            $('#staff-modal-alert').hide().text('');
            $('#staff-modal-success').hide().text('');
            $('#btn-submit-staff').text('Gửi mã OTP xác nhận').prop('disabled', false);
            isOtpSent = false;
            document.getElementById('createStaffModal').style.display = 'flex';
        }

        function closeModal() {
            document.getElementById('createStaffModal').style.display = 'none';
        }

        $('#btn-submit-staff').click(function() {
            var $btn = $(this);
            $('#staff-modal-alert').hide().text('');
            $('#staff-modal-success').hide().text('');

            if (!isOtpSent) {
                // Gửi OTP
                var fullName = $('#createStaffForm input[name="fullName"]').val();
                var email = $('#createStaffForm input[name="email"]').val();
                var phone = $('#createStaffForm input[name="phone"]').val();
                var roleId = $('#createStaffForm select[name="roleId"]').val();
                var password = $('#createStaffForm input[name="password"]').val();

                if (!fullName || !email || !phone || !password || !roleId) {
                    $('#staff-modal-alert').text('Vui lòng điền đầy đủ các thông tin bắt buộc.').show();
                    return;
                }

                $btn.text('Đang gửi OTP...').prop('disabled', true);

                $.ajax({
                    url: '@Url.Action("SendStaffOtp", "Home", new { area = "Admin" })',
                    type: 'POST',
                    data: {
                        fullName: fullName,
                        email: email,
                        phone: phone,
                        roleId: roleId,
                        password: password,
                        __RequestVerificationToken: $('#createStaffForm input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(res) {
                        if (res.success) {
                            isOtpSent = true;
                            $('#staff-otp-group').slideDown();
                            $('#staff-modal-success').text(res.message).show();
                            $btn.text('Xác thực & Cấp tài khoản').prop('disabled', false);
                        } else {
                            $('#staff-modal-alert').text(res.message).show();
                            $btn.text('Gửi mã OTP xác nhận').prop('disabled', false);
                        }
                    },
                    error: function() {
                        $('#staff-modal-alert').text('Đã xảy ra lỗi hệ thống khi gửi OTP.').show();
                        $btn.text('Gửi mã OTP xác nhận').prop('disabled', false);
                    }
                });
            } else {
                // Xác thực OTP và Tạo tài khoản
                var otpCode = $('#staff-otp-code').val();
                if (!otpCode) {
                    $('#staff-modal-alert').text('Vui lòng nhập mã OTP.').show();
                    return;
                }

                $btn.text('Đang xác thực...').prop('disabled', true);

                $.ajax({
                    url: '@Url.Action("VerifyStaffOtpAndCreate", "Home", new { area = "Admin" })',
                    type: 'POST',
                    data: {
                        otpCode: otpCode,
                        __RequestVerificationToken: $('#createStaffForm input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(res) {
                        if (res.success) {
                            window.location.reload();
                        } else {
                            $('#staff-modal-alert').text(res.message).show();
                            $btn.text('Xác thực & Cấp tài khoản').prop('disabled', false);
                        }
                    },
                    error: function() {
                        $('#staff-modal-alert').text('Đã xảy ra lỗi hệ thống khi xác thực.').show();
                        $btn.text('Xác thực & Cấp tài khoản').prop('disabled', false);
                    }
                });
            }
        });
        
        // Mở View Staff Details Modal
        $(document).on('click', '.btn-view-staff', function() {
            var userId = $(this).data('userid');
            var fullname = $(this).data('fullname');
            var email = $(this).data('email');
            var phone = $(this).data('phone');
            var role = $(this).data('role');
            var password = $(this).data('password');
            var createdat = $(this).data('createdat');
            var status = $(this).data('status');
            var avatar = $(this).data('avatar');

            // Điền thông tin vào modal
            $('#viewStaffId').text('STF-' + String(userId).padStart(3, '0'));
            $('#viewStaffFullName').text(fullname);
            $('#viewStaffEmail').text(email || 'Chưa liên kết');
            $('#viewStaffPhone').text(phone || 'Chưa liên kết');
            $('#viewStaffRole').text(role);
            $('#viewStaffPassword').text(password);
            $('#viewStaffCreatedAt').text(createdat);
            
            if (status === 'Active') {
                $('#viewStaffStatus').html('<span class="badge-status badge-status-active"><span style="width: 8px; height: 8px; border-radius: 50%; background-color: #2F9E58; display: inline-block;"></span> HOẠT ĐỘNG</span>');
            } else {
                $('#viewStaffStatus').html('<span class="badge-status badge-status-locked"><span style="width: 8px; height: 8px; border-radius: 50%; background-color: #EC5959; display: inline-block;"></span> BỊ KHÓA</span>');
            }

            if (avatar) {
                $('#viewStaffAvatar').html('<img src="' + avatar + '" style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover; border: 3px solid #FFF2EA;" />');
            } else {
                var firstChar = fullname.substring(0, 1).toUpperCase();
                $('#viewStaffAvatar').html('<div class="admin-avatar" style="width: 80px; height: 80px; font-size: 2rem; border-radius: 50%; display: flex; align-items: center; justify-content: center; background-color: var(--admin-primary); color: white;">' + firstChar + '</div>');
            }

            $('#viewStaffModal').css('display', 'flex');
        });

        function closeViewStaffModal() {
            $('#viewStaffModal').css('display', 'none');
        }

        // Mở View Customer Details Modal
        $(document).on('click', '.btn-view-customer', function() {
            var userId = $(this).data('userid');
            var fullname = $(this).data('fullname');
            var email = $(this).data('email');
            var phone = $(this).data('phone');
            var password = $(this).data('password');
            var createdat = $(this).data('createdat');
            var status = $(this).data('status');
            var avatar = $(this).data('avatar');
            var loyaltypoints = $(this).data('loyaltypoints');
            var membership = $(this).data('membership');

            // Điền thông tin vào modal
            $('#viewCustomerId').text('ACC-' + String(userId).padStart(3, '0'));
            $('#viewCustomerFullName').text(fullname);
            $('#viewCustomerEmail').text(email || 'Chưa liên kết');
            $('#viewCustomerPhone').text(phone || 'Chưa liên kết');
            $('#viewCustomerPassword').text(password);
            $('#viewCustomerCreatedAt').text(createdat);
            $('#viewCustomerLoyaltyPoints').text(loyaltypoints);
            $('#viewCustomerMembership').text(membership);
            
            if (status === 'Active') {
                $('#viewCustomerStatus').html('<span class="badge-status badge-status-active"><span style="width: 8px; height: 8px; border-radius: 50%; background-color: #2F9E58; display: inline-block;"></span> HOẠT ĐỘNG</span>');
            } else {
                $('#viewCustomerStatus').html('<span class="badge-status badge-status-locked"><span style="width: 8px; height: 8px; border-radius: 50%; background-color: #EC5959; display: inline-block;"></span> BỊ KHÓA</span>');
            }

            if (avatar) {
                $('#viewCustomerAvatar').html('<img src="' + avatar + '" style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover; border: 3px solid #FFF2EA;" />');
            } else {
                var firstChar = fullname.substring(0, 1).toUpperCase();
                $('#viewCustomerAvatar').html('<div class="admin-avatar" style="width: 80px; height: 80px; font-size: 2rem; border-radius: 50%; display: flex; align-items: center; justify-content: center; background-color: #D66505; color: white;">' + firstChar + '</div>');
            }

            $('#viewCustomerModal').css('display', 'flex');
        });

        function closeViewCustomerModal() {
            $('#viewCustomerModal').css('display', 'none');
        }
        
        // Đóng modal khi bấm bên ngoài
        window.onclick = function(event) {
            var createModal = document.getElementById('createStaffModal');
            var viewStaffModal = document.getElementById('viewStaffModal');
            var viewCustomerModal = document.getElementById('viewCustomerModal');
            if (event.target == createModal) {
                createModal.style.display = 'none';
            }
            if (event.target == viewStaffModal) {
                viewStaffModal.style.display = 'none';
            }
            if (event.target == viewCustomerModal) {
                viewCustomerModal.style.display = 'none';
            }
        }
    </script>
}
