@model ManagePetStore.Models.User
@{
    Layout = null;
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Pet Store</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body class="auth-body">
    <div class="auth-wrapper">
        <!-- Left Section (Welcome) -->
        <div class="auth-left">
            <div class="auth-left-content">
                <div class="auth-puppy-frame">
                    <img src="~/images/cute_puppy.png" alt="Pet Store Puppy" class="auth-puppy-img" />
                </div>
                <h2>Chào mừng bạn đến với <span>Pet Store</span></h2>
                <p>Nơi mang lại hạnh phúc cho những người bạn bốn chân của bạn.</p>
            </div>
        </div>

        <!-- Right Section (Form) -->
        <div class="auth-right">
            <div class="auth-form-container">
                <div class="auth-header">
                    <h1>Đăng nhập</h1>
                    <p>Chào mừng trở lại! Vui lòng điền thông tin tài khoản.</p>
                </div>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="auth-alert auth-alert-success">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        @TempData["SuccessMessage"]
                    </div>
                }

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="auth-alert auth-alert-danger">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <div asp-validation-summary="All" style="list-style-type: none; padding: 0; margin: 0;"></div>
                    </div>
                }

                <form asp-action="Login" method="post" asp-route-returnUrl="@returnUrl">
                    @Html.AntiForgeryToken()

                    <div class="auth-input-group">
                        <label class="auth-input-label">Email đăng nhập</label>
                        <div class="auth-input-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                            <input type="text" name="usernameOrEmail" class="auth-input-field" placeholder="example@petstore.com" required autocomplete="email" />
                        </div>
                    </div>

                    <div class="auth-input-group">
                        <label class="auth-input-label">Mật khẩu</label>
                        <div class="auth-input-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                            </svg>
                            <input type="password" name="password" id="login-password" class="auth-input-field" placeholder="........" required autocomplete="current-password" />
                            <button type="button" class="auth-password-toggle" onclick="togglePasswordVisibility('login-password')">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" id="login-password-eye">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                </svg>
                            </button>
                        </div>
                    </div>

                    <div class="auth-options">
                        <label class="auth-remember">
                            <input type="checkbox" name="rememberMe" value="true" />
                            Ghi nhớ đăng nhập
                        </label>
                        <a asp-action="ForgotPassword" class="auth-forgot">Quên mật khẩu?</a>
                    </div>

                    <button type="submit" class="auth-btn-submit">
                        Đăng nhập ngay
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                        </svg>
                    </button>
                </form>

                <div class="auth-footer-link">
                    Bạn chưa có tài khoản? <a asp-action="Register">Đăng ký tại đây</a>
                </div>
            </div>
        </div>
    </div>

    <script>
        function togglePasswordVisibility(id) {
            var input = document.getElementById(id);
            var eyeIcon = document.getElementById(id + '-eye');
            if (input.type === "password") {
                input.type = "text";
                eyeIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.542 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />';
            } else {
                input.type = "password";
                eyeIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />';
            }
        }
    </script>
</body>
</html>
