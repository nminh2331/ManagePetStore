@model ManagePetStore.Models.User
@{
    Layout = "/Views/Shared/_PetStoreLayout.cshtml";
    ViewData["Title"] = "Thông tin cá nhân";
}

@if (TempData["Success"] != null)
{
    <div class="cp-toast success" id="walletToast">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="cp-toast error" id="walletToast">@TempData["Error"]</div>
}

<!-- Cropper.js CDN Assets -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
<link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />

<style>
    /* 2-Column Responsive Layout */
    .profile-layout-container {
        max-width: 1200px;
        margin: 0 auto;
        font-family: 'Outfit', sans-serif;
    }

    /* Left Card: Banner, Avatar, Name & Sidebar Menu Combined */
    .profile-left-card {
        background-color: #FFFFFF;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.04);
        text-align: center;
        border: 1px solid #EAEAEA;
    }

    .profile-cover-photo {
        height: 120px;
        background: linear-gradient(135deg, #FF9F43 0%, #F2780C 100%);
    }

    .profile-avatar-container-wrapper {
        margin-top: -65px;
        position: relative;
        display: inline-block;
    }

    .fb-avatar-wrapper {
        width: 130px;
        height: 130px;
        border-radius: 50%;
        border: 4px solid #FFFFFF;
        background-color: #FFFFFF;
        position: relative;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        display: flex;
        justify-content: center;
        align-items: center;
        transition: transform 0.2s;
        cursor: pointer;
    }

    .fb-avatar-wrapper:hover {
        transform: scale(1.02);
    }

    .fb-avatar-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .avatar-upload-overlay {
        position: absolute;
        inset: 0;
        background-color: rgba(0,0,0,0.45);
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: opacity 0.3s;
        cursor: pointer;
        color: #FFFFFF;
    }

    .fb-avatar-wrapper:hover .avatar-upload-overlay {
        opacity: 1;
    }

    /* Left Menu (Minimalist styling) */
    .profile-sidebar-menu {
        padding: 0 20px 25px 20px;
    }

    .profile-sidebar-item {
        font-weight: 600;
        border: none !important;
        display: flex;
        align-items: center;
        gap: 12px;
        border-radius: 8px !important;
        margin-bottom: 8px;
        padding: 12px 20px !important;
        color: #4B5563 !important;
        background-color: transparent !important;
        border-left: 4px solid transparent !important;
        transition: all 0.2s ease;
        text-decoration: none;
    }

    .profile-sidebar-item:hover {
        background-color: #F9FAFB !important;
        color: var(--auth-primary) !important;
    }

    .profile-sidebar-item.active-tab-btn {
        background-color: #FDF8ED !important; /* ultra-light warm grey/tint */
        color: var(--auth-primary) !important;
        border-left: 4px solid var(--auth-primary) !important;
        border-radius: 0 8px 8px 0 !important; /* Flat left border area */
    }

    .profile-sidebar-item.active-tab-btn svg {
        color: var(--auth-primary) !important;
    }

    /* Right Card: Content Panel */
    .profile-right-card {
        background-color: #FFFFFF;
        border-radius: 20px;
        padding: 35px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.04);
        border: 1px solid #EAEAEA;
    }

    /* Spacing fields to make them "dễ thở" */
    .auth-input-group {
        margin-bottom: 24px;
        position: relative;
    }

    .auth-input-field:disabled {
        background-color: #F3F4F6 !important;
        cursor: not-allowed;
        border-color: #E5E7EB !important;
        color: #6B7280 !important;
        padding-right: 40px;
    }

    /* Custom CSS-Based Modal for Crop Feature */
    .custom-modal {
        display: none;
        position: fixed;
        z-index: 1050;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
        outline: 0;
        background-color: rgba(0, 0, 0, 0.55);
        align-items: center;
        justify-content: center;
    }

    .custom-modal.show {
        display: flex;
    }

    .custom-modal-dialog {
        position: relative;
        max-width: 500px;
        width: 100%;
        margin: 1.75rem;
        pointer-events: none;
    }

    .custom-modal-content {
        position: relative;
        display: flex;
        flex-direction: column;
        width: 100%;
        pointer-events: auto;
        background-color: #ffffff;
        background-clip: padding-box;
        border: 0 solid rgba(0,0,0,.2);
        border-radius: 20px;
        outline: 0;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        animation: modalSlideIn 0.25s ease-out;
    }

    @@keyframes modalSlideIn {
        from { transform: translateY(-15px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }

    /* Animations */
    .fade-in-tab {
        animation: fadeIn 0.3s ease-out;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(6px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Wallet Specific Styles */
    .wallet-card {
        background: linear-gradient(135deg, #3d2314 0%, #2c1810 100%);
        color: #fff;
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(61, 35, 20, 0.15);
        position: relative;
        overflow: hidden;
        margin-bottom: 24px;
        border: none;
        text-align: left;
    }
    .wallet-card::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 250px;
        height: 250px;
        border-radius: 50%;
        background: rgba(249, 115, 22, 0.15);
        pointer-events: none;
    }
    .wallet-balance-label {
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: rgba(255, 255, 255, 0.7);
        margin-bottom: 8px;
    }
    .wallet-balance-amount {
        font-size: 2.2rem;
        font-weight: 800;
        color: #f97316;
        margin-bottom: 12px;
        line-height: 1;
    }
    .wallet-status {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.85rem;
        padding: 4px 12px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.1);
    }
    .wallet-status.active {
        color: #4ade80;
        background: rgba(74, 222, 128, 0.1);
    }
    .wallet-status.locked {
        color: #f87171;
        background: rgba(248, 113, 113, 0.1);
    }
    .btn-deposit {
        background-color: #f97316;
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 12px 24px;
        font-weight: 700;
        transition: all 0.2s ease;
        box-shadow: 0 4px 14px rgba(249, 115, 22, 0.3);
    }
    .btn-deposit:hover {
        background-color: #ea580c;
        color: #fff;
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(249, 115, 22, 0.4);
    }
    .transaction-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 4px 24px rgba(61, 35, 20, 0.06);
        overflow: hidden;
        border: 1px solid #EAEAEA;
    }
    .transaction-header {
        padding: 20px 24px;
        border-bottom: 1px solid #f3f4f6;
        display: flex;
        justify-content: space-between;
        align-items: center;
        text-align: left;
    }
    .transaction-title {
        font-size: 1.1rem;
        font-weight: 800;
        color: #3d2314;
        margin: 0;
    }
    .table-transactions th {
        font-weight: 700;
        color: #6b7280;
        border-bottom: 2px solid #f3f4f6;
        font-size: 0.85rem;
        text-transform: uppercase;
        padding: 16px 24px;
        text-align: left;
    }
    .table-transactions td {
        padding: 18px 24px;
        vertical-align: middle;
        color: #374151;
        font-size: 0.9rem;
        border-bottom: 1px solid #f3f4f6;
        text-align: left;
    }
    .table-transactions tr:last-child td {
        border-bottom: none;
    }
    .badge-type {
        font-weight: 700;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 0.75rem;
        display: inline-block;
    }
    .badge-deposit {
        background-color: #dcfce7;
        color: #15803d;
    }
    .badge-payment {
        background-color: #fef3c7;
        color: #d97706;
    }
    .badge-refund {
        background-color: #dbeafe;
        color: #1d4ed8;
    }
    .amount-positive {
        color: #16a34a;
        font-weight: 700;
    }
    .amount-negative {
        color: #dc2626;
        font-weight: 700;
    }
    .modal-wallet-content {
        border-radius: 24px;
        border: none;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(0,0,0,0.15);
    }
    .modal-wallet-header {
        background: linear-gradient(135deg, #3d2314 0%, #2c1810 100%);
        color: #fff;
        border-bottom: none;
        padding: 24px;
    }
    .modal-wallet-header .btn-close {
        filter: invert(1);
    }
    .modal-wallet-body {
        padding: 30px 24px;
        text-align: left;
    }
    .modal-wallet-footer {
        border-top: none;
        padding: 16px 24px 24px;
    }
    .deposit-input {
        border-radius: 12px;
        border: 2px solid #e5e7eb;
        padding: 14px;
        font-size: 1.1rem;
        font-weight: 600;
        color: #3d2314;
        transition: all 0.2s;
    }
    .deposit-input:focus {
        border-color: #f97316;
        box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.15);
    }
</style>

<div class="container py-5 profile-layout-container">
    <div class="row">
        
        <!-- Left Column: Avatar & Sidebar Navigation Card (30% / col-lg-4) -->
        <div class="col-lg-4 col-md-5 mb-4">
            <div class="profile-left-card">
                <!-- Cover Gradient Banner -->
                <div class="profile-cover-photo"></div>
                
                <!-- Avatar Circular Frame -->
                <div class="profile-avatar-container-wrapper">
                    <div class="fb-avatar-wrapper" id="avatarWrapper" title="Nhấn để đổi ảnh đại diện">
                        @if (!string.IsNullOrEmpty(Model.AvatarPath))
                        {
                            <img id="avatarImage" src="@Model.AvatarPath" alt="Avatar" />
                        }
                        else
                        {
                            <div id="avatarLetter" style="width: 100%; height: 100%; background-color: #F2780C; color: #FFFFFF; font-size: 3.5rem; font-weight: 700; display: flex; justify-content: center; align-items: center;">
                                @Model.FullName.Substring(0, 1).ToUpper()
                            </div>
                        }
                        <!-- Hover Camera Icon -->
                        <div class="avatar-upload-overlay" id="avatarUploadOverlay">
                            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                        </div>
                    </div>
                </div>

                <!-- Username and Role Badge -->
                <div style="padding: 15px 20px 20px 20px;">
                    <h4 style="margin: 5px 0 2px 0; color: #1A1A1A; font-weight: 700; font-size: 1.4rem;">
                        @(System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(Model.FullName?.ToLower() ?? ""))
                    </h4>
                    <span class="badge text-uppercase" style="background-color: #FEF3C7; color: #D97706; font-size: 0.75rem; font-weight: 600; padding: 4px 12px; border-radius: 12px; letter-spacing: 0.5px; display: inline-block; margin-top: 5px;">
                        @Model.Role.RoleName
                    </span>
                </div>

                <!-- Navigation List -->
                <div class="profile-sidebar-menu">
                    <div class="list-group border-0">
                        <a href="#" id="btn-info-tab" class="list-group-item list-group-item-action profile-sidebar-item active-tab-btn">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                            Thông tin tài khoản
                        </a>
                        <a href="#" id="btn-password-tab" class="list-group-item list-group-item-action profile-sidebar-item text-muted">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                            </svg>
                            Đổi mật khẩu
                        </a>
                        <a href="#" id="btn-wallet-tab" class="list-group-item list-group-item-action profile-sidebar-item text-muted">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                            </svg>
                            Ví điện tử
                        </a>
                        <a href="#" id="btn-return-tab" class="list-group-item list-group-item-action profile-sidebar-item text-muted">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                            </svg>
                            Yêu cầu trả hàng
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Content panel (70% / col-lg-8) -->
        <div class="col-lg-8 col-md-7">
            
            <!-- Panel 1: Update Account Information -->
            <div id="info-tab" class="profile-right-card fade-in-tab">
                <h4 class="profile-section-title" style="font-size: 1.2rem; font-weight: 700; color: #3A2B20; margin-bottom: 25px; border-left: 4px solid #F2780C; padding-left: 12px;">Cập nhật thông tin tài khoản</h4>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="auth-alert auth-alert-success" style="border-radius: 12px; margin-bottom: 25px;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        @TempData["SuccessMessage"]
                    </div>
                }
                
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="auth-alert auth-alert-danger" style="border-radius: 12px; margin-bottom: 25px;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        @TempData["ErrorMessage"]
                    </div>
                }

                <form asp-action="Profile" method="post" id="profileInfoForm">
                    @Html.AntiForgeryToken()

                    <!-- Read-Only Email field with lock icon -->
                    <div class="auth-input-group">
                        <label class="auth-input-label">Email tài khoản (không thể sửa)</label>
                        <div class="auth-input-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                            <input type="text" class="auth-input-field" value="@Model.Email" disabled />
                            <span style="position: absolute; right: 16px; color: #9CA3AF;">🔒</span>
                        </div>
                    </div>

                    <!-- Side-by-side: Họ & Tên and Số Điện Thoại -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="auth-input-group">
                                <label class="auth-input-label">Họ và tên *</label>
                                <div class="auth-input-wrapper">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                    <input type="text" name="fullName" class="auth-input-field" value="@Model.FullName" required />
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="auth-input-group">
                                <label class="auth-input-label">Số điện thoại *</label>
                                <div class="auth-input-wrapper">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                                    </svg>
                                    <input type="tel"
                                           name="phone"
                                           id="profilePhone"
                                           class="auth-input-field"
                                           value="@Model.Phone"
                                           inputmode="numeric"
                                           pattern="[0-9]{10,}"
                                           minlength="10"
                                           maxlength="15"
                                           required />
                                </div>
                                <div id="phoneErrorMsg" class="text-danger" style="font-size: 0.85rem; margin-top: 6px; display: none;"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Email liên hệ (editable) -->
                    <div class="auth-input-group">
                        <label class="auth-input-label">Email liên hệ *</label>
                        <div class="auth-input-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                            <input type="email" name="email" class="auth-input-field" value="@Model.Email" required />
                        </div>
                    </div>

                    <!-- Read-Only CreatedAt field with lock icon -->
                    <div class="auth-input-group">
                        <label class="auth-input-label">Ngày tham gia hệ thống</label>
                        <div class="auth-input-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                            </svg>
                            <input type="text" class="auth-input-field" value="@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")" disabled />
                            <span style="position: absolute; right: 16px; color: #9CA3AF;">🔒</span>
                        </div>
                    </div>

                    <!-- Submit Button nicely aligned at bottom right -->
                    <div class="text-end" style="margin-top: 25px;">
                        <button type="submit" class="auth-btn-submit text-white" style="width: auto; display: inline-flex; padding: 12px 30px; background-color: #F2780C; font-weight: 600; border-radius: 12px; border: none; box-shadow: 0 4px 12px rgba(242, 120, 12, 0.2);">
                            Lưu thay đổi
                        </button>
                    </div>
                </form>
            </div>

            <!-- Panel 2: Change Password -->
            <div id="password-tab" class="profile-right-card fade-in-tab" style="display: none;">
                <h4 class="profile-section-title" style="font-size: 1.2rem; font-weight: 700; color: #3A2B20; margin-bottom: 25px; border-left: 4px solid #F2780C; padding-left: 12px;">Đổi mật khẩu</h4>

                @if (TempData["PasswordSuccess"] != null)
                {
                    <div class="auth-alert auth-alert-success" style="border-radius: 12px; margin-bottom: 25px;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        @TempData["PasswordSuccess"]
                    </div>
                }

                @if (TempData["PasswordError"] != null)
                {
                    <div class="auth-alert auth-alert-danger" style="border-radius: 12px; margin-bottom: 25px;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        @TempData["PasswordError"]
                    </div>
                }

                <form asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()

                    <div class="auth-input-group">
                        <label class="auth-input-label">Mật khẩu hiện tại</label>
                        <div class="auth-input-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                            </svg>
                            <input type="password" name="currentPassword" id="currentPassword" class="auth-input-field" required placeholder="Mật khẩu hiện tại" />
                            <button type="button" class="auth-password-toggle" onclick="togglePasswordVisibility('currentPassword')">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" id="currentPassword-eye">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                </svg>
                            </button>
                        </div>
                    </div>

                    <div class="auth-input-group">
                        <label class="auth-input-label">Mật khẩu mới</label>
                        <div class="auth-input-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                            </svg>
                            <input type="password" name="newPassword" id="newPassword" class="auth-input-field" required placeholder="Tối thiểu 8 ký tự, có in hoa, số, ký tự đặc biệt" />
                            <button type="button" class="auth-password-toggle" onclick="togglePasswordVisibility('newPassword')">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" id="newPassword-eye">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                </svg>
                            </button>
                        </div>
                    </div>

                    <div class="auth-input-group">
                        <label class="auth-input-label">Xác nhận mật khẩu mới</label>
                        <div class="auth-input-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                            </svg>
                            <input type="password" name="confirmNewPassword" id="confirmNewPassword" class="auth-input-field" required placeholder="Nhập lại mật khẩu mới" />
                            <button type="button" class="auth-password-toggle" onclick="togglePasswordVisibility('confirmNewPassword')">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" id="confirmNewPassword-eye">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                </svg>
                            </button>
                        </div>
                    </div>

                    <!-- Submit Button nicely aligned at bottom right -->
                    <div class="text-end" style="margin-top: 25px;">
                        <button type="submit" class="auth-btn-submit text-white" style="width: auto; display: inline-flex; padding: 12px 30px; background-color: #F2780C; font-weight: 600; border-radius: 12px; border: none; box-shadow: 0 4px 12px rgba(242, 120, 12, 0.2);">
                            Lưu thay đổi
                        </button>
                    </div>
                </form>
            </div>

            <!-- Panel 3: E-Wallet -->
            @{
                var wallet = Model.Customer?.Wallets?.FirstOrDefault();
            }
            @if (wallet != null)
            {
                <div id="wallet-tab" class="profile-right-card fade-in-tab p-0" style="display: none; border: none; box-shadow: none; background: transparent;">
                    <!-- Wallet Info Card -->
                    <div class="wallet-card">
                        <div class="row align-items-center">
                            <div class="col-md-7 text-start">
                                <div class="wallet-balance-label">Số dư khả dụng</div>
                                <div class="wallet-balance-amount">@wallet.Balance.ToString("N0") <span style="font-size: 1.5rem;">VNĐ</span></div>
                                <div class="text-start">
                                    @if (wallet.Status == "Active")
                                    {
                                        <span class="wallet-status active">
                                            <i class="bi bi-patch-check-fill"></i> Tài khoản hoạt động
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="wallet-status locked">
                                            <i class="bi bi-lock-fill"></i> Đang tạm khóa
                                        </span>
                                    }
                                </div>
                            </div>
                            <div class="col-md-5 text-md-end text-start mt-4 mt-md-0">
                                <button type="button" class="btn btn-deposit btn-lg" data-bs-toggle="modal" data-bs-target="#depositModal">
                                    <i class="bi bi-plus-circle-fill"></i> Nạp tiền vào ví
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Transaction History -->
                    <div class="transaction-card">
                        <div class="transaction-header">
                            <h3 class="transaction-title"><i class="bi bi-clock-history me-2"></i>Lịch sử giao dịch</h3>
                        </div>
                        <div class="p-0">
                            <div class="table-responsive">
                                <table class="table table-transactions table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Mã GD</th>
                                            <th>Thời Gian</th>
                                            <th>Loại</th>
                                            <th>Số Tiền</th>
                                            <th>Nội Dung</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (wallet.WalletTransactions != null && wallet.WalletTransactions.Any())
                                        {
                                            foreach (var trans in wallet.WalletTransactions)
                                            {
                                                <tr>
                                                    <td class="fw-semibold" style="color: #6b7280;">#@trans.TransactionId</td>
                                                    <td>@trans.TransactionDate.ToString("dd/MM/yyyy HH:mm")</td>
                                                    <td>
                                                        @if (trans.Type == "Deposit")
                                                        {
                                                            <span class="badge-type badge-deposit"><i class="bi bi-arrow-down-left-circle-fill me-1"></i>Nạp Tiền</span>
                                                        }
                                                        else if (trans.Type == "Payment")
                                                        {
                                                            <span class="badge-type badge-payment"><i class="bi bi-arrow-up-right-circle-fill me-1"></i>Thanh Toán</span>
                                                        }
                                                        else if (trans.Type == "Refund")
                                                        {
                                                            <span class="badge-type badge-refund"><i class="bi bi-reply-fill me-1"></i>Hoàn Tiền</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-secondary">@trans.Type</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (trans.Type == "Deposit" || trans.Type == "Refund" || trans.Amount > 0)
                                                        {
                                                            <span class="amount-positive">+@trans.Amount.ToString("N0") đ</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="amount-negative">-@trans.Amount.ToString("N0") đ</span>
                                                        }
                                                    </td>
                                                    <td style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@trans.Description">
                                                        @trans.Description
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="5" class="text-center py-5 text-muted">
                                                    <i class="bi bi-receipt-cutoff d-block mb-3" style="font-size: 3rem; color: #cbd5e1;"></i>
                                                    Chưa có giao dịch phát sinh nào từ tài khoản này.
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- Panel 4: Return Requests -->
            @{
                var returnRequests = ViewBag.ReturnRequests as List<ReturnRequest>;
                var eligibleOrders = ViewBag.EligibleOrders as List<Order>;
                var productInfo = ViewBag.ProductInfo as Dictionary<string, Tuple<string, string?>>;
            }
            <div id="return-tab" class="profile-right-card fade-in-tab" style="display: none;">
                <h4 class="profile-section-title" style="font-size: 1.2rem; font-weight: 700; color: #3A2B20; margin-bottom: 25px; border-left: 4px solid #F2780C; padding-left: 12px;">Trả hàng / Hoàn tiền</h4>

                <!-- Sub Navigation Tabs -->
                <ul class="nav nav-pills mb-4" id="returnSubTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active fw-bold px-4" id="return-history-tab-btn" data-bs-toggle="pill" data-bs-target="#return-history-pane" type="button" role="tab" style="border-radius: 10px; font-size: 0.9rem;">Lịch sử yêu cầu</button>
                    </li>
                    <li class="nav-item ms-2" role="presentation">
                        <button class="nav-link fw-bold px-4" id="eligible-orders-tab-btn" data-bs-toggle="pill" data-bs-target="#eligible-orders-pane" type="button" role="tab" style="border-radius: 10px; font-size: 0.9rem;">Đơn hàng đủ điều kiện trả</button>
                    </li>
                </ul>

                <div class="tab-content" id="returnSubTabsContent">
                    <!-- History Pane -->
                    <div class="tab-pane fade show active" id="return-history-pane" role="tabpanel">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Mã Yêu Cầu</th>
                                        <th>Mã Đơn Hàng</th>
                                        <th>Ngày Gửi</th>
                                        <th>Số Tiền</th>
                                        <th>Trạng Thái</th>
                                        <th>Thao Tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (returnRequests != null && returnRequests.Any())
                                    {
                                        foreach (var req in returnRequests)
                                        {
                                            var parsedImages = new List<string>();
                                            var parsedVideo = "";
                                            var rejectReason = "";
                                            if (!string.IsNullOrEmpty(req.Notes))
                                            {
                                                var parts = req.Notes.Split('|');
                                                foreach (var part in parts)
                                                {
                                                    if (part.StartsWith("IMAGES:"))
                                                    {
                                                        parsedImages.AddRange(part.Substring("IMAGES:".Length).Split(';', StringSplitOptions.RemoveEmptyEntries));
                                                    }
                                                    else if (part.StartsWith("VIDEO:"))
                                                    {
                                                        parsedVideo = part.Substring("VIDEO:".Length);
                                                    }
                                                    else if (part.StartsWith("REJECT:"))
                                                    {
                                                        rejectReason = part.Substring("REJECT:".Length);
                                                    }
                                                }
                                                if (!req.Notes.Contains("IMAGES:") && !req.Notes.Contains("REJECT:") && !req.Notes.Contains("VIDEO:"))
                                                {
                                                    rejectReason = req.Notes;
                                                }
                                            }
                                            <tr>
                                                <td class="fw-semibold">#REQ-@req.RequestId</td>
                                                <td>#OD-@req.OrderId.Split('-')[^1]</td>
                                                <td>@req.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                                <td class="fw-bold text-primary">@req.RefundAmount.ToString("N0") đ</td>
                                                <td>
                                                    @if (req.Status == "Submitted")
                                                    {
                                                        <span class="badge bg-warning text-dark px-3 py-2" style="border-radius: 8px;">Chờ duyệt online</span>
                                                    }
                                                    else if (req.Status == "OnlineRejected")
                                                    {
                                                        <span class="badge bg-danger px-3 py-2" style="border-radius: 8px;" title="@req.Notes">Từ chối duyệt online</span>
                                                    }
                                                    else if (req.Status == "WaitingForReturn")
                                                    {
                                                        <span class="badge bg-info text-dark px-3 py-2" style="border-radius: 8px;">Chờ trả hàng tại quầy</span>
                                                    }
                                                    else if (req.Status == "PhysicalRejected")
                                                    {
                                                        <span class="badge bg-danger px-3 py-2" style="border-radius: 8px;" title="@req.Notes">Từ chối tại quầy</span>
                                                    }
                                                    else if (req.Status == "Success")
                                                    {
                                                        <span class="badge bg-success px-3 py-2" style="border-radius: 8px;">Đã hoàn tiền</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary px-3 py-2" style="border-radius: 8px;">@req.Status</span>
                                                    }
                                                </td>
                                                <td>
                                                    <button type="button" class="btn btn-outline-primary btn-sm rounded-3 px-3" onclick="toggleRequestDetails(@req.RequestId)">Xem chi tiết</button>
                                                </td>
                                            </tr>
                                            <!-- Hidden Detail Box -->
                                            <tr id="req-detail-@req.RequestId" style="display: none; background-color: #fafafa;">
                                                <td colspan="6" class="p-4 text-start">
                                                    <div class="row">
                                                        <div class="col-md-6">
                                                            <p class="mb-2"><strong>Lý do trả hàng:</strong> @req.Reason</p>
                                                            @if (parsedImages.Any())
                                                            {
                                                                <div class="mb-3">
                                                                    <strong>Ảnh minh chứng:</strong>
                                                                    <div class="d-flex gap-2 mt-2">
                                                                        @foreach (var img in parsedImages)
                                                                        {
                                                                            <a href="@img" target="_blank">
                                                                                <img src="@img" style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px; border: 1px solid #ddd;" />
                                                                            </a>
                                                                        }
                                                                    </div>
                                                                </div>
                                                            }
                                                            @if (!string.IsNullOrEmpty(parsedVideo))
                                                            {
                                                                <div class="mb-3">
                                                                    <strong>Video đập hộp:</strong>
                                                                    <div class="mt-2">
                                                                        <video src="@parsedVideo" width="240" controls style="border-radius: 8px; border: 1px solid #ddd;"></video>
                                                                    </div>
                                                                </div>
                                                            }
                                                            @if (!string.IsNullOrEmpty(rejectReason))
                                                            {
                                                                <p class="mb-2 text-danger"><strong>Phản hồi của nhân viên:</strong> @rejectReason</p>
                                                            }
                                                            @if (req.ProcessedAt.HasValue)
                                                            {
                                                                <p class="mb-0 text-muted"><strong>Thời gian xử lý:</strong> @req.ProcessedAt.Value.ToString("dd/MM/yyyy HH:mm")</p>
                                                            }
                                                        </div>
                                                        <div class="col-md-6">
                                                            <h6 class="fw-bold mb-2">Sản phẩm trả lại:</h6>
                                                            <ul class="list-unstyled mb-0">
                                                                @foreach (var ri in req.ReturnRequestItems)
                                                                {
                                                                    string prodName = ri.Sku;
                                                                    if (productInfo != null && productInfo.TryGetValue(ri.Sku, out var info))
                                                                    {
                                                                        prodName = info.Item1;
                                                                    }
                                                                    <li class="mb-1 text-muted" style="font-size: 0.9rem;">
                                                                        <i class="bi bi-box me-2"></i>@prodName (SKU: @ri.Sku) x @ri.Quantity (Đơn giá: @ri.RefundPrice.ToString("N0") đ)
                                                                    </li>
                                                                }
                                                            </ul>
                                                        </div>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center py-5 text-muted">
                                                <i class="bi bi-clock-history d-block mb-3" style="font-size: 3rem; color: #cbd5e1;"></i>
                                                Chưa có yêu cầu trả hàng nào được tạo.
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Eligible Orders Pane -->
                    <div class="tab-pane fade" id="eligible-orders-pane" role="tabpanel">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Mã Đơn Hàng</th>
                                        <th>Ngày Mua</th>
                                        <th>Tổng Tiền</th>
                                        <th>Thao Tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (eligibleOrders != null && eligibleOrders.Any())
                                    {
                                        foreach (var o in eligibleOrders)
                                        {
                                            <tr>
                                                <td class="fw-bold">#OD-@o.OrderId.Split('-')[^1]</td>
                                                <td>@o.Date.ToString("dd/MM/yyyy HH:mm")</td>
                                                <td class="fw-bold text-success">@o.Total.ToString("N0") đ</td>
                                                <td>
                                                    <button type="button" class="btn btn-primary btn-sm rounded-3 px-3" onclick="showReturnForm('@o.OrderId')">Yêu cầu trả hàng</button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="4" class="text-center py-5 text-muted">
                                                <i class="bi bi-check-circle d-block mb-3" style="font-size: 3rem; color: #10b981;"></i>
                                                Không có đơn hàng nào đủ điều kiện trả hàng (hoặc đã được tạo yêu cầu).
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Create Return Form (Hidden by default) -->
                <div id="return-form-container" style="display: none; border-top: 1px solid #eee; padding-top: 25px; margin-top: 15px;">
                    <h5 class="fw-bold text-start mb-4" id="returnFormHeader">Tạo yêu cầu trả hàng cho đơn hàng</h5>
                    
                    <form asp-action="CreateReturnRequest" method="post" id="actualReturnForm" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="orderId" id="returnFormOrderId" />

                        <div class="mb-4 text-start">
                            <label class="form-label fw-bold text-muted" style="font-size: 0.85rem; text-transform: uppercase;">1. Chọn sản phẩm trả lại và số lượng</label>
                            
                            <!-- Container where JS will inject items for the selected order -->
                            <div id="returnFormItemsContainer" class="border rounded-3 p-3 bg-light">
                                <!-- Dynamic order items list will go here via JS -->
                            </div>
                        </div>

                        <div class="mb-4 text-start">
                            <label for="returnReason" class="form-label fw-bold text-muted" style="font-size: 0.85rem; text-transform: uppercase;">2. Lý do trả hàng / hoàn tiền *</label>
                            <textarea name="reason" id="returnReason" class="form-control" rows="3" required placeholder="Mô tả lý do trả hàng (ví dụ: Sản phẩm bị rách bao bì, cận ngày hết hạn, giao nhầm mẫu mã...)"></textarea>
                        </div>

                        <div class="mb-4 text-start">
                            <label for="evidenceFiles" class="form-label fw-bold text-muted" style="font-size: 0.85rem; text-transform: uppercase;">3. Ảnh minh chứng * (Tải lên từ 1 - 3 ảnh, tối đa 5MB/ảnh)</label>
                            <input type="file" id="evidenceFiles" name="evidenceFiles" class="form-control" accept=".jpg,.jpeg,.png,.webp" multiple required />
                            <div class="form-text text-danger" id="evidenceValidationError" style="display: none; font-size: 0.85rem; margin-top: 5px;"></div>
                            <div id="evidencePreviewContainer" class="d-flex gap-2 mt-2 flex-wrap"></div>
                        </div>

                        <div class="mb-4 text-start">
                            <label for="evidenceVideo" class="form-label fw-bold text-muted" style="font-size: 0.85rem; text-transform: uppercase;">4. Video đập hộp sản phẩm * (Tối đa 20MB, định dạng .mp4, .mov, .webm, dài 10 - 15s)</label>
                            <input type="file" id="evidenceVideo" name="evidenceVideo" class="form-control" accept=".mp4,.mov,.webm" required />
                            <div class="form-text text-danger" id="videoValidationError" style="display: none; font-size: 0.85rem; margin-top: 5px;"></div>
                            <div id="videoPreviewContainer" class="mt-2" style="display: none;">
                                <video id="videoPreview" width="200" controls style="border-radius: 8px; border: 1px solid #ddd;"></video>
                            </div>
                        </div>

                        <div class="p-3 bg-light rounded-3 d-flex justify-content-between align-items-center mb-4 text-start">
                            <div>
                                <span class="fw-bold text-muted d-block" style="font-size: 0.85rem;">SỐ TIỀN HOÀN TRẢ ĐỀ XUẤT</span>
                                <span class="text-muted" style="font-size: 0.8rem;">(Tính theo giá trị các sản phẩm được chọn để hoàn trả)</span>
                            </div>
                            <span class="fs-4 fw-bold text-primary" id="returnTotalAmount">0 VNĐ</span>
                        </div>

                        <div class="text-end">
                            <button type="button" class="btn btn-light px-4 py-2 fw-semibold rounded-3" onclick="hideReturnForm()">Hủy</button>
                            <button type="submit" class="btn btn-deposit px-4 py-2 rounded-3 ms-2" id="btnSubmitReturn">Gửi yêu cầu duyệt</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Pass eligible orders items data to Javascript dynamically safely using JSON -->
            <script>
                window.eligibleOrdersData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    eligibleOrders == null ? (object)new List<object>() : eligibleOrders.Select(o => new {
                        OrderId = o.OrderId,
                        DisplayId = "#OD-" + o.OrderId.Split('-')[^1],
                        Items = o.OrderItems.Select(oi => new {
                            Sku = oi.ProductSku,
                            Name = (productInfo != null && productInfo.TryGetValue(oi.ProductSku ?? "", out var pi)) ? pi.Item1 : (oi.ProductSku ?? "Sản phẩm"),
                            ImageUrl = (productInfo != null && productInfo.TryGetValue(oi.ProductSku ?? "", out var pi2)) ? pi2.Item2 : null,
                            Quantity = oi.Quantity,
                            Price = oi.Price
                        })
                    })
                ));
            </script>
        </div>
    </div>
</div>

<!-- Hidden File Input for Avatar Selection -->
<input type="file" id="avatarFileInput" accept="image/png, image/jpeg" style="display: none;" />

<!-- Custom CSS-Based Self-Contained Modal for Image Cropper -->
<div class="custom-modal" id="cropModal">
    <div class="custom-modal-dialog">
        <div class="custom-modal-content">
            <div class="modal-header border-0 pb-0" style="padding: 20px 24px; display: flex; justify-content: space-between; align-items: center;">
                <h5 class="modal-title font-weight-bold" style="font-weight: 700; color: #1A1A1A; margin: 0; font-size: 1.25rem;">Cắt ảnh đại diện</h5>
                <button type="button" id="cropModalCloseBtn" style="background: none; border: none; font-size: 1.75rem; cursor: pointer; color: #9CA3AF; line-height: 1; padding: 0;">&times;</button>
            </div>
            <div class="modal-body" style="padding: 20px 24px;">
                <div class="img-container" style="max-height: 350px; width: 100%; overflow: hidden; border-radius: 12px; background-color: #F9FAFB; display: flex; justify-content: center; align-items: center;">
                    <img id="imageToCrop" src="" style="max-width: 100%; display: block;" />
                </div>
            </div>
            <div class="modal-footer border-0 pt-0" style="padding: 15px 24px 20px 24px; display: flex; justify-content: flex-end; gap: 12px;">
                <button type="button" id="cropModalCancelBtn" class="btn btn-light py-2 px-4 rounded-3" style="font-weight: 600; border: 1px solid #E5E7EB; background-color: #F9FAFB; color: #4B5563;">Hủy</button>
                <button type="button" id="btnCropAndSave" class="btn py-2 px-4 rounded-3 text-white" style="background-color: #F2780C; border: none; font-weight: 600;">Lưu thay đổi</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Nạp Tiền -->
<div class="modal fade" id="depositModal" tabindex="-1" aria-labelledby="depositModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-wallet-content">
            <form asp-area="Customer" asp-controller="Wallet" asp-action="Deposit" method="post">
                <div class="modal-header modal-wallet-header">
                    <h5 class="modal-title fw-bold" id="depositModalLabel"><i class="bi bi-wallet2 me-2"></i>Nạp Tiền Vào Ví</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body modal-wallet-body">
                    <div class="alert alert-warning mb-4" role="alert" style="border-radius: 12px; font-size: 0.9rem;">
                        <i class="bi bi-shield-lock-fill me-2"></i>Giao dịch nạp tiền được xử lý bảo mật tự động thông qua cổng thanh toán an toàn <strong>PayOS</strong>.
                    </div>
                    <div class="mb-3">
                        <label for="amount" class="form-label fw-bold text-muted" style="font-size: 0.85rem; text-transform: uppercase;">Số tiền cần nạp (VNĐ)</label>
                        <input type="number" class="form-control deposit-input" id="amount" name="amount" min="10000" step="10000" placeholder="Ví dụ: 100000" required>
                        <div class="form-text mt-2"><i class="bi bi-info-circle me-1"></i>Số tiền nạp tối thiểu là <strong>10,000 VNĐ</strong>.</div>
                    </div>
                </div>
                <div class="modal-footer modal-wallet-footer">
                    <button type="button" class="btn btn-light px-4 py-2 fw-semibold" data-bs-dismiss="modal" style="border-radius: 10px;">Hủy</button>
                    <button type="submit" class="btn btn-deposit px-4 py-2" style="border-radius: 10px;">Xác nhận nạp tiền</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Cropper.js Script -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>

    <script>
        // Tab Switching Logic
        function switchTab(tabId, element) {
            const infoTab = document.getElementById('info-tab');
            const passwordTab = document.getElementById('password-tab');
            const walletTab = document.getElementById('wallet-tab');
            const returnTab = document.getElementById('return-tab');
            if (infoTab) infoTab.style.display = 'none';
            if (passwordTab) passwordTab.style.display = 'none';
            if (walletTab) walletTab.style.display = 'none';
            if (returnTab) returnTab.style.display = 'none';
            
            const target = document.getElementById(tabId);
            if (target) {
                target.style.display = 'block';
            }

            document.querySelectorAll('.profile-sidebar-item').forEach(function (btn) {
                btn.classList.remove('active-tab-btn');
                btn.classList.add('text-muted');
            });

            element.classList.add('active-tab-btn');
            element.classList.remove('text-muted');
        }

        function validateProfilePhone(phone) {
            var value = (phone || '').trim();
            if (!value) {
                return 'Số điện thoại không được để trống.';
            }
            if (!/^\d+$/.test(value)) {
                return 'Số điện thoại chỉ được chứa chữ số, không được có chữ cái.';
            }
            if (value.length < 10) {
                return 'Số điện thoại phải có ít nhất 10 chữ số.';
            }
            if (Number(value) <= 0) {
                return 'Số điện thoại phải là số lớn hơn 0.';
            }
            return '';
        }

        // Toggle Password Visibility helper
        function togglePasswordVisibility(id) {
            const input = document.getElementById(id);
            const eyeIcon = document.getElementById(id + '-eye');
            if (input.type === "password") {
                input.type = "text";
                eyeIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />';
            } else {
                input.type = "password";
                eyeIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />';
            }
        }

        document.addEventListener("DOMContentLoaded", function() {
            var infoBtn = document.getElementById('btn-info-tab');
            var passwordBtn = document.getElementById('btn-password-tab');
            var walletBtn = document.getElementById('btn-wallet-tab');
            var returnBtn = document.getElementById('btn-return-tab');
            var avatarWrapper = document.getElementById('avatarWrapper');
            var avatarOverlay = document.getElementById('avatarUploadOverlay');
            var profilePhone = document.getElementById('profilePhone');
            var phoneErrorMsg = document.getElementById('phoneErrorMsg');
            var profileInfoForm = document.getElementById('profileInfoForm');

            if (infoBtn) {
                infoBtn.addEventListener('click', function (e) {
                    e.preventDefault();
                    switchTab('info-tab', infoBtn);
                });
            }

            if (passwordBtn) {
                passwordBtn.addEventListener('click', function (e) {
                    e.preventDefault();
                    switchTab('password-tab', passwordBtn);
                });
            }

            if (walletBtn) {
                walletBtn.addEventListener('click', function (e) {
                    e.preventDefault();
                    switchTab('wallet-tab', walletBtn);
                });
            }

            if (returnBtn) {
                returnBtn.addEventListener('click', function (e) {
                    e.preventDefault();
                    switchTab('return-tab', returnBtn);
                });
            }

            if (avatarWrapper) {
                avatarWrapper.addEventListener('click', function () {
                    triggerAvatarSelect();
                });
            }

            if (avatarOverlay) {
                avatarOverlay.addEventListener('click', function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    triggerAvatarSelect();
                });
            }

            if (profilePhone) {
                profilePhone.addEventListener('input', function () {
                    profilePhone.value = profilePhone.value.replace(/\D/g, '');
                    if (phoneErrorMsg) {
                        phoneErrorMsg.style.display = 'none';
                    }
                });
            }

            if (profileInfoForm) {
                profileInfoForm.addEventListener('submit', function (e) {
                    var message = validateProfilePhone(profilePhone ? profilePhone.value : '');
                    if (message) {
                        e.preventDefault();
                        if (phoneErrorMsg) {
                            phoneErrorMsg.textContent = message;
                            phoneErrorMsg.style.display = 'block';
                        }
                        if (profilePhone) {
                            profilePhone.focus();
                        }
                    }
                });
            }

            var hasPasswordMessage = @(TempData["PasswordSuccess"] != null || TempData["PasswordError"] != null ? "true" : "false");
            var hasWalletMessage = @(TempData["Success"] != null || TempData["Error"] != null ? "true" : "false");

            // URL check for tab parameter
            const urlParams = new URLSearchParams(window.location.search);
            const tabParam = urlParams.get('tab');
            const orderIdParam = urlParams.get('orderId');

            if (hasWalletMessage || tabParam === 'wallet') {
                if (walletBtn) switchTab('wallet-tab', walletBtn);
            } else if (tabParam === 'return') {
                if (returnBtn) {
                    switchTab('return-tab', returnBtn);
                    if (orderIdParam) {
                        showReturnForm(orderIdParam);
                    }
                }
            } else if (hasPasswordMessage && passwordBtn) {
                switchTab('password-tab', passwordBtn);
            }

            // Auto-dismiss toast
            setTimeout(function () {
                var toast = document.getElementById('walletToast');
                if (toast) {
                    toast.style.transition = 'opacity 0.5s ease';
                    toast.style.opacity = '0';
                    setTimeout(function () {
                        toast.remove();
                    }, 500);
                }
            }, 4000);
        });

        // Cropper.js Flow Logic with self-contained Custom Modal triggers
        let cropper = null;
        const cropModalEl = document.getElementById('cropModal');
        
        // Self-contained custom modal controls to prevent dependency errors
        const cropModal = {
            show: function() {
                cropModalEl.style.display = 'flex';
                cropModalEl.classList.add('show');
                
                // Add backdrop element
                let backdrop = document.getElementById('customModalBackdrop');
                if (!backdrop) {
                    backdrop = document.createElement('div');
                    backdrop.id = 'customModalBackdrop';
                    backdrop.style.position = 'fixed';
                    backdrop.style.top = '0';
                    backdrop.style.left = '0';
                    backdrop.style.width = '100vw';
                    backdrop.style.height = '100vh';
                    backdrop.style.backgroundColor = 'rgba(0,0,0,0.5)';
                    backdrop.style.zIndex = '1040';
                    document.body.appendChild(backdrop);
                }
                document.body.style.overflow = 'hidden';
                
                // Initialize cropper after layout rendering
                setTimeout(function() {
                    if (cropper) {
                        cropper.destroy();
                    }
                    cropper = new Cropper(imageToCrop, {
                        aspectRatio: 1,
                        viewMode: 2,
                        background: false,
                        autoCropArea: 1
                    });
                }, 100);
            },
            hide: function() {
                cropModalEl.style.display = 'none';
                cropModalEl.classList.remove('show');
                
                // Remove backdrop
                const backdrop = document.getElementById('customModalBackdrop');
                if (backdrop) {
                    backdrop.remove();
                }
                document.body.style.overflow = '';
                
                if (cropper) {
                    cropper.destroy();
                    cropper = null;
                }
                fileInput.value = '';
            }
        };

        const imageToCrop = document.getElementById('imageToCrop');
        const fileInput = document.getElementById('avatarFileInput');

        function triggerAvatarSelect() {
            if (fileInput) {
                fileInput.click();
            }
        }

        if (fileInput) {
            fileInput.addEventListener('change', handleFileSelect);
        }

        function handleFileSelect(e) {
            const files = e.target.files;
            if (files && files.length > 0) {
                const file = files[0];
                
                // Validate size on frontend (max 10MB)
                if (file.size > 10 * 1024 * 1024) {
                    alert('Dung lượng ảnh vượt quá giới hạn 10MB.');
                    fileInput.value = '';
                    return;
                }

                // Validate extension on frontend
                if (file.type !== 'image/jpeg' && file.type !== 'image/png') {
                    alert('Chỉ hỗ trợ file ảnh định dạng JPG hoặc PNG.');
                    fileInput.value = '';
                    return;
                }

                const reader = new FileReader();
                reader.onload = function(event) {
                    imageToCrop.src = event.target.result;
                    cropModal.show();
                };
                reader.readAsDataURL(file);
            }
        }

        document.getElementById('cropModalCloseBtn')?.addEventListener('click', function () {
            cropModal.hide();
        });

        document.getElementById('cropModalCancelBtn')?.addEventListener('click', function () {
            cropModal.hide();
        });

        // Save cropped avatar via AJAX
        document.getElementById('btnCropAndSave')?.addEventListener('click', function() {
            if (!cropper) return;

            const canvas = cropper.getCroppedCanvas({
                width: 300,
                height: 300
            });

            canvas.toBlob(function(blob) {
                const formData = new FormData();
                formData.append('avatarFile', blob, 'avatar.png');

                // Request Verification Token
                const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
                if (tokenElement) {
                    formData.append('__RequestVerificationToken', tokenElement.value);
                }

                // Disable button during load
                const saveBtn = document.getElementById('btnCropAndSave');
                const originalText = saveBtn.innerText;
                saveBtn.disabled = true;
                saveBtn.innerText = 'Đang lưu...';

                fetch('/Customer/Account/UploadAvatar', {
                    method: 'POST',
                    body: formData
                })
                .then(response => response.json())
                .then(data => {
                    saveBtn.disabled = false;
                    saveBtn.innerText = originalText;
                    if (data.success) {
                        // Update avatar image sources
                        const avatarImg = document.getElementById('avatarImage');
                        const avatarContainer = document.querySelector('.fb-avatar-wrapper');
                        
                        if (avatarImg) {
                            avatarImg.src = data.avatarPath;
                        } else if (avatarContainer) {
                            avatarContainer.innerHTML = `
                                <img id="avatarImage" src="${data.avatarPath}" alt="Avatar" />
                                <div class="avatar-upload-overlay" id="avatarUploadOverlay">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
                                    </svg>
                                </div>
                            `;
                            avatarContainer.addEventListener('click', function () {
                                triggerAvatarSelect();
                            });
                            document.getElementById('avatarUploadOverlay')?.addEventListener('click', function (e) {
                                e.preventDefault();
                                e.stopPropagation();
                                triggerAvatarSelect();
                            });
                        }
                        cropModal.hide();
                        alert('Cập nhật ảnh đại diện thành công!');
                    } else {
                        alert('Có lỗi xảy ra: ' + data.message);
                    }
                })
                .catch(err => {
                    saveBtn.disabled = false;
                    saveBtn.innerText = originalText;
                    console.error(err);
                    alert('Đã xảy ra lỗi khi kết nối máy chủ.');
                });
            }, 'image/png');
        });
        // Return Request Helper Functions
        function toggleRequestDetails(requestId) {
            var detailRow = document.getElementById('req-detail-' + requestId);
            if (detailRow) {
                if (detailRow.style.display === 'none') {
                    detailRow.style.display = 'table-row';
                } else {
                    detailRow.style.display = 'none';
                }
            }
        }

        function showReturnForm(orderId) {
            // Find the order data in JSON
            var order = window.eligibleOrdersData.find(function(o) { return o.OrderId === orderId; });
            if (!order) {
                alert('Không tìm thấy dữ liệu đơn hàng tương ứng.');
                return;
            }

            // Hide tabs nav and content
            document.getElementById('returnSubTabs').style.display = 'none';
            document.getElementById('returnSubTabsContent').style.display = 'none';

            // Set OrderId in form
            document.getElementById('returnFormOrderId').value = orderId;
            document.getElementById('returnFormHeader').innerText = 'Tạo yêu cầu trả hàng cho đơn hàng ' + order.DisplayId;

            // Generate items HTML
            var itemsHtml = '';
            order.Items.forEach(function(item) {
                var imgUrl = item.ImageUrl || 'https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=100&h=100&fit=crop';
                itemsHtml += `
                <div class="d-flex align-items-center justify-content-between mb-3 border-bottom pb-3">
                    <div class="d-flex align-items-center text-start">
                        <input type="checkbox" name="selectedSkus" value="${item.Sku}" class="return-item-checkbox form-check-input me-3" data-price="${item.Price}" onchange="updateRefundSum()" style="width: 20px; height: 20px;" />
                        <img src="${imgUrl}" style="width: 55px; height: 55px; object-fit: cover; border-radius: 8px; margin-right: 15px; border: 1px solid #ddd;" />
                        <div>
                            <div class="fw-bold text-dark" style="font-size: 0.95rem;">${item.Name}</div>
                            <div class="text-muted" style="font-size: 0.8rem;">SKU: ${item.Sku} | Đơn giá: ${item.Price.toLocaleString('vi-VN')} đ | Mua x${item.Quantity}</div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center">
                        <span class="text-muted me-2" style="font-size: 0.8rem;">Số lượng trả:</span>
                        <input type="number" name="returnQuantities[${item.Sku}]" value="1" min="1" max="${item.Quantity}" class="form-control return-qty-input text-center fw-bold" style="width: 70px; border-radius: 8px; border: 2px solid #ddd;" onchange="updateRefundSum()" disabled />
                    </div>
                </div>`;
            });

            document.getElementById('returnFormItemsContainer').innerHTML = itemsHtml;
            document.getElementById('return-form-container').style.display = 'block';
            
            // Reset reason, files and total
            document.getElementById('returnReason').value = '';
            document.getElementById('returnTotalAmount').innerText = '0 VNĐ';
            if (document.getElementById('evidenceFiles')) {
                document.getElementById('evidenceFiles').value = '';
            }
            if (document.getElementById('evidencePreviewContainer')) {
                document.getElementById('evidencePreviewContainer').innerHTML = '';
            }
            if (document.getElementById('evidenceValidationError')) {
                document.getElementById('evidenceValidationError').style.display = 'none';
            }
            if (document.getElementById('evidenceVideo')) {
                document.getElementById('evidenceVideo').value = '';
            }
            if (document.getElementById('videoPreviewContainer')) {
                document.getElementById('videoPreviewContainer').style.display = 'none';
            }
            if (document.getElementById('videoPreview')) {
                document.getElementById('videoPreview').src = '';
            }
            if (document.getElementById('videoValidationError')) {
                document.getElementById('videoValidationError').style.display = 'none';
            }
            if (document.getElementById('btnSubmitReturn')) {
                document.getElementById('btnSubmitReturn').disabled = false;
            }
        }

        function hideReturnForm() {
            document.getElementById('return-form-container').style.display = 'none';
            document.getElementById('returnSubTabs').style.display = 'flex';
            document.getElementById('returnSubTabsContent').style.display = 'block';
        }

        function updateRefundSum() {
            var sum = 0;
            var checkboxes = document.querySelectorAll('.return-item-checkbox');
            checkboxes.forEach(function(cb) {
                var parentRow = cb.closest('.border-bottom');
                var qtyInput = parentRow.querySelector('.return-qty-input');
                
                if (cb.checked) {
                    qtyInput.disabled = false;
                    var qty = parseInt(qtyInput.value) || 0;
                    var price = parseFloat(cb.getAttribute('data-price')) || 0;
                    sum += qty * price;
                } else {
                    qtyInput.disabled = true;
                }
            });

            document.getElementById('returnTotalAmount').innerText = sum.toLocaleString('vi-VN') + ' VNĐ';
        }

        // Validate evidence files
        document.getElementById('evidenceFiles')?.addEventListener('change', function(e) {
            var files = e.target.files;
            var previewContainer = document.getElementById('evidencePreviewContainer');
            var errorDiv = document.getElementById('evidenceValidationError');
            var submitBtn = document.getElementById('btnSubmitReturn');
            
            previewContainer.innerHTML = '';
            errorDiv.style.display = 'none';
            errorDiv.innerText = '';
            submitBtn.disabled = false;

            if (files.length === 0) return;

            if (files.length < 1 || files.length > 3) {
                errorDiv.innerText = 'Vui lòng chọn từ 1 đến 3 ảnh minh chứng.';
                errorDiv.style.display = 'block';
                e.target.value = '';
                submitBtn.disabled = true;
                return;
            }

            var allowedExtensions = ['jpg', 'jpeg', 'png', 'webp'];
            var maxSize = 5 * 1024 * 1024; // 5MB

            for (var i = 0; i < files.length; i++) {
                var file = files[i];
                var ext = file.name.split('.').pop().toLowerCase();
                
                if (allowedExtensions.indexOf(ext) === -1) {
                    errorDiv.innerText = 'Định dạng ảnh không hợp lệ. Chỉ hỗ trợ .jpg, .jpeg, .png, .webp.';
                    errorDiv.style.display = 'block';
                    e.target.value = '';
                    submitBtn.disabled = true;
                    return;
                }

                if (file.size > maxSize) {
                    errorDiv.innerText = 'Dung lượng mỗi ảnh không được vượt quá 5MB.';
                    errorDiv.style.display = 'block';
                    e.target.value = '';
                    submitBtn.disabled = true;
                    return;
                }

                // Render preview
                (function(file) {
                    var reader = new FileReader();
                    reader.onload = function(event) {
                        var img = document.createElement('img');
                        img.src = event.target.result;
                        img.style.width = '70px';
                        img.style.height = '70px';
                        img.style.objectFit = 'cover';
                        img.style.borderRadius = '8px';
                        img.style.border = '1px solid #ddd';
                        previewContainer.appendChild(img);
                    };
                    reader.readAsDataURL(file);
                })(file);
            }
        });

        // Validate evidence video
        document.getElementById('evidenceVideo')?.addEventListener('change', function(e) {
            var file = e.target.files[0];
            var previewContainer = document.getElementById('videoPreviewContainer');
            var previewVideo = document.getElementById('videoPreview');
            var errorDiv = document.getElementById('videoValidationError');
            var submitBtn = document.getElementById('btnSubmitReturn');

            previewContainer.style.display = 'none';
            previewVideo.src = '';
            errorDiv.style.display = 'none';
            errorDiv.innerText = '';
            submitBtn.disabled = false;

            if (!file) return;

            var allowedExtensions = ['mp4', 'mov', 'webm'];
            var ext = file.name.split('.').pop().toLowerCase();

            if (allowedExtensions.indexOf(ext) === -1) {
                errorDiv.innerText = 'Định dạng video không hợp lệ. Chỉ hỗ trợ .mp4, .mov, .webm.';
                errorDiv.style.display = 'block';
                e.target.value = '';
                submitBtn.disabled = true;
                return;
            }

            var maxSize = 20 * 1024 * 1024; // 20MB
            if (file.size > maxSize) {
                errorDiv.innerText = 'Dung lượng video không được vượt quá 20MB.';
                errorDiv.style.display = 'block';
                e.target.value = '';
                submitBtn.disabled = true;
                return;
            }

            // Create temporary URL to read video duration
            var videoUrl = URL.createObjectURL(file);
            var tempVideo = document.createElement('video');
            tempVideo.preload = 'metadata';
            tempVideo.src = videoUrl;
            tempVideo.onloadedmetadata = function() {
                URL.revokeObjectURL(videoUrl);
                var duration = tempVideo.duration;
                if (duration < 10 || duration > 15) {
                    errorDiv.innerText = 'Độ dài video đập hộp phải từ 10 đến 15 giây. Hiện tại: ' + Math.round(duration) + ' giây.';
                    errorDiv.style.display = 'block';
                    e.target.value = '';
                    submitBtn.disabled = true;
                } else {
                    // Valid length: show preview
                    previewVideo.src = URL.createObjectURL(file);
                    previewContainer.style.display = 'block';
                }
            };
            tempVideo.onerror = function() {
                errorDiv.innerText = 'Không thể đọc được file video. Vui lòng kiểm tra lại file.';
                errorDiv.style.display = 'block';
                e.target.value = '';
                submitBtn.disabled = true;
            };
        });
    </script>
}
