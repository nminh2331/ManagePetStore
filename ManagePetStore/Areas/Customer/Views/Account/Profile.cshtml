@model ManagePetStore.Models.User
@{
    ViewData["Title"] = "Thông tin cá nhân";
}

<link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />

<div class="container py-5" style="font-family: 'Outfit', sans-serif;">
    <!-- Profile Summary Banner -->
    <div class="profile-card mb-5">
        <div class="profile-header">
            <div class="profile-avatar-wrapper">
                @Model.FullName.Substring(0, 1).ToUpper()
            </div>
            <h3 class="profile-name">@Model.FullName</h3>
            <span class="profile-role badge bg-light text-dark px-3 py-2" style="font-size: 0.8rem; font-weight: 600; border-radius: 20px;">
                @Model.Role.RoleName.ToUpper()
            </span>
        </div>

        @if (Model.RoleId == 5 && Model.Customer != null)
        {
            <!-- Customer Stats block -->
            <div class="profile-stats">
                <div class="profile-stat-item">
                    <div class="profile-stat-val">@Model.Customer.LoyaltyPoints</div>
                    <div class="profile-stat-lbl">Điểm tích lũy</div>
                </div>
                <div class="profile-stat-item">
                    <div class="profile-stat-val text-uppercase" style="color: #D66505;">
                        @Model.Customer.MembershipTier
                    </div>
                    <div class="profile-stat-lbl">Hạng thành viên</div>
                </div>
            </div>
        }
    </div>

    <div class="row">
        <!-- Edit Profile Form -->
        <div class="col-lg-7 mb-4">
            <div class="card border-0 shadow-sm p-4" style="border-radius: 20px;">
                <h4 class="profile-section-title">Cập nhật thông tin tài khoản</h4>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="auth-alert auth-alert-success">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        @TempData["SuccessMessage"]
                    </div>
                }
                
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="auth-alert auth-alert-danger">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        @TempData["ErrorMessage"]
                    </div>
                }

                <form asp-action="Profile" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label font-weight-bold" style="color: var(--auth-text-dark); font-weight: 600;">Tên đăng nhập</label>
                        <input type="text" class="form-control px-3 py-2" value="@Model.Username" disabled style="background-color: #f1f1f1; border-radius: 10px;" />
                        <small class="text-muted">Không thể thay đổi tên đăng nhập của tài khoản.</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" style="color: var(--auth-text-dark); font-weight: 600;">Họ và tên *</label>
                        <input type="text" name="fullName" class="form-control px-3 py-2" value="@Model.FullName" required style="border-radius: 10px; border: 1px solid var(--auth-border-color);" />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label" style="color: var(--auth-text-dark); font-weight: 600;">Email *</label>
                            <input type="email" name="email" class="form-control px-3 py-2" value="@Model.Email" required style="border-radius: 10px; border: 1px solid var(--auth-border-color);" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label" style="color: var(--auth-text-dark); font-weight: 600;">Số điện thoại *</label>
                            <input type="tel" name="phone" class="form-control px-3 py-2" value="@Model.Phone" required style="border-radius: 10px; border: 1px solid var(--auth-border-color);" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label" style="color: var(--auth-text-dark); font-weight: 600;">Ngày tạo tài khoản</label>
                        <input type="text" class="form-control px-3 py-2" value="@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")" disabled style="background-color: #f1f1f1; border-radius: 10px;" />
                    </div>

                    <button type="submit" class="btn text-white w-100 py-2" style="background-color: var(--auth-primary); border-radius: 10px; font-weight: 600; box-shadow: 0 4px 12px rgba(242, 120, 12, 0.2);">
                        Lưu thay đổi
                    </button>
                </form>
            </div>
        </div>

        <!-- Change Password Form -->
        <div class="col-lg-5 mb-4">
            <div class="card border-0 shadow-sm p-4" style="border-radius: 20px;">
                <h4 class="profile-section-title">Đổi mật khẩu</h4>

                @if (TempData["PasswordSuccess"] != null)
                {
                    <div class="auth-alert auth-alert-success">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        @TempData["PasswordSuccess"]
                    </div>
                }

                @if (TempData["PasswordError"] != null)
                {
                    <div class="auth-alert auth-alert-danger">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        @TempData["PasswordError"]
                    </div>
                }

                <form asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label" style="color: var(--auth-text-dark); font-weight: 600;">Mật khẩu hiện tại</label>
                        <input type="password" name="currentPassword" class="form-control px-3 py-2" required style="border-radius: 10px; border: 1px solid var(--auth-border-color);" placeholder="Mật khẩu hiện tại" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" style="color: var(--auth-text-dark); font-weight: 600;">Mật khẩu mới</label>
                        <input type="password" name="newPassword" class="form-control px-3 py-2" required style="border-radius: 10px; border: 1px solid var(--auth-border-color);" placeholder="Tối thiểu 6 ký tự" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label" style="color: var(--auth-text-dark); font-weight: 600;">Xác nhận mật khẩu mới</label>
                        <input type="password" name="confirmNewPassword" class="form-control px-3 py-2" required style="border-radius: 10px; border: 1px solid var(--auth-border-color);" placeholder="Nhập lại mật khẩu mới" />
                    </div>

                    <button type="submit" class="btn btn-outline-warning w-100 py-2" style="border-radius: 10px; font-weight: 600; border-color: var(--auth-primary); color: var(--auth-primary);">
                        Cập nhật mật khẩu
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
