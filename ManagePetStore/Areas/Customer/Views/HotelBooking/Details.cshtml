@model ManagePetStore.Areas.Customer.Models.HotelBookingDetailPageViewModel

@{
    Layout = "/Views/Shared/_PetStoreLayout.cshtml";
    ViewData["Title"] = $"Chi tiết {Model.Booking.DisplayBookingId}";
}

@section Styles {
    <link rel="stylesheet" href="~/css/customer-pets.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/customer-hotel-bookings.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/hotel-booking-history.css" asp-append-version="true" />
}

<div class="cp-dashboard">
    @await Html.PartialAsync("_CustomerSidebar", Model)

    <section class="cp-main">
        <div class="hbh-page-header">
            <div>
                <a asp-action="Index" class="hbh-back-link"><i class="bi bi-arrow-left"></i> Lịch sử lưu trú</a>
                <h1>Chi tiết lần lưu trú</h1>
                <p>Toàn bộ thông tin và hoạt động được ghi theo từng booking của thú cưng.</p>
            </div>
        </div>

        @await Html.PartialAsync("_HotelBookingHistoryDetail", Model.Booking)
    </section>
</div>
