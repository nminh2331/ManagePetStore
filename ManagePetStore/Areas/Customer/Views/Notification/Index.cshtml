@model ManagePetStore.Areas.Customer.Models.CustomerNotificationPageViewModel

@{
    Layout = "/Views/Shared/_PetStoreLayout.cshtml";
    ViewData["Title"] = "Thông báo chăm sóc";
}

@section Styles {
    <link rel="stylesheet" href="~/css/customer-pets.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/customer-notifications.css" asp-append-version="true" />
}

<div class="cp-dashboard">
    @await Html.PartialAsync("_CustomerSidebar", Model)

    <section class="cp-main">
        <div class="cp-main-header">
            <div>
                <h1 class="cp-main-title">Thông báo chăm sóc</h1>
                <p class="cp-main-subtitle">Cập nhật mới nhất từ nhân viên trong từng lượt lưu trú của thú cưng.</p>
            </div>
            <div class="cn-header-actions">
                @if (Model.UnreadCount > 0)
                {
                    <form action="/Customer/Notifications/MarkAllRead" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button class="cn-mark-all" type="submit"><i class="bi bi-check2-all"></i> Đánh dấu đã đọc</button>
                    </form>
                }
                @if (Model.Notifications.Count > 0)
                {
                    <form action="/Customer/Notifications/DeleteAll" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa tất cả thông báo?');">
                        @Html.AntiForgeryToken()
                        <button class="cn-delete-all" type="submit"><i class="bi bi-trash"></i> Xóa tất cả</button>
                    </form>
                }
            </div>
        </div>

        <div class="cn-list" data-cn-page-list>
            @if (Model.Notifications.Count == 0)
            {
                <div class="cp-empty" data-cn-empty><i class="bi bi-bell"></i><p>Chưa có thông báo chăm sóc nào.</p></div>
            }
            else
            {
                @foreach (var item in Model.Notifications)
                {
                    <div class="cn-row-wrapper" data-notification-id="@item.NotificationId">
                        <a class="cn-row @(!item.IsRead ? "is-unread" : "")" href="/Customer/Notifications/Open/@item.NotificationId">
                            <span class="cn-row-icon"><i class="bi bi-heart-pulse"></i></span>
                            <span class="cn-row-body"><strong>@item.DisplayTitle</strong><span>@item.DisplayMessage</span></span>
                            <time>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</time>
                            <i class="bi bi-chevron-right"></i>
                        </a>
                        <button type="button" class="cn-row-delete" data-notification-delete="@item.NotificationId" title="Xóa thông báo">&times;</button>
                    </div>
                }
            }
        </div>
    </section>
</div>
