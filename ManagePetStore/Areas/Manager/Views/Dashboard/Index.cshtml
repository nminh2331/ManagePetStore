        // =========================================================================
        // AJAX FETCH FUNCTIONS
        // =========================================================================

        function startLoading(title) {
            $('#detailSectionTitle').text(title);
            $('#detailSectionSub').text('Đang tải dữ liệu thực tế...');
            $('#detailEmpty').hide();
            $('#detailTableContainer').hide();
            $('#detailLoader').css('display', 'flex');
            
            // Cuộn mượt mà tới phần chi tiết
            document.getElementById('detailSection').scrollIntoView({ behavior: 'smooth' });
        }

        function endLoading(hasData) {
            $('#detailLoader').hide();
            if (hasData) {
                $('#detailTableContainer').fadeIn(300);
                $('#detailSectionSub').text('Lấy dữ liệu thực tế thành công từ hệ thống.');
            } else {
                $('#detailEmpty').fadeIn(300);
                $('#detailSectionSub').text('Không tìm thấy dữ liệu phù hợp trong kỳ.');
            }
        }

        function clearDetails() {
            $('#detailTableContainer').hide();
            $('#detailLoader').hide();
            $('#detailEmpty').show();
            $('#detailSectionTitle').text('Chi Tiết Dữ Liệu Thực Tế');
            $('#detailSectionSub').text('Bấm vào biểu đồ hoặc chỉ số KPI ở trên để tải bảng thống kê chi tiết thực tế.');
        }

        // Lấy chi tiết doanh thu theo mảng
        function fetchRevenueDetails(category, title) {
            startLoading(title);

            $.ajax({
                url: '/Manager/Dashboard/GetRevenueDetails',
                data: { category: category, fromDate: fromDateVal, toDate: toDateVal },
                type: 'GET',
                success: function (res) {
                    if (res && res.length > 0) {
                        let header = `
                            <tr>
                                <th>Mã đơn hàng</th>
                                <th>Khách hàng</th>
                                <th>Ngày giao dịch</th>
                                <th>Giá trị đơn hàng</th>
                                <th>PT Thanh toán</th>
                                <th>Hành động</th>
                            </tr>
                        `;
                        $('#detailTableHeader').html(header);

                        let rows = '';
                        res.forEach(item => {
                            rows += `
                                <tr>
                                    <td><strong class="text-primary">${item.orderId}</strong></td>
                                    <td>${item.customerName}</td>
                                    <td>${formatDateString(item.orderDate)}</td>
                                    <td><strong style="color: var(--admin-primary);">${formatVND(item.total)}</strong></td>
                                    <td><span class="badge-pill-outline">${item.paymentMethod}</span></td>
                                    <td>
                                        <a href="/Manager/Dashboard/OrderDetail?id=${item.orderId}" target="_blank" class="btn btn-sm btn-light border" style="border-radius: 8px;">
                                            Xem hóa đơn
                                        </a>
                                    </td>
                                </tr>
                            `;
                        });
                        $('#detailTableBody').html(rows);
                        endLoading(true);
                    } else {
                        endLoading(false);
                    }
                },
                error: function () {
                    endLoading(false);
                }
            });
        }

