        // Lấy chi tiết dòng tiền (In / Out)
        function fetchCashFlowDetails(type, title) {
            startLoading(title);

            $.ajax({
                url: '/Manager/Dashboard/GetCashFlowDetails',
                data: { type: type, fromDate: fromDateVal, toDate: toDateVal },
                type: 'GET',
                success: function (res) {
                    if (res && res.length > 0) {
                        let header = `
                            <tr>
                                <th>Mã đối chiếu</th>
                                <th>Phân loại</th>
                                <th>Nguồn</th>
                                <th>Ngày giao dịch</th>
                                <th>Số tiền</th>
                                <th>Mô tả chi tiết</th>
                                <th>Hành động</th>
                            </tr>
                        `;
                        $('#detailTableHeader').html(header);

                        let rows = '';
                        res.forEach(item => {
                            const isOut = item.type.includes('Out');
                            const amountColor = isOut ? 'text-danger' : 'text-success';
                            const amountPrefix = isOut ? '-' : '+';
                            
                            // Link hành động tùy thuộc vào Nguồn
                            let actionLink = '';
                            if (item.source === 'Đơn hàng') {
                                actionLink = `/Manager/Dashboard/OrderDetail?id=${item.referenceId}`;
                            } else if (item.source === 'Nhập kho') {
                                actionLink = `/Manager/Warehouse/Details?id=${item.referenceId}`;
                            }

                            rows += `
                                <tr>
                                    <td><strong class="text-primary">${item.referenceId}</strong></td>
                                    <td><span class="badge ${isOut ? 'bg-danger-subtle text-danger' : 'bg-success-subtle text-success'}" style="padding: 4px 8px; border-radius: 6px;">${item.type}</span></td>
                                    <td><span class="badge bg-secondary-subtle text-secondary" style="padding: 4px 8px; border-radius: 6px;">${item.source}</span></td>
                                    <td>${formatDateString(item.date)}</td>
                                    <td><strong class="${amountColor}">${amountPrefix} ${formatVND(item.amount)}</strong></td>
                                    <td><span class="text-xs text-muted">${item.description}</span></td>
                                    <td>
                                        ${actionLink ? `<a href="${actionLink}" target="_blank" class="btn btn-sm btn-light border" style="border-radius: 8px;">Chi tiết</a>` : 'N/A'}
                                    </td>
                                </tr>
                            `;
                        });
                        $('#detailTableBody').html(rows);
                        endLoading(true);
                    } else {
                        endLoading(false);
                    }
                },
                error: function () {
                    endLoading(false);
                }
            });
        }

