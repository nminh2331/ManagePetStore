@model IEnumerable<ManagePetStore.Models.Blog>
@{
    Layout = "_ManagerLayout";
    ViewData["Title"] = "Quản lý Blog";
    ViewData["ManagerNav"] = "blogs";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    string? search = ViewBag.Search;
    int totalCount = ViewBag.TotalCount ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1" style="color: var(--admin-text-primary);">
            📝 Quản lý Blog
        </h2>
        <p class="text-muted mb-0">Tổng cộng <strong>@totalCount</strong> bài viết trong hệ thống</p>
    </div>
    <a asp-area="Manager" asp-controller="Blogs" asp-action="Create"
       class="btn btn-primary d-flex align-items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Tạo bài viết mới
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert" id="successAlert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Search bar -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <form asp-area="Manager" asp-controller="Blogs" asp-action="Index" method="get" class="d-flex gap-3">
            <input type="text" name="search" value="@search" placeholder="Tìm theo tiêu đề, thể loại..."
                   class="form-control" style="max-width: 400px;" />
            <button type="submit" class="btn btn-outline-primary px-4">
                <i class="bi bi-search"></i> Tìm kiếm
            </button>
            @if (!string.IsNullOrEmpty(search))
            {
                <a asp-area="Manager" asp-controller="Blogs" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg"></i> Xóa lọc
                </a>
            }
        </form>
    </div>
</div>

<!-- Blog table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0" id="blogsTable">
                <thead style="background: #f8f9fa;">
                    <tr>
                        <th class="px-4 py-3" style="width: 80px;">#ID</th>
                        <th class="py-3">Bài viết</th>
                        <th class="py-3" style="width: 130px;">Thể loại</th>
                        <th class="py-3 text-center" style="width: 110px;">Trạng thái</th>
                        <th class="py-3 text-center" style="width: 90px;">Nổi bật</th>
                        <th class="py-3 text-center" style="width: 100px;">Lượt xem</th>
                        <th class="py-3 text-center" style="width: 130px;">Ngày tạo</th>
                        <th class="py-3 text-center" style="width: 160px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">
                                <i class="bi bi-journal-x fs-2 d-block mb-2"></i>
                                @if (!string.IsNullOrEmpty(search))
                                {
                                    <span>Không tìm thấy bài viết phù hợp với "<strong>@search</strong>"</span>
                                }
                                else
                                {
                                    <span>Chưa có bài viết nào. <a asp-area="Manager" asp-controller="Blogs" asp-action="Create">Tạo bài viết đầu tiên</a></span>
                                }
                            </td>
                        </tr>
                    }
                    @foreach (var blog in Model)
                    {
                        <tr>
                            <td class="px-4 py-3 text-muted">#@blog.BlogId</td>
                            <td class="py-3">
                                <div class="d-flex align-items-center gap-3">
                                    @if (!string.IsNullOrEmpty(blog.CoverImage))
                                    {
                                        <img src="@blog.CoverImage" alt="@blog.Title"
                                             style="width:56px;height:42px;object-fit:cover;border-radius:6px;flex-shrink:0;" />
                                    }
                                    else
                                    {
                                        <div style="width:56px;height:42px;border-radius:6px;background:#e9ecef;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                            <i class="bi bi-image text-muted"></i>
                                        </div>
                                    }
                                    <div>
                                        <div class="fw-semibold" style="max-width:340px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                            @blog.Title
                                        </div>
                                        <small class="text-muted font-monospace">/@blog.Slug</small>
                                        <div><small class="text-muted">Tác giả: @(blog.Author?.FullName ?? "N/A")</small></div>
                                    </div>
                                </div>
                            </td>
                            <td class="py-3">
                                @if (!string.IsNullOrEmpty(blog.Category))
                                {
                                    <span class="badge rounded-pill" style="background:#e0f2fe;color:#0369a1;font-weight:600;">@blog.Category</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="py-3 text-center">
                                <form asp-area="Manager" asp-controller="Blogs" asp-action="TogglePublish"
                                      method="post" class="d-inline toggle-publish-form" data-blog-id="@blog.BlogId">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@blog.BlogId" />
                                    <button type="submit"
                                            class="badge border-0 py-2 px-3 fs-6 toggle-publish-btn cursor-pointer"
                                            style="background: @(blog.IsPublished ? "#d1fae5" : "#fee2e2"); color: @(blog.IsPublished ? "#065f46" : "#991b1b");"
                                            title="@(blog.IsPublished ? "Nhấn để gỡ bài" : "Nhấn để đăng bài")"
                                            id="toggleBtn_@blog.BlogId">
                                        @(blog.IsPublished ? "Đã đăng" : "Bản nháp")
                                    </button>
                                </form>
                            </td>
                            <td class="py-3 text-center">
                                @if (blog.IsFeatured)
                                {
                                    <span title="Bài nổi bật" class="fs-5">⭐</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="py-3 text-center">
                                <span class="fw-semibold text-primary">@blog.ViewCount.ToString("N0")</span>
                            </td>
                            <td class="py-3 text-center">
                                <small class="text-muted">@blog.CreatedAt.ToString("dd/MM/yyyy")</small>
                            </td>
                            <td class="py-3 text-center">
                                <div class="d-flex gap-2 justify-content-center">
                                    <a asp-area="Manager" asp-controller="Blogs" asp-action="Edit"
                                       asp-route-id="@blog.BlogId"
                                       class="btn btn-sm btn-outline-primary" title="Chỉnh sửa">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-outline-danger"
                                            title="Xóa bài viết"
                                            onclick="confirmDelete(@blog.BlogId, '@Html.Raw(blog.Title.Replace("'", "\\'"))')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Phân trang -->
@if (totalPages > 1)
{
    <nav class="mt-4 d-flex justify-content-center">
        <ul class="pagination">
            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                <a class="page-link" asp-area="Manager" asp-controller="Blogs" asp-action="Index"
                   asp-route-page="@(currentPage - 1)" asp-route-search="@search">«</a>
            </li>
            @for (int p = 1; p <= totalPages; p++)
            {
                <li class="page-item @(p == currentPage ? "active" : "")">
                    <a class="page-link" asp-area="Manager" asp-controller="Blogs" asp-action="Index"
                       asp-route-page="@p" asp-route-search="@search">@p</a>
                </li>
            }
            <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                <a class="page-link" asp-area="Manager" asp-controller="Blogs" asp-action="Index"
                   asp-route-page="@(currentPage + 1)" asp-route-search="@search">»</a>
            </li>
        </ul>
    </nav>
}

<!-- Modal xác nhận xóa -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-danger">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>Xác nhận xóa bài viết
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc chắn muốn xóa bài viết:</p>
                <p class="fw-semibold" id="deleteTargetTitle"></p>
                <p class="text-muted small">Hành động này không thể hoàn tác.</p>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <form id="deleteForm" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Xóa bài viết
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <script>
        function confirmDelete(blogId, title) {
            document.getElementById('deleteTargetTitle').textContent = '"' + title + '"';
            document.getElementById('deleteForm').action = '/Manager/Blogs/Delete/' + blogId;
            new bootstrap.Modal(document.getElementById('deleteConfirmModal')).show();
        }

        // Auto-dismiss success alert sau 4 giây
        setTimeout(function () {
            var el = document.getElementById('successAlert');
            if (el) bootstrap.Alert.getOrCreateInstance(el).close();
        }, 4000);
    </script>
}
