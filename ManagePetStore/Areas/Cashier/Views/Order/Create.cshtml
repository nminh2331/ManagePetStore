@{
    Layout = "_PetStoreLayout";
    ViewData["Title"] = "Tạo Đơn Tại Quầy (POS)";
}

@section Styles {
    <link href="~/css/cashier-pos.css" rel="stylesheet" />
}

<div class="pos-container">
    <!-- Cột trái: Danh sách lịch Spa chờ thu tiền -->
    <div class="pos-left">
        <div class="pos-header" style="display: flex; justify-content: space-between; align-items: center; padding: 16px 24px;">
            <h2 style="margin: 0;"><i class="bi bi-cash-stack"></i> Danh Sách Chờ Thu</h2>
            <button class="btn-pos-outline" id="btnShowHeldOrders" style="padding: 8px 16px; font-size: 14px;">
                <i class="bi bi-clock-history"></i> Đơn lưu tạm (<span id="heldOrderCount">0</span>)
            </button>
        </div>

        <div class="pos-cart-section">
            <div class="pos-tabs">
                <button class="pos-tab active" data-target="cart-spa-pending" id="tabSpaPendingBtn">Spa Chờ Thu (<span id="countSpaPending">0</span>)</button>
                <!-- Thành viên khác sẽ thêm tab Hotel và Chuồng ở đây -->
            </div>

            <!-- Tab Spa Chờ Thu -->
            <div class="pos-tab-content active" id="cart-spa-pending" style="padding: 16px 24px 24px 24px;">
                <div class="pos-empty-state" id="emptySpaPending">
                    <i class="bi bi-calendar-check"></i>
                    <p>Không có lịch hẹn Spa nào cần thu tiền</p>
                </div>
                <div id="listSpaPending" style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; max-height: 520px; overflow-y: auto; padding: 4px;">
                    <!-- Lịch spa cần thu sẽ được load vào đây -->
                </div>
            </div>
        </div>
    </div>

    <!-- Cột phải: Khách hàng & Thanh toán -->
    <div class="pos-right">
        <!-- Khu vực Khách hàng -->
        <div class="pos-customer-card">
            <div class="pos-customer-search">
                <div class="input-with-icon" style="width: 100%;">
                    <i class="bi bi-person-bounding-box"></i>
                    <input type="text" id="posSearchCustomer" placeholder="Tìm Khách Hàng (SĐT, Tên KH, Tên Pet)..." autocomplete="off" />
                </div>
                <div class="pos-search-results" id="posCustomerResults" style="display: none;"></div>
            </div>

            <div class="pos-selected-customer" id="selectedCustomerInfo" style="display: none;">
                <div class="customer-info-header">
                    <div class="customer-avatar">
                        <i class="bi bi-person-circle"></i>
                    </div>
                    <div class="customer-details">
                        <h4 id="lblCustomerName">Nguyễn Văn A</h4>
                        <p id="lblCustomerPhone">0901234567</p>
                    </div>
                    <button class="btn-pos-icon text-danger" id="btnClearCustomer" title="Bỏ chọn">
                        <i class="bi bi-x-circle"></i>
                    </button>
                </div>



                <!-- Thông tin ca Spa thanh toán -->
                <div class="spa-booking-summary" id="spaBookingSummary" style="display: none; margin-top: 12px; padding: 12px; background: #fffbeb; border-radius: 8px; border: 1px solid #fef3c7;">
                    <p style="margin: 0; font-size: 13px; color: #b45309; font-weight: 700; margin-bottom: 4px;"><i class="bi bi-scissors"></i> Ca Spa: <span id="lblSpaBookingService" style="font-weight: 500;">Dịch vụ</span></p>
                    <p style="margin: 0; font-size: 13px; color: #b45309; font-weight: 700;"><i class="bi bi-heart"></i> Thú cưng: <span id="lblSpaBookingPet" style="font-weight: 500;">Tên thú cưng</span></p>
                </div>
            </div>
        <!-- Chi tiết đơn hàng -->
        <div class="pos-customer-card" id="cartItemsCard" style="display: none; padding: 16px; margin-bottom: 16px;">
            <h4 style="margin-top: 0; margin-bottom: 12px; font-size: 15px; font-weight: 800; color: var(--admin-primary);"><i class="bi bi-cart3"></i> Chi tiết đơn hàng</h4>
            <div class="pos-cart-list" id="listProducts" style="max-height: 200px; overflow-y: auto;"></div>
            <span id="emptyProducts" style="display: none;"></span> <!-- Placeholder to prevent JS errors -->
        </div>

        <!-- Khu vực Tổng tiền -->
        <div class="pos-summary-card">
            <h3>Tổng cộng</h3>
            <div class="summary-row">
                <span>Tạm tính:</span>
                <strong id="lblSubtotal">0đ</strong>
            </div>
            <div class="summary-row highlight" style="margin-bottom: 8px;">
                <span>Tổng thanh toán:</span>
                <strong class="total-amount" id="lblTotal">0đ</strong>
            </div>



            <!-- Payment logic moved to modal -->
            
            <div class="pos-actions" style="margin-top: 20px;">
                <button class="btn-pos-outline" id="btnHoldOrder">
                    <i class="bi bi-pause-circle"></i> Lưu Đơn Tạm
                </button>
                <button class="btn-pos-primary" id="btnSubmitOrder">
                    <i class="bi bi-check-circle"></i> TẠO ĐƠN &amp; THANH TOÁN
                </button>
            </div>
        </div>
    </div>
</div>





<!-- Modal Danh Sách Đơn Tạm -->
<div class="pos-modal-overlay" id="heldOrdersModal">
    <div class="pos-modal-card">
        <div class="pos-modal-header">
            <h3>Danh sách đơn lưu tạm</h3>
            <button class="btn-pos-close" id="btnCloseHeldOrders"><i class="bi bi-x"></i></button>
        </div>
        <div class="pos-modal-body" style="max-height: 400px; overflow-y: auto; padding: 16px;">
            <div id="heldOrdersList">
                <!-- Sẽ load danh sách vào đây -->
            </div>
        </div>
        <div class="pos-modal-footer">
            <button class="btn-pos-secondary" id="btnCancelHeldOrders">Đóng</button>
        </div>
    </div>
</div>

<!-- Modal Thanh Toán -->
<div class="pos-modal-overlay" id="paymentModal">
    <div class="pos-modal-card">
        <div class="pos-modal-header">
            <h3>Xác nhận thanh toán</h3>
            <button class="btn-pos-close" id="btnClosePaymentModal"><i class="bi bi-x"></i></button>
        </div>
        <div class="pos-modal-body">
             <div class="summary-row" style="margin-bottom: 8px; font-size: 14px; color: var(--pos-text-muted);">
                <span>Tạm tính:</span>
                <span id="lblModalSubtotal">0đ</span>
            </div>
            <div class="summary-row" id="rowModalDiscount" style="margin-bottom: 8px; font-size: 14px; color: var(--pos-danger); display: none;">
                <span>Giảm giá (Voucher):</span>
                <span id="lblModalDiscount">-0đ</span>
            </div>
            <div class="summary-row highlight" style="margin-bottom: 16px;">
                <span style="font-size: 16px;">Tổng thanh toán:</span>
                <strong class="total-amount" id="lblModalTotal" style="font-size: 24px; color: var(--pos-primary);">0đ</strong>
            </div>

            <!-- Áp dụng Voucher -->
            <div class="pos-form-group" style="margin-top: 12px; margin-bottom: 16px;">
                <label>Mã giảm giá (Voucher)</label>
                <div style="display: flex; gap: 8px;">
                    <input type="text" id="txtVoucherCode" class="pos-input" placeholder="Nhập mã voucher (VD: PET20)" style="text-transform: uppercase;" autocomplete="off" />
                    <button class="btn-pos-primary" id="btnApplyVoucher" style="white-space: nowrap; padding: 0 16px;">Áp dụng</button>
                </div>
                <div id="voucherMessage" style="font-size: 13px; margin-top: 4px; display: none;"></div>
            </div>

            <div class="pos-form-group" style="margin-top: 12px;">
                <label>Phương thức thanh toán</label>
                <select id="posPaymentMethod" class="pos-select">
                    <option value="Tiền mặt">Tiền mặt</option>
                    <option value="Thanh toán online">Thanh toán online (PayOS)</option>
                </select>
            </div>

            <!-- Tiền mặt khách đưa -->
            <div class="pos-form-group" id="cashInputGroup" style="margin-top: 12px;">
                <label>Tiền mặt khách đưa (đ)</label>
                <input type="text" id="txtCashReceived" class="pos-input" placeholder="VD: 500,000" autocomplete="off" />
            </div>

            <!-- Box thông tin thanh toán kết hợp / thối tiền -->
            <div class="pos-payment-info-box" id="paymentInfoBox" style="margin-top: 12px; padding: 12px; border-radius: 12px; background: var(--pos-bg); border: 1px solid var(--pos-border); display: none;">
                <div class="summary-row" id="rowChangeDue" style="margin-bottom: 0; display: none;">
                    <span style="font-size: 14px;">Tiền thối lại:</span>
                    <strong id="lblChangeDue" style="color: var(--pos-success); font-weight: 800; font-size: 16px;">0đ</strong>
                </div>
                <div class="summary-row" id="rowOnlineAmount" style="margin-bottom: 0; display: none;">
                    <span style="font-size: 14px;">Cần chuyển khoản:</span>
                    <strong id="lblOnlineAmount" style="color: var(--pos-primary); font-weight: 800; font-size: 16px;">0đ</strong>
                </div>
            </div>
        </div>
        <div class="pos-modal-footer">
            <button class="btn-pos-secondary" id="btnCancelPayment">Hủy</button>
            <button class="btn-pos-primary" id="btnConfirmPayment">
                <i class="bi bi-check-circle"></i> XÁC NHẬN
            </button>
        </div>
    </div>
</div>

<!-- QR Modal removed -->

<style>
@Html.Raw("@keyframes posSpinnerAnim { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }")
.pos-spinner {
    display: inline-block;
}
</style>

<!-- Modal Thông báo thanh toán thành công và Hiện hóa đơn -->
<div class="pos-modal-overlay" id="posSuccessModal" style="display: none; align-items: center; justify-content: center; z-index: 1060;">
    <div class="pos-modal" style="width: 420px; max-width: 95%; max-height: 90vh; display: flex; flex-direction: column; padding: 0; overflow: hidden; border-radius: 16px; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04);">
        <!-- Header -->
        <div style="background: #10b981; color: white; padding: 20px; text-align: center; border-top-left-radius: 16px; border-top-right-radius: 16px;">
            <div style="font-size: 40px; line-height: 1; margin-bottom: 8px;"><i class="bi bi-check-circle-fill"></i></div>
            <h3 style="margin: 0; font-size: 18px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px;">Thanh toán thành công!</h3>
            <p style="margin: 4px 0 0 0; font-size: 13px; opacity: 0.9;">Đơn hàng đã được lưu trữ thành công</p>
        </div>

        <!-- Body (Receipt scroll area) -->
        <div style="flex-grow: 1; overflow-y: auto; padding: 20px; background: #f9fafb;">
            <!-- Receipt Container mimicking print receipt -->
            <div id="printReceiptContent" style="background: white; border: 1px solid #e5e7eb; border-radius: 8px; padding: 20px; font-family: 'Courier New', Courier, monospace; font-size: 12px; color: #111827; line-height: 1.4; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
                <!-- Dữ liệu hóa đơn sẽ được render động bằng JS vào đây -->
            </div>
        </div>

        <!-- Footer Actions -->
        <div style="padding: 16px 20px; background: white; border-top: 1px solid #f3f4f6; display: flex; gap: 12px; justify-content: flex-end;">
            <button class="btn-pos-outline" id="btnSuccessPDF" style="padding: 10px 20px; font-size: 14px; font-weight: 700; border-radius: 8px; flex-grow: 1; border: 1px solid #d1d5db; background: white; color: #374151;">
                <i class="bi bi-file-earmark-pdf"></i> Xuất PDF
            </button>
            <button class="btn-pos-primary" id="btnSuccessClose" style="padding: 10px 20px; font-size: 14px; font-weight: 700; border-radius: 8px; flex-grow: 1;">XÁC NHẬN &amp; ĐÓNG</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="~/js/cashier-pos.js"></script>
}
