@using ManagePetStore.Models
@{
    Layout = "/Views/Shared/_PetStoreLayout.cshtml";
    ViewData["Title"] = "Quản lý Trả hàng / Hoàn tiền - Thu ngân";
    
    var submittedRequests = ViewBag.SubmittedRequests as List<ReturnRequest> ?? new List<ReturnRequest>();
    var waitingRequests = ViewBag.WaitingRequests as List<ReturnRequest> ?? new List<ReturnRequest>();
    var processedRequests = ViewBag.ProcessedRequests as List<ReturnRequest> ?? new List<ReturnRequest>();
}

@section Styles {
    <style>
        .cashier-container {
            max-width: 1300px;
            margin: 40px auto;
            padding: 0 24px;
            font-family: 'Be Vietnam Pro', sans-serif;
            color: #3d2314;
        }
        .dashboard-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            border-bottom: 2px dashed #f1ebd9;
            padding-bottom: 20px;
        }
        .dashboard-title {
            font-size: 1.8rem;
            font-weight: 800;
            color: #3d2314;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .dashboard-title i {
            color: #f97316 !important;
        }
        .stats-row {
            display: flex;
            gap: 24px;
            margin-bottom: 40px;
        }
        .stat-card {
            flex: 1;
            background: #fff;
            border-radius: 20px;
            padding: 24px;
            box-shadow: 0 10px 25px -5px rgba(61, 35, 20, 0.05);
            border: 1px solid #f1ebd9;
            display: flex;
            align-items: center;
            gap: 20px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 30px rgba(61, 35, 20, 0.1);
            border-color: #f97316;
        }
        .stat-icon {
            width: 60px;
            height: 60px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
        }
        .stat-info h3 {
            font-size: 2.2rem;
            font-weight: 800;
            margin: 0;
            color: #3d2314;
            line-height: 1.1;
        }
        .stat-info p {
            margin: 4px 0 0;
            color: #6b7280;
            font-size: 0.9rem;
            font-weight: 600;
        }
        .nav-cashier-tabs {
            border-bottom: 2px solid #f1ebd9;
            gap: 8px;
            margin-bottom: 30px;
        }
        .nav-cashier-tabs .nav-link {
            border: none;
            color: #6b7280;
            font-weight: 700;
            padding: 14px 28px;
            position: relative;
            background: none;
            transition: all 0.25s ease;
            font-size: 0.95rem;
            border-radius: 12px 12px 0 0;
        }
        .nav-cashier-tabs .nav-link:hover {
            color: #f97316;
            background-color: rgba(249, 115, 22, 0.05);
        }
        .nav-cashier-tabs .nav-link.active {
            color: #f97316;
            background: none;
        }
        .nav-cashier-tabs .nav-link.active::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            width: 100%;
            height: 3px;
            background-color: #f97316;
            border-radius: 3px;
        }
        .request-card {
            background: #fff;
            border-radius: 20px;
            border: 1px solid #f1ebd9;
            box-shadow: 0 8px 24px rgba(61, 35, 20, 0.03);
            margin-bottom: 28px;
            overflow: hidden;
            transition: all 0.3s ease;
        }
        .request-card:hover {
            box-shadow: 0 12px 30px rgba(61, 35, 20, 0.08);
            border-color: #f97316;
        }
        .card-header-bar {
            padding: 18px 24px;
            background-color: #fff9f0;
            border-bottom: 1px solid #f1ebd9;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .card-body-content {
            padding: 24px;
        }
        .item-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 0;
            border-bottom: 1px dashed #f1ebd9;
        }
        .item-row:last-child {
            border-bottom: none;
        }
        .btn-approve {
            background-color: #22c55e;
            color: #fff;
            font-weight: 700;
            border: none;
            padding: 12px 24px;
            border-radius: 12px;
            transition: all 0.25s ease;
            box-shadow: 0 4px 12px rgba(34, 197, 94, 0.2);
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .btn-approve:hover {
            background-color: #16a34a;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(34, 197, 94, 0.3);
        }
        .btn-reject {
            background-color: #ef4444;
            color: #fff;
            font-weight: 700;
            border: none;
            padding: 12px 24px;
            border-radius: 12px;
            transition: all 0.25s ease;
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.2);
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .btn-reject:hover {
            background-color: #dc2626;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(239, 68, 68, 0.3);
        }
        .reject-box {
            display: none;
            margin-top: 20px;
            padding: 20px;
            background-color: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 16px;
            animation: slideDown 0.2s ease-out;
        }
        
        
        .badge.bg-warning {
            background-color: #fff7ed !important;
            color: #c2410c !important;
            border: 1px solid #ffedd5;
        }
        .badge.bg-info {
            background-color: #eff6ff !important;
            color: #1d4ed8 !important;
            border: 1px solid #dbeafe;
        }
        .badge.bg-success {
            background-color: #f0fdf4 !important;
            color: #15803d !important;
            border: 1px solid #dcfce7;
        }
        .badge.bg-danger {
            background-color: #fef2f2 !important;
            color: #b91c1c !important;
            border: 1px solid #fee2e2;
        }
        .table-responsive {
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid #f1ebd9;
        }
        .table {
            margin-bottom: 0;
        }
        .table thead th {
            background-color: #fff9f0 !important;
            color: #3d2314 !important;
            font-weight: 700 !important;
            border-bottom: 2px solid #f1ebd9 !important;
            padding: 16px;
        }
        .table tbody td {
            padding: 16px;
            border-bottom: 1px solid #f1ebd9;
            color: #3d2314;
        }
        .table-hover tbody tr:hover {
            background-color: #fffdf9 !important;
        }
    </style>
}

<div class="cashier-container">
    <!-- Header -->
    <div class="dashboard-header">
        <div>
            <h1 class="dashboard-title"><i class="bi bi-arrow-counterclockwise text-primary"></i> Quản lý Yêu cầu Trả hàng / Hoàn tiền</h1>
            <p class="text-muted mb-0">Xử lý yêu cầu trả hàng trực tuyến và hoàn tiền trực tiếp tại quầy vào ví điện tử khách hàng.</p>
        </div>
    </div>

    <!-- Alert notifications -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4 p-3" role="alert" style="border-left: 5px solid #10b981;">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4 p-3" role="alert" style="border-left: 5px solid #ef4444;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Stat Dashboard -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-icon" style="background-color: #FEF3C7; color: #D97706;">
                <i class="bi bi-file-earmark-arrow-up"></i>
            </div>
            <div class="stat-info">
                <h3>@submittedRequests.Count</h3>
                <p>Chờ duyệt online</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background-color: #DBEAFE; color: #2563EB;">
                <i class="bi bi-shop"></i>
            </div>
            <div class="stat-info">
                <h3>@waitingRequests.Count</h3>
                <p>Chờ khách mang qua quầy</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background-color: #D1FAE5; color: #059669;">
                <i class="bi bi-check-circle"></i>
            </div>
            <div class="stat-info">
                <h3>@processedRequests.Count</h3>
                <p>Đã xử lý lịch sử</p>
            </div>
        </div>
    </div>

    <!-- Navigation Tabs -->
    <ul class="nav nav-tabs nav-cashier-tabs mb-4" id="cashierTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="submitted-tab" data-bs-toggle="tab" data-bs-target="#submitted-pane" type="button" role="tab">
                Chờ duyệt online (@submittedRequests.Count)
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="waiting-tab" data-bs-toggle="tab" data-bs-target="#waiting-pane" type="button" role="tab">
                Chờ trả hàng tại quầy (@waitingRequests.Count)
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="processed-tab" data-bs-toggle="tab" data-bs-target="#processed-pane" type="button" role="tab">
                Lịch sử xử lý (@processedRequests.Count)
            </button>
        </li>
    </ul>

    <div class="tab-content" id="cashierTabsContent">
        <!-- 1. Submitted Pane -->
        <div class="tab-pane fade show active" id="submitted-pane" role="tabpanel">
            <!-- Submitted Search Controls -->
            <div class="mb-3 p-3 bg-light border rounded-3 d-flex gap-3 align-items-center">
                <div class="flex-grow-1">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" id="submittedSearch" class="form-control" placeholder="Tìm theo Mã Yêu Cầu, Mã Đơn Hàng, Khách Hàng, SĐT..." style="border-radius: 0 8px 8px 0; border: 1px solid #ced4da; padding: 8px 12px;" />
                    </div>
                </div>
            </div>

            <div id="submittedCardsContainer">
                @if (submittedRequests.Any())
                {
                    foreach (var req in submittedRequests)
                    {
                        <div class="request-card submitted-card" data-req-id="#REQ-@req.RequestId" data-order-id="#OD-@req.OrderId.Split('-')[^1]" data-customer="@(req.Customer?.FullName?.ToLower() ?? "")" data-phone="@(req.Customer?.Phone ?? "")">
                            <div class="card-header-bar">
                                <div>
                                    <span class="fw-bold text-dark" style="font-size: 1.05rem;">Mã Yêu Cầu: #REQ-@req.RequestId</span>
                                    <span class="mx-2 text-muted">|</span>
                                    <span class="text-muted">Đơn mua: #OD-@req.OrderId.Split('-')[^1]</span>
                                </div>
                                <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">Chờ duyệt online</span>
                            </div>
                            <div class="card-body-content text-start">
                                <div class="row">
                                    <div class="col-md-7">
                                        <h6 class="fw-bold text-muted mb-2">Thông tin khách hàng:</h6>
                                        <p class="mb-1"><strong>Khách hàng:</strong> @req.Customer.FullName</p>
                                        <p class="mb-3"><strong>Số điện thoại:</strong> @req.Customer.Phone</p>

                                        <h6 class="fw-bold text-muted mb-2">Lý do hoàn trả:</h6>
                                        <blockquote class="bg-light p-3 rounded-3 border-start border-warning mb-0" style="font-style: italic; color: #555;">
                                            "@req.Reason"
                                        </blockquote>
                                        @{
                                            var parsedImages = new List<string>();
                                            var parsedVideo = "";
                                            if (!string.IsNullOrEmpty(req.Notes))
                                            {
                                                var parts = req.Notes.Split('|');
                                                foreach (var part in parts)
                                                {
                                                    if (part.StartsWith("IMAGES:"))
                                                    {
                                                        parsedImages.AddRange(part.Substring("IMAGES:".Length).Split(';', StringSplitOptions.RemoveEmptyEntries));
                                                    }
                                                    else if (part.StartsWith("VIDEO:"))
                                                    {
                                                        parsedVideo = part.Substring("VIDEO:".Length);
                                                    }
                                                }
                                            }
                                        }
                                        @if (parsedImages.Any())
                                        {
                                            <div class="mt-3">
                                                <h6 class="fw-bold text-muted mb-2">Ảnh minh chứng khách gửi:</h6>
                                                <div class="d-flex gap-2">
                                                    @foreach (var img in parsedImages)
                                                    {
                                                        <a href="@img" target="_blank">
                                                            <img src="@img" style="width: 75px; height: 75px; object-fit: cover; border-radius: 8px; border: 1px solid #ddd;" />
                                                        </a>
                                                    }
                                                </div>
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(parsedVideo))
                                        {
                                            <div class="mt-3">
                                                <h6 class="fw-bold text-muted mb-2">Video đập hộp khách gửi:</h6>
                                                <div>
                                                    <video src="@parsedVideo" width="260" controls style="border-radius: 8px; border: 1px solid #ddd;"></video>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    <div class="col-md-5 border-start ps-4">
                                        <h6 class="fw-bold text-muted mb-2">Sản phẩm yêu cầu trả:</h6>
                                        <div class="mb-3">
                                            @foreach (var item in req.ReturnRequestItems)
                                            {
                                                <div class="item-row">
                                                    <div class="d-flex align-items-center">
                                                        @if (item.SkuNavigation != null && !string.IsNullOrEmpty(item.SkuNavigation.ImageUrl))
                                                        {
                                                            <img src="@item.SkuNavigation.ImageUrl" style="width: 40px; height: 40px; object-fit: cover; border-radius: 6px; margin-right: 10px;" />
                                                        }
                                                        <div>
                                                            <div class="fw-bold" style="font-size: 0.9rem;">@(item.SkuNavigation?.Name ?? item.Sku)</div>
                                                            <div class="text-muted" style="font-size: 0.8rem;">SKU: @item.Sku | Giá: @item.RefundPrice.ToString("N0")đ</div>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                        <div class="d-flex justify-content-between align-items-center p-3 bg-light rounded-3">
                                            <span class="fw-bold text-muted">Số tiền hoàn đề xuất:</span>
                                            <span class="fs-5 fw-bold text-primary">@req.RefundAmount.ToString("N0") đ</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                                    <button type="button" class="btn btn-reject px-4" onclick="showRejectBox('online', @req.RequestId)">Từ chối duyệt</button>
                                    
                                    <form asp-action="ApproveOnline" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@req.RequestId" />
                                        <button type="submit" class="btn btn-approve px-4" onclick="return confirm('Bạn có chắc chắn muốn DUYỆT ONLINE yêu cầu này không? Khách hàng sẽ nhận thông báo mang hàng qua quầy.')">Duyệt yêu cầu online</button>
                                    </form>
                                </div>

                                <!-- Reject input container -->
                                <div class="reject-box" id="reject-online-@req.RequestId">
                                    <form asp-action="RejectOnline" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@req.RequestId" />
                                        <div class="mb-3 text-start">
                                            <label class="form-label fw-bold text-danger">Nhập lý do từ chối duyệt online *</label>
                                            <textarea class="form-control" name="rejectReason" rows="2" required placeholder="Lý do từ chối (Ví dụ: Sản phẩm quá hạn đổi trả, lý do không hợp lệ...)"></textarea>
                                        </div>
                                        <div class="text-end">
                                            <button type="button" class="btn btn-light btn-sm" onclick="hideRejectBox('online', @req.RequestId)">Hủy</button>
                                            <button type="submit" class="btn btn-danger btn-sm ms-1">Xác nhận từ chối</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-5 text-muted bg-white rounded-3 border">
                        <i class="bi bi-inbox d-block mb-3" style="font-size: 3rem; color: #cbd5e1;"></i>
                        Không có yêu cầu trả hàng nào chờ duyệt online.
                    </div>
                }
            </div>

            <!-- Empty Search State -->
            <div id="submittedSearchEmpty" class="text-center py-5 text-muted bg-white rounded-3 border" style="display: none;">
                <i class="bi bi-search d-block mb-3" style="font-size: 3rem; color: #cbd5e1;"></i>
                Không tìm thấy yêu cầu trả hàng nào khớp với tìm kiếm.
            </div>

            <!-- Submitted Pagination controls -->
            <div class="p-3 d-flex justify-content-between align-items-center border rounded-3 bg-light mt-3" id="submittedPagination">
                <span class="text-muted" style="font-size: 0.85rem;" id="submittedPaginationInfo">Hiển thị 0-0 trên 0 yêu cầu</span>
                <div class="d-flex gap-1" id="submittedPaginationButtons"></div>
            </div>
        </div>

        <!-- 2. Waiting Pane -->
        <div class="tab-pane fade" id="waiting-pane" role="tabpanel">
            <!-- Waiting Search Controls -->
            <div class="mb-3 p-3 bg-light border rounded-3 d-flex gap-3 align-items-center">
                <div class="flex-grow-1">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" id="waitingSearch" class="form-control" placeholder="Tìm theo Mã Yêu Cầu, Mã Đơn Hàng, Khách Hàng, SĐT..." style="border-radius: 0 8px 8px 0; border: 1px solid #ced4da; padding: 8px 12px;" />
                    </div>
                </div>
            </div>

            <div id="waitingCardsContainer">
                @if (waitingRequests.Any())
                {
                    foreach (var req in waitingRequests)
                    {
                        <div class="request-card waiting-card" data-req-id="#REQ-@req.RequestId" data-order-id="#OD-@req.OrderId.Split('-')[^1]" data-customer="@(req.Customer?.FullName?.ToLower() ?? "")" data-phone="@(req.Customer?.Phone ?? "")">
                            <div class="card-header-bar">
                                <div>
                                    <span class="fw-bold text-dark" style="font-size: 1.05rem;">Mã Yêu Cầu: #REQ-@req.RequestId</span>
                                    <span class="mx-2 text-muted">|</span>
                                    <span class="text-muted">Đơn mua: #OD-@req.OrderId.Split('-')[^1]</span>
                                </div>
                                <span class="badge bg-info text-dark px-3 py-2 rounded-pill">Chờ khách mang hàng qua quầy</span>
                            </div>
                            <div class="card-body-content text-start">
                                <div class="row">
                                    <div class="col-md-7">
                                        <h6 class="fw-bold text-muted mb-2">Thông tin khách hàng:</h6>
                                        <p class="mb-1"><strong>Khách hàng:</strong> @req.Customer.FullName</p>
                                        <p class="mb-3"><strong>Số điện thoại:</strong> @req.Customer.Phone</p>

                                        <h6 class="fw-bold text-muted mb-2">Lý do hoàn trả:</h6>
                                        <blockquote class="bg-light p-3 rounded-3 border-start border-info mb-0" style="font-style: italic; color: #555;">
                                            "@req.Reason"
                                        </blockquote>
                                        @{
                                            var parsedImages = new List<string>();
                                            var parsedVideo = "";
                                            if (!string.IsNullOrEmpty(req.Notes))
                                            {
                                                var parts = req.Notes.Split('|');
                                                foreach (var part in parts)
                                                {
                                                    if (part.StartsWith("IMAGES:"))
                                                    {
                                                        parsedImages.AddRange(part.Substring("IMAGES:".Length).Split(';', StringSplitOptions.RemoveEmptyEntries));
                                                    }
                                                    else if (part.StartsWith("VIDEO:"))
                                                    {
                                                        parsedVideo = part.Substring("VIDEO:".Length);
                                                    }
                                                }
                                            }
                                        }
                                        @if (parsedImages.Any())
                                        {
                                            <div class="mt-3">
                                                <h6 class="fw-bold text-muted mb-2">Ảnh minh chứng khách gửi:</h6>
                                                <div class="d-flex gap-2">
                                                    @foreach (var img in parsedImages)
                                                    {
                                                        <a href="@img" target="_blank">
                                                            <img src="@img" style="width: 75px; height: 75px; object-fit: cover; border-radius: 8px; border: 1px solid #ddd;" />
                                                        </a>
                                                    }
                                                </div>
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(parsedVideo))
                                        {
                                            <div class="mt-3">
                                                <h6 class="fw-bold text-muted mb-2">Video đập hộp khách gửi:</h6>
                                                <div>
                                                    <video src="@parsedVideo" width="260" controls style="border-radius: 8px; border: 1px solid #ddd;"></video>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    <div class="col-md-5 border-start ps-4">
                                        <h6 class="fw-bold text-muted mb-2">Sản phẩm cần đối chiếu thực tế:</h6>
                                        <div class="mb-3">
                                            @foreach (var item in req.ReturnRequestItems)
                                            {
                                                <div class="item-row">
                                                    <div class="d-flex align-items-center">
                                                        @if (item.SkuNavigation != null && !string.IsNullOrEmpty(item.SkuNavigation.ImageUrl))
                                                        {
                                                            <img src="@item.SkuNavigation.ImageUrl" style="width: 40px; height: 40px; object-fit: cover; border-radius: 6px; margin-right: 10px;" />
                                                        }
                                                        <div>
                                                            <div class="fw-bold" style="font-size: 0.9rem;">@(item.SkuNavigation?.Name ?? item.Sku)</div>
                                                            <div class="text-muted" style="font-size: 0.8rem;">SKU: @item.Sku | Giá: @item.RefundPrice.ToString("N0")đ</div>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                        <div class="d-flex justify-content-between align-items-center p-3 bg-light rounded-3">
                                            <span class="fw-bold text-muted">Số tiền hoàn vào ví:</span>
                                            <span class="fs-5 fw-bold text-primary">@req.RefundAmount.ToString("N0") đ</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                                    <button type="button" class="btn btn-reject px-4" onclick="showRejectBox('physical', @req.RequestId)">Từ chối nhận hàng tại quầy</button>
                                    
                                    <form asp-action="ConfirmPhysicalReturn" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@req.RequestId" />
                                        <button type="submit" class="btn btn-approve px-4" onclick="return confirm('Xác nhận đã kiểm tra và nhận đủ sản phẩm thực tế? Hệ thống sẽ tự động cộng @req.RefundAmount.ToString("N0")đ vào ví khách hàng và cộng trả hàng vào kho.')">Xác nhận đã nhận hàng & Hoàn tiền</button>
                                    </form>
                                </div>

                                <!-- Reject input container -->
                                <div class="reject-box" id="reject-physical-@req.RequestId">
                                    <form asp-action="RejectPhysicalReturn" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@req.RequestId" />
                                        <div class="mb-3 text-start">
                                            <label class="form-label fw-bold text-danger">Nhập lý do từ chối nhận hàng tại quầy *</label>
                                            <textarea class="form-control" name="rejectReason" rows="2" required placeholder="Lý do từ chối (Ví dụ: Sản phẩm thực tế đã bị hư hỏng thêm, bao bì bị khui, thiếu phụ kiện...)"></textarea>
                                        </div>
                                        <div class="text-end">
                                            <button type="button" class="btn btn-light btn-sm" onclick="hideRejectBox('physical', @req.RequestId)">Hủy</button>
                                            <button type="submit" class="btn btn-danger btn-sm ms-1">Xác nhận từ chối</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-5 text-muted bg-white rounded-3 border">
                        <i class="bi bi-clock text-info d-block mb-3" style="font-size: 3rem;"></i>
                        Không có yêu cầu trả hàng nào đang chờ mang sản phẩm đến quầy.
                    </div>
                }
            </div>

            <!-- Empty Search State -->
            <div id="waitingSearchEmpty" class="text-center py-5 text-muted bg-white rounded-3 border" style="display: none;">
                <i class="bi bi-search d-block mb-3" style="font-size: 3rem; color: #cbd5e1;"></i>
                Không tìm thấy yêu cầu trả hàng nào khớp với tìm kiếm.
            </div>

            <!-- Waiting Pagination controls -->
            <div class="p-3 d-flex justify-content-between align-items-center border rounded-3 bg-light mt-3" id="waitingPagination">
                <span class="text-muted" style="font-size: 0.85rem;" id="waitingPaginationInfo">Hiển thị 0-0 trên 0 yêu cầu</span>
                <div class="d-flex gap-1" id="waitingPaginationButtons"></div>
            </div>
        </div>

        <!-- 3. Processed Pane -->
        <div class="tab-pane fade" id="processed-pane" role="tabpanel">
            <!-- Processed Search Controls -->
            <div class="mb-3 p-3 bg-light border rounded-3 d-flex gap-3 align-items-center flex-wrap">
                <div class="flex-grow-1" style="min-width: 200px;">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" id="processedSearch" class="form-control" placeholder="Tìm theo Mã Yêu Cầu, Mã Đơn Hàng, Khách Hàng, SĐT..." style="border-radius: 0 8px 8px 0; border: 1px solid #ced4da; padding: 8px 12px;" />
                    </div>
                </div>
                <div style="width: 200px;">
                    <select id="processedStatusSelect" class="form-select" style="border-radius: 8px; font-weight: 600;">
                        <option value="">Tất cả trạng thái</option>
                        <option value="OnlineRejected">Từ chối online</option>
                        <option value="PhysicalRejected">Từ chối tại quầy</option>
                        <option value="Success">Thành công</option>
                    </select>
                </div>
            </div>

            @if (processedRequests.Any())
            {
                <div class="bg-white rounded-3 border overflow-hidden">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Mã Yêu Cầu</th>
                                <th>Mã Đơn Hàng</th>
                                <th>Khách Hàng</th>
                                <th>Số Tiền Hoàn</th>
                                <th>Ngày Gửi</th>
                                <th>Trạng Thái</th>
                                <th>Xử Lý Lúc</th>
                            </tr>
                        </thead>
                        <tbody class="text-start" id="processedTableBody">
                            @foreach (var req in processedRequests)
                            {
                                var historyImages = new List<string>();
                                var historyVideo = "";
                                var rejectReason = "";
                                if (!string.IsNullOrEmpty(req.Notes))
                                {
                                    var parts = req.Notes.Split('|');
                                    foreach (var part in parts)
                                    {
                                        if (part.StartsWith("IMAGES:"))
                                        {
                                            historyImages.AddRange(part.Substring("IMAGES:".Length).Split(';', StringSplitOptions.RemoveEmptyEntries));
                                        }
                                        else if (part.StartsWith("VIDEO:"))
                                        {
                                            historyVideo = part.Substring("VIDEO:".Length);
                                        }
                                        else if (part.StartsWith("REJECT:"))
                                        {
                                            rejectReason = part.Substring("REJECT:".Length);
                                        }
                                    }
                                    if (!req.Notes.Contains("IMAGES:") && !req.Notes.Contains("REJECT:") && !req.Notes.Contains("VIDEO:"))
                                    {
                                        rejectReason = req.Notes;
                                    }
                                }
                                <tr class="processed-tr" data-req-id="#REQ-@req.RequestId" data-order-id="#OD-@req.OrderId.Split('-')[^1]" data-customer="@(req.Customer?.FullName?.ToLower() ?? "")" data-phone="@(req.Customer?.Phone ?? "")" data-status="@req.Status">
                                    <td class="fw-bold">#REQ-@req.RequestId</td>
                                    <td>#OD-@req.OrderId.Split('-')[^1]</td>
                                    <td>
                                        <div><strong>@req.Customer.FullName</strong></div>
                                        <small class="text-muted">SĐT: @req.Customer.Phone</small>
                                    </td>
                                    <td class="fw-bold text-primary">@req.RefundAmount.ToString("N0") đ</td>
                                    <td>@req.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        @if (req.Status == "OnlineRejected")
                                        {
                                            <span class="badge bg-danger px-3 py-2 rounded-pill" title="Lý do từ chối: @req.Notes">Từ chối online</span>
                                        }
                                        else if (req.Status == "PhysicalRejected")
                                        {
                                            <span class="badge bg-danger px-3 py-2 rounded-pill" title="Lý do từ chối: @req.Notes">Từ chối tại quầy</span>
                                        }
                                        else if (req.Status == "Success")
                                        {
                                            <span class="badge bg-success px-3 py-2 rounded-pill">Thành công</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary px-3 py-2 rounded-pill">@req.Status</span>
                                        }
                                    </td>
                                    <td>
                                        @if (req.ProcessedAt.HasValue)
                                        {
                                            <span>@req.ProcessedAt.Value.ToString("dd/MM/yyyy HH:mm")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                </tr>
                                <!-- Sub row to display reasons and details -->
                                <tr class="processed-detail-tr" data-parent-id="#REQ-@req.RequestId" style="background-color: #fafafa; display: none;">
                                    <td colspan="7" class="p-3" style="font-size: 0.85rem;">
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="mb-2"><strong>Lý do trả hàng:</strong> @req.Reason</div>
                                                @if (historyImages.Any())
                                                {
                                                    <div class="d-flex gap-2 mt-1">
                                                        @foreach (var img in historyImages)
                                                        {
                                                            <a href="@img" target="_blank">
                                                                <img src="@img" style="width: 50px; height: 50px; object-fit: cover; border-radius: 6px; border: 1px solid #ddd;" />
                                                            </a>
                                                        }
                                                    </div>
                                                }
                                                @if (!string.IsNullOrEmpty(historyVideo))
                                                {
                                                    <div class="mt-2">
                                                        <strong>Video minh chứng:</strong>
                                                        <div class="mt-1">
                                                            <video src="@historyVideo" width="200" controls style="border-radius: 6px; border: 1px solid #ddd;"></video>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                            <div class="col-md-6 border-start">
                                                @if (!string.IsNullOrEmpty(rejectReason))
                                                {
                                                    <strong>Ghi chú từ chối:</strong> <span class="text-danger">@rejectReason</span>
                                                }
                                                else
                                                {
                                                    <span class="text-success"><i class="bi bi-check-circle"></i> Trả hàng và hoàn tiền thành công.</span>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted bg-white rounded-3 border">
                    <i class="bi bi-clock-history d-block mb-3" style="font-size: 3rem; color: #cbd5e1;"></i>
                    Chưa có lịch sử xử lý trả hàng nào.
                </div>
            }

            <!-- Empty Search State -->
            <div id="processedSearchEmpty" class="text-center py-5 text-muted bg-white rounded-3 border" style="display: none;">
                <i class="bi bi-search d-block mb-3" style="font-size: 3rem; color: #cbd5e1;"></i>
                Không tìm thấy lịch sử yêu cầu trả hàng nào khớp với tìm kiếm.
            </div>

            <!-- Processed Pagination controls -->
            <div class="p-3 d-flex justify-content-between align-items-center border rounded-3 bg-light mt-3" id="processedPagination">
                <span class="text-muted" style="font-size: 0.85rem;" id="processedPaginationInfo">Hiển thị 0-0 trên 0 yêu cầu</span>
                <div class="d-flex gap-1" id="processedPaginationButtons"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showRejectBox(type, requestId) {
            document.getElementById('reject-' + type + '-' + requestId).style.display = 'block';
        }

        function hideRejectBox(type, requestId) {
            document.getElementById('reject-' + type + '-' + requestId).style.display = 'none';
        }

        // ========================================================
        // CASHIER RETURN REQUESTS CLIENT-SIDE PAGINATION & FILTERS
        // ========================================================
        document.addEventListener("DOMContentLoaded", function () {
            const PAGE_SIZE = 5;

            // 1. SUBMITTED PANE (Chờ duyệt online)
            const submittedSearch = document.getElementById("submittedSearch");
            const submittedCardsContainer = document.getElementById("submittedCardsContainer");
            const submittedSearchEmpty = document.getElementById("submittedSearchEmpty");
            const submittedPaginationInfo = document.getElementById("submittedPaginationInfo");
            const submittedPaginationButtons = document.getElementById("submittedPaginationButtons");

            let currentSubmittedPage = 1;

            function updateSubmittedCards() {
                const cards = Array.from(document.querySelectorAll(".submitted-card"));
                const query = submittedSearch ? submittedSearch.value.toLowerCase().trim() : "";

                // Filter
                const filtered = cards.filter(card => {
                    const reqId = card.getAttribute("data-req-id").toLowerCase();
                    const orderId = card.getAttribute("data-order-id").toLowerCase();
                    const customer = card.getAttribute("data-customer");
                    const phone = card.getAttribute("data-phone");
                    return reqId.includes(query) || orderId.includes(query) || customer.includes(query) || phone.includes(query);
                });

                const totalItems = filtered.length;
                const totalPages = Math.ceil(totalItems / PAGE_SIZE) || 1;

                if (currentSubmittedPage > totalPages) currentSubmittedPage = totalPages;
                if (currentSubmittedPage < 1) currentSubmittedPage = 1;

                // Hide all cards
                cards.forEach(card => card.style.display = "none");

                const start = (currentSubmittedPage - 1) * PAGE_SIZE;
                const end = Math.min(start + PAGE_SIZE, totalItems);

                filtered.slice(start, end).forEach(card => {
                    card.style.display = "";
                });

                // Show/hide empty state
                if (totalItems === 0) {
                    if (submittedCardsContainer) submittedCardsContainer.style.display = "none";
                    if (submittedSearchEmpty) submittedSearchEmpty.style.display = "";
                } else {
                    if (submittedCardsContainer) submittedCardsContainer.style.display = "";
                    if (submittedSearchEmpty) submittedSearchEmpty.style.display = "none";
                }

                // Render pagination info
                if (submittedPaginationInfo) {
                    if (totalItems === 0) {
                        submittedPaginationInfo.textContent = "Không tìm thấy yêu cầu nào";
                    } else {
                        submittedPaginationInfo.textContent = `Hiển thị ${start + 1}-${end} trên ${totalItems} yêu cầu`;
                    }
                }

                renderPaginationButtons(submittedPaginationButtons, currentSubmittedPage, totalPages, function (p) {
                    currentSubmittedPage = p;
                    updateSubmittedCards();
                });
            }

            if (submittedSearch) submittedSearch.addEventListener("input", () => { currentSubmittedPage = 1; updateSubmittedCards(); });

            if (document.querySelector(".submitted-card")) {
                updateSubmittedCards();
            }


            // 2. WAITING PANE (Chờ trả hàng tại quầy)
            const waitingSearch = document.getElementById("waitingSearch");
            const waitingCardsContainer = document.getElementById("waitingCardsContainer");
            const waitingSearchEmpty = document.getElementById("waitingSearchEmpty");
            const waitingPaginationInfo = document.getElementById("waitingPaginationInfo");
            const waitingPaginationButtons = document.getElementById("waitingPaginationButtons");

            let currentWaitingPage = 1;

            function updateWaitingCards() {
                const cards = Array.from(document.querySelectorAll(".waiting-card"));
                const query = waitingSearch ? waitingSearch.value.toLowerCase().trim() : "";

                // Filter
                const filtered = cards.filter(card => {
                    const reqId = card.getAttribute("data-req-id").toLowerCase();
                    const orderId = card.getAttribute("data-order-id").toLowerCase();
                    const customer = card.getAttribute("data-customer");
                    const phone = card.getAttribute("data-phone");
                    return reqId.includes(query) || orderId.includes(query) || customer.includes(query) || phone.includes(query);
                });

                const totalItems = filtered.length;
                const totalPages = Math.ceil(totalItems / PAGE_SIZE) || 1;

                if (currentWaitingPage > totalPages) currentWaitingPage = totalPages;
                if (currentWaitingPage < 1) currentWaitingPage = 1;

                // Hide all cards
                cards.forEach(card => card.style.display = "none");

                const start = (currentWaitingPage - 1) * PAGE_SIZE;
                const end = Math.min(start + PAGE_SIZE, totalItems);

                filtered.slice(start, end).forEach(card => {
                    card.style.display = "";
                });

                if (totalItems === 0) {
                    if (waitingCardsContainer) waitingCardsContainer.style.display = "none";
                    if (waitingSearchEmpty) waitingSearchEmpty.style.display = "";
                } else {
                    if (waitingCardsContainer) waitingCardsContainer.style.display = "";
                    if (waitingSearchEmpty) waitingSearchEmpty.style.display = "none";
                }

                if (waitingPaginationInfo) {
                    if (totalItems === 0) {
                        waitingPaginationInfo.textContent = "Không tìm thấy yêu cầu nào";
                    } else {
                        waitingPaginationInfo.textContent = `Hiển thị ${start + 1}-${end} trên ${totalItems} yêu cầu`;
                    }
                }

                renderPaginationButtons(waitingPaginationButtons, currentWaitingPage, totalPages, function (p) {
                    currentWaitingPage = p;
                    updateWaitingCards();
                });
            }

            if (waitingSearch) waitingSearch.addEventListener("input", () => { currentWaitingPage = 1; updateWaitingCards(); });

            if (document.querySelector(".waiting-card")) {
                updateWaitingCards();
            }


            // 3. PROCESSED PANE (Lịch sử xử lý)
            const processedSearch = document.getElementById("processedSearch");
            const processedStatusSelect = document.getElementById("processedStatusSelect");
            const processedTableBody = document.getElementById("processedTableBody");
            const processedSearchEmpty = document.getElementById("processedSearchEmpty");
            const processedPaginationInfo = document.getElementById("processedPaginationInfo");
            const processedPaginationButtons = document.getElementById("processedPaginationButtons");

            let currentProcessedPage = 1;

            function updateProcessedTable() {
                const trs = Array.from(document.querySelectorAll(".processed-tr"));
                const details = Array.from(document.querySelectorAll(".processed-detail-tr"));
                const query = processedSearch ? processedSearch.value.toLowerCase().trim() : "";
                const selectedStatus = processedStatusSelect ? processedStatusSelect.value : "";

                // Filter
                const filtered = trs.filter(tr => {
                    const reqId = tr.getAttribute("data-req-id").toLowerCase();
                    const orderId = tr.getAttribute("data-order-id").toLowerCase();
                    const customer = tr.getAttribute("data-customer");
                    const phone = tr.getAttribute("data-phone");
                    const status = tr.getAttribute("data-status");

                    const matchesQuery = reqId.includes(query) || orderId.includes(query) || customer.includes(query) || phone.includes(query);
                    const matchesStatus = selectedStatus === "" || status === selectedStatus;
                    return matchesQuery && matchesStatus;
                });

                const totalItems = filtered.length;
                const totalPages = Math.ceil(totalItems / PAGE_SIZE) || 1;

                if (currentProcessedPage > totalPages) currentProcessedPage = totalPages;
                if (currentProcessedPage < 1) currentProcessedPage = 1;

                // Hide all rows
                trs.forEach(tr => tr.style.display = "none");
                details.forEach(det => det.style.display = "none");

                const start = (currentProcessedPage - 1) * PAGE_SIZE;
                const end = Math.min(start + PAGE_SIZE, totalItems);

                const activePageRows = filtered.slice(start, end);
                activePageRows.forEach(tr => {
                    tr.style.display = "";
                    
                    // Hook double row click toggle to show details sub-row
                    tr.onclick = function() {
                        const targetId = tr.getAttribute("data-req-id");
                        const detailRow = document.querySelector(`.processed-detail-tr[data-parent-id="${targetId}"]`);
                        if (detailRow) {
                            if (detailRow.style.display === "none") {
                                detailRow.style.display = "table-row";
                            } else {
                                detailRow.style.display = "none";
                            }
                        }
                    };
                });

                if (totalItems === 0) {
                    if (processedTableBody) processedTableBody.closest("div").style.display = "none";
                    if (processedSearchEmpty) processedSearchEmpty.style.display = "";
                } else {
                    if (processedTableBody) processedTableBody.closest("div").style.display = "";
                    if (processedSearchEmpty) processedSearchEmpty.style.display = "none";
                }

                if (processedPaginationInfo) {
                    if (totalItems === 0) {
                        processedPaginationInfo.textContent = "Không tìm thấy yêu cầu nào";
                    } else {
                        processedPaginationInfo.textContent = `Hiển thị ${start + 1}-${end} trên ${totalItems} yêu cầu`;
                    }
                }

                renderPaginationButtons(processedPaginationButtons, currentProcessedPage, totalPages, function (p) {
                    currentProcessedPage = p;
                    updateProcessedTable();
                });
            }

            if (processedSearch) processedSearch.addEventListener("input", () => { currentProcessedPage = 1; updateProcessedTable(); });
            if (processedStatusSelect) processedStatusSelect.addEventListener("change", () => { currentProcessedPage = 1; updateProcessedTable(); });

            if (document.querySelector(".processed-tr")) {
                updateProcessedTable();
            }


            // PAGINATION BUTTONS RENDERER
            function renderPaginationButtons(container, currentPage, totalPages, onPageClick) {
                if (!container) return;
                container.innerHTML = "";

                if (totalPages <= 1) return;

                // Prev button
                const prevBtn = document.createElement("button");
                prevBtn.type = "button";
                prevBtn.className = `btn btn-sm btn-outline-secondary px-2 ${currentPage === 1 ? 'disabled' : ''}`;
                prevBtn.innerHTML = '<i class="bi bi-chevron-left"></i>';
                prevBtn.addEventListener("click", () => {
                    if (currentPage > 1) onPageClick(currentPage - 1);
                });
                container.appendChild(prevBtn);

                // Numbers
                for (let i = 1; i <= totalPages; i++) {
                    const pageBtn = document.createElement("button");
                    pageBtn.type = "button";
                    pageBtn.className = `btn btn-sm px-3 ${currentPage === i ? 'btn-primary' : 'btn-outline-secondary'}`;
                    if (currentPage === i) {
                        pageBtn.style.backgroundColor = "#f97316";
                        pageBtn.style.borderColor = "#f97316";
                        pageBtn.style.color = "#ffffff";
                    }
                    pageBtn.textContent = i;
                    pageBtn.addEventListener("click", () => onPageClick(i));
                    container.appendChild(pageBtn);
                }

                // Next button
                const nextBtn = document.createElement("button");
                nextBtn.type = "button";
                nextBtn.className = `btn btn-sm btn-outline-secondary px-2 ${currentPage === totalPages ? 'disabled' : ''}`;
                nextBtn.innerHTML = '<i class="bi bi-chevron-right"></i>';
                nextBtn.addEventListener("click", () => {
                    if (currentPage < totalPages) onPageClick(currentPage + 1);
                });
                container.appendChild(nextBtn);
            }
        });
    </script>
}
