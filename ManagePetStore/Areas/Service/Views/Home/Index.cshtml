@using ManagePetStore.Models
@{
    Layout = "_ServiceLayout";
    ViewData["Title"] = "Tiếp nhận thú cưng";

    var activeBookings  = ViewBag.ActiveBookings  as List<HotelBooking> ?? new List<HotelBooking>();
    var pendingCheckIn  = ViewBag.PendingCheckIn  as List<HotelBooking> ?? new List<HotelBooking>();
    var assessedBookings = ViewBag.AssessedBookings as List<HotelBooking> ?? new List<HotelBooking>();
    int totalActive   = ViewBag.TotalActive   ?? 0;
    int pendingCount  = ViewBag.PendingCount  ?? 0;
    int assessedCount = ViewBag.AssessedCount ?? 0;
    int todayCount    = ViewBag.CheckedInToday ?? 0;
}

<!-- Tiêu đề -->
<div class="admin-title-row">
    <div>
        <h1>Tiếp nhận thú cưng</h1>
        <p>Quản lý thú cưng đang lưu trú. Ghi nhận tình trạng khi nhận phòng ngay trên trang này.</p>
    </div>
    <div style="text-align:right;color:var(--admin-text-muted);font-size:0.85rem;">
        <div style="font-weight:700;font-size:1rem;color:var(--admin-text-dark);">@DateTime.Now.ToString("dd/MM/yyyy")</div>
        <div>@DateTime.Now.ToString("HH:mm") — Ca hiện tại</div>
    </div>
</div>

<!-- Thông báo -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius:12px;font-family:'Outfit';">
        <strong>Thành công!</strong> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius:12px;font-family:'Outfit';">
        <strong>Lỗi!</strong> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Thống kê -->
<div class="admin-stats-grid" style="grid-template-columns:repeat(3,1fr);max-width:680px;margin-bottom:28px;">
    <div class="admin-stat-card">
        <div class="admin-stat-icon admin-stat-icon-active">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
        </div>
        <div class="admin-stat-details"><h4>ĐANG LƯU TRÚ</h4><div>@totalActive</div></div>
    </div>
    <div class="admin-stat-card" style="border-color:@(pendingCount > 0 ? "#FCD34D" : "var(--admin-border)");">
        <div class="admin-stat-icon" style="background:#FEF3C7;color:#D97706;">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
            </svg>
        </div>
        <div class="admin-stat-details"><h4>CHỜ TIẾP NHẬN</h4><div>@pendingCount</div></div>
    </div>
    <div class="admin-stat-card">
        <div class="admin-stat-icon" style="background:#ECFDF5;color:#059669;">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
        </div>
        <div class="admin-stat-details"><h4>ĐÃ TIẾP NHẬN</h4><div>@assessedCount</div></div>
    </div>
</div>

<!-- ===================================================================== -->
<!-- BẢNG THÔNG BÁO: THÚ CƯNG CHỜ TIẾP NHẬN                               -->
<!-- ===================================================================== -->
@if (pendingCheckIn.Any())
{
    <div style="background:linear-gradient(135deg,#FFFBEB,#FEF3C7);border:1.5px solid #FCD34D;border-radius:16px;padding:20px 24px;margin-bottom:28px;">
        <div style="display:flex;align-items:center;gap:10px;font-weight:700;font-size:1rem;color:#92400E;margin-bottom:16px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
            </svg>
            @pendingCount thú cưng đang chờ được tiếp nhận
        </div>

        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:12px;">
            @foreach (var b in pendingCheckIn)
            {
                <div style="background:#ffffff;border-radius:12px;padding:16px;border:1px solid #FDE68A;box-shadow:0 2px 8px rgba(245,158,11,0.08);">
                    <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px;">
                        <div style="width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,#0D9488,#0F766E);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1.1rem;flex-shrink:0;">
                            @(b.Pet?.Name?.Substring(0,1).ToUpper() ?? "?")
                        </div>
                        <div>
                            <div style="font-weight:700;color:#1E3A3A;">@b.Pet?.Name</div>
                            <div style="font-size:0.75rem;color:#6B8FA0;">@b.Pet?.Species @(string.IsNullOrEmpty(b.Pet?.Breed) ? "" : $"· {b.Pet.Breed}")</div>
                        </div>
                    </div>
                    <div style="font-size:0.8rem;color:#6B8FA0;line-height:1.8;">
                        <div>🏠 <strong>@b.CageId</strong> · @b.Cage?.RoomType?.Type</div>
                        <div>👤 @b.Customer?.FullName</div>
                        <div>⏰ Nhận: @b.CheckInDate.ToString("dd/MM HH:mm")</div>
                    </div>
                    <button class="btn-open-checkin"
                            style="margin-top:12px;width:100%;background:linear-gradient(135deg,#0D9488,#0F766E);color:#fff;border:none;border-radius:10px;padding:9px;font-weight:600;font-size:0.85rem;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;transition:all 0.2s;"
                            onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'"
                            data-booking-id="@b.HotelBookingId"
                            data-pet-name="@b.Pet?.Name"
                            data-pet-weight="@b.Pet?.Weight"
                            data-pet-species="@b.Pet?.Species"
                            data-pet-breed="@b.Pet?.Breed"
                            data-pet-age="@b.Pet?.Age"
                            data-pet-pathology="@b.Pet?.Pathology"
                            data-customer-name="@b.Customer?.FullName"
                            data-customer-phone="@b.Customer?.Phone"
                            data-cage-id="@b.CageId"
                            data-room-type="@b.Cage?.RoomType?.Type">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                        </svg>
                        Tiếp nhận ngay
                    </button>
                </div>
            }
        </div>
    </div>
}

<!-- ===================================================================== -->
<!-- BẢNG TẤT CẢ BOOKING ĐANG HOẠT ĐỘNG                                   -->
<!-- ===================================================================== -->
<div style="font-size:1rem;font-weight:700;color:var(--admin-text-dark);margin-bottom:14px;display:flex;align-items:center;gap:8px;">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
    </svg>
    Tất cả thú cưng đang lưu trú (@totalActive)
</div>

<div class="admin-table-container">
    <table class="admin-table">
        <thead>
            <tr>
                <th>Thú cưng</th>
                <th>Chủ nuôi</th>
                <th>Chuồng / Phòng</th>
                <th>Check-in</th>
                <th>Check-out</th>
                <th>Tình trạng</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (!activeBookings.Any())
            {
                <tr>
                    <td colspan="7" class="text-center py-5" style="color:var(--admin-text-muted);">
                        Chưa có thú cưng nào đang lưu trú.
                    </td>
                </tr>
            }
            @foreach (var b in activeBookings)
            {
                bool isPending = b.Pet != null && !b.Pet.PetBioTimelines.Any(t => t.Type == "CheckIn");
                var checkInTimeline = b.Pet?.PetBioTimelines.FirstOrDefault(t => t.Type == "CheckIn");
                <tr style="@(isPending ? "background:#FFFBEB;" : "")">
                    <td>
                        <div style="display:flex;align-items:center;gap:12px;">
                            <div class="admin-avatar" style="width:38px;height:38px;background:var(--admin-bg-light);color:var(--admin-primary);font-size:0.95rem;">
                                @(b.Pet?.Name?.Substring(0,1).ToUpper() ?? "?")
                            </div>
                            <div>
                                <div style="font-weight:600;">@b.Pet?.Name</div>
                                <div style="font-size:0.74rem;color:var(--admin-text-muted);">
                                    @b.Pet?.Species @(string.IsNullOrEmpty(b.Pet?.Breed) ? "" : $"· {b.Pet.Breed}")
                                </div>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div style="font-weight:500;">@b.Customer?.FullName</div>
                        <div style="font-size:0.78rem;color:var(--admin-text-muted);">@b.Customer?.Phone</div>
                    </td>
                    <td>
                        <div style="font-weight:600;">🏠 @b.CageId</div>
                        <div style="font-size:0.74rem;color:var(--admin-text-muted);">@b.Cage?.RoomType?.Type</div>
                    </td>
                    <td style="font-size:0.83rem;">
                        <div style="color:var(--admin-text-muted);">@b.CheckInDate.ToString("dd/MM/yyyy")</div>
                        <div style="font-weight:600;">@b.CheckInDate.ToString("HH:mm")</div>
                    </td>
                    <td style="font-size:0.83rem;color:var(--admin-text-muted);">
                        @if (b.CheckOutDate.HasValue)
                        {
                            <div>@b.CheckOutDate.Value.ToString("dd/MM/yyyy")</div>
                            <div style="font-weight:600;color:var(--admin-text-dark);">@b.CheckOutDate.Value.ToString("HH:mm")</div>
                        }
                        else { <span style="font-style:italic;">Chưa xác định</span> }
                    </td>
                    <td>
                        @if (isPending)
                        {
                            <span style="background:#FEF3C7;color:#D97706;font-size:0.75rem;font-weight:600;padding:4px 10px;border-radius:8px;display:inline-block;">
                                ⏳ Chờ tiếp nhận
                            </span>
                        }
                        else
                        {
                            <span style="background:#ECFDF5;color:#059669;font-size:0.75rem;font-weight:600;padding:4px 10px;border-radius:8px;display:inline-block;">
                                ✅ Đã tiếp nhận
                            </span>
                        }
                    </td>
                    <td>
                        @if (isPending)
                        {
                            <button class="service-action-btn btn-open-checkin"
                                    data-booking-id="@b.HotelBookingId"
                                    data-pet-name="@b.Pet?.Name"
                                    data-pet-weight="@b.Pet?.Weight"
                                    data-pet-species="@b.Pet?.Species"
                                    data-pet-breed="@b.Pet?.Breed"
                                    data-pet-age="@b.Pet?.Age"
                                    data-pet-pathology="@b.Pet?.Pathology"
                                    data-customer-name="@b.Customer?.FullName"
                                    data-customer-phone="@b.Customer?.Phone"
                                    data-cage-id="@b.CageId"
                                    data-room-type="@b.Cage?.RoomType?.Type">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                                </svg>
                                Tiếp nhận
                            </button>
                        }
                        else if (checkInTimeline != null)
                        {
                            <div style="display:flex;gap:6px;">
                                <button class="btn-open-edit"
                                        style="background:#EFF6FF;color:#2563EB;border:1px solid #BFDBFE;border-radius:8px;padding:6px 10px;font-size:0.78rem;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:4px;transition:all 0.2s;"
                                        onmouseover="this.style.background='#DBEAFE'" onmouseout="this.style.background='#EFF6FF'"
                                        data-timeline-id="@checkInTimeline.TimelineId"
                                        data-pet-name="@b.Pet?.Name"
                                        data-pet-species="@b.Pet?.Species"
                                        data-pet-breed="@b.Pet?.Breed"
                                        data-pet-age="@b.Pet?.Age"
                                        data-pet-weight="@b.Pet?.Weight"
                                        data-pet-pathology="@b.Pet?.Pathology"
                                        data-description="@checkInTimeline.Description">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                    </svg>
                                    Sửa
                                </button>
                                <button class="btn-open-delete"
                                        style="background:#FFF1F2;color:#E11D48;border:1px solid #FECDD3;border-radius:8px;padding:6px 10px;font-size:0.78rem;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:4px;transition:all 0.2s;"
                                        onmouseover="this.style.background='#FFE4E6'" onmouseout="this.style.background='#FFF1F2'"
                                        data-timeline-id="@checkInTimeline.TimelineId"
                                        data-pet-name="@b.Pet?.Name">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                    </svg>
                                    Xóa
                                </button>
                            </div>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- ===================================================================== -->
<!-- MODAL: FORM TIẾP NHẬN                                                 -->
<!-- ===================================================================== -->
<div class="modal fade" id="checkInModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content" style="border:none;border-radius:20px;overflow:hidden;box-shadow:0 24px 64px rgba(0,0,0,0.18);">

            <!-- Header gradient teal -->
            <div id="modalPetHeader" style="background:linear-gradient(135deg,#0D9488 0%,#0F766E 100%);color:#fff;padding:24px 28px;">
                <div style="display:flex;align-items:center;gap:14px;">
                    <div id="modalPetAvatar" style="width:52px;height:52px;border-radius:50%;background:rgba(255,255,255,0.2);border:2px solid rgba(255,255,255,0.4);display:flex;align-items:center;justify-content:center;font-size:1.5rem;font-weight:700;flex-shrink:0;">?</div>
                    <div style="flex:1;">
                        <div id="modalPetName" style="font-size:1.35rem;font-weight:700;">—</div>
                        <div id="modalPetMeta" style="font-size:0.88rem;opacity:0.85;margin-top:2px;">—</div>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div id="modalBookingInfo" style="display:flex;gap:24px;margin-top:14px;padding-top:12px;border-top:1px solid rgba(255,255,255,0.2);font-size:0.83rem;flex-wrap:wrap;"></div>
                <div id="modalPathologyWarn" style="display:none;margin-top:10px;background:rgba(255,255,255,0.15);border-radius:8px;padding:8px 12px;font-size:0.83rem;">
                    ⚠️ <strong>Bệnh lý tiền sử:</strong> <span id="modalPathologyText"></span>
                </div>
            </div>

            <!-- Form -->
            <form method="post" asp-area="Service" asp-controller="Home" asp-action="CheckIn">
                @Html.AntiForgeryToken()
                <input type="hidden" name="hotelBookingId" id="modalBookingId" />

                <div class="modal-body" style="padding:0;">

                    <!-- ======================================================= -->
                    <!-- BƯỚC 1: THÔNG TIN THÚ CƯNG                              -->
                    <!-- ======================================================= -->
                    <div style="padding:24px 28px 20px;background:#F8FFFE;border-bottom:1.5px solid #D1FAF5;">
                        <div style="display:flex;align-items:center;gap:8px;font-weight:700;font-size:0.95rem;color:#0D9488;margin-bottom:18px;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
                            </svg>
                            Bước 1 &mdash; Thông tin thú cưng
                            <span style="font-size:0.72rem;background:#D1FAF5;color:#0F766E;padding:2px 8px;border-radius:20px;font-weight:500;margin-left:4px;">Xác nhận / cập nhật</span>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-4">
                                <div class="admin-form-group" style="margin:0;">
                                    <label>Cân nặng (kg) <span style="color:#EC5959;">*</span></label>
                                    <input type="number" id="modalWeight" name="weight" class="admin-form-input"
                                           min="0.1" max="200" step="0.01" required />
                                    <div id="modalWeightHint" style="font-size:0.75rem;color:var(--admin-text-muted);margin-top:4px;"></div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="admin-form-group" style="margin:0;">
                                    <label>Giống</label>
                                    <input type="text" id="modalBreed" name="breed" class="admin-form-input"
                                           placeholder="VD: Poodle, Corgi..." />
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="admin-form-group" style="margin:0;">
                                    <label>Tuổi</label>
                                    <input type="text" id="modalAge" name="age" class="admin-form-input"
                                           placeholder="VD: 2 tuổi..." />
                                </div>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-12">
                                <div class="admin-form-group" style="margin:0;">
                                    <label>Dặn dò / Yêu cầu đặc biệt từ chủ nuôi</label>
                                    <textarea id="ownerNotes" name="ownerNotes" class="admin-form-input" rows="2"
                                              placeholder="VD: Bé hay cắn khi sợ, không ăn thịt bò, cần nhiều sự chú ý..."
                                              style="resize:vertical;"></textarea>
                                </div>
                            </div>
                        </div>

                        <div class="row g-3 mt-0">
                            <div class="col-6">
                                <div class="admin-form-group" style="margin:0;">
                                    <label>Hướng dẫn cho ăn</label>
                                    <textarea id="feedingInstructions" name="feedingInstructions" class="admin-form-input" rows="2"
                                              placeholder="VD: 80g hạt Royal Canin, 2 bữa/ngày..."
                                              style="resize:vertical;"></textarea>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="admin-form-group" style="margin:0;">
                                    <label>Thuốc cần uống (nếu có)</label>
                                    <textarea id="medications" name="medications" class="admin-form-input" rows="2"
                                              placeholder="VD: Amoxicillin 125mg, sáng + tối sau khi ăn..."
                                              style="resize:vertical;"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ======================================================= -->
                    <!-- BƯỚC 2: TÌNH TRẠNG SỨC KHỎE                             -->
                    <!-- ======================================================= -->
                    <div style="padding:24px 28px 16px;">
                        <div style="display:flex;align-items:center;gap:8px;font-weight:700;font-size:0.95rem;color:var(--admin-text-dark);margin-bottom:18px;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:var(--admin-primary);">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                            </svg>
                            Bước 2 &mdash; Tình trạng sức khỏe
