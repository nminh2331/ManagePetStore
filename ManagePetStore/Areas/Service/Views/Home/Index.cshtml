                                            <option value="@cage.CageId" data-price="@cage.RoomType?.DailyPrice" data-type="@cage.RoomType?.Type">
                                                🏠 @cage.CageId — @cage.RoomType?.Type (@cage.RoomType?.DailyPrice.ToString("N0") đ/ngày)
