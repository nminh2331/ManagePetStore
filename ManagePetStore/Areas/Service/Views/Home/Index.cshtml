                        </div>
                        <div class="row g-3">
                            <div class="col-6"><div class="admin-form-group" style="margin:0;"><label>Hành vi / Tâm lý</label><textarea id="editBehaviorNote" name="behaviorNote" class="admin-form-input" rows="3" style="resize:vertical;"></textarea></div></div>
                            <div class="col-6"><div class="admin-form-group" style="margin:0;"><label>Ghi chú thêm</label><textarea id="editGeneralNote" name="generalNote" class="admin-form-input" rows="3" style="resize:vertical;"></textarea></div></div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer" style="border-top:1px solid var(--admin-border);padding:14px 28px;gap:10px;">
                    <button type="button" class="admin-btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" style="background:linear-gradient(135deg,#2563EB,#1D4ED8);color:#fff;border:none;border-radius:10px;padding:10px 22px;font-weight:600;font-size:0.9rem;cursor:pointer;display:flex;align-items:center;gap:6px;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                        Lưu thay đổi
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ===================================================================== -->
<!-- MODAL: XÁC NHẬN XÓA TÌNH TRẠNG                                        -->
<!-- ===================================================================== -->
<div class="modal fade" id="deleteCheckInModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:400px;">
        <div class="modal-content" style="border:none;border-radius:20px;overflow:hidden;">
            <div style="background:linear-gradient(135deg,#E11D48,#BE123C);color:#fff;padding:18px 22px;display:flex;align-items:center;gap:10px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                <div style="font-size:1rem;font-weight:700;">Xóa tình trạng tiếp nhận</div>
                <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="modal"></button>
            </div>
            <div style="padding:20px 22px 8px;text-align:center;">
                <p style="font-size:0.92rem;color:#374151;">Xóa thông tin tình trạng của <strong id="deleteTTPetName" style="color:#E11D48;"></strong>?<br/><span style="font-size:0.82rem;color:#6B7280;">Thú cưng sẽ về trạng thái Chờ tiếp nhận.</span></p>
            </div>
            <form method="post" asp-area="Service" asp-controller="Home" asp-action="DeleteCheckIn">
                @Html.AntiForgeryToken()
                <input type="hidden" name="timelineId" id="deleteTTTimelineId" />
                <div class="modal-footer" style="border-top:1px solid #F3F4F6;padding:12px 22px;gap:8px;justify-content:center;">
                    <button type="button" class="admin-btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" style="background:linear-gradient(135deg,#E11D48,#BE123C);color:#fff;border:none;border-radius:10px;padding:9px 20px;font-weight:600;font-size:0.88rem;cursor:pointer;">Xác nhận xóa</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ===================================================================== -->
<!-- MODAL: XÁC NHẬN XÓA BOOKING                                           -->
<!-- ===================================================================== -->
<div class="modal fade" id="deleteBookingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:420px;">
        <div class="modal-content" style="border:none;border-radius:20px;overflow:hidden;">
            <div style="background:linear-gradient(135deg,#EA580C,#C2410C);color:#fff;padding:18px 22px;display:flex;align-items:center;gap:10px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                <div style="font-size:1rem;font-weight:700;">Xóa yêu cầu tiếp nhận</div>
                <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="modal"></button>
            </div>
            <div style="padding:20px 22px 8px;text-align:center;">
                <p style="font-size:0.92rem;color:#374151;">Xóa toàn bộ yêu cầu tiếp nhận của <strong id="deleteBookingPetName" style="color:#EA580C;"></strong>?<br/><span style="font-size:0.82rem;color:#6B7280;">Chuồng sẽ được trả về trạng thái trống.</span></p>
            </div>
            <form method="post" asp-area="Service" asp-controller="Home" asp-action="DeleteBooking">
                @Html.AntiForgeryToken()
                <input type="hidden" name="hotelBookingId" id="deleteBookingId" />
                <div class="modal-footer" style="border-top:1px solid #F3F4F6;padding:12px 22px;gap:8px;justify-content:center;">
                    <button type="button" class="admin-btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" style="background:linear-gradient(135deg,#EA580C,#C2410C);color:#fff;border:none;border-radius:10px;padding:9px 20px;font-weight:600;font-size:0.88rem;cursor:pointer;">Xác nhận xóa</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
// ============================================================
// MODAL TẠO BOOKING
// ============================================================
document.getElementById('btn-create-booking').addEventListener('click', function () {
    // Reset form
    document.getElementById('cb-customer').value = '';
    document.getElementById('cb-pet').innerHTML = '<option value="" disabled selected>-- Chọn khách hàng trước --</option>';
    document.getElementById('cb-pet').disabled = true;
    document.getElementById('pet-info-preview').style.display = 'none';
    document.getElementById('cb-cage').value = '';
    document.getElementById('stay-summary').style.display = 'none';
    new bootstrap.Modal(document.getElementById('createBookingModal')).show();
});

function loadPetsForCustomer(customerId) {
    if (!customerId) return;
    var sel = document.getElementById('cb-pet');
    sel.innerHTML = '<option value="" disabled selected>Đang tải...</option>';
    sel.disabled = true;

    fetch('/Service/Home/GetPetsByCustomer?customerId=' + customerId)
        .then(r => r.json())
        .then(pets => {
            sel.innerHTML = '<option value="" disabled selected>-- Chọn thú cưng --</option>';
            if (pets.length === 0) {
                sel.innerHTML = '<option value="" disabled selected>-- Khách hàng chưa có thú cưng --</option>';
            } else {
                pets.forEach(function (p) {
                    var opt = document.createElement('option');
                    opt.value = p.petId;
                    opt.textContent = p.name + ' (' + p.species + (p.breed ? ' · ' + p.breed : '') + ')';
                    opt.dataset.species  = p.species  || '';
                    opt.dataset.breed    = p.breed    || '';
                    opt.dataset.age      = p.age      || '';
                    opt.dataset.weight   = p.weight   || '';
                    opt.dataset.pathology = p.pathology || '';
                    sel.appendChild(opt);
                });
                sel.disabled = false;
            }
        })
        .catch(() => {
            sel.innerHTML = '<option value="" disabled selected>-- Lỗi tải dữ liệu --</option>';
        });
    document.getElementById('pet-info-preview').style.display = 'none';
}

document.getElementById('cb-pet').addEventListener('change', function () {
    var opt = this.options[this.selectedIndex];
    if (!opt || !opt.value) return;
    document.getElementById('pi-species').textContent  = opt.dataset.species;
    document.getElementById('pi-breed').textContent    = opt.dataset.breed || '—';
    document.getElementById('pi-age').textContent      = opt.dataset.age   || '—';
    document.getElementById('pi-weight').textContent   = opt.dataset.weight || '—';
    var path = opt.dataset.pathology;
    if (path) {
        document.getElementById('pi-pathology').textContent = path;
        document.getElementById('pi-pathology-row').style.display = 'block';
    } else {
        document.getElementById('pi-pathology-row').style.display = 'none';
    }
    document.getElementById('pet-info-preview').style.display = 'block';
});

function updateCagePrice(sel) {
    var opt = sel.options[sel.selectedIndex];
    if (opt && opt.value) {
        var price = parseFloat(opt.dataset.price) || 0;
        document.getElementById('cage-price-hint').textContent = 'Giá: ' + price.toLocaleString('vi-VN') + ' đ/ngày';
        calcStayDays();
    }
}

function calcStayDays() {
    var ci = document.getElementById('cb-checkin').value;
    var co = document.getElementById('cb-checkout').value;
    var cageSel = document.getElementById('cb-cage');
    var opt = cageSel.options[cageSel.selectedIndex];
    if (!ci || !co || !opt || !opt.value) { document.getElementById('stay-summary').style.display = 'none'; return; }
    var days = Math.max(1, Math.round((new Date(co) - new Date(ci)) / 86400000));
    var price = parseFloat(opt.dataset.price) || 0;
    var total = days * price;
    document.getElementById('stay-summary').textContent =
        '📅 ' + days + ' ngày lưu trú · Dự tính: ' + total.toLocaleString('vi-VN') + ' đ';
    document.getElementById('stay-summary').style.display = 'block';
}

// ============================================================
// MODAL GHI NHẬN TÌNH TRẠNG (CHECKIN)
// ============================================================
document.querySelectorAll('.btn-open-checkin').forEach(function (btn) {
    btn.addEventListener('click', function () {
        var d = this.dataset;
        document.getElementById('modalBookingId').value = d.bookingId;
        document.getElementById('modalPetAvatar').textContent = d.petName ? d.petName.charAt(0).toUpperCase() : '?';
        document.getElementById('modalPetName').textContent   = d.petName || '—';
        var meta = d.petSpecies || '';
        if (d.petBreed) meta += ' · ' + d.petBreed;
        document.getElementById('modalPetMeta').textContent = meta;

        var w = parseFloat(d.petWeight) || '';
        document.getElementById('modalWeight').value = w;
        document.getElementById('modalWeightHint').textContent = w ? 'Trước đây: ' + w + ' kg' : '';
        document.getElementById('modalBreed').value = d.petBreed || '';
        document.getElementById('modalAge').value   = d.petAge   || '';

        var pathDiv = document.getElementById('modalPathologyWarn');
        if (d.petPathology && d.petPathology.trim()) {
            document.getElementById('modalPathologyText').textContent = d.petPathology;
            pathDiv.style.display = 'block';
        } else { pathDiv.style.display = 'none'; }

        document.getElementById('modalBookingInfo').innerHTML =
            '<div style="opacity:0.75">Chuồng<div style="font-weight:700;opacity:1;">🏠 ' + (d.cageId || '—') + '</div></div>' +
            '<div style="opacity:0.75">Loại phòng<div style="font-weight:700;opacity:1;">' + (d.roomType || '—') + '</div></div>' +
            '<div style="opacity:0.75">Chủ nuôi<div style="font-weight:700;opacity:1;">' + (d.customerName || '—') + '</div></div>' +
            '<div style="opacity:0.75">SĐT<div style="font-weight:700;opacity:1;">' + (d.customerPhone || '—') + '</div></div>';

        document.getElementById('coatCondition').value = '';
        document.getElementById('hasInjury').checked  = false;
        toggleInjuryNote(false);
        ['behaviorNote','generalNote','ownerNotes','feedingInstructions','medications'].forEach(function(id){
            document.getElementById(id).value = '';
        });
        new bootstrap.Modal(document.getElementById('checkInModal')).show();
    });
});

function toggleInjuryNote(checked) {
    var g = document.getElementById('injuryNoteGroup');
    var ta = document.getElementById('injuryNote');
    g.style.display = checked ? 'block' : 'none';
    checked ? ta.setAttribute('required','required') : (ta.removeAttribute('required'), ta.value = '');
}

// ============================================================
// MODAL SỬA LỊCH BOOKING
// ============================================================
document.querySelectorAll('.btn-open-edit-booking').forEach(function (btn) {
    btn.addEventListener('click', function () {
        var d = this.dataset;
        document.getElementById('eb-booking-id').value = d.bookingId;
        document.getElementById('eb-pet-label').textContent = (d.petName || '') + ' — ' + (d.customerName || '');
        document.getElementById('eb-checkin').value  = d.checkIn  || '';
        document.getElementById('eb-checkout').value = d.checkOut || '';

        // Chọn đúng chuồng hiện tại
        var cageSel = document.getElementById('eb-cage');
        for (var i = 0; i < cageSel.options.length; i++) {
            if (cageSel.options[i].value === d.cageId) { cageSel.selectedIndex = i; break; }
        }

        new bootstrap.Modal(document.getElementById('editBookingModal')).show();
    });
});

// ============================================================
// MODAL SỬA TÌNH TRẠNG
// ============================================================
document.querySelectorAll('.btn-open-edit').forEach(function (btn) {
    btn.addEventListener('click', function () {
        var d = this.dataset;
        document.getElementById('editModalTimelineId').value = d.timelineId;
        document.getElementById('editModalPetAvatar').textContent = d.petName ? d.petName.charAt(0).toUpperCase() : '?';
        document.getElementById('editModalPetName').textContent   = d.petName || '—';
        document.getElementById('editModalWeight').value = parseFloat(d.petWeight) || '';
        document.getElementById('editModalBreed').value  = d.petBreed || '';
        document.getElementById('editModalAge').value    = d.petAge   || '';

        var desc = d.description || '';
        document.getElementById('editOwnerNotes').value          = extractSection(desc, 'Dặn dò từ chủ nuôi');
        document.getElementById('editFeedingInstructions').value = extractSection(desc, 'Hướng dẫn cho ăn');
        document.getElementById('editMedications').value         = extractSection(desc, 'Thuốc cần uống');
        document.getElementById('editBehaviorNote').value        = extractSection(desc, 'Tâm lý / Hành vi');
        document.getElementById('editGeneralNote').value         = extractSection(desc, 'Ghi chú khác');

        var coat = extractSection(desc, 'Tình trạng lông');
        var coatSel = document.getElementById('editCoatCondition');
        for (var i = 0; i < coatSel.options.length; i++) {
            if (coatSel.options[i].value === coat) { coatSel.selectedIndex = i; break; }
        }

        var injVal = extractSection(desc, 'Vết thương');
        var hasInj = injVal === 'CÓ';
        document.getElementById('editHasInjury').checked = hasInj;
        toggleEditInjuryNote(hasInj);
        if (hasInj) document.getElementById('editInjuryNote').value = extractSection(desc, 'Mô tả vết thương');

        new bootstrap.Modal(document.getElementById('editCheckInModal')).show();
    });
});

function toggleEditInjuryNote(checked) {
    var g = document.getElementById('editInjuryNoteGroup');
    var ta = document.getElementById('editInjuryNote');
    g.style.display = checked ? 'block' : 'none';
    checked ? ta.setAttribute('required','required') : (ta.removeAttribute('required'), ta.value = '');
}

function extractSection(desc, label) {
    var regex = new RegExp('\\[' + label.replace('/', '\\/') + '\\]\\s*(.+?)(?=\\[|$)', 's');
    var m = desc.match(regex);
    return m ? m[1].trim() : '';
}

// ============================================================
// MODAL XÓA TÌNH TRẠNG
// ============================================================
document.querySelectorAll('.btn-open-delete-tt').forEach(function (btn) {
    btn.addEventListener('click', function () {
        document.getElementById('deleteTTTimelineId').value = this.dataset.timelineId;
        document.getElementById('deleteTTPetName').textContent = this.dataset.petName || 'thú cưng';
        new bootstrap.Modal(document.getElementById('deleteCheckInModal')).show();
    });
});

// ============================================================
// MODAL XÓA BOOKING
// ============================================================
document.querySelectorAll('.btn-open-delete-booking').forEach(function (btn) {
    btn.addEventListener('click', function () {
        document.getElementById('deleteBookingId').value = this.dataset.bookingId;
        document.getElementById('deleteBookingPetName').textContent = this.dataset.petName || 'thú cưng';
        new bootstrap.Modal(document.getElementById('deleteBookingModal')).show();
    });
});
</script>
}
