@section Scripts {
    <script>
        // ======================================================
        // MODAL TIẾP NHẬN (MỚI)
        // ======================================================
        document.querySelectorAll('.btn-open-checkin').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var d = this.dataset;

                document.getElementById('modalBookingId').value = d.bookingId;
                document.getElementById('modalPetAvatar').textContent = d.petName ? d.petName.charAt(0).toUpperCase() : '?';
                document.getElementById('modalPetName').textContent = d.petName || '—';

                var meta = d.petSpecies || '';
                if (d.petBreed) meta += ' · ' + d.petBreed;
                document.getElementById('modalPetMeta').textContent = meta;

                // Pre-fill weight, breed, age
                var w = parseFloat(d.petWeight) || '';
                document.getElementById('modalWeight').value = w;
                document.getElementById('modalWeightHint').textContent = w ? 'Trước đây: ' + w + ' kg' : '';
                document.getElementById('modalBreed').value = d.petBreed || '';
                document.getElementById('modalAge').value = d.petAge || '';

                // Bệnh lý tiền sử
                var pathDiv = document.getElementById('modalPathologyWarn');
                if (d.petPathology && d.petPathology.trim() !== '') {
                    document.getElementById('modalPathologyText').textContent = d.petPathology;
                    pathDiv.style.display = 'block';
                } else {
                    pathDiv.style.display = 'none';
                }

                // Thông tin booking
                document.getElementById('modalBookingInfo').innerHTML =
                    '<div style="opacity:0.75">Chuồng<div style="font-weight:700;opacity:1;">🏠 ' + (d.cageId || '—') + '</div></div>' +
                    '<div style="opacity:0.75">Loại phòng<div style="font-weight:700;opacity:1;">' + (d.roomType || '—') + '</div></div>' +
                    '<div style="opacity:0.75">Chủ nuôi<div style="font-weight:700;opacity:1;">' + (d.customerName || '—') + '</div></div>' +
                    '<div style="opacity:0.75">SĐT<div style="font-weight:700;opacity:1;">' + (d.customerPhone || '—') + '</div></div>';

                // Reset tình trạng sức khỏe
                document.getElementById('coatCondition').value = '';
                document.getElementById('hasInjury').checked = false;
                toggleInjuryNote(false);
                document.getElementById('behaviorNote').value = '';
                document.getElementById('generalNote').value = '';
                document.getElementById('ownerNotes').value = '';
                document.getElementById('feedingInstructions').value = '';
                document.getElementById('medications').value = '';

                new bootstrap.Modal(document.getElementById('checkInModal')).show();
            });
        });

        function toggleInjuryNote(checked) {
            var g = document.getElementById('injuryNoteGroup');
            var ta = document.getElementById('injuryNote');
            g.style.display = checked ? 'block' : 'none';
            if (checked) { ta.setAttribute('required', 'required'); }
            else { ta.removeAttribute('required'); ta.value = ''; }
        }

        // ======================================================
        // MODAL SỬA
        // ======================================================
        document.querySelectorAll('.btn-open-edit').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var d = this.dataset;

                document.getElementById('editModalTimelineId').value = d.timelineId;
                document.getElementById('editModalPetAvatar').textContent = d.petName ? d.petName.charAt(0).toUpperCase() : '?';
                document.getElementById('editModalPetName').textContent = d.petName || '—';
                document.getElementById('editModalPetMeta').textContent = (d.petSpecies || '') + (d.petBreed ? ' · ' + d.petBreed : '');

                document.getElementById('editModalWeight').value = parseFloat(d.petWeight) || '';
                document.getElementById('editModalBreed').value = d.petBreed || '';
                document.getElementById('editModalAge').value = d.petAge || '';

                // Parse description để điền lại các trường
                var desc = d.description || '';
                document.getElementById('editOwnerNotes').value = extractSection(desc, 'Dặn dò từ chủ nuôi');
                document.getElementById('editFeedingInstructions').value = extractSection(desc, 'Hướng dẫn cho ăn');
                document.getElementById('editMedications').value = extractSection(desc, 'Thuốc cần uống');
                document.getElementById('editBehaviorNote').value = extractSection(desc, 'Tâm lý / Hành vi');
                document.getElementById('editGeneralNote').value = extractSection(desc, 'Ghi chú khác');

                // Tình trạng lông
                var coat = extractSection(desc, 'Tình trạng lông');
                var coatSel = document.getElementById('editCoatCondition');
                for (var i = 0; i < coatSel.options.length; i++) {
                    if (coatSel.options[i].value === coat) {
                        coatSel.selectedIndex = i;
                        break;
                    }
                }

                // Vết thương
                var injuryVal = extractSection(desc, 'Vết thương');
                var hasInj = injuryVal === 'CÓ';
                document.getElementById('editHasInjury').checked = hasInj;
                toggleEditInjuryNote(hasInj);
                if (hasInj) {
                    document.getElementById('editInjuryNote').value = extractSection(desc, 'Mô tả vết thương');
                }

                new bootstrap.Modal(document.getElementById('editCheckInModal')).show();
            });
        });

        function toggleEditInjuryNote(checked) {
            var g = document.getElementById('editInjuryNoteGroup');
            var ta = document.getElementById('editInjuryNote');
            g.style.display = checked ? 'block' : 'none';
            if (checked) { ta.setAttribute('required', 'required'); }
            else { ta.removeAttribute('required'); ta.value = ''; }
        }

        // Helper: tách giá trị từ description dạng "[Label] value"
        function extractSection(desc, label) {
            var regex = new RegExp('\\[' + label.replace('/', '\\/') + '\\]\\s*(.+?)(?=\\[|$)', 's');
            var m = desc.match(regex);
            return m ? m[1].trim() : '';
        }

        // ======================================================
        // MODAL XÓA
        // ======================================================
        document.querySelectorAll('.btn-open-delete').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var d = this.dataset;
                document.getElementById('deleteTimelineId').value = d.timelineId;
                document.getElementById('deletePetName').textContent = d.petName || 'thú cưng';
                new bootstrap.Modal(document.getElementById('deleteCheckInModal')).show();
            });
        });
    </script>
}
