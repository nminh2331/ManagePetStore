@{
    ViewData["Title"] = "Trang Nhân Viên Dịch Vụ";
}

<div class="container py-5" style="font-family: 'Outfit', sans-serif;">
    <div class="card border-0 shadow-sm p-5" style="border-radius: 20px; background: linear-gradient(135deg, #cc2b5e 0%, #753a88 100%); color: #ffffff;">
        <div class="row align-items-center">
            <div class="col-md-8">
                <span class="badge bg-warning text-dark mb-3 px-3 py-2" style="font-size: 0.8rem; font-weight: 600; border-radius: 20px;">PHÂN HỆ DỊCH VỤ SPA & KHÁCH SẠN</span>
                <h1 class="display-4 font-weight-bold" style="font-weight: 700;">Xin chào, @User.FindFirst("FullName")?.Value!</h1>
                <p class="lead" style="opacity: 0.9;">Bạn đang đăng nhập dưới quyền <strong>Service Staff (Nhân viên dịch vụ)</strong>. Tại đây bạn có thể quản lý lịch đặt chỗ spa, theo dõi nhật ký ăn uống cho thú cưng và cập nhật trạng thái sức khỏe của pet.</p>
                <hr class="my-4" style="background-color: rgba(255,255,255,0.2);">
                <div class="d-flex gap-3 flex-wrap">
                    <a href="/Customer/Account/Profile" class="btn btn-warning px-4 py-2 text-dark font-weight-bold" style="border-radius: 10px; font-weight: 600;">
                        Xem Thông Tin Cá Nhân
                    </a>
                    <form asp-area="Customer" asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-outline-light px-4 py-2" style="border-radius: 10px; font-weight: 600;">
                            Đăng xuất
                        </button>
                    </form>
                </div>
            </div>
            <div class="col-md-4 text-center d-none d-md-block">
                <svg xmlns="http://www.w3.org/2000/svg" width="180" height="180" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="opacity: 0.2;">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                </svg>
            </div>
        </div>
    </div>
</div>
