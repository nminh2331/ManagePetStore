@using ManagePetStore.Models
@model HotelBooking
@{
    Layout = "_ServiceLayout";
    ViewData["Title"] = $"Khám Sức khoẻ — {Model.Pet?.Name}";

    var pet = Model.Pet;
    var customer = Model.Customer;
    var cage = Model.Cage;
    var roomType = cage?.RoomType;

    // Lần khám gần nhất
    var lastCheckIn = pet?.PetBioTimelines?
        .Where(t => t.Type == "CheckIn")
        .OrderByDescending(t => t.Date)
        .FirstOrDefault();
}

<!-- Nút quay lại -->
<div style="margin-bottom: 20px;">
    <a asp-area="Service" asp-controller="Home" asp-action="Index"
       style="display: inline-flex; align-items: center; gap: 6px; color: var(--admin-text-muted); text-decoration: none; font-size: 0.9rem; font-weight: 500; transition: color 0.2s;"
       onmouseover="this.style.color='var(--admin-primary)'"
       onmouseout="this.style.color='var(--admin-text-muted)'">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Quay lại danh sách
    </a>
</div>

<!-- Thẻ thông tin Thú cưng & Booking (gradient teal) -->
<div class="checkin-pet-card">
    <div class="d-flex align-items-center gap-4">
        <div class="checkin-pet-avatar">
            @(pet?.Name?.Substring(0, 1).ToUpper() ?? "?")
        </div>
        <div style="flex: 1;">
            <h2>@pet?.Name</h2>
            <p class="pet-meta">
                @pet?.Species @(string.IsNullOrEmpty(pet?.Breed) ? "" : $"· {pet.Breed}")
                &nbsp;·&nbsp; Cân nặng hiện tại: <strong>@pet?.Weight kg</strong>
            </p>
            @if (!string.IsNullOrEmpty(pet?.Pathology))
            {
                <div style="margin-top: 8px; background: rgba(255,255,255,0.15); border-radius: 8px; padding: 6px 12px; font-size: 0.85rem;">
                    ⚠️ <strong>Bệnh lý tiền sử:</strong> @pet.Pathology
                </div>
            }
        </div>
        <div style="text-align: right; opacity: 0.9;">
            <div style="font-size: 0.78rem; opacity: 0.75;">Booking #@Model.HotelBookingId.ToString("D4")</div>
            <div style="font-weight: 700; font-size: 1.1rem;">🏠 @Model.CageId</div>
            <div style="font-size: 0.82rem; opacity: 0.85;">@roomType?.Type</div>
            <div style="font-size: 0.78rem; margin-top: 4px; opacity: 0.75;">
                Check-in: @Model.CheckInDate.ToString("dd/MM/yyyy HH:mm")
            </div>
        </div>
    </div>

    <!-- Thông tin chủ nuôi -->
    <div style="margin-top: 16px; padding-top: 14px; border-top: 1px solid rgba(255,255,255,0.2); display: flex; gap: 32px; font-size: 0.88rem;">
        <div>
            <span style="opacity: 0.75;">Chủ nuôi</span>
            <div style="font-weight: 600;">@customer?.FullName</div>
        </div>
        <div>
            <span style="opacity: 0.75;">Số điện thoại</span>
            <div style="font-weight: 600;">@customer?.Phone</div>
        </div>
        @if (lastCheckIn != null)
        {
            <div>
                <span style="opacity: 0.75;">Lần khám gần nhất</span>
                <div style="font-weight: 600;">@lastCheckIn.Date.ToString("dd/MM/yyyy")</div>
            </div>
        }
    </div>
</div>

<!-- Form khám sức khoẻ -->
<form asp-area="Service" asp-controller="Home" asp-action="CheckIn" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="hotelBookingId" value="@Model.HotelBookingId" />

    <div class="row">
        <div class="col-lg-7">

            <!-- MỤC 1: Thể chất -->
            <div class="checkin-section-card">
                <div class="checkin-section-title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                    </svg>
                    Đánh giá Thể chất
                </div>

                <!-- Cân nặng -->
                <div class="admin-form-group">
                    <label>Cân nặng ghi nhận (kg) <span style="color: #EC5959;">*</span></label>
                    <div style="display: flex; align-items: center; gap: 10px;">
                        <input type="number" id="weight" name="weight" class="admin-form-input"
                               value="@pet?.Weight" min="0.1" max="200" step="0.01"
                               style="max-width: 160px;" required />
                        <span style="font-size: 0.85rem; color: var(--admin-text-muted);">
                            Trước đây: <strong>@pet?.Weight kg</strong>
                        </span>
                    </div>
                    <div style="font-size: 0.78rem; color: var(--admin-text-muted); margin-top: 4px;">
                        Giá trị này sẽ cập nhật lên hồ sơ thú cưng.
                    </div>
                </div>

                <!-- Tình trạng lông -->
                <div class="admin-form-group">
                    <label>Tình trạng lông / da <span style="color: #EC5959;">*</span></label>
                    <select name="coatCondition" id="coatCondition" class="admin-form-select" required>
                        <option value="" disabled selected>-- Chọn tình trạng --</option>
                        <option value="Tốt, sạch sẽ">Tốt, sạch sẽ</option>
                        <option value="Bình thường, chưa tắm">Bình thường, chưa tắm</option>
                        <option value="Rối / bết">Rối / bết</option>
                        <option value="Bẩn, cần tắm ngay">Bẩn, cần tắm ngay</option>
                        <option value="Rụng nhiều bất thường">Rụng nhiều bất thường</option>
                        <option value="Có dấu hiệu da liễu">Có dấu hiệu da liễu (mẩn, ghẻ...)</option>
                    </select>
                </div>

                <!-- Vết thương -->
                <div class="admin-form-group">
                    <label>Vết thương / Tổn thương bên ngoài</label>
                    <label class="toggle-checkbox-row" for="hasInjury">
                        <input type="hidden" name="hasInjury" value="false" />
                        <input type="checkbox" id="hasInjury" name="hasInjury" value="true"
                               onchange="toggleInjuryNote(this.checked)" />
                        <span style="font-weight: 600;">Có phát hiện vết thương hoặc tổn thương</span>
                    </label>
                </div>

                <!-- Mô tả vết thương (ẩn theo mặc định) -->
                <div class="admin-form-group" id="injuryNoteGroup" style="display: none;">
                    <label>Mô tả chi tiết vết thương <span style="color: #EC5959;">*</span></label>
                    <textarea name="injuryNote" id="injuryNote" class="admin-form-input"
                              rows="3" placeholder="Vị trí, kích thước, mức độ tổn thương..."
                              style="resize: vertical;"></textarea>
                    <div style="font-size: 0.78rem; color: #EC5959; margin-top: 4px;">
                        ⚠️ Bắt buộc mô tả khi có vết thương để làm bằng chứng tránh tranh chấp.
                    </div>
                </div>
            </div>

            <!-- MỤC 2: Tâm lý & Hành vi -->
            <div class="checkin-section-card">
                <div class="checkin-section-title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                    </svg>
                    Biểu hiện Tâm lý / Hành vi
                </div>

                <div class="admin-form-group">
                    <label>Trạng thái tâm lý khi tiếp nhận</label>
                    <textarea name="behaviorNote" id="behaviorNote" class="admin-form-input"
                              rows="4" placeholder="VD: Bình thường, vui vẻ · Lo lắng, bồn chồn · Hung hăng, cắn cào · Thụ động, buồn ngủ · Không hợp tác..."
                              style="resize: vertical;"></textarea>
                </div>
            </div>

        </div>

        <div class="col-lg-5">

            <!-- MỤC 3: Ghi chú tổng quát -->
            <div class="checkin-section-card">
                <div class="checkin-section-title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                    Ghi chú Thêm
                </div>

                <div class="admin-form-group">
                    <label>Ghi chú tổng quát (tuỳ chọn)</label>
                    <textarea name="generalNote" class="admin-form-input"
                              rows="5" placeholder="Các lưu ý đặc biệt từ chủ nuôi, yêu cầu chế độ ăn, thuốc cần uống, dị ứng..."
                              style="resize: vertical;"></textarea>
                </div>
            </div>

            <!-- Tóm tắt & Xác nhận -->
            <div class="checkin-section-card" style="border: 2px solid var(--admin-primary);">
                <div class="checkin-section-title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Xác nhận & Lưu hồ sơ
                </div>

                <div style="background: var(--admin-bg-light); border-radius: 12px; padding: 16px; margin-bottom: 20px; font-size: 0.85rem; line-height: 1.8;">
                    <div>📋 Hệ thống sẽ tự động:</div>
                    <ul style="margin: 8px 0 0 16px; padding: 0;">
                        <li>Tạo bản ghi <strong>lịch sử sức khoẻ</strong> cho thú cưng</li>
                        <li>Cập nhật <strong>cân nặng mới</strong> vào hồ sơ</li>
                        <li>Gắn thông tin vào <strong>booking #@Model.HotelBookingId.ToString("D4")</strong></li>
                    </ul>
                </div>

                <div style="display: flex; gap: 12px; flex-direction: column;">
                    <button type="submit" class="admin-btn-primary" style="width: 100%; justify-content: center; box-shadow: none; padding: 14px;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        Lưu hồ sơ sức khoẻ
                    </button>
                    <a asp-area="Service" asp-controller="Home" asp-action="Index"
                       class="admin-btn-secondary" style="width: 100%; text-align: center; display: block; text-decoration: none;">
                        Huỷ, quay lại
                    </a>
                </div>
            </div>

        </div>
    </div>
</form>

@section Scripts {
    <script>
        function toggleInjuryNote(checked) {
            var group = document.getElementById('injuryNoteGroup');
            var textarea = document.getElementById('injuryNote');
            if (checked) {
                group.style.display = 'block';
                textarea.setAttribute('required', 'required');
            } else {
                group.style.display = 'none';
                textarea.removeAttribute('required');
                textarea.value = '';
            }
        }
    </script>
}
