@using ManagePetStore.Models
@{
    Layout = "_ServiceLayout";
    ViewData["Title"] = "Quản lý Loại Chuồng / Phòng";

    var roomTypes = ViewBag.RoomTypes as List<RoomType> ?? new List<RoomType>();
    string search = ViewBag.Search as string ?? "";
    string statusFilter = ViewBag.StatusFilter as string ?? "All";
    int totalCount = ViewBag.TotalCount ?? 0;
    int activeCount = ViewBag.ActiveCount ?? 0;
    int inactiveCount = ViewBag.InactiveCount ?? 0;
}

<div class="admin-title-row">
    <div>
        <h1>Loại Chuồng / Phòng</h1>
        <p>Định nghĩa danh mục phòng lưu trú, thiết lập giá theo giờ/ngày và tiện ích đi kèm.</p>
    </div>
    <button class="admin-btn-primary" onclick="openCreateModal()">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Thêm Loại Phòng
    </button>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: 12px; font-family: 'Outfit';">
        <strong>Thành công!</strong> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: 12px; font-family: 'Outfit';">
        <strong>Lỗi!</strong> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="admin-stats-grid">
    <div class="admin-stat-card">
        <div class="admin-stat-icon admin-stat-icon-total">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
        </div>
        <div class="admin-stat-details"><h4>TỔNG LOẠI PHÒNG</h4><div>@totalCount</div></div>
    </div>
    <div class="admin-stat-card">
        <div class="admin-stat-icon admin-stat-icon-active">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </div>
        <div class="admin-stat-details"><h4>ĐANG HOẠT ĐỘNG</h4><div>@activeCount</div></div>
    </div>
    <div class="admin-stat-card">
        <div class="admin-stat-icon admin-stat-icon-blocked">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </div>
        <div class="admin-stat-details"><h4>TẠM NGỪNG</h4><div>@inactiveCount</div></div>
    </div>
</div>

<div class="admin-table-filters">
    <form method="get" action="@Url.Action("Index")" class="d-flex align-items-center gap-2">
        <input type="hidden" name="statusFilter" value="@statusFilter" />
        <div class="admin-search-wrapper" style="max-width: 320px; width: 100%;">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input type="text" name="search" class="admin-search-input" value="@search" placeholder="Tìm theo tên phòng, kích thước..." />
        </div>
        <button type="submit" class="btn btn-sm btn-dark" style="border-radius: 20px; font-size: 0.8rem; padding: 8px 16px;">Tìm</button>
    </form>
    <div class="admin-filter-pills">
        <a href="@Url.Action("Index", new { search = search, statusFilter = "All" })" class="admin-filter-pill @(statusFilter == "All" ? "active" : "")">Tất cả</a>
        <a href="@Url.Action("Index", new { search = search, statusFilter = "Active" })" class="admin-filter-pill @(statusFilter == "Active" ? "active" : "")">Đang hoạt động</a>
        <a href="@Url.Action("Index", new { search = search, statusFilter = "Inactive" })" class="admin-filter-pill @(statusFilter == "Inactive" ? "active" : "")">Tạm ngừng</a>
    </div>
</div>

<div class="admin-table-container">
    <table class="admin-table">
        <thead>
            <tr>
                <th>Loại phòng</th><th>Kích thước</th><th>Sức chứa</th>
                <th>Giá / Giờ</th><th>Giá / Ngày</th><th>Tiện ích</th>
                <th>Trạng thái</th><th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (!roomTypes.Any())
            {
                <tr><td colspan="8" class="text-center text-muted py-5">Không tìm thấy loại phòng nào.</td></tr>
            }
            @foreach (var rt in roomTypes)
            {
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-3">
                            <div class="admin-avatar" style="width: 38px; height: 38px; font-size: 0.9rem; background-color: #E6FDF9; color: var(--admin-primary);">
                                @rt.Type.Substring(0, 1).ToUpper()
                            </div>
                            <div>
                                <div style="font-weight: 600;">@rt.Type</div>
                                <div style="font-size: 0.72rem; color: var(--admin-text-muted);">RT-@rt.RoomTypeId.ToString("D3")</div>
                            </div>
                        </div>
                    </td>
                    <td><span style="font-family: monospace; font-weight: 500;">@rt.Size</span></td>
                    <td><span style="font-weight: 600;">@rt.Capacity</span> <span style="font-size: 0.8rem; color: var(--admin-text-muted);">thú</span></td>
                    <td style="color: var(--admin-text-muted);">@rt.HourlyPrice.ToString("N0") ₫</td>
                    <td style="font-weight: 700; color: var(--admin-primary); font-size: 1rem;">@rt.DailyPrice.ToString("N0") ₫</td>
                    <td>
                        @if (rt.HasAc) { <span class="amenity-badge amenity-badge-ac">❄ AC</span> }
                        @if (rt.HasCamera) { <span class="amenity-badge amenity-badge-cam">📸 Ảnh</span> }
                        @if (rt.HasPremiumFood) { <span class="amenity-badge amenity-badge-food">⭐ VIP</span> }
                        @if (!rt.HasAc && !rt.HasCamera && !rt.HasPremiumFood) { <span style="color: var(--admin-text-muted);">—</span> }
                    </td>
                    <td>
                        @if (rt.Status)
                        {
                            <span class="badge-status badge-status-active">
                                <span style="width:7px;height:7px;border-radius:50%;background:#2F9E58;display:inline-block;"></span> HOẠT ĐỘNG
                            </span>
                        }
                        else
                        {
                            <span class="badge-status" style="color:#AAAAAA;">
                                <span style="width:7px;height:7px;border-radius:50%;background:#CCCCCC;display:inline-block;"></span> TẠM NGỪNG
                            </span>
                        }
                    </td>
                    <td>
                        <button type="button" class="admin-action-btn btn-edit-roomtype" title="Chỉnh sửa"
                                data-id="@rt.RoomTypeId" data-type="@rt.Type" data-size="@rt.Size"
                                data-capacity="@rt.Capacity" data-hourlyprice="@rt.HourlyPrice" data-dailyprice="@rt.DailyPrice"
                                data-hasac="@rt.HasAc.ToString().ToLower()" data-hascamera="@rt.HasCamera.ToString().ToLower()"
                                data-haspremiumfood="@rt.HasPremiumFood.ToString().ToLower()">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                            </svg>
                        </button>
                        <form asp-action="ToggleStatus" method="post" class="d-inline"
                              onsubmit="return confirm('@(rt.Status ? "Tạm ngừng loại phòng này?" : "Kích hoạt lại loại phòng này?")')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="roomTypeId" value="@rt.RoomTypeId" />
                            <button type="submit" title="@(rt.Status ? "Tạm ngừng" : "Kích hoạt")"
                                    class="admin-action-btn @(rt.Status ? "admin-action-btn-lock" : "")">
                                @if (rt.Status)
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                }
                                else
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                }
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- MODAL TẠO MỚI -->
<div class="admin-modal-backdrop" id="createRoomTypeModal">
    <div class="admin-modal" style="max-width: 560px;">
        <div class="admin-modal-header">
            <div>
                <div class="admin-modal-title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                    Thêm Loại Phòng mới
                </div>
                <div class="admin-modal-subtitle">Nhập thông tin chi tiết và bảng giá loại phòng lưu trú.</div>
            </div>
            <button class="admin-modal-close" onclick="closeCreateModal()">&times;</button>
        </div>
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="admin-form-group">
                <label>Tên loại phòng *</label>
                <input type="text" name="type" class="admin-form-input" placeholder="VD: Phòng VIP Luxury..." required />
            </div>
            <div class="row">
                <div class="col-7">
                    <div class="admin-form-group">
                        <label>Kích thước phòng *</label>
                        <input type="text" name="size" class="admin-form-input" placeholder="VD: 1.5m x 1.5m" required />
                    </div>
                </div>
                <div class="col-5">
                    <div class="admin-form-group">
                        <label>Sức chứa (thú) *</label>
                        <input type="number" name="capacity" class="admin-form-input" value="1" min="1" max="10" required />
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-6">
                    <div class="admin-form-group">
                        <label>Giá / Giờ (₫) *</label>
                        <input type="number" name="hourlyPrice" class="admin-form-input" placeholder="25000" min="0" step="1000" required />
                    </div>
                </div>
                <div class="col-6">
                    <div class="admin-form-group">
                        <label>Giá / Ngày (₫) *</label>
                        <input type="number" name="dailyPrice" class="admin-form-input" placeholder="200000" min="0" step="1000" required />
                    </div>
                </div>
            </div>
            <div class="admin-form-group">
                <label>Tiện ích đi kèm</label>
                <div class="d-flex gap-3 flex-wrap mt-1">
                    <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-weight:400;">
                        <input type="hidden" name="hasAc" value="false" />
                        <input type="checkbox" name="hasAc" value="true" style="width:16px;height:16px;accent-color:var(--admin-primary);" />
                        <span class="amenity-badge amenity-badge-ac">❄ Điều hoà AC</span>
                    </label>
                    <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-weight:400;">
                        <input type="hidden" name="hasCamera" value="false" />
                        <input type="checkbox" name="hasCamera" value="true" style="width:16px;height:16px;accent-color:var(--admin-primary);" />
                        <span class="amenity-badge amenity-badge-cam">📸 Cập nhật ảnh định kỳ</span>
                    </label>
                    <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-weight:400;">
                        <input type="hidden" name="hasPremiumFood" value="false" />
                        <input type="checkbox" name="hasPremiumFood" value="true" style="width:16px;height:16px;accent-color:var(--admin-primary);" />
                        <span class="amenity-badge amenity-badge-food">⭐ Thức ăn cao cấp</span>
                    </label>
                </div>
            </div>
            <div class="admin-modal-footer">
                <button type="button" class="admin-btn-secondary" onclick="closeCreateModal()">Hủy</button>
                <button type="submit" class="admin-btn-primary" style="box-shadow:none;">Thêm loại phòng</button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL CHỈNH SỬA -->
<div class="admin-modal-backdrop" id="editRoomTypeModal">
    <div class="admin-modal" style="max-width: 560px;">
        <div class="admin-modal-header">
            <div>
                <div class="admin-modal-title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                    Chỉnh sửa Loại Phòng
                </div>
                <div class="admin-modal-subtitle">Cập nhật thông tin và bảng giá loại phòng lưu trú.</div>
            </div>
            <button class="admin-modal-close" onclick="closeEditModal()">&times;</button>
        </div>
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="roomTypeId" id="editRoomTypeId" />
            <div class="admin-form-group">
                <label>Tên loại phòng *</label>
                <input type="text" name="type" id="editType" class="admin-form-input" required />
            </div>
            <div class="row">
                <div class="col-7">
                    <div class="admin-form-group">
                        <label>Kích thước phòng *</label>
                        <input type="text" name="size" id="editSize" class="admin-form-input" required />
                    </div>
                </div>
                <div class="col-5">
                    <div class="admin-form-group">
                        <label>Sức chứa (thú) *</label>
                        <input type="number" name="capacity" id="editCapacity" class="admin-form-input" min="1" max="10" required />
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-6">
                    <div class="admin-form-group">
                        <label>Giá / Giờ (₫) *</label>
                        <input type="number" name="hourlyPrice" id="editHourlyPrice" class="admin-form-input" min="0" step="1000" required />
                    </div>
                </div>
                <div class="col-6">
                    <div class="admin-form-group">
                        <label>Giá / Ngày (₫) *</label>
                        <input type="number" name="dailyPrice" id="editDailyPrice" class="admin-form-input" min="0" step="1000" required />
                    </div>
                </div>
            </div>
            <div class="admin-form-group">
                <label>Tiện ích đi kèm</label>
                <div class="d-flex gap-3 flex-wrap mt-1">
                    <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-weight:400;">
                        <input type="hidden" name="hasAc" value="false" />
                        <input type="checkbox" id="editHasAc" name="hasAc" value="true" style="width:16px;height:16px;accent-color:var(--admin-primary);" />
                        <span class="amenity-badge amenity-badge-ac">❄ Điều hoà AC</span>
                    </label>
                    <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-weight:400;">
                        <input type="hidden" name="hasCamera" value="false" />
                        <input type="checkbox" id="editHasCamera" name="hasCamera" value="true" style="width:16px;height:16px;accent-color:var(--admin-primary);" />
                        <span class="amenity-badge amenity-badge-cam">📸 Cập nhật ảnh định kỳ</span>
                    </label>
                    <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-weight:400;">
                        <input type="hidden" name="hasPremiumFood" value="false" />
                        <input type="checkbox" id="editHasPremiumFood" name="hasPremiumFood" value="true" style="width:16px;height:16px;accent-color:var(--admin-primary);" />
                        <span class="amenity-badge amenity-badge-food">⭐ Thức ăn cao cấp</span>
                    </label>
                </div>
            </div>
            <div class="admin-modal-footer">
                <button type="button" class="admin-btn-secondary" onclick="closeEditModal()">Hủy</button>
                <button type="submit" class="admin-btn-primary" style="box-shadow:none;">Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openCreateModal() { document.getElementById('createRoomTypeModal').style.display = 'flex'; }
        function closeCreateModal() { document.getElementById('createRoomTypeModal').style.display = 'none'; }

        $(document).on('click', '.btn-edit-roomtype', function () {
            var d = $(this).data();
            $('#editRoomTypeId').val(d.id);
            $('#editType').val(d.type);
            $('#editSize').val(d.size);
            $('#editCapacity').val(d.capacity);
            $('#editHourlyPrice').val(d.hourlyprice);
            $('#editDailyPrice').val(d.dailyprice);
            $('#editHasAc').prop('checked', d.hasac === true || d.hasac === 'true');
            $('#editHasCamera').prop('checked', d.hascamera === true || d.hascamera === 'true');
            $('#editHasPremiumFood').prop('checked', d.haspremiumfood === true || d.haspremiumfood === 'true');
            $('#editRoomTypeModal').css('display', 'flex');
        });
        function closeEditModal() { $('#editRoomTypeModal').css('display', 'none'); }

        window.onclick = function (e) {
            var c = document.getElementById('createRoomTypeModal');
            var ed = document.getElementById('editRoomTypeModal');
            if (e.target === c) c.style.display = 'none';
            if (e.target === ed) ed.style.display = 'none';
        };
    </script>
}
