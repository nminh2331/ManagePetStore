@model IEnumerable<ManagePetStore.Models.Supplier>
@{
    ViewData["Title"] = "Quản lý Nhà cung cấp";
    Layout = "~/Areas/Warehouse/Views/Shared/_WarehouseLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row mb-4 align-items-center">
        <div class="col">
            <h2 class="mb-0 text-primary"><i class="fas fa-truck text-primary me-2"></i>Quản lý Nhà cung cấp</h2>
            <p class="text-muted mb-0">Quản lý danh sách các đối tác cung cấp hàng hóa</p>
        </div>
        <div class="col-auto text-end">
            <a asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="fas fa-plus me-1"></i> Thêm Nhà cung cấp
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-secondary">
                        <tr>
                            <th class="ps-4">Tên nhà cung cấp</th>
                            <th>Liên hệ</th>
                            <th>Địa chỉ</th>
                            <th>Cung cấp danh mục</th>
                            <th>Trạng thái</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">
                                    @item.Name
                                </td>
                                <td>
                                    <div><i class="fas fa-phone-alt text-muted me-2" style="width: 15px"></i> @(item.Phone ?? "-")</div>
                                    <div class="small text-muted"><i class="fas fa-envelope text-muted me-2" style="width: 15px"></i> @(item.Email ?? "-")</div>
                                </td>
                                <td>@item.Address</td>
                                <td>
                                    @if (item.SupplierCategories != null && item.SupplierCategories.Any())
                                    {
                                        foreach (var cat in item.SupplierCategories)
                                        {
                                            <span class="badge bg-info text-dark mb-1">@cat.Category.Name</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Chưa phân loại</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success px-2 py-1"><i class="fas fa-circle me-1" style="font-size: 0.5rem;"></i>Đang hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger px-2 py-1"><i class="fas fa-circle me-1" style="font-size: 0.5rem;"></i>Ngừng cung cấp</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="Edit" asp-route-id="@item.SupplierId" class="btn btn-sm btn-outline-primary" title="Sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.SupplierId" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa nhà cung cấp này?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="fas fa-box-open fs-1 text-light mb-3"></i>
                                    <p class="mb-0">Chưa có nhà cung cấp nào.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
