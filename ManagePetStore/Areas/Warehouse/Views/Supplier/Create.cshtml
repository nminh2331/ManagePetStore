@model ManagePetStore.Models.Supplier
@{
    ViewData["Title"] = "Thêm Nhà Cung Cấp";
    Layout = "~/Areas/Warehouse/Views/Shared/_WarehouseLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <h2 class="mb-0 text-primary"><i class="fas fa-plus-circle text-primary me-2"></i>Thêm Nhà Cung Cấp</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0 mb-0 mt-2">
                    <li class="breadcrumb-item"><a asp-action="Index">Danh sách</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Thêm mới</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="card shadow border-0 rounded-3 max-w-800">
        <div class="card-body p-4">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label fw-bold">Tên nhà cung cấp <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="Nhập tên nhà cung cấp..." />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Phone" class="form-label fw-bold">Số điện thoại</label>
                        <input asp-for="Phone" class="form-control" placeholder="Nhập số điện thoại..." />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-bold">Email</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="Nhập email..." />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Danh mục cung cấp</label>
                        <select name="categoryIds" class="form-select" multiple asp-items="ViewBag.Categories" style="height: 100px;">
                        </select>
                        <div class="form-text text-muted">Giữ phím Ctrl (hoặc Cmd) để chọn nhiều danh mục.</div>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Address" class="form-label fw-bold">Địa chỉ</label>
                    <textarea asp-for="Address" class="form-control" rows="2" placeholder="Nhập địa chỉ..."></textarea>
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>

                <div class="mb-4 form-check form-switch">
                    <input class="form-check-input" type="checkbox" asp-for="IsActive" checked>
                    <label class="form-check-label" asp-for="IsActive">Đang hoạt động</label>
                </div>

                @{
                    var selectedSkus = (ViewBag.SelectedProductSkus as List<string>) ?? new List<string>();
                }
                <div class="mb-4">
                    <label class="form-label fw-bold">
                        <i class="fas fa-box me-1 text-success"></i>
                        Sản phẩm cụ thể NCC này cung cấp
                        <span class="text-muted fw-normal small ms-1">(tùy chọn — để trống = cung cấp tất cả theo danh mục)</span>
                    </label>
                    <div class="border rounded-3 p-3" style="max-height:220px;overflow-y:auto;background:#f9fafb;">
                        <input type="text" id="prodSearch" class="form-control form-control-sm mb-2"
                               placeholder="🔍 Tìm nhanh sản phẩm..." oninput="filterProducts(this.value)" />
                        <div id="prodList">
                        @foreach (var p in ViewBag.AllProducts as IEnumerable<ManagePetStore.Models.Product> ?? Enumerable.Empty<ManagePetStore.Models.Product>())
                        {
                            var isChecked = selectedSkus.Contains(p.Sku);
                            <div class="form-check prod-item" data-name="@p.Name.ToLower()">
                                <input class="form-check-input" type="checkbox"
                                       name="productSkus" value="@p.Sku"
                                       id="prod_@p.Sku" @(isChecked ? "checked" : "") />
                                <label class="form-check-label" for="prod_@p.Sku">
                                    <span class="fw-semibold">@p.Name</span>
                                    <span class="text-muted small ms-1">(@p.Sku)</span>
                                </label>
                            </div>
                        }
                        </div>
                    </div>
                    <div class="form-text text-muted mt-1">
                        <i class="fas fa-info-circle me-1"></i>
                        Khi tạo đơn nhập, NCC này sẽ được ưu tiên hiển thị cho các sản phẩm đã chọn.
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i> Lưu thông tin</button>
                    <a asp-action="Index" class="btn btn-light border">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function filterProducts(query) {
            const q = query.toLowerCase();
            document.querySelectorAll('.prod-item').forEach(el => {
                el.style.display = el.dataset.name.includes(q) ? '' : 'none';
            });
        }
    </script>
}
