@model ManagePetStore.Models.ProductCategory

@{
    ViewData["Title"] = "Thêm Danh mục";
}

<div class="mb-4">
    <a asp-action="Index" class="text-decoration-none text-muted mb-2 d-inline-block">
        <i class="fas fa-arrow-left"></i> Quay lại danh sách
    </a>
    <h2 class="fw-bold m-0" style="color: #333;">Thêm Danh mục Sản phẩm mới</h2>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 12px; max-width: 600px;">
    <div class="card-body p-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-bold">Tên danh mục <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control" style="border-radius: 8px;" placeholder="Nhập tên danh mục..." />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Keywords" class="form-label fw-bold">Từ khóa tìm kiếm</label>
                <input asp-for="Keywords" class="form-control" style="border-radius: 8px;" placeholder="Ví dụ: thucanchomeo, cat food, do an cho meo..." />
                <div class="form-text text-muted">Giúp khách hàng dễ tìm thấy danh mục này. Viết liền hay cách đều được, cách nhau bằng dấu phẩy.</div>
                <span asp-validation-for="Keywords" class="text-danger small"></span>
            </div>
            
            <div class="mb-4">
                <label asp-for="Description" class="form-label fw-bold">Mô tả</label>
                <textarea asp-for="Description" class="form-control" style="border-radius: 8px;" rows="4" placeholder="Nhập mô tả (không bắt buộc)..."></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>
            
            <div class="text-end">
                <button type="submit" class="btn btn-primary-custom px-4 py-2">
                    <i class="fas fa-save"></i> Lưu danh mục
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
