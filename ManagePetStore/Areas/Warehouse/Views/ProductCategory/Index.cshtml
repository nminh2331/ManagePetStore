@model IEnumerable<ManagePetStore.Models.ProductCategory>

@{
    ViewData["Title"] = "Danh mục Sản phẩm";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold m-0" style="color: #333;"><i class="fas fa-tags" style="color: #e65c00;"></i> Quản lý Danh mục Sản phẩm</h2>
    <a asp-action="Create" class="btn btn-primary-custom">
        <i class="fas fa-plus"></i> Thêm mới
    </a>
</div>

<div class="table-custom">
    <table class="table mb-0">
        <thead>
            <tr>
                <th>ID</th>
                <th>Tên danh mục</th>
                <th>Mô tả</th>
                <th class="text-end">Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.CategoryId</td>
                        <td class="fw-bold">@item.Name</td>
                        <td>@item.Description</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.CategoryId" class="btn btn-sm btn-outline-primary" style="border-radius: 8px;">
                                <i class="fas fa-edit"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.CategoryId" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc muốn xóa danh mục này?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger" style="border-radius: 8px;">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center py-4 text-muted">Chưa có danh mục nào.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
