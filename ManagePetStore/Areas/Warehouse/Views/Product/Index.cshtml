@model IEnumerable<ManagePetStore.Models.Product>

@{
    ViewData["Title"] = "Danh sách Sản phẩm";
    int totalProducts   = ViewBag.TotalProducts  ?? 0;
    int lowStockCount   = ViewBag.LowStockCount  ?? 0;
    int outOfStockCount = ViewBag.OutOfStockCount ?? 0;
    decimal totalValue  = ViewBag.TotalValue      ?? 0m;
    int categoryCount   = ViewBag.CategoryCount   ?? 0;
}

<!-- ── Stat Cards ───────────────────────────────────────────── -->
<div class="row g-3 mb-4">
    <div class="col-6 col-xl-3">
        <div class="stat-card" style="--accent:#e65c00;">
            <div class="stat-icon" style="background:rgba(230,92,0,.12);">
                <i class="fas fa-box-open" style="color:#e65c00;"></i>
            </div>
            <div>
                <p class="stat-label">Tổng sản phẩm</p>
                <h3 class="stat-value">@totalProducts</h3>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="stat-card" style="--accent:#f59e0b;">
            <div class="stat-icon" style="background:rgba(245,158,11,.12);">
                <i class="fas fa-exclamation-triangle" style="color:#f59e0b;"></i>
            </div>
            <div>
                <p class="stat-label">Sắp hết hàng</p>
                <h3 class="stat-value">@lowStockCount</h3>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="stat-card" style="--accent:#ef4444;">
            <div class="stat-icon" style="background:rgba(239,68,68,.12);">
                <i class="fas fa-times-circle" style="color:#ef4444;"></i>
            </div>
            <div>
                <p class="stat-label">Hết hàng</p>
                <h3 class="stat-value">@outOfStockCount</h3>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="stat-card" style="--accent:#10b981;">
            <div class="stat-icon" style="background:rgba(16,185,129,.12);">
                <i class="fas fa-coins" style="color:#10b981;"></i>
            </div>
            <div>
                <p class="stat-label">Giá trị tồn kho</p>
                <h3 class="stat-value" style="font-size:1.1rem;">@string.Format("{0:N0} đ", totalValue)</h3>
            </div>
        </div>
    </div>
</div>

<!-- ── Header ─────────────────────────────────────────────── -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="fw-bold m-0" style="color:#333;">
            <i class="fas fa-box-open" style="color:#e65c00;"></i> Danh sách Sản phẩm
        </h2>
        <p class="text-muted small mb-0">@categoryCount danh mục · @totalProducts sản phẩm</p>
    </div>
    <a asp-action="Create" class="btn btn-primary-custom btn-custom">
        <i class="fas fa-plus"></i> Thêm sản phẩm
    </a>
</div>

<!-- ── Alert low-stock banner ─────────────────────────────── -->
@if (lowStockCount > 0 || outOfStockCount > 0)
{
    <div class="alert d-flex align-items-center gap-2 mb-3"
         style="background:#fff8f0;border:1px solid #f59e0b;border-radius:10px;color:#92400e;">
        <i class="fas fa-exclamation-triangle" style="color:#f59e0b;"></i>
        <span>
            Có <strong>@outOfStockCount</strong> sản phẩm <strong>hết hàng</strong> và
            <strong>@lowStockCount</strong> sản phẩm <strong>sắp hết</strong> cần nhập thêm.
        </span>
    </div>
}

<!-- ── Table ──────────────────────────────────────────────── -->
<div class="table-custom">
    <table class="table mb-0">
        <thead>
            <tr>
                <th style="width:60px;">Ảnh</th>
                <th>Mã SP (SKU)</th>
                <th>Tên sản phẩm</th>
                <th>Danh mục</th>
                <th>Đơn vị</th>
                <th>Tồn kho</th>
                <th>Giá bán</th>
                <th class="text-end">Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.Name"
                                     style="width:48px;height:48px;object-fit:cover;border-radius:8px;border:1px solid #eee;"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                <div style="display:none;width:48px;height:48px;border-radius:8px;background:#f3f3f3;align-items:center;justify-content:center;">
                                    <i class="fas fa-image text-muted" style="font-size:18px;"></i>
                                </div>
                            }
                            else
                            {
                                <div style="width:48px;height:48px;border-radius:8px;background:#f3f3f3;display:flex;align-items:center;justify-content:center;">
                                    <i class="fas fa-image text-muted" style="font-size:18px;"></i>
                                </div>
                            }
                        </td>
                        <td class="fw-bold" style="color:#666;">@item.Sku</td>
                        <td class="fw-bold">@item.Name</td>
                        <td>
                            @if (item.Category != null)
                            {
                                <span class="badge" style="background:#fff3e0;color:#e65c00;font-weight:600;border-radius:20px;padding:4px 10px;">
                                    @item.Category.Name
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>@item.Unit</td>
                        <td>
                            @if (item.Stock == 0)
                            {
                                <span class="badge bg-danger rounded-pill">Hết hàng</span>
                            }
                            else if (item.Stock <= item.MinStock)
                            {
                                <span class="badge bg-warning text-dark rounded-pill" title="Tối thiểu: @item.MinStock">
                                    @item.Stock <i class="fas fa-arrow-down" style="font-size:10px;"></i>
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success rounded-pill">@item.Stock</span>
                            }
                        </td>
                        <td class="fw-bold text-success">@string.Format("{0:N0} đ", item.Price)</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.Sku"
                               class="btn btn-sm btn-outline-primary" style="border-radius:8px;" title="Chỉnh sửa">
                                <i class="fas fa-edit"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.Sku" method="post"
                                  class="d-inline" onsubmit="return confirm('Bạn có chắc muốn xóa sản phẩm này?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                        style="border-radius:8px;" title="Xóa">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center py-5 text-muted">
                        <i class="fas fa-box-open" style="font-size:2rem;opacity:.3;"></i>
                        <p class="mt-2 mb-0">Chưa có sản phẩm nào. Hãy thêm sản phẩm đầu tiên!</p>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    .stat-card {
        background: #fff;
        border-radius: 14px;
        padding: 1.1rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        box-shadow: 0 2px 10px rgba(0,0,0,.06);
        border-left: 4px solid var(--accent);
        transition: transform .2s, box-shadow .2s;
    }
    .stat-card:hover { transform: translateY(-2px); box-shadow: 0 6px 18px rgba(0,0,0,.1); }
    .stat-icon {
        width: 48px; height: 48px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.3rem; flex-shrink: 0;
    }
    .stat-label { font-size: .78rem; color: #888; margin: 0; font-weight: 500; }
    .stat-value { font-size: 1.4rem; font-weight: 700; margin: 0; color: #222; }
</style>
