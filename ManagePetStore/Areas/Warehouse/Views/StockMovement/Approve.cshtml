@model ManagePetStore.Models.StockMovement

@{
    ViewData["Title"] = "Kiểm hàng - Phiếu #" + Model.MovementId;
}

<div class="mb-4">
    <a asp-action="Details" asp-route-id="@Model.MovementId" class="text-decoration-none text-muted mb-2 d-inline-block">
        <i class="fas fa-arrow-left"></i> Quay lại chi tiết phiếu
    </a>
    <h2 class="fw-bold m-0" style="color: #333;">Kiểm hàng - Phiếu Nhập Kho #@Model.MovementId</h2>
    <p class="text-muted small mt-1">Vui lòng điền Hạn sử dụng thực tế cho từng sản phẩm dựa trên thông tin trên bao bì hàng hóa.</p>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm" style="border-radius:16px;">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3 border-bottom pb-2">Thông tin phiếu</h5>
                <p class="mb-2"><span class="text-muted fw-bold">Mã phiếu:</span> #@Model.MovementId</p>
                <p class="mb-2"><span class="text-muted fw-bold">Ngày tạo:</span> @Model.Date.ToString("dd/MM/yyyy HH:mm")</p>
                <p class="mb-2"><span class="text-muted fw-bold">Nhà cung cấp:</span> @Model.Supplier</p>
                <p class="mb-2"><span class="text-muted fw-bold">Người tạo:</span> @Model.CreatedBy?.FullName</p>
                <p class="mb-0 fs-5 mt-3">
                    <span class="text-muted fw-bold fs-6">Tổng giá trị:</span>
                    <span class="fw-bold text-primary">@string.Format("{0:N0} đ", Model.TotalValue)</span>
                </p>
            </div>
        </div>

        <div class="alert alert-warning mt-3" style="border-radius:12px;">
            <i class="fas fa-info-circle me-2"></i>
            <strong>Lưu ý:</strong> Sau khi xác nhận, số lượng tồn kho sẽ được cập nhật ngay lập tức và không thể hoàn tác.
        </div>
    </div>

    <div class="col-md-8">
        <div class="card border-0 shadow-sm" style="border-radius:16px;">
            <div class="card-body p-0">
                <div class="p-4 border-bottom" style="background:#f8f9fa; border-radius:16px 16px 0 0;">
                    <h5 class="fw-bold m-0">
                        <i class="fas fa-clipboard-check me-2 text-primary"></i>
                        Danh sách hàng cần kiểm tra
                    </h5>
                </div>

                <form asp-action="Approve" asp-route-id="@Model.MovementId" method="post" id="approveForm">
                    @Html.AntiForgeryToken()

                    <div class="table-responsive">
                        <table class="table mb-0 align-middle">
                            <thead class="text-muted small" style="background:#fafafa;">
                                <tr>
                                    <th class="px-4 py-3">Sản phẩm</th>
                                    <th class="px-4 py-3 text-center">SL đặt</th>
                                    <th class="px-4 py-3 text-end">Đơn giá nhập</th>
                                    <th class="px-4 py-3 text-center" style="min-width:180px;">
                                        Hạn sử dụng <span class="text-danger">*</span>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var detail in Model.StockMovementDetails)
                                {
                                    <tr>
                                        <td class="px-4 py-3">
                                            <div class="fw-bold">@detail.ProductSkuNavigation.Name</div>
                                            <small class="text-muted">SKU: @detail.ProductSku</small>
                                            <input type="hidden" name="detailIds" value="@detail.DetailId" />
                                        </td>
                                        <td class="px-4 py-3 text-center">
                                            <span class="badge bg-primary rounded-pill px-3 py-2 fs-6">@detail.Quantity</span>
                                        </td>
                                        <td class="px-4 py-3 text-end fw-bold">
                                            @string.Format("{0:N0} đ", detail.CostPrice)
                                        </td>
                                        <td class="px-4 py-3">
                                            <input type="date"
                                                   name="expiryDateInputs"
                                                   class="form-control expiry-input"
                                                   style="border-radius:8px;"
                                                   required
                                                   min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="p-4 border-top d-flex justify-content-end gap-2">
                        <a asp-action="Details" asp-route-id="@Model.MovementId" class="btn btn-outline-secondary px-4" style="border-radius:10px;">
                            <i class="fas fa-times me-1"></i> Hủy bỏ
                        </a>
                        <button type="submit" class="btn btn-success px-4 fw-bold shadow-sm" style="border-radius:10px;"
                                onclick="return confirm('Xác nhận duyệt phiếu nhập kho? Tồn kho sẽ được cập nhật ngay lập tức.');">
                            <i class="fas fa-check-circle me-1"></i> Xác nhận nhập kho
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Tô đỏ ô nhập nếu bỏ trống khi submit
        document.getElementById('approveForm').addEventListener('submit', function (e) {
            var inputs = document.querySelectorAll('.expiry-input');
            var hasEmpty = false;
            inputs.forEach(function (input) {
                if (!input.value) {
                    input.classList.add('is-invalid');
                    hasEmpty = true;
                } else {
                    input.classList.remove('is-invalid');
                }
            });
            if (hasEmpty) {
                e.preventDefault();
                alert('Vui lòng điền Hạn sử dụng cho tất cả sản phẩm trước khi xác nhận.');
            }
        });
    </script>
}
