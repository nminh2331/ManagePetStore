@model ManagePetStore.Models.StockMovement

@{
    ViewData["Title"] = "Chi tiết Phiếu #" + Model.MovementId;
}

<div class="mb-4">
    <a asp-action="Index" class="text-decoration-none text-muted mb-2 d-inline-block">
        <i class="fas fa-arrow-left"></i> Quay lại danh sách
    </a>
    <h2 class="fw-bold m-0" style="color: #333;">Chi tiết Phiếu @(Model.Type == "Nhập hàng" ? "Nhập Kho" : "Xuất Kho") #@Model.MovementId</h2>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100" style="border-radius:16px;">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3 border-bottom pb-2">Thông tin chung</h5>
                
                <p class="mb-2"><span class="text-muted fw-bold">Loại phiếu:</span> 
                    @if (Model.Type == "Nhập hàng")
                    {
                        <span class="text-success fw-bold"><i class="fas fa-arrow-down"></i> Nhập hàng</span>
                    }
                    else
                    {
                        <span class="text-danger fw-bold"><i class="fas fa-arrow-up"></i> Xuất nội bộ</span>
                    }
                </p>
                <p class="mb-2"><span class="text-muted fw-bold">Ngày tạo:</span> @Model.Date.ToString("dd/MM/yyyy HH:mm")</p>
                <p class="mb-2"><span class="text-muted fw-bold">Người tạo:</span> @Model.CreatedBy.FullName</p>
                <p class="mb-2"><span class="text-muted fw-bold">Trạng thái:</span> 
                    @if (Model.Status == "Hoàn thành")
                    {
                        <span class="badge bg-success px-2 py-1">Hoàn thành</span>
                    }
                    else if (Model.Status == "Chờ duyệt")
                    {
                        <span class="badge bg-warning text-dark px-2 py-1">Chờ duyệt</span>
                    }
                    else
                    {
                        <span class="badge bg-danger px-2 py-1">Đã hủy</span>
                    }
                </p>
                <hr />
                <p class="mb-2"><span class="text-muted fw-bold">@(Model.Type == "Nhập hàng" ? "Nhà cung cấp" : "Ghi chú xuất"):</span> <br/>@Model.Supplier</p>
                @if (Model.Type == "Nhập hàng")
                {
                    <p class="mb-0 fs-5 mt-3"><span class="text-muted fw-bold fs-6">Tổng giá trị:</span> <span class="fw-bold text-primary">@string.Format("{0:N0} đ", Model.TotalValue)</span></p>
                }

                @if (Model.Status == "Chờ duyệt")
                {
                    <div class="mt-4 pt-3 border-top d-grid gap-2">
                        <form asp-action="Approve" asp-route-id="@Model.MovementId" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn duyệt phiếu này? Số lượng tồn kho sẽ được cập nhật ngay lập tức.');">
                            <button type="submit" class="btn btn-success w-100 fw-bold shadow-sm mb-2" style="border-radius:10px;">
                                <i class="fas fa-check-circle"></i> Duyệt phiếu
                            </button>
                        </form>
                        
                        <form asp-action="Cancel" asp-route-id="@Model.MovementId" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn hủy phiếu này?');">
                            <button type="submit" class="btn btn-outline-danger w-100 fw-bold" style="border-radius:10px;">
                                <i class="fas fa-times-circle"></i> Hủy phiếu
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="card border-0 shadow-sm h-100" style="border-radius:16px;">
            <div class="card-body p-0">
                <div class="p-4 border-bottom bg-light" style="border-radius: 16px 16px 0 0;">
                    <h5 class="fw-bold m-0">Danh sách sản phẩm</h5>
                </div>
                <div class="table-responsive p-3">
                    <table class="table mb-0 align-middle">
                        <thead class="text-muted small">
                            <tr>
                                <th>Sản phẩm</th>
                                <th class="text-center">Số lượng</th>
                                @if (Model.Type == "Nhập hàng")
                                {
                                    <th class="text-end">Đơn giá nhập</th>
                                    <th class="text-end">Thành tiền</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detail in Model.StockMovementDetails)
                            {
                                <tr>
                                    <td class="fw-bold">@detail.ProductSkuNavigation.Name <br/> <small class="text-muted fw-normal">SKU: @detail.ProductSku</small></td>
                                    <td class="text-center fw-bold fs-5 text-primary">@detail.Quantity</td>
                                    @if (Model.Type == "Nhập hàng")
                                    {
                                        <td class="text-end">@string.Format("{0:N0} đ", detail.CostPrice)</td>
                                        <td class="text-end fw-bold">@string.Format("{0:N0} đ", detail.Quantity * detail.CostPrice)</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
