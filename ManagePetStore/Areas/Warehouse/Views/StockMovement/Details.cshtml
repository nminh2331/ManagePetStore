@model ManagePetStore.Models.StockMovement

@{
    ViewData["Title"] = "Chi tiết Phiếu #" + Model.MovementId;
}

<style>
    .document-page {
        background: #fff;
        max-width: 850px;
        margin: 0 auto;
        padding: 3rem 4rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        border-radius: 8px;
        min-height: 1000px;
        position: relative;
    }
    .doc-header {
        text-align: center;
        margin-bottom: 2.5rem;
    }
    .doc-title {
        font-size: 24px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    .doc-table th {
        background-color: #f8f9fa !important;
        border-bottom: 2px solid #333;
        font-weight: 700;
    }
    .doc-table td, .doc-table th {
        padding: 12px 8px;
        vertical-align: middle;
    }
    .doc-footer-total {
        font-size: 1.25rem;
        font-weight: bold;
    }
    .signature-box {
        text-align: center;
        margin-top: 4rem;
    }
    .signature-title {
        font-weight: bold;
        margin-bottom: 5rem;
    }
    
    @@media print {
        body * { visibility: hidden; }
        .document-page, .document-page * { visibility: visible; }
        .document-page {
            position: absolute; left: 0; top: 0;
            margin: 0; padding: 0;
            box-shadow: none; border-radius: 0;
        }
        .no-print { display: none !important; }
    }
</style>

<div class="mb-4 d-flex justify-content-between align-items-center max-w-850 mx-auto" style="max-width: 850px;">
    <a asp-action="Index" class="text-decoration-none text-muted">
        <i class="fas fa-arrow-left"></i> Quay lại danh sách
    </a>
    
    <div class="no-print">
        <button onclick="window.print()" class="btn btn-outline-secondary me-2">
            <i class="fas fa-print"></i> In phiếu
        </button>

        @{
            var userRole = User.FindFirst("RoleId")?.Value;
            bool isManager = userRole == "6" || User.IsInRole("admin");
            bool isWarehouse = userRole == "4";
        }

        @* Manager duyệt hoặc hủy đơn Nhập hàng đang chờ *@
        @if (isManager && Model.Status == "Chờ quản lý duyệt")
        {
            <form asp-action="ApproveStatus" method="post" class="d-inline">
                <input type="hidden" name="id" value="@Model.MovementId" />
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-success fw-bold me-2">
                    <i class="fas fa-check-circle"></i> Duyệt đơn
                </button>
            </form>
            <form asp-action="Cancel" method="post" class="d-inline" 
                  onsubmit="return confirm('Xác nhận hủy phiếu này?');">
                <input type="hidden" name="id" value="@Model.MovementId" />
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger fw-bold">
                    <i class="fas fa-times-circle"></i> Từ chối
                </button>
            </form>
        }

        @* Warehouse kiểm hàng khi đã được Manager duyệt *@
        @if (isWarehouse && Model.Status == "Chờ kiểm hàng" && Model.Type == "Nhập hàng")
        {
            <a asp-action="Approve" asp-route-id="@Model.MovementId" class="btn btn-warning fw-bold text-dark me-2">
                <i class="fas fa-clipboard-check"></i> Kiểm & Nhận hàng
            </a>
            <form asp-action="Cancel" method="post" class="d-inline" 
                  onsubmit="return confirm('Xác nhận hủy phiếu này?');">
                <input type="hidden" name="id" value="@Model.MovementId" />
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger fw-bold">
                    <i class="fas fa-times"></i> Hủy phiếu
                </button>
            </form>
        }

        @* Manager/Warehouse duyệt phiếu Xuất nội bộ *@
        @if (isManager && Model.Status == "Chờ quản lý duyệt" && Model.Type == "Xuất nội bộ")
        {
            @* Đã được xử lý ở khối Manager ở trên *@
        }
    </div>
</div>

<div class="document-page">
    @if (Model.Status == "Đã hủy")
    {
        <div class="position-absolute" style="top: 100px; left: 50%; transform: translateX(-50%) rotate(-15deg); opacity: 0.1; pointer-events: none;">
            <h1 style="font-size: 8rem; color: red; font-weight: 900; border: 10px solid red; padding: 20px; border-radius: 20px;">ĐÃ HỦY</h1>
        </div>
    }
    
    <div class="row mb-4 border-bottom pb-3">
        <div class="col-6">
            <h4 class="fw-bold mb-0">PET STORE</h4>
            <p class="text-muted small mb-0">Hệ thống quản lý thú cưng</p>
        </div>
        <div class="col-6 text-end">
            <div class="fs-5 fw-bold text-muted">Mẫu số: @(Model.Type.StartsWith("Nhập") ? "01-VT" : "02-VT")</div>
        </div>
    </div>

    <div class="doc-header">
        <div class="doc-title">@{
                string docTitle = Model.Type switch {
                    "Nhập hàng" => "PHIẾU NHẬP KHO",
                    "Xuất kho (Bán hàng online)" => "PHIẾU XUẤT KHO (ONLINE)",
                    "Xuất kho (Bán hàng POS)" => "PHIẾU XUẤT KHO (POS)",
                    "Nhập kho (Hủy đơn)" => "PHIẾU NHẬP KHO (HOÀN TRẢ)",
                    "Xuất nội bộ" => "PHIẾU XUẤT NỘI BỘ",
                    _ => "PHIẾU KHO"
                };
            }@docTitle</div>
        <div class="text-muted mt-1">Ngày lập: @Model.Date.ToString("dd/MM/yyyy HH:mm")</div>
        <div>
            @{
                var badgeClass = Model.Status switch {
                    "Hoàn thành" => "bg-success",
                    "Đã hoàn thành" => "bg-success",
                    "Chờ quản lý duyệt" => "bg-danger",
                    "Chờ kiểm hàng" => "bg-warning text-dark",
                    "Đã hủy" => "bg-secondary",
                    _ => "bg-secondary"
                };
            }
            <span class="badge @badgeClass mt-2 px-3 py-2">@(Model.Status == "Đã hoàn thành" ? "Hoàn thành" : Model.Status)</span>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-7">
            <p class="mb-1"><strong>Người lập phiếu:</strong> @(Model.CreatedBy?.FullName ?? "N/A")</p>
            <p class="mb-1">
                <strong>@(Model.Type == "Nhập hàng" ? "Nhà cung cấp" : "Đơn vị nhận"):</strong> 
                @(Model.SupplierNavigation?.Name ?? Model.Supplier ?? "N/A")
            </p>
        </div>
        <div class="col-5">
            <p class="mb-1"><strong>Số phiếu:</strong> #@Model.MovementId.ToString("D5")</p>
            <p class="mb-1"><strong>Loại phiếu:</strong> @Model.Type</p>
        </div>
    </div>

    <table class="table table-bordered doc-table mb-4">
        <thead>
            <tr>
                <th class="text-center" width="5%">STT</th>
                <th width="15%">Mã hàng</th>
                <th width="35%">Tên hàng hóa</th>
                <th class="text-center" width="10%">ĐVT</th>
                <th class="text-end" width="10%">Số lượng</th>
                <th class="text-end" width="15%">Đơn giá (đ)</th>
                <th class="text-end" width="15%">Thành tiền (đ)</th>
            </tr>
        </thead>
        <tbody>
            @{
                int stt = 1;
                foreach (var item in Model.StockMovementDetails)
                {
                    <tr>
                        <td class="text-center">@(stt++)</td>
                        <td>@item.ProductSku</td>
                        <td>
                            <div class="fw-bold">@item.ProductSkuNavigation?.Name</div>
                        </td>
                        <td class="text-center">@item.ProductSkuNavigation?.Unit</td>
                        <td class="text-end fw-bold">@item.Quantity</td>
                        <td class="text-end">@string.Format("{0:N0}", item.CostPrice)</td>
                        <td class="text-end">@string.Format("{0:N0}", item.Quantity * item.CostPrice)</td>
                    </tr>
                }
            }
        </tbody>
        <tfoot>
            <tr>
                <td colspan="4" class="text-end fw-bold">Cộng khoản:</td>
                <td class="text-end fw-bold">@Model.StockMovementDetails.Sum(d => d.Quantity)</td>
                <td class="text-end fw-bold">Tổng tiền:</td>
                <td class="text-end doc-footer-total text-primary">@string.Format("{0:N0}", Model.TotalValue)</td>
            </tr>
        </tfoot>
    </table>

    <div class="row signature-box">
        <div class="col-4">
            <div class="signature-title">Người lập phiếu</div>
            <div class="text-muted fst-italic mb-5">(Ký, họ tên)</div>
            <div class="fw-bold mt-5 pt-3">@(Model.CreatedBy?.FullName ?? "N/A")</div>
        </div>
        <div class="col-4">
            <div class="signature-title">Người giao hàng</div>
            <div class="text-muted fst-italic mb-5">(Ký, họ tên)</div>
        </div>
        <div class="col-4">
            <div class="signature-title">Thủ kho</div>
            <div class="text-muted fst-italic mb-5">(Ký, họ tên)</div>
            @if (Model.Status == "Hoàn thành")
            {
                <div class="fw-bold mt-5 pt-3 text-success">
                    <i class="fas fa-check-circle"></i> Đã xác nhận
                </div>
            }
        </div>
    </div>
</div>
