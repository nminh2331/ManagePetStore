@model IEnumerable<ManagePetStore.Models.StockMovement>

@{
    ViewData["Title"] = "Lịch sử Xuất/Nhập Kho";
}

<div class="mb-4 d-flex justify-content-between align-items-center">
    <div>
        <h2 class="fw-bold m-0" style="color: #333;">Lịch sử Xuất/Nhập Kho</h2>
        <p class="text-muted small mt-1 mb-0">Quản lý các Phiếu nhập hàng và Phiếu xuất nội bộ</p>
    </div>
    
    <div>
        @if (User.IsInRole("warehouse") || User.IsInRole("manager"))
        {
            <a asp-action="ExportExcel" 
               asp-route-tab="@ViewBag.Tab" 
               asp-route-fromDate="@ViewBag.FromDate" 
               asp-route-toDate="@ViewBag.ToDate" 
               asp-route-search="@ViewBag.Search"
               class="btn btn-outline-success btn-custom me-2" title="Xuất danh sách ra file Excel">
                <i class="fas fa-file-excel"></i> Xuất file
            </a>
        }
        @if (User.FindFirst("RoleId")?.Value == "4" || User.IsInRole("admin"))
        {
            <a asp-action="CreateExport" class="btn btn-outline-primary btn-custom me-2">
                <i class="fas fa-arrow-up"></i> Tạo Phiếu Xuất Nội Bộ
            </a>
            <a asp-action="CreateImport" class="btn btn-primary-custom btn-custom">
                <i class="fas fa-arrow-down"></i> Tạo Đơn Nhập
            </a>
        }
    </div>
</div>

@{
    var currentTab = (string)(ViewBag.Tab ?? "all");
    var allMovements = Model?.ToList() ?? new List<ManagePetStore.Models.StockMovement>();
    var importOnly = allMovements.Where(m => m.Type == "Nhập hàng").ToList();
    var exportOnly = allMovements.Where(m => m.Type != "Nhập hàng").ToList();

    // Sử dụng count từ ViewBag (lấy từ toàn bộ DB, không bị filter ngày)
    int pendingManagerCount = (int)(ViewBag.PendingManagerCount ?? 0);
    int pendingInspectionCount = (int)(ViewBag.PendingInspectionCount ?? 0);

    // Phân loại để hiển thị từ danh sách đã filter
    var pendingManager = allMovements.Where(m => m.Status == "Chờ quản lý duyệt").ToList();
    var pendingInspection = allMovements.Where(m => m.Status == "Chờ kiểm hàng").ToList();

    var displayList = allMovements;
    if (currentTab == "manager") displayList = pendingManager;
    else if (currentTab == "inspection") displayList = pendingInspection;
    else if (currentTab == "import") displayList = importOnly;
    else if (currentTab == "export") displayList = exportOnly;
}

<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <a class="nav-link @(currentTab == "all" ? "active fw-bold" : "")" 
           asp-action="Index" asp-route-tab="all" asp-route-fromDate="@ViewBag.FromDate" asp-route-toDate="@ViewBag.ToDate" asp-route-search="@ViewBag.Search">
            <i class="fas fa-list me-1"></i> Tất cả phiếu
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(currentTab == "import" ? "active fw-bold" : "")" 
           asp-action="Index" asp-route-tab="import" asp-route-fromDate="@ViewBag.FromDate" asp-route-toDate="@ViewBag.ToDate" asp-route-search="@ViewBag.Search">
            <i class="fas fa-arrow-down me-1 text-success"></i> Phiếu nhập
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(currentTab == "export" ? "active fw-bold" : "")" 
           asp-action="Index" asp-route-tab="export" asp-route-fromDate="@ViewBag.FromDate" asp-route-toDate="@ViewBag.ToDate" asp-route-search="@ViewBag.Search">
            <i class="fas fa-arrow-up me-1 text-danger"></i> Phiếu xuất
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(currentTab == "manager" ? "active fw-bold" : "")" 
           asp-action="Index" asp-route-tab="manager" asp-route-fromDate="@ViewBag.FromDate" asp-route-toDate="@ViewBag.ToDate" asp-route-search="@ViewBag.Search">
            <i class="fas fa-user-tie me-1"></i> Chờ quản lý duyệt
            @if (pendingManagerCount > 0)
            {
                <span class="badge bg-danger ms-1">@pendingManagerCount</span>
            }
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(currentTab == "inspection" ? "active fw-bold" : "")" 
           asp-action="Index" asp-route-tab="inspection" asp-route-fromDate="@ViewBag.FromDate" asp-route-toDate="@ViewBag.ToDate" asp-route-search="@ViewBag.Search">
            <i class="fas fa-boxes me-1"></i> Chờ kiểm hàng
            @if (pendingInspectionCount > 0)
            {
                <span class="badge bg-warning text-dark ms-1">@pendingInspectionCount</span>
            }
        </a>
    </li>
</ul>

<div class="card border-0 shadow-sm mb-4" style="border-radius:12px;">
    <div class="card-body p-3">
        <form method="get" class="row g-3 align-items-end mb-3">
            <input type="hidden" name="tab" value="@currentTab" />
            
            <div class="col-md-3">
                <label class="form-label text-muted small fw-bold mb-1">Tìm kiếm</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" name="search" class="form-control border-start-0 ps-0" placeholder="Sản phẩm, nhà CC..." value="@ViewBag.Search" />
                </div>
            </div>
            
            <div class="col-md-3">
                <label class="form-label text-muted small fw-bold mb-1">Từ ngày</label>
                <input type="date" name="fromDate" class="form-control" value="@ViewBag.FromDate" />
            </div>
            <div class="col-md-3">
                <label class="form-label text-muted small fw-bold mb-1">Đến ngày</label>
                <input type="date" name="toDate" class="form-control" value="@ViewBag.ToDate" />
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100 fw-bold">
                    <i class="fas fa-filter"></i> Lọc dữ liệu
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm" style="border-radius:16px;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0 table-hover align-middle">
                <thead style="background-color: #fafafa;">
                    <tr>
                        <th class="border-0 px-4 py-3">Mã phiếu</th>
                        <th class="border-0 px-4 py-3">Ngày tạo</th>
                        <th class="border-0 px-4 py-3">Loại / Ghi chú</th>
                        <th class="border-0 px-4 py-3">Mặt hàng (Tóm tắt)</th>
                        <th class="border-0 px-4 py-3 text-end">Tổng giá trị</th>
                        <th class="border-0 px-4 py-3 text-center">Trạng thái</th>
                        <th class="border-0 px-4 py-3 text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (displayList != null && displayList.Any())
                    {
                        foreach (var item in displayList)
                        {
                            <tr>
                                <td class="px-4 py-3 fw-bold text-muted">#@item.MovementId</td>
                                <td class="px-4 py-3">@item.Date.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="px-4 py-3">
                                    @if (item.Type == "Nhập hàng")
                                    {
                                        <span class="text-success fw-bold"><i class="fas fa-arrow-down"></i> Nhập hàng</span>
                                        <div class="text-muted small mt-1"><i class="fas fa-truck"></i> @(item.SupplierNavigation?.Name ?? item.Supplier ?? "N/A")</div>
                                    }
                                    else if (item.Type == "Xuất nội bộ")
                                    {
                                        <span class="text-warning fw-bold"><i class="fas fa-arrow-up"></i> Xuất nội bộ</span>
                                        <div class="text-muted small mt-1"><i class="fas fa-sticky-note"></i> @(item.Supplier ?? "Không có ghi chú")</div>
                                    }
                                    else if (item.Type == "Xuất kho (Bán hàng online)")
                                    {
                                        <span class="text-danger fw-bold"><i class="fas fa-shopping-cart"></i> Xuất kho (Online)</span>
                                        <div class="text-muted small mt-1"><i class="fas fa-globe"></i> Đơn hàng trực tuyến</div>
                                    }
                                    else if (item.Type == "Xuất kho (Bán hàng POS)")
                                    {
                                        <span class="text-danger fw-bold"><i class="fas fa-cash-register"></i> Xuất kho (POS)</span>
                                        <div class="text-muted small mt-1"><i class="fas fa-store"></i> Bán tại quầy (Cashier)</div>
                                    }
                                    else
                                    {
                                        <span class="text-danger fw-bold"><i class="fas fa-arrow-up"></i> @item.Type</span>
                                        <div class="text-muted small mt-1">@(item.Supplier ?? "N/A")</div>
                                    }
                                </td>
                                <td class="px-4 py-3">
                                    <ul class="list-unstyled mb-0 small">
                                        @foreach(var detail in item.StockMovementDetails.Take(2))
                                        {
                                            <li><span class="fw-bold">@detail.Quantity</span> x @detail.ProductSkuNavigation?.Name</li>
                                        }
                                        @if(item.StockMovementDetails.Count > 2)
                                        {
                                            <li class="text-muted fst-italic">+ @(item.StockMovementDetails.Count - 2) mặt hàng khác...</li>
                                        }
                                    </ul>
                                </td>
                                <td class="px-4 py-3 text-end fw-bold">@string.Format("{0:N0} đ", item.TotalValue)</td>
                                <td class="px-4 py-3 text-center">
                                    @if (item.Status == "Hoàn thành" || item.Status == "Đã hoàn thành")
                                    {
                                        <span class="badge bg-success rounded-pill px-3 py-2">Hoàn thành</span>
                                    }
                                    else if (item.Status == "Chờ quản lý duyệt")
                                    {
                                        <span class="badge bg-danger rounded-pill px-3 py-2">Chờ quản lý duyệt</span>
                                    }
                                    else if (item.Status == "Chờ kiểm hàng")
                                    {
                                        <span class="badge bg-warning text-dark rounded-pill px-3 py-2">Chờ kiểm hàng</span>
                                    }
                                    else if (item.Status == "Đã hủy")
                                    {
                                        <span class="badge bg-secondary rounded-pill px-3 py-2">Đã hủy</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-pill px-3 py-2">@item.Status</span>
                                    }
                                </td>
                                <td class="px-4 py-3 text-end">
                                    @if (item.Type == "Nhập hàng" && item.Status == "Chờ kiểm hàng")
                                    {
                                        <a asp-action="Approve" asp-route-id="@item.MovementId" class="btn btn-sm btn-warning fw-bold" style="border-radius:8px;">
                                            <i class="fas fa-clipboard-check"></i> Kiểm hàng
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-action="Details" asp-route-id="@item.MovementId" class="btn btn-sm btn-outline-primary" style="border-radius:8px;">
                                            <i class="fas fa-eye"></i> Chi tiết
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="fas fa-file-invoice" style="font-size:2rem;opacity:.3;"></i>
                                <p class="mt-2 mb-0">@(currentTab == "inspection" ? "Không có đơn nào đang chờ kiểm hàng." : "Chưa có giao dịch xuất/nhập nào.")</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
