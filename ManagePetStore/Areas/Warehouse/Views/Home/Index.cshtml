@{
    ViewData["Title"] = "Trang Nhân Viên Kho";
}

<div class="container py-5" style="font-family: 'Outfit', sans-serif;">
    <div class="card border-0 shadow-sm p-5" style="border-radius: 20px; background: linear-gradient(135deg, #e65c00 0%, #F9D423 100%); color: #ffffff;">
        <div class="row align-items-center">
            <div class="col-md-8">
                <span class="badge bg-dark text-white mb-3 px-3 py-2" style="font-size: 0.8rem; font-weight: 600; border-radius: 20px;">PHÂN HỆ QUẢN LÝ KHO</span>
                <h1 class="display-4 font-weight-bold" style="font-weight: 700;">Xin chào, @User.FindFirst("FullName")?.Value!</h1>
                <p class="lead" style="opacity: 0.9;">Bạn đang đăng nhập dưới quyền <strong>Warehouse Staff (Nhân viên kho)</strong>. Tại đây bạn có thể quản lý sản phẩm, danh mục sản phẩm, và theo dõi các phiếu xuất/nhập kho (stock movement) của Pet Store.</p>
                <hr class="my-4" style="background-color: rgba(255,255,255,0.2);">
                <div class="d-flex gap-3 flex-wrap">
                    <a href="/Customer/Account/Profile" class="btn btn-dark px-4 py-2 text-white font-weight-bold" style="border-radius: 10px; font-weight: 600;">
                        Xem Thông Tin Cá Nhân
                    </a>
                    <form asp-area="Customer" asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-outline-light px-4 py-2" style="border-radius: 10px; font-weight: 600;">
                            Đăng xuất
                        </button>
                    </form>
                </div>
            </div>
            <div class="col-md-4 text-center d-none d-md-block">
                <svg xmlns="http://www.w3.org/2000/svg" width="180" height="180" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="opacity: 0.2;">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                </svg>
            </div>
        </div>
    </div>
</div>
