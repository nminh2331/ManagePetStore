@model ManagePetStore.Areas.ServiceStaff.Models.StaffHotelBookingDetailPageViewModel

@{
    Layout = "~/Areas/ServiceStaff/Views/Shared/_ServiceLayout.cshtml";
    ViewData["Title"] = $"Chi tiết {Model.Booking.DisplayBookingId}";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/customer-hotel-bookings.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/hotel-booking-history.css" asp-append-version="true" />
}

<div class="container-fluid py-3">
    <div class="hbh-page-header">
        <div>
            <a href="/SpaServices/HotelHistory?petId=@Model.Booking.PetId" class="hbh-back-link"><i class="fa-solid fa-arrow-left"></i> Lịch sử của @Model.Booking.PetName</a>
            <h1>Chi tiết lần lưu trú</h1>
            <p>Booking, hoạt động chăm sóc và hồ sơ sức khỏe được truy vết trên cùng một màn hình.</p>
        </div>
    </div>

    @if (TempData["HotelCareSuccess"] is string successMessage)
    {
        <div class="hbh-alert hbh-alert-success" role="status"><i class="bi bi-check-circle"></i> @successMessage</div>
    }
    @if (TempData["HotelCareError"] is string errorMessage)
    {
        <div class="hbh-alert hbh-alert-error" role="alert"><i class="bi bi-exclamation-circle"></i> @errorMessage</div>
    }

    @if (Model.Booking.StatusKey == "active")
    {
        <section class="hbh-care-editor" aria-labelledby="care-log-heading">
            <div class="hbh-care-editor-heading">
                <div>
                    <span class="hbh-eyebrow">@Model.Booking.DisplayBookingId · @Model.Booking.CageId</span>
                    <h2 id="care-log-heading">Cập nhật nhật ký chăm sóc</h2>
                    <p>Thông tin được lưu theo đúng booking của @Model.Booking.PetName. Bật thông báo để chủ nuôi nhận ngay trên web.</p>
                </div>
                <i class="bi bi-journal-plus" aria-hidden="true"></i>
            </div>

            <form action="/SpaServices/HotelCareLog" method="post" enctype="multipart/form-data" class="hbh-care-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="HotelBookingId" value="@Model.Booking.HotelBookingId" />

                <label><span>Loại hoạt động</span><select name="ActivityType" required>
                    <option value="General">Chăm sóc chung</option><option value="Feeding">Ăn uống</option>
                    <option value="Health">Sức khỏe</option><option value="Medication">Thuốc</option>
                    <option value="Exercise">Vận động</option><option value="Hygiene">Vệ sinh</option>
                    <option value="CameraSnapshot">Ảnh từ camera</option>
                </select></label>
                <label><span>Tiêu đề</span><input name="Title" maxlength="150" required placeholder="Ví dụ: Bữa trưa và kiểm tra sức khỏe" /></label>
                <label><span>Thời gian thực hiện</span><input type="datetime-local" name="OccurredAt" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required /></label>
                <label><span>Tình trạng</span><input name="Status" maxlength="30" required placeholder="Ví dụ: Ăn tốt, tinh thần vui vẻ" /></label>
                <label><span>Thức ăn</span><input name="FoodType" maxlength="100" placeholder="Để trống nếu không liên quan" /></label>
                <label><span>Khẩu phần</span><input name="Amount" maxlength="50" placeholder="Ví dụ: 120 g" /></label>
                <label class="hbh-care-form-wide"><span>Ghi chú chi tiết</span><textarea name="Note" maxlength="1000" rows="3" placeholder="Hành vi, phản ứng, thay đổi hoặc lưu ý cho chủ nuôi"></textarea></label>
                <label class="hbh-care-form-wide"><span>Ảnh hoặc video</span><input type="file" name="MediaFile" accept="image/jpeg,image/png,image/webp,video/mp4,video/webm,video/quicktime" /><small>Ảnh tối đa 10 MB; video tối đa 50 MB.</small></label>
                <label class="hbh-care-toggle hbh-care-form-wide">
                    <input type="checkbox" name="IsVisibleToCustomer" value="true" checked />
                    <input type="hidden" name="IsVisibleToCustomer" value="false" />
                    <span><strong>Thông báo cho chủ nuôi</strong><small>Lưu thông báo và đẩy realtime trên web cá nhân.</small></span>
                </label>
                <div class="hbh-care-actions hbh-care-form-wide"><button type="submit"><i class="bi bi-send"></i> Đăng nhật ký</button></div>
            </form>
        </section>
    }

    @await Html.PartialAsync("_HotelBookingHistoryDetail", Model.Booking)
</div>
