                        <select name="targetSpecies" id="editServiceSpecies" class="form-control-custom">
                            <option value="Tất cả">Tất cả</option>
                            <option value="Chó">Chó</option>
                            <option value="Mèo">Mèo</option>
                            <option value="Chuột">Chuột</option>
                            <option value="Rùa">Rùa</option>
                        </select>
                    </div>

                    <div class="modal-btn-row">
                        <button type="button" class="btn-custom-cancel" data-bs-dismiss="modal">Hủy bỏ</button>
                        <button type="submit" class="btn-custom-submit">Cập nhật</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- ======================================================= -->
<!-- MODAL E: XÁC NHẬN CHỌN GROOMER KHI BẮT ĐẦU QUEUE -->
<!-- ======================================================= -->
<div class="modal fade" id="startQueueModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content custom-modal-dialog">
            <div class="custom-modal-header">
                <span class="custom-modal-title">
                    <i class="fa-solid fa-play text-success"></i>
                    Bắt đầu thực hiện ca Spa
                </span>
                <button type="button" class="custom-modal-close-btn" data-bs-dismiss="modal" aria-label="Close">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="custom-modal-body">
                <input type="hidden" id="queueIdInput">
                
                <!-- Added hidden inputs for date and time to check groomer availability -->
                <input type="hidden" id="startQueueDateInput">
                <input type="hidden" id="startQueueTimeInput">
                
                <div class="alert alert-warning" style="font-size: 0.8rem; border-radius: 10px;">
                    Bạn đang tiến hành bắt đầu dịch vụ cho hàng đợi số <strong id="queueNumberText">SPA-00</strong>. Vui lòng chọn Kỹ thuật viên (Groomer) thực hiện.
                </div>

                <div class="form-group-custom">
                    <label>Kỹ thuật viên thực hiện</label>
                    <select id="queueGroomerSelect" class="form-control-custom" required>
                        <option value="">-- Chọn Groomer --</option>
                        @foreach (var gr in allGroomers)
                        {
                            <option value="@gr.UserId">@gr.FullName</option>
                        }
                    </select>
                </div>

                <!-- Groomer availability feedback warnings -->
                <div id="groomerAvailabilityWarning" class="alert alert-danger d-none mt-2 animate__animated animate__fadeIn" style="font-size: 0.8rem; border-radius: 10px; font-weight: bold; background-color: #FFF5F5; border-color: #F8D7DA; color: #721C24;">
                    ⚠️ Kỹ thuật viên này đã có lịch làm việc vào khung giờ này!
                </div>
                <div id="groomerAvailabilitySuccess" class="alert alert-success d-none mt-2 animate__animated animate__fadeIn" style="font-size: 0.8rem; border-radius: 10px; font-weight: bold; background-color: #E6F7ED; border-color: #D4EDDA; color: #155724;">
                    ✓ Kỹ thuật viên đang trống lịch vào khung giờ này.
                </div>

                <div class="modal-btn-row">
                    <button type="button" class="btn-custom-cancel" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="button" id="btnConfirmStartQueue" class="btn-custom-submit">Bắt đầu ngay</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ======================================================= -->
<!-- MODAL E.2: XÁC NHẬN HỦY VÀ NHẬP LÝ DO -->
<!-- ======================================================= -->
<div class="modal fade" id="cancelQueueModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content custom-modal-dialog">
            <div class="custom-modal-header">
                <span class="custom-modal-title">
                    <i class="fa-solid fa-ban text-danger"></i>
                    Hủy lịch hẹn ca Spa
                </span>
                <button type="button" class="custom-modal-close-btn" data-bs-dismiss="modal" aria-label="Close">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="custom-modal-body">
                <input type="hidden" id="cancelQueueIdInput">
                
                <div class="alert alert-danger" style="font-size: 0.8rem; border-radius: 10px;">
                    Bạn đang thực hiện hủy lịch hẹn cho hàng đợi số <strong id="cancelQueueNumberText">SPA-00</strong>. Hành động này không thể hoàn tác.
                </div>

                <div class="form-group-custom">
                    <label>Lý do hủy lịch hẹn <strong class="text-danger">*</strong></label>
                    <textarea id="cancelReasonInput" class="form-control-custom" rows="3" placeholder="Vui lòng nhập lý do hủy lịch hẹn (bắt buộc)..." required></textarea>
                </div>

                <div class="modal-btn-row">
                    <button type="button" class="btn-custom-cancel" data-bs-dismiss="modal">Đóng</button>
                    <button type="button" id="btnConfirmCancelQueue" class="btn btn-danger" style="border-radius: 12px; font-weight: 700; font-size: 0.85rem; height: 46px; padding: 0 20px;">Hủy lịch hẹn</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ======================================================= -->
<!-- MODAL F: XEM CHI TIẾT HÀNG ĐỢI (ONLINE & WALK-IN PENDING) -->
<!-- ======================================================= -->
<div class="modal fade" id="queueDetailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content custom-modal-dialog">
            <div class="custom-modal-header">
                <span class="custom-modal-title">
                    <i class="fa-solid fa-circle-info text-info"></i>
                    Chi tiết thông tin hàng đợi
                </span>
                <button type="button" class="custom-modal-close-btn" data-bs-dismiss="modal" aria-label="Close">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="custom-modal-body" style="font-size: 0.85rem;">
                <input type="hidden" id="detailsQueueIdInput">
                <input type="hidden" id="detailsQueueNumberInput">
                
                <!-- Customer info -->
                <div style="background-color: #f8f9fa; border-radius: 12px; padding: 15px; border: 1px solid #ECE9E5; margin-bottom: 15px;">
                    <h5 style="font-size: 0.9rem; font-weight: 700; color: #2D2521; border-bottom: 1px solid #EFECE9; padding-bottom: 6px; margin-bottom: 10px;">
                        <i class="fa-solid fa-user" style="color: #FF7815;"></i> THÔNG TIN KHÁCH HÀNG
                    </h5>
                    <p style="margin: 4px 0;">Họ tên: <strong id="detailsCustomerName">--</strong></p>
                    <p style="margin: 4px 0;">Số điện thoại: <strong id="detailsCustomerPhone">--</strong></p>
                </div>

                <!-- Pet info -->
                <div style="background-color: #f8f9fa; border-radius: 12px; padding: 15px; border: 1px solid #ECE9E5; margin-bottom: 15px;">
                    <h5 style="font-size: 0.9rem; font-weight: 700; color: #2D2521; border-bottom: 1px solid #EFECE9; padding-bottom: 6px; margin-bottom: 10px;">
                        <i class="fa-solid fa-paw" style="color: #FF7815;"></i> THÔNG TIN THÚ CƯNG
                    </h5>
                    <div class="row">
                        <div class="col-6"><p style="margin: 4px 0;">Tên Pet: <strong id="detailsPetName">--</strong></p></div>
                        <div class="col-6"><p style="margin: 4px 0;">Loài: <strong id="detailsPetSpecies">--</strong></p></div>
                        <div class="col-6"><p style="margin: 4px 0;">Giống: <strong id="detailsPetBreed">--</strong></p></div>
                        <div class="col-6"><p style="margin: 4px 0;">Tuổi: <strong id="detailsPetAge">--</strong></p></div>
                        <div class="col-6"><p style="margin: 4px 0;">Cân nặng: <strong id="detailsPetWeight">-- kg</strong></p></div>
                    </div>
                    <div style="margin-top: 10px; padding: 8px 12px; background-color: #FFF5F5; border-radius: 8px; border-left: 3px solid #EC5959;">
                        <span style="font-size: 0.72rem; font-weight: 700; color: #EC5959; display: block;">Lưu ý sức khỏe & Bệnh lý:</span>
                        <p id="detailsPetPathology" style="margin: 4px 0 0 0; font-size: 0.78rem; color: #5D524D;">Khỏe mạnh, bình thường</p>
                    </div>
                </div>

                <!-- Service info -->
                <div style="background-color: #f8f9fa; border-radius: 12px; padding: 15px; border: 1px solid #ECE9E5; margin-bottom: 20px;">
                    <h5 style="font-size: 0.9rem; font-weight: 700; color: #2D2521; border-bottom: 1px solid #EFECE9; padding-bottom: 6px; margin-bottom: 10px;">
                        <i class="fa-solid fa-file-invoice" style="color: #FF7815;"></i> THÔNG TIN ĐẶT LỊCH DỊCH VỤ
                    </h5>
                    <p style="margin: 4px 0;">Vé chờ: <strong id="detailsQueueNumber">--</strong></p>
                    <p style="margin: 4px 0;">Dịch vụ Spa: <strong id="detailsServiceName" style="color: #FF7815;">--</strong></p>
                    <p style="margin: 4px 0;">Giờ hẹn: <strong id="detailsTimeSlot">--</strong></p>
                    <p style="margin: 4px 0;">Ghi chú yêu cầu: <span id="detailsNote" style="font-style: italic; color: #7E736F;">--</span></p>
                </div>

                <div class="modal-btn-row">
                    <button type="button" class="btn-custom-cancel" data-bs-dismiss="modal" style="flex: 1;">Đóng</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {


            // =========================================================================
            // 2. DATEPICKER CHANGED -> RELOAD DATE
            // =========================================================================
            $('#datePicker').change(function () {
                var date = $(this).val();
                window.location.href = '/SpaServices?date=' + date;
            });



            // =========================================================================
            // 4. INTERACTION: TOGGLE ACTIVE SERVICE STATUS (AJAX)
            // =========================================================================
            $('.toggle-service-status').change(function () {
                var id = $(this).data('id');
                var isChecked = $(this).is(':checked');
                var self = this;

                $.post('/SpaServices/ToggleActive', { id: id }, function (response) {
                    if (response.success) {
                        showToast(response.active ? 'Kích hoạt dịch vụ thành công! Đang tải lại...' : 'Ngưng áp dụng dịch vụ thành công! Đang tải lại...', 'success');
                        
                        setTimeout(function () {
                            window.location.reload();
                        }, 1000);
                    } else {
                        showToast('Có lỗi xảy ra: ' + response.message, 'danger');
                        $(self).prop('checked', !isChecked);
                    }
                }).fail(function () {
                    showToast('Lỗi kết nối máy chủ.', 'danger');
                    $(self).prop('checked', !isChecked);
                });
            });

            // =========================================================================
            // 5. INTERACTION: EDIT & DELETE SERVICE (AJAX / MODAL)
            // =========================================================================
            $('.btn-edit-service-trigger').click(function () {
                var id = $(this).data('id');
                var name = $(this).data('name');
                var duration = $(this).data('duration');
                var price = $(this).data('price');
                var species = $(this).data('species') || 'Tất cả';

                $('#editServiceId').val(id);
                $('#editServiceName').val(name);
                $('#editServiceDuration').val(duration);
                $('#editServicePrice').val(price);
                $('#editServiceSpecies').val(species);

                $('#editServiceModal').modal('show');
            });

            $('.btn-delete-service-trigger').click(function () {
                var id = $(this).data('id');
                var name = $(this).data('name');

                if (confirm('Bạn có chắc chắn muốn xóa dịch vụ "' + name + '" không?')) {
                    $.post('/SpaServices/DeleteService', { id: id }, function (response) {
                        if (response.success) {
                            showToast(response.message, 'success');
                            setTimeout(function () {
                                window.location.reload();
                            }, 1000);
                        } else {
                            showToast('Lỗi: ' + response.message, 'danger');
                        }
                    });
                }
            });

            // =========================================================================
            // 6. INTERACTION: CANCEL SPA APPOINTMENT (AJAX)
            // =========================================================================
            $('.btn-cancel-booking').click(function (e) {
                e.stopPropagation();
                var bookingId = $(this).data('id');
                var self = this;

                if (confirm('Bạn có chắc chắn muốn hủy lịch hẹn Spa này không?')) {
                    $.post('/SpaServices/CancelBooking', { bookingId: bookingId }, function (response) {
                        if (response.success) {
                            showToast(response.message, 'success');
                            setTimeout(function () {
                                window.location.reload();
                            }, 1000);
                        } else {
                            showToast('Lỗi: ' + response.message, 'danger');
                        }
                    });
                }
            });

            // =========================================================================
            // 6.5 INTERACTION: EDIT WALK-IN GUEST & PET (AJAX)
            // =========================================================================
            $(document).on('click', '.btn-edit-walkin', function () {
                var queueId = $(this).data('id');
                
                $.getJSON('/SpaServices/GetWalkInDetails', { queueId: queueId }, function (data) {
                    $('#editWalkInQueueId').val(data.queueId);
                    $('#editWalkInPetName').val(data.petName);
                    $('#editWalkInSpecies').val(data.species);
                    $('#editWalkInBreed').val(data.breed);
                    $('#editWalkInAge').val(data.age);
                    $('#editWalkInWeight').val(data.weight);
                    $('#editWalkInCustomerName').val(data.customerName);
                    $('#editWalkInPhone').val(data.phone);
                    $('#editWalkInServiceId').val(data.serviceId);
                    $('#editWalkInTimeSlot').val(data.timeSlot);
                    $('#editWalkInNote').val(data.note);

                    $('#editWalkInModal').modal('show');
                }).fail(function() {
                    showToast('Không thể tải thông tin khách vãng lai.', 'danger');
                });
            });

            // =========================================================================
            // 7. INTERACTION: START REAL-TIME QUEUE (NHẬN CHĂM SÓC / BẮT ĐẦU NGAY)
            // =========================================================================
            var busyGroomers = [];

            function checkAllGroomersAvailability() {
                var date = $('#startQueueDateInput').val();
                var time = $('#startQueueTimeInput').val();
                var selectEl = $('#queueGroomerSelect');
                
                if (!date || !time) return;

                $.getJSON('/SpaServices/GetGroomersBusyStatus', { date: date, time: time }, function (busyIds) {
                    busyGroomers = busyIds;
                    
                    selectEl.find('option').each(function () {
                        var option = $(this);
                        var groomerId = parseInt(option.val());
                        if (isNaN(groomerId)) return;

                        var originalText = option.data('original-text');
                        if (!originalText) {
                            originalText = option.text();
                            option.data('original-text', originalText);
                        }

                        if (busyIds.includes(groomerId)) {
                            option.css('color', '#c62828');
                            option.css('background-color', '#ffebee');
                            option.text(originalText + ' (Đã có lịch)');
                        } else {
                            option.css('color', '#155724');
                            option.css('background-color', '#e6f7ed');
                            option.text(originalText + ' (Trống lịch)');
                        }
                    });

                    updateSelectedGroomerAlert();
                });
            }

            function updateSelectedGroomerAlert() {
                var selectedGroomerId = parseInt($('#queueGroomerSelect').val());
                
                $('#groomerAvailabilityWarning').addClass('d-none');
                $('#groomerAvailabilitySuccess').addClass('d-none');
                $('#btnConfirmStartQueue').prop('disabled', false); // default to enabled

                if (!selectedGroomerId) {
                    return;
                }

                if (busyGroomers.includes(selectedGroomerId)) {
                    $('#groomerAvailabilityWarning').removeClass('d-none');
                    $('#btnConfirmStartQueue').prop('disabled', true); // Block start!
                } else {
                    $('#groomerAvailabilitySuccess').removeClass('d-none');
                }
            }

            $('#queueGroomerSelect').change(function () {
                updateSelectedGroomerAlert();
            });

            $(document).on('click', '.btn-start-queue', function () {
                var queueId = $(this).data('id');
                var queueNumber = $(this).data('number');

                $('#queueIdInput').val(queueId);
                $('#queueNumberText').text(queueNumber);
                $('#queueGroomerSelect').val('');

                $('#groomerAvailabilityWarning').addClass('d-none');
                $('#groomerAvailabilitySuccess').addClass('d-none');
                $('#btnConfirmStartQueue').prop('disabled', false); // reset state

                var selectedDate = $('#datePicker').val();
                $('#startQueueDateInput').val(selectedDate);

                $.getJSON('/SpaServices/GetWalkInDetails', { queueId: queueId }, function (data) {
                    $('#startQueueTimeInput').val(data.timeSlot);
                    checkAllGroomersAvailability();
                    $('#startQueueModal').modal('show');
                }).fail(function () {
                    $('#startQueueTimeInput').val('08:00');
                    checkAllGroomersAvailability();
                    $('#startQueueModal').modal('show');
                });
            });

            $('#btnConfirmStartQueue').click(function () {
                var queueId = $('#queueIdInput').val();
                var groomerId = $('#queueGroomerSelect').val();
                var selectedDate = $('#datePicker').val();

                if (!groomerId) {
                    alert('Vui lòng chọn Kỹ thuật viên (Groomer) thực hiện.');
                    return;
                }

                if (busyGroomers.includes(parseInt(groomerId))) {
                    alert('Kỹ thuật viên này đã có lịch làm việc vào khung giờ này. Vui lòng chọn Kỹ thuật viên khác!');
                    return;
                }

                $.post('/SpaServices/StartQueue', { queueId: queueId, groomerId: groomerId, date: selectedDate }, function (response) {
                    if (response.success) {
                        showToast(response.message, 'success');
                        $('#startQueueModal').modal('hide');
                        setTimeout(function () {
                            window.location.reload();
                        }, 1000);
                    } else {
                        showToast('Lỗi: ' + response.message, 'danger');
                    }
                }).fail(function () {
                    showToast('Lỗi kết nối máy chủ.', 'danger');
                });
            });

            // =========================================================================
            // 7.1. INTERACTION: ACCEPT WALK-IN PET (PENDING -> REAL-TIME QUEUE)
            // =========================================================================
            $(document).on('click', '.btn-accept-walkin', function () {
                var queueId = $(this).data('id');
                $.post('/SpaServices/AcceptWalkIn', { queueId: queueId }, function (response) {
                    if (response.success) {
                        showToast(response.message, 'success');
                        setTimeout(function () {
                            window.location.reload();
                        }, 1000);
                    } else {
                        showToast('Lỗi: ' + response.message, 'danger');
                    }
                }).fail(function () {
                    showToast('Lỗi kết nối máy chủ.', 'danger');
                });
            });

            // =========================================================================
            // 7.2. INTERACTION: CANCEL QUEUE ITEM (OL- OR WI-)
            // =========================================================================
            $(document).on('click', '.btn-cancel-queue', function () {
                var queueId = $(this).data('id');
                var queueNumber = $(this).data('number');

                $('#cancelQueueIdInput').val(queueId);
                $('#cancelQueueNumberText').text(queueNumber);
                $('#cancelReasonInput').val('');

                $('#cancelQueueModal').modal('show');
            });

            $('#btnConfirmCancelQueue').click(function () {
                var queueId = $('#cancelQueueIdInput').val();
                var reason = $('#cancelReasonInput').val().trim();

                if (!reason) {
                    alert('Vui lòng nhập lý do hủy lịch hẹn.');
                    return;
                }

                $.post('/SpaServices/CancelQueueItem', { queueId: queueId, reason: reason }, function (response) {
                    if (response.success) {
                        showToast(response.message, 'success');
                        $('#cancelQueueModal').modal('hide');
                        setTimeout(function () {
                            window.location.reload();
                        }, 1000);
                    } else {
                        showToast('Lỗi: ' + response.message, 'danger');
                    }
                }).fail(function () {
                    showToast('Lỗi kết nối máy chủ.', 'danger');
                });
            });

            // =========================================================================
            // 7.3. INTERACTION: VIEW QUEUE DETAILS MODAL
            // =========================================================================
            $(document).on('click', '.btn-view-queue-details', function () {
                var queueId = $(this).data('id');
                
                $.getJSON('/SpaServices/GetWalkInDetails', { queueId: queueId }, function (data) {
                    $('#detailsQueueIdInput').val(data.queueId);
                    $('#detailsQueueNumberInput').val(data.queueNumber);
                    
                    $('#detailsCustomerName').text(data.customerName);
                    $('#detailsCustomerPhone').text(data.phone);
                    
                    $('#detailsPetName').text(data.petName);
                    $('#detailsPetSpecies').text(data.species === 'Chó' ? 'CHÓ' : 'MÈO');
                    $('#detailsPetBreed').text(data.breed);
                    $('#detailsPetAge').text(data.age);
                    $('#detailsPetWeight').text(data.weight + ' kg');
                    $('#detailsPetPathology').text(data.pathology);
                    
                    $('#detailsQueueNumber').text(data.queueNumber);
                    $('#detailsServiceName').text(data.serviceName);
                    $('#detailsTimeSlot').text(data.timeSlot);
                    $('#detailsNote').text(data.note ? data.note : 'Không có ghi chú đặc biệt');
                    
                    $('#queueDetailsModal').modal('show');
                }).fail(function() {
                    showToast('Không thể tải thông tin chi tiết hàng đợi.', 'danger');
                });
            });



            // =========================================================================
            // 8. INTERACTION: OPEN PROGRESS TIMELINE MODAL (MOCKUP 2)
            // =========================================================================
            $('.btn-view-progress').click(function (e) {
                if ($(e.target).closest('.btn-cancel-booking').length > 0) return;

                var bookingId = $(this).data('id');
                
                $.getJSON('/SpaServices/GetBookingDetails', { bookingId: bookingId }, function (data) {
                    $('#progBookingIdInput').val(data.bookingId);
                    $('#progGroomerName').text(data.groomerName);
                    $('#progTimeSlot').text(data.timeSlot);
                    $('#progPetName').text(data.petName);
                    $('#progPetBreed').text(data.petBreed + ' • ' + (data.petSpecies === 'Chó' ? 'CHÓ' : 'MÈO'));
                    $('#progPetAge').text(data.petAge);
                    $('#progPetWeight').text(data.petWeight + ' kg');
                    $('#progPetPathology').text(data.petPathology);
                    
                    updateStepperUI(data.activeStep, data.completedSteps);

                    $('#spaProgressModal').modal('show');
                });
            });

            function updateStepperUI(activeStep, completedSteps) {
                var statuses = ["Tiếp nhận", "Tắm & Sấy", "Cắt & Tỉa", "Massage", "Hoàn thành"];
                
                // Clear classes
                $('.timeline-step').removeClass('completed active');
                $('.status-active-tag').addClass('d-none');

                $.each(statuses, function (index, status) {
                    var safeId = '#step-' + status.replace(/\s+/g, '-').replace('&', '').replace('--', '-');
                    var badgeId = '#badge-' + status.replace(/\s+/g, '-').replace('&', '').replace('--', '-');

                    // Trạng thái đã hoàn thành (Tích chọn V)
                    if (completedSteps.includes(status)) {
                        $(safeId).addClass('completed');
                    }
                    
                    // Trạng thái đang làm (ĐANG THỰC HIỆN)
                    if (status === activeStep) {
                        $(safeId).addClass('active');
                        $(badgeId).removeClass('d-none');
                    }
                });

                // Cập nhật class Active cho nút bấm tương ứng
                $('.btn-status-option').removeClass('active');
                $('.btn-status-option[data-status="' + activeStep + '"]').addClass('active');
            }

            $('.btn-status-option').click(function () {
                var bookingId = $('#progBookingIdInput').val();
                var status = $(this).data('status');
                var self = this;

                $.post('/SpaServices/UpdateSpaStatus', { bookingId: bookingId, status: status }, function (response) {
                    if (response.success) {
                        showToast(response.message, 'success');
                        updateStepperUI(response.activeStep, response.completedSteps);

                        setTimeout(function () {
                            window.location.reload();
                        }, 1200);
                    } else {
                        showToast('Có lỗi: ' + response.message, 'danger');
                    }
                });
            });

            // =========================================================================
            // 9. REAL-TIME QUEUE POLLING EVERY 30 SECONDS
            // =========================================================================
            function escapeHtml(str) {
                if (!str) return '';
                return str.toString()
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#039;");
            }

            var currentQueuePage = @ViewBag.QueuePage;
            setInterval(function () {
                $.getJSON('/SpaServices/GetRealtimeQueue', { page: currentQueuePage }, function (data) {
                    $('#queueCount').text(data.totalItems + ' Chờ');
                    
                    var html = '';
                    $.each(data.queue, function (index, item) {
                        html += '<div class="queue-item-card" id="queueItem-' + item.queueId + '">';
                        html += '  <div class="queue-item-row1">';
                        html += '    <span class="queue-number-badge"><i class="fa-solid fa-ticket"></i> ' + escapeHtml(item.queueNumber) + '</span>';
                        html += '    <span class="queue-arrival-time">' + escapeHtml(item.arrivalTime) + '</span>';
                        html += '  </div>';
                        html += '  <p class="queue-pet-name">' + escapeHtml(item.petName) + '</p>';
                        html += '  <p class="queue-service-name">' + escapeHtml(item.serviceDescription) + '</p>';
                        
                        if (item.note) {
                            html += '  <div class="queue-note-text"><strong>Ghi chú:</strong> ' + escapeHtml(item.note) + '</div>';
                        }
                        
                        html += '  <p class="queue-owner-text">Khách: <strong>' + escapeHtml(item.ownerName) + '</strong></p>';
                        html += '  <div class="d-flex gap-1 mt-2">';
                        html += '    <button class="btn btn-sm btn-start-queue flex-grow-1" data-id="' + item.queueId + '" data-number="' + escapeHtml(item.queueNumber) + '" style="background-color: #FF7815; color: #FFFFFF; border: none; font-size: 0.72rem; font-weight: 700; border-radius: 8px; padding: 6px 10px;">';
                        html += '      <i class="fa-solid fa-play"></i> BẮT ĐẦU';
                        html += '    </button>';
                        html += '    <button class="btn btn-sm btn-view-queue-details" data-id="' + item.queueId + '" style="background-color: #17a2b8; color: #FFFFFF; border: none; font-size: 0.72rem; font-weight: 700; border-radius: 8px; padding: 6px 10px;" title="Xem chi tiết">';
                        html += '      <i class="fa-solid fa-circle-info"></i> CHI TIẾT';
                        html += '    </button>';
                        html += '    <button class="btn btn-sm btn-cancel-queue" data-id="' + item.queueId + '" data-number="' + escapeHtml(item.queueNumber) + '" style="background-color: #dc3545; color: #FFFFFF; border: none; font-size: 0.72rem; font-weight: 700; border-radius: 8px; padding: 6px 10px;" title="Hủy lịch hẹn">';
                        html += '      <i class="fa-solid fa-trash"></i> HỦY';
                        html += '    </button>';
                        html += '  </div>';
                        html += '</div>';
                    });
                    
                    $('#queueList').html(html);
                });
            }, 30000);

            function showToast(message, type) {
                var toastHtml = '<div class="toast align-items-center text-white bg-' + type + ' border-0 shadow" role="alert" aria-live="assertive" aria-atomic="true" style="border-radius: 12px; margin-bottom: 10px;">' +
                                '  <div class="d-flex">' +
                                '    <div class="toast-body">' +
                                '      <i class="fa-solid ' + (type === 'success' ? 'fa-circle-check' : 'fa-circle-xmark') + ' me-2"></i> ' + escapeHtml(message) +
                                '    </div>' +
                                '    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>' +
                                '  </div>' +
                                '</div>';
                
                var $toast = $(toastHtml).appendTo('.toast-container');
                var bsToast = new bootstrap.Toast($toast[0]);
                bsToast.show();
                
                $toast.on('hidden.bs.toast', function () {
                    $(this).remove();
                });
            }
        });
    </script>
}
