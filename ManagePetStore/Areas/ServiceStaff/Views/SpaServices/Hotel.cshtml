<!-- MODAL: TIẾP NHẬN THÚ CƯNG (CHECK-IN)                          -->
<!-- =============================================================== -->
<div class="modal fade" id="checkInModal" tabindex="-1">
    <div class="modal-dialog hotel-modal-dialog modal-lg">
        <div class="modal-content">
            <div class="hotel-modal-header">
                <h5 class="hotel-modal-title">
                    <i class="fa-solid fa-clipboard-list"></i>
                    Tiếp nhận thú cưng vào chuồng
                </h5>
                <button class="hotel-modal-close" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="hotel-modal-body">
                <form method="post" action="/SpaServices/CheckIn" id="checkInForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="hotelBookingId" id="ci-hotelBookingId" value="">

                    <p class="form-section-label"><i class="fa-solid fa-route"></i> Hình thức tiếp nhận</p>
                    <div class="reception-mode-grid" role="radiogroup" aria-label="Hình thức tiếp nhận">
                        <label class="reception-mode-option" for="ci-mode-medical">
                            <input type="radio" name="receptionMode" id="ci-mode-medical" value="MedicalRecord" required onchange="setReceptionMode()">
                            <strong>Dùng sổ y tế có sẵn</strong>
                            <small>Chọn thú cưng có sổ y tế, hệ thống hiển thị thông tin gần nhất để đối chiếu.</small>
                        </label>
                        <label class="reception-mode-option" for="ci-mode-new">
                            <input type="radio" name="receptionMode" id="ci-mode-new" value="NoMedicalRecord" required onchange="setReceptionMode()">
                            <strong>Chưa có sổ y tế</strong>
                            <small>Kiểm tra ban đầu và tạo bản ghi y tế đầu tiên từ lần tiếp nhận này.</small>
                        </label>
                    </div>
                    <div id="receptionModeHint" class="health-warning-strip">
                        <i class="fa-solid fa-circle-info"></i>
                        Chọn hình thức trước khi tra cứu thú cưng.
                    </div>

                    <!-- THÔNG TIN CHỦ -->
                    <p class="form-section-label"><i class="fa-solid fa-user"></i> Thông tin chủ thú cưng</p>

                    <div class="grid-2">
                        <div class="hform-group">
                            <label class="hform-label">Số điện thoại <span class="req">*</span></label>
                            <input type="tel" name="customerPhone" id="ci-phone" class="hform-control"
                                placeholder="0912345678" required maxlength="15" pattern="0(?:[\s.-]?\d){9,10}"
                                title="Số điện thoại phải bắt đầu bằng 0 và gồm 10-11 chữ số."
                                oninput="lookupCustomer(this.value)">
                        </div>
                        <div class="hform-group">
                            <label class="hform-label">Họ tên chủ thú cưng <span class="req">*</span></label>
                            <input type="text" name="customerName" id="ci-customerName" class="hform-control"
                                placeholder="Nhập họ tên..." required maxlength="100">
                        </div>
                    </div>

                    <!-- THÔNG TIN THÚ CƯNG -->
                    <p class="form-section-label"><i class="fa-solid fa-paw"></i> Thông tin thú cưng</p>

                    <!-- Dropdown chọn pet có sẵn hoặc tạo mới -->
                    <div class="hform-group" id="existingPetGroup" style="display:none;">
                        <label class="hform-label" id="existingPetLabel">Chọn thú cưng đã có hồ sơ</label>
                        <select id="ci-existingPet" class="hform-control" onchange="fillExistingPet(this)">
                            <option value="">— Tạo mới —</option>
                        </select>
                        <small id="existingPetHelp" style="display:block; color:#9E918B; margin-top:6px; font-size:.74rem;"></small>
                    </div>
                    <input type="hidden" name="existingPetId" id="ci-existingPetHidden" value="">

                    <div id="medicalRecordSummary" class="medical-record-summary" aria-live="polite"></div>

                    <div id="petNewForm">
                        <div class="grid-3">
                            <div class="hform-group">
                                <label class="hform-label">Tên thú cưng <span class="req">*</span></label>
                                <input type="text" name="petName" id="ci-petName" class="hform-control" placeholder="VD: Mochi" required maxlength="50">
                            </div>
                            <div class="hform-group">
                                <label class="hform-label">Loài <span class="req">*</span></label>
                                <select name="species" id="ci-species" class="hform-control">
                                    <option value="Chó">🐕 Chó</option>
                                    <option value="Mèo">🐈 Mèo</option>
                                    <option value="Thỏ">🐇 Thỏ</option>
                                    <option value="Hamster">🐹 Hamster</option>
                                    <option value="Khác">Khác</option>
                                </select>
                            </div>
                            <div class="hform-group">
                                <label class="hform-label">Giống</label>
                                <input type="text" name="breed" id="ci-breed" class="hform-control" placeholder="VD: Poodle" maxlength="50">
                            </div>
                        </div>
                        <div class="grid-2">
                            <div class="hform-group">
                                <label class="hform-label">Tuổi</label>
                                <input type="text" name="age" id="ci-age" class="hform-control" placeholder="VD: 2 tuổi" maxlength="30">
                            </div>
                            <div class="hform-group">
                                <label class="hform-label">Cân nặng (kg) <span class="req">*</span></label>
                                <input type="number" name="weight" id="ci-weight" class="hform-control" placeholder="4.5"
                                    step="0.01" min="0.1" max="200" required>
                            </div>
                        </div>
                    </div>

                    <!-- TÌNH TRẠNG SỨC KHỎE -->
                    <p class="form-section-label"><i class="fa-solid fa-heart-pulse"></i> Kiểm tra sức khỏe khi tiếp nhận</p>

                    <div class="health-warning-strip">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                        Phải hoàn tất và xác nhận kiểm tra sức khỏe trước khi hệ thống nhận thú cưng vào chuồng.
                    </div>

                    <div class="grid-2">
                        <div class="hform-group">
                            <label class="hform-label">Kết luận kiểm tra <span class="req">*</span></label>
                            <select name="healthStatus" id="ci-healthStatus" class="hform-control" required onchange="updateHealthStatus()">
                                <option value="">— Chọn kết luận —</option>
                                <option value="Fit">Đủ điều kiện lưu trú</option>
                                <option value="Monitor">Đủ điều kiện, cần theo dõi</option>
                                <option value="Rejected">Không đủ điều kiện lưu trú</option>
                            </select>
                        </div>
                        <div class="hform-group">
                            <label class="hform-label">Nhiệt độ cơ thể (°C) <span class="req">*</span></label>
                            <input type="number" name="bodyTemperature" id="ci-temperature" class="hform-control"
                                placeholder="VD: 38.5" step="0.1" min="30" max="45" required>
                        </div>
                    </div>
                    <div class="hform-group">
                        <label class="hform-label">Bệnh lý / Tình trạng đặc biệt</label>
                        <input type="text" name="pathology" id="ci-pathology" class="hform-control health-input"
                            maxlength="1000"
                            placeholder="VD: Bị dị ứng thức ăn hải sản, đang dùng thuốc tim... (để trống nếu khỏe mạnh)">
                    </div>
                    <div class="hform-group">
                        <label class="hform-label">Kết quả quan sát / Ghi chú kiểm tra <span class="req">*</span></label>
                        <textarea name="healthNote" id="ci-healthNote" class="hform-control" rows="2"
                            required minlength="5" maxlength="1000"
                            placeholder="VD: Tỉnh táo, ăn uống bình thường, không có vết thương ngoài da..."></textarea>
                    </div>
                    <div id="healthStatusMessage" class="health-warning-strip" style="display:none;"></div>
                    <div class="hform-group" style="display:flex; gap:9px; align-items:flex-start;">
                        <input type="checkbox" name="healthCheckConfirmed" id="ci-healthConfirmed" value="true" required style="margin-top:3px;">
                        <label for="ci-healthConfirmed" class="hform-label" style="text-transform:none; line-height:1.45; cursor:pointer;">
                            Tôi xác nhận đã trực tiếp kiểm tra và ghi nhận đúng tình trạng sức khỏe của thú cưng.
                            <span class="req">*</span>
                        </label>
                    </div>

                    <!-- CHỌN CHUỒNG -->
                    <p class="form-section-label"><i class="fa-solid fa-border-all"></i> Chọn chuồng</p>

                    <div class="grid-2">
                        <div class="hform-group">
                            <label class="hform-label">Loại chuồng <span class="req">*</span></label>
                            <select name="roomTypeId" id="ci-roomType" class="hform-control" onchange="loadAvailableCages(this.value)" required>
                                <option value="">— Chọn loại chuồng —</option>
                                @foreach (var rt in activeRoomTypes)
                                {
                                    <option value="@rt.RoomTypeId" data-price="@rt.DailyPrice">
                                        @rt.Type — @rt.DailyPrice.ToString("N0")đ/ngày
                                    </option>
                                }
                            </select>
                        </div>
                        <div class="hform-group">
                            <label class="hform-label">Chuồng trống <span class="req">*</span></label>
                            <select name="cageId" id="ci-cage" class="hform-control" required>
                                <option value="">— Chọn loại chuồng trước —</option>
                            </select>
                        </div>
                    </div>

                    <div class="grid-2">
                        <div class="hform-group">
                            <label class="hform-label">Ngày nhận <span class="req">*</span></label>
                            <input type="datetime-local" name="checkInDate" id="ci-checkIn" class="hform-control" required>
                        </div>
                        <div class="hform-group">
                            <label class="hform-label">Ngày trả dự kiến</label>
                            <input type="datetime-local" name="checkOutDate" id="ci-checkOut" class="hform-control">
                        </div>
                    </div>

                    <!-- Preview giá -->
                    <div id="pricePreview" style="display:none; background:#FFF9F5; border:1px solid #FFE0CC; border-radius:12px; padding:14px 16px; margin-top:4px;">
                        <div style="display:flex; justify-content:space-between; align-items:center;">
                            <span style="font-size:0.8rem; color:#9E918B;">Ước tính chi phí:</span>
                            <span id="pricePreviewValue" style="font-size:1.1rem; font-weight:800; color:#FF7815;"></span>
                        </div>
                        <p style="font-size:0.72rem; color:#9E918B; margin:4px 0 0 0;" id="pricePreviewDetail"></p>
                    </div>

                    <div class="modal-btn-row">
                        <button type="button" class="btn-modal-cancel" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn-modal-submit" id="checkInSubmitBtn">
                            <i class="fa-solid fa-clipboard-check" style="margin-right:6px;"></i>
                            Xác nhận tiếp nhận
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

