                    </div>
                    <div class="hform-group">
                        <label class="hform-label">Loại chuồng <span class="req">*</span></label>
                        <select name="roomTypeId" id="edit-cage-roomtype" class="hform-control" required>
                            @foreach (var rt in activeRoomTypes)
                            {
                                <option value="@rt.RoomTypeId">@rt.Type (@rt.DailyPrice.ToString("N0")đ/ngày)</option>
                            }
                        </select>
                    </div>
                    <div class="hform-group">
                        <label class="hform-label">Lịch cho ăn</label>
                        <input type="text" name="feedSchedule" id="edit-cage-feed" class="hform-control">
                    </div>
                    <div class="hform-group">
                        <label class="hform-label">Khẩu phần (gram)</label>
                        <input type="number" name="portion" id="edit-cage-portion" class="hform-control" min="10">
                    </div>
                    <div class="modal-btn-row">
                        <button type="button" class="btn-modal-cancel" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn-modal-submit">
                            <i class="fa-solid fa-floppy-disk" style="margin-right:6px;"></i>Lưu thay đổi
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- =============================================================== -->
<!-- MODAL: XÁC NHẬN CHECK-OUT                                      -->
<!-- =============================================================== -->
<div class="modal fade" id="checkOutModal" tabindex="-1">
    <div class="modal-dialog" style="max-width:420px;">
        <div class="modal-content" style="border-radius:20px; border:none; box-shadow:0 20px 60px rgba(45,37,33,0.18);">
            <div class="hotel-modal-header">
                <h5 class="hotel-modal-title" style="color:#DC3545;">
                    <i class="fa-solid fa-right-from-bracket" style="color:#DC3545;"></i>
                    Xác nhận trả chuồng
                </h5>
                <button class="hotel-modal-close" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="hotel-modal-body">
                <div style="background:#FDE8E8; border-radius:12px; padding:16px; margin-bottom:16px; text-align:center;">
                    <i class="fa-solid fa-paw" style="font-size:1.8rem; color:#DC3545; margin-bottom:8px; display:block;"></i>
                    <p style="font-size:0.9rem; font-weight:700; color:#2D2521; margin:0;" id="checkoutPetName">—</p>
                    <p style="font-size:0.78rem; color:#9E918B; margin:4px 0 0 0;" id="checkoutCageId">Chuồng —</p>
                </div>
                <div id="checkoutLoading" style="text-align:center; padding:12px;">Đang tính chi phí...</div>
                <div id="checkoutCostContent" hidden>
                    <div id="checkoutCostItems" style="display:grid; gap:6px; margin-bottom:12px;"></div>
                    <div style="display:flex;justify-content:space-between;border-top:1px solid #eee;padding-top:10px;"><span>Giảm giá phòng</span><strong id="checkoutDiscount">0đ</strong></div>
                    <div style="display:flex;justify-content:space-between;font-size:1rem;margin-top:8px;"><strong>Tổng chốt</strong><strong id="checkoutTotal" style="color:#DC3545;">0đ</strong></div>
                    <div id="checkoutOtherFields" style="margin-top:12px;display:grid;gap:8px;">
                        <input class="form-control" id="checkoutOtherDescription" maxlength="250" placeholder="Chi phí khác (nếu có)" />
                        <input class="form-control" id="checkoutOtherAmount" type="number" min="0" step="1000" value="0" placeholder="Số tiền" />
                    </div>
                    <p id="checkoutPaymentStatus" style="font-size:0.78rem;color:#7A6E68;margin:10px 0 0;"></p>
                </div>
                <div class="modal-btn-row">
                    <button type="button" class="btn-modal-cancel" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn-modal-danger" id="confirmCheckoutBtn">
                        <i class="fa-solid fa-paper-plane" style="margin-right:6px;"></i>Chốt và gửi thu ngân
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const MIN_ROOM_TYPE_DAILY_PRICE = 150000;
const MIN_ROOM_TYPE_HOURLY_PRICE = 40000;

// ===== AUTO-DISMISS TOAST =====
setTimeout(() => {
    document.querySelectorAll('.toast-hotel .alert').forEach(el => {
        el.style.transition = 'opacity 0.5s';
        el.style.opacity = '0';
        setTimeout(() => el.closest('.toast-hotel')?.remove(), 500);
    });
}, 3500);

// ===== INTERACTIVE CAGE MAP =====
function escapeMapHtml(value) {
    return String(value ?? '').replace(/[&<>"']/g, char => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#039;'
    })[char]);
}

function formatMapDate(value) {
    if (!value) return 'Chưa xác định';
    return new Intl.DateTimeFormat('vi-VN', {
        day: '2-digit',
        month: '2-digit',
        year: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
    }).format(new Date(value));
}

function setMapText(id, value) {
    document.getElementById(id).textContent = value ?? '—';
}

const mapMaintenanceStatuses = ['Đang dọn dẹp', 'Bảo trì', 'Khóa'];

function updateMapMaintenanceReasonVisibility() {
    const status = document.getElementById('mapOperationalStatus')?.value;
    const reasonGroup = document.getElementById('mapMaintenanceReasonGroup');
    const reasonInput = document.getElementById('mapMaintenanceReason');
    if (!reasonGroup || !reasonInput) return;

    const needsReason = mapMaintenanceStatuses.includes(status);
    reasonGroup.style.display = needsReason ? 'block' : 'none';
    reasonInput.required = needsReason;
}

function openCageMapDetail(cageId) {
    fetch('/SpaServices/GetCageMapDetail?cageId=' + encodeURIComponent(cageId))
        .then(response => response.json())
        .then(data => {
            if (!data.success) {
                alert('Lỗi: ' + data.message);
                return;
            }

            const cage = data.cage;
            const room = cage.roomType;
            const booking = data.booking;

            document.getElementById('mapCurrentCageId').value = cage.cageId;
            document.getElementById('mapCurrentBookingId').value = booking?.hotelBookingId ?? '';
            setMapText('mapDetailTitle', 'Chi tiết chuồng ' + cage.cageId);
            setMapText('mapRoomStatus', booking ? 'Đang dùng' : cage.status);
            setMapText('mapRoomType', room.type);
            setMapText('mapRoomSize', `${room.size} · tối đa ${room.capacity} thú`);
            setMapText('mapFeedSchedule', cage.feedSchedule || 'Chưa thiết lập');
            setMapText('mapPortion', `${cage.portion || 0} g`);

            const amenities = [];
            if (room.hasAc) amenities.push('<span class="amenity-tag amenity-ac"><i class="fa-solid fa-wind"></i>A/C</span>');
            if (room.hasCamera) amenities.push('<span class="amenity-tag amenity-cam"><i class="fa-solid fa-camera"></i>Camera</span>');
            if (room.hasPremiumFood) amenities.push('<span class="amenity-tag amenity-food"><i class="fa-solid fa-star"></i>Thức ăn VIP</span>');
            document.getElementById('mapRoomAmenities').innerHTML = amenities.length
                ? amenities.join('')
                : '<span style="font-size:.72rem;color:#9E918B;">Không có thiết bị bổ sung.</span>';

            document.getElementById('mapPetPanel').style.display = booking ? 'block' : 'none';
            document.getElementById('mapMovePanel').style.display = booking ? 'block' : 'none';
            document.getElementById('mapStatusPanel').style.display = booking ? 'none' : 'block';

            if (booking) {
                setMapText('mapPetName', `${booking.pet.name} · ${booking.pet.species}`);
                setMapText('mapPetBreedAge', `${booking.pet.breed || 'Chưa rõ'} · ${booking.pet.age || 'Chưa rõ'}`);
                setMapText('mapPetWeight', `${booking.pet.weight} kg`);
                setMapText('mapPetPathology', booking.pet.pathology || 'Không ghi nhận');
                setMapText('mapCustomerName', booking.customer.fullName);
                setMapText('mapCustomerContact', [booking.customer.phone, booking.customer.email].filter(Boolean).join(' · '));
                setMapText('mapCheckInDate', formatMapDate(booking.checkInDate));
                setMapText('mapCheckOutDate', formatMapDate(booking.checkOutDate));

                const targetSelect = document.getElementById('mapTargetCage');
                targetSelect.innerHTML = '<option value="">— Chọn chuồng đích —</option>';
                data.availableDestinations.forEach(target => {
                    const option = document.createElement('option');
                    option.value = target.cageId;
                    option.textContent = `${target.cageId} · ${target.roomType} (${target.size})`;
                    targetSelect.appendChild(option);
                });
                document.getElementById('mapMoveButton').disabled = data.availableDestinations.length === 0;
            } else {
                document.getElementById('mapOperationalStatus').value =
                    ['Trống', 'Đang dọn dẹp', 'Bảo trì', 'Khóa'].includes(cage.status) ? cage.status : 'Trống';
            }

            const openMaintenanceLog = data.openMaintenanceLog;
            document.getElementById('mapMaintenanceReason').value = openMaintenanceLog?.reason || '';
            document.getElementById('mapMaintenanceNote').value = openMaintenanceLog?.note || '';
            updateMapMaintenanceReasonVisibility();

            const careLogs = data.careLogs || [];
            document.getElementById('mapCareLogs').innerHTML = careLogs.length
                ? careLogs.map(log =>
                    `<li><strong>${escapeMapHtml(log.status)}</strong> · ${escapeMapHtml(log.foodType)} ${escapeMapHtml(log.amount)}<br>` +
                    `<span style="color:#A0938C;">${escapeMapHtml(log.time)} · ${escapeMapHtml(log.staffName)}${log.note ? ' · ' + escapeMapHtml(log.note) : ''}</span></li>`
                ).join('')
                : '<li>Chưa có ghi nhận chăm sóc tại chuồng này.</li>';

            const addons = booking?.addons || [];
            document.getElementById('mapAddons').innerHTML = addons.length
                ? addons.map(addon =>
                    `<li><strong>${escapeMapHtml(addon.name)}</strong><span style="float:right;">${Number(addon.price).toLocaleString('vi-VN')}đ</span></li>`
                ).join('')
                : '<li>Không có dịch vụ bổ sung.</li>';

            const maintenanceHistory = data.maintenanceHistory || [];
            document.getElementById('mapMaintenanceHistory').innerHTML = maintenanceHistory.length
                ? maintenanceHistory.map(log => {
                    const finishedText = log.endedAt ? formatMapDate(log.endedAt) : 'Đang mở';
                    const actorText = [log.createdByName, log.endedByName ? 'kết thúc bởi ' + log.endedByName : '']
                        .filter(Boolean)
                        .join(' · ');
                    return `<li><strong>${escapeMapHtml(log.newStatus)}</strong>${log.isOpen ? '<span class="maintenance-log-badge">Đang mở</span>' : ''}<br>` +
                        `<span style="color:#A0938C;">${formatMapDate(log.startedAt)} → ${finishedText}${actorText ? ' · ' + escapeMapHtml(actorText) : ''}</span><br>` +
                        `<span>${escapeMapHtml(log.reason)}</span>${log.note ? `<br><span style="color:#A0938C;">Ghi chú: ${escapeMapHtml(log.note)}</span>` : ''}</li>`;
                }).join('')
                : '<li>Chưa có lịch sử bảo trì hoặc khóa phòng.</li>';

            new bootstrap.Modal(document.getElementById('cageMapDetailModal')).show();
        })
        .catch(() => alert('Không thể tải chi tiết chuồng. Vui lòng thử lại.'));
}

function movePetCage(bookingId, targetCageId) {
    if (!bookingId || !targetCageId) {
        alert('Vui lòng chọn chuồng đích.');
        return;
    }

    if (!confirm(`Chuyển thú cưng sang chuồng ${targetCageId}?`)) return;

    fetch('/SpaServices/MovePetCage', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': getAntiForgeryToken() },
        body: 'bookingId=' + encodeURIComponent(bookingId) + '&targetCageId=' + encodeURIComponent(targetCageId)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('Lỗi: ' + data.message);
        }
    })
    .catch(() => alert('Không thể chuyển chuồng. Vui lòng thử lại.'));
}

document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.cage-map-filter').forEach(button => {
        button.addEventListener('click', () => {
            document.querySelectorAll('.cage-map-filter').forEach(item => item.classList.remove('active'));
            button.classList.add('active');
            const filter = button.dataset.mapFilter;
            document.querySelectorAll('.cage-map-room').forEach(room => {
                room.classList.toggle('map-hidden', filter !== 'all' && room.dataset.mapStatus !== filter);
            });
        });
    });

    document.querySelectorAll('.cage-map-room[data-booking-id]:not([data-booking-id=""])').forEach(room => {
        room.addEventListener('dragstart', event => {
            event.dataTransfer.effectAllowed = 'move';
            event.dataTransfer.setData('text/plain', room.dataset.bookingId);
        });
    });

    document.querySelectorAll('.cage-map-room.status-empty').forEach(room => {
        room.addEventListener('dragover', event => {
            event.preventDefault();
            event.dataTransfer.dropEffect = 'move';
            room.classList.add('drag-target');
        });
        room.addEventListener('dragleave', () => room.classList.remove('drag-target'));
        room.addEventListener('drop', event => {
            event.preventDefault();
            room.classList.remove('drag-target');
            movePetCage(event.dataTransfer.getData('text/plain'), room.dataset.cageId);
        });
    });

    document.getElementById('mapMoveButton').addEventListener('click', () => {
        movePetCage(
            document.getElementById('mapCurrentBookingId').value,
            document.getElementById('mapTargetCage').value
        );
    });

    document.getElementById('mapOperationalStatus').addEventListener('change', updateMapMaintenanceReasonVisibility);

    document.getElementById('mapStatusButton').addEventListener('click', () => {
        const cageId = document.getElementById('mapCurrentCageId').value;
        const status = document.getElementById('mapOperationalStatus').value;
        const reason = document.getElementById('mapMaintenanceReason').value.trim();
        const note = document.getElementById('mapMaintenanceNote').value.trim();

        if (mapMaintenanceStatuses.includes(status) && reason.length < 5) {
            alert('Vui lòng nhập lý do ít nhất 5 ký tự trước khi dọn dẹp, bảo trì hoặc khóa phòng.');
            document.getElementById('mapMaintenanceReason').focus();
            return;
        }

        if (reason.length > 500) {
            alert('Lý do không được vượt quá 500 ký tự.');
            document.getElementById('mapMaintenanceReason').focus();
            return;
        }

        if (note.length > 1000) {
            alert('Ghi chú không được vượt quá 1000 ký tự.');
            document.getElementById('mapMaintenanceNote').focus();
            return;
        }

        if (!confirm(`Cập nhật chuồng ${cageId} sang trạng thái "${status}"?`)) return;

        const body = new URLSearchParams();
        body.set('cageId', cageId);
        body.set('status', status);
        body.set('reason', reason);
        body.set('note', note);

        fetch('/SpaServices/UpdateCageOperationalStatus', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': getAntiForgeryToken() },
            body: body.toString()
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert(data.message);
                location.reload();
            } else {
                alert('Lỗi: ' + data.message);
            }
        })
        .catch(() => alert('Không thể cập nhật trạng thái chuồng. Vui lòng thử lại.'));
    });
});

// ===== TAB SWITCHING =====
function switchTab(tabName, btn) {
    document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
    document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));
    document.getElementById('tabContent-' + tabName).classList.add('active');
    btn.classList.add('active');
}

// ===== RECEPTION: MEDICAL RECORD OR INITIAL HEALTH CHECK =====
let lookupTimer;
let pendingReceptionPetId = '';

function getReceptionMode() {
    return document.querySelector('input[name="receptionMode"]:checked')?.value || '';
}

function isMedicalRecordMode() {
    return getReceptionMode() === 'MedicalRecord';
}

function enableNewPetForm() {
    const form = document.getElementById('petNewForm');
    form.style.opacity = '1';
    form.style.pointerEvents = 'auto';
}

function hideMedicalRecordSummary() {
    const summary = document.getElementById('medicalRecordSummary');
    summary.replaceChildren();
    summary.classList.remove('visible');
}

function setReceptionModeHint(message, type = 'info') {
    const hint = document.getElementById('receptionModeHint');
    hint.innerHTML = '';
    const icon = document.createElement('i');
    icon.className = type === 'error' ? 'fa-solid fa-triangle-exclamation' : 'fa-solid fa-circle-info';
    hint.append(icon, document.createTextNode(' ' + message));
}

function resetPetSelection() {
    const select = document.getElementById('ci-existingPet');
    select.value = '';
    document.getElementById('ci-existingPetHidden').value = '';
    enableNewPetForm();
    hideMedicalRecordSummary();
}

function clearOnlineReceptionContext() {
    const form = document.getElementById('checkInForm');
    const token = form.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    form.reset();
    const tokenInput = form.querySelector('input[name="__RequestVerificationToken"]');
    if (tokenInput) tokenInput.value = token;

    pendingReceptionPetId = '';
    document.getElementById('ci-hotelBookingId').value = '';
    document.getElementById('ci-existingPetHidden').value = '';
    document.getElementById('existingPetGroup').style.display = 'none';
    document.getElementById('ci-cage').innerHTML = '<option value="">— Chọn loại chuồng trước —</option>';
    document.getElementById('pricePreview').style.display = 'none';
    enableNewPetForm();
    hideMedicalRecordSummary();
    resetHealthCheckFields();

    const nowValue = formatDateTimeLocal(new Date());
    const checkInInput = document.getElementById('ci-checkIn');
    const checkOutInput = document.getElementById('ci-checkOut');
    checkInInput.value = nowValue;
    checkInInput.max = nowValue;
    checkOutInput.value = '';
    checkOutInput.min = nowValue;

    setReceptionModeHint('Chọn hình thức trước khi tra cứu thú cưng.');
}

function resetHealthCheckFields() {
    document.getElementById('ci-healthStatus').value = '';
    document.getElementById('ci-temperature').value = '';
    document.getElementById('ci-healthNote').value = '';
    document.getElementById('ci-healthConfirmed').checked = false;
    document.getElementById('healthStatusMessage').style.display = 'none';
    document.getElementById('healthStatusMessage').innerHTML = '';
}

function startOnlineReception(button) {
    const data = button.dataset;
    pendingReceptionPetId = data.petId || '';

    document.getElementById('ci-hotelBookingId').value = data.bookingId || '';
    document.getElementById('ci-phone').value = data.customerPhone || '';
    document.getElementById('ci-customerName').value = data.customerName || '';
    document.getElementById('ci-petName').value = data.petName || '';
    document.getElementById('ci-species').value = data.petSpecies || 'Chó';
    document.getElementById('ci-breed').value = data.petBreed || '';
    document.getElementById('ci-age').value = data.petAge || '';
    document.getElementById('ci-weight').value = data.petWeight || '';
    document.getElementById('ci-pathology').value = data.petPathology || '';
    resetHealthCheckFields();

    const modeInput = data.hasMedicalRecord === 'true'
        ? document.getElementById('ci-mode-medical')
        : document.getElementById('ci-mode-new');
    modeInput.checked = true;
    setReceptionMode();
    document.getElementById('ci-existingPetHidden').value = data.petId || '';

    const nowValue = formatDateTimeLocal(new Date());
    document.getElementById('ci-checkIn').value = nowValue;
    document.getElementById('ci-checkOut').value = data.checkOut || '';

    if (data.roomTypeId) {
        document.getElementById('ci-roomType').value = data.roomTypeId;
        loadAvailableCages(data.roomTypeId, data.cageId);
    }

    setReceptionModeHint('Đang tiếp nhận từ lịch đặt online. Vui lòng kiểm tra sức khỏe thực tế rồi xác nhận vào chuồng.');
}

function cancelOnlineReception(button) {
    const bookingId = button.dataset.bookingId;
    const petName = button.dataset.petName || 'thú cưng';
    if (!bookingId) return;

    if (!confirm(`Hủy lịch đặt online của ${petName}? Lịch này sẽ không còn chờ tiếp nhận.`)) {
        return;
    }

    fetch('/SpaServices/CancelOnlineHotelBooking', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'RequestVerificationToken': getAntiForgeryToken()
        },
        body: 'bookingId=' + encodeURIComponent(bookingId)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert(data.message);
            location.reload();
        } else {
            alert('Lỗi: ' + data.message);
        }
    })
    .catch(() => alert('Không thể hủy lịch đặt online. Vui lòng thử lại.'));
}

function setReceptionMode() {
    const mode = getReceptionMode();
    const isMedicalMode = mode === 'MedicalRecord';
    const select = document.getElementById('ci-existingPet');
    const label = document.getElementById('existingPetLabel');
    const help = document.getElementById('existingPetHelp');

    select.required = isMedicalMode;
    label.textContent = isMedicalMode
        ? 'Chọn thú cưng có sổ y tế'
        : 'Chọn thú cưng chưa có sổ y tế hoặc tạo hồ sơ mới';
    help.textContent = isMedicalMode
        ? 'Chỉ hiển thị thú cưng đã có sổ y tế trên hệ thống.'
        : 'Lần tiếp nhận này sẽ tạo bản ghi y tế đầu tiên cho thú cưng được chọn hoặc thú cưng mới.';
    setReceptionModeHint(isMedicalMode
        ? 'Thông tin sổ y tế chỉ dùng để đối chiếu. Kiểm tra thực tế vẫn là bắt buộc.'
        : 'Hệ thống sẽ lưu kết quả kiểm tra này thành bản ghi y tế đầu tiên.');

    resetPetSelection();
    const phone = document.getElementById('ci-phone').value;
    if (phone.replace(/\D/g, '').length >= 10) {
        lookupCustomer(phone);
    }
}

function populateExistingPets(pets) {
    if (!getReceptionMode()) {
        document.getElementById('existingPetGroup').style.display = 'none';
        return;
    }

    const isMedicalMode = isMedicalRecordMode();
    const select = document.getElementById('ci-existingPet');
    const group = document.getElementById('existingPetGroup');
    const help = document.getElementById('existingPetHelp');
    const eligiblePets = isMedicalMode
        ? pets.filter(p => p.hasMedicalRecord)
        : pets.filter(p => !p.hasMedicalRecord);

    select.replaceChildren();
    const initialOption = document.createElement('option');
    initialOption.value = '';
    initialOption.textContent = isMedicalMode
        ? (eligiblePets.length ? '— Chọn thú cưng có sổ y tế —' : '— Không có thú cưng có sổ y tế —')
        : '— Tạo hồ sơ thú cưng mới —';
    select.appendChild(initialOption);

    eligiblePets.forEach(p => {
        const option = document.createElement('option');
        option.value = p.petId;
        option.textContent = `${p.name} (${p.species})`;
        option.dataset.name = p.name;
        option.dataset.species = p.species;
        option.dataset.breed = p.breed;
        option.dataset.age = p.age;
        option.dataset.weight = p.weight;
        option.dataset.pathology = p.pathology;
        option.dataset.hasMedicalRecord = p.hasMedicalRecord ? 'true' : 'false';
        select.appendChild(option);
    });

    select.required = isMedicalMode;
    group.style.display = (eligiblePets.length > 0 || isMedicalMode) ? 'block' : 'none';
    if (isMedicalMode && !eligiblePets.length) {
        help.textContent = 'Khách này chưa có thú cưng nào có sổ y tế. Hãy chuyển sang luồng chưa có sổ y tế.';
    }

    if (pendingReceptionPetId) {
        const selectedPetId = pendingReceptionPetId;
        pendingReceptionPetId = '';
        const matchingOption = Array.from(select.options).find(option => option.value === selectedPetId);
        if (matchingOption) {
            select.value = selectedPetId;
            fillExistingPet(select);
        } else {
            setReceptionModeHint('Thú cưng trong lịch online không khớp với hình thức tiếp nhận đã chọn.', 'error');
        }
    }
}

function lookupCustomer(phone) {
    clearTimeout(lookupTimer);
    const normalizedPhone = phone.replace(/\D/g, '');
    if (normalizedPhone.length < 10) {
        document.getElementById('existingPetGroup').style.display = 'none';
        document.getElementById('ci-customerName').value = '';
        resetPetSelection();
        return;
    }

    lookupTimer = setTimeout(() => {
        const customers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(customers.Select(c => new { c.CustomerId, c.FullName, c.Phone })));
        const found = customers.find(c => (c.phone || '').replace(/\D/g, '') === normalizedPhone);
        if (!found) {
            document.getElementById('existingPetGroup').style.display = 'none';
            resetPetSelection();
            return;
        }

        document.getElementById('ci-customerName').value = found.fullName;
        fetch('/SpaServices/GetHotelPetsByCustomer?customerId=' + encodeURIComponent(found.customerId))
            .then(response => response.ok ? response.json() : Promise.reject())
            .then(populateExistingPets)
            .catch(() => setReceptionModeHint('Không thể tải hồ sơ thú cưng của khách. Vui lòng thử lại.', 'error'));
    }, 400);
}

function renderMedicalRecordSummary(record) {
    const summary = document.getElementById('medicalRecordSummary');
    summary.replaceChildren();

    const title = document.createElement('strong');
    title.textContent = 'Sổ y tế gần nhất';
    summary.appendChild(title);

    const fields = [
        ['Ngày ghi nhận', record.dateCreated],
        ['Tình trạng', record.healthStatus],
        ['Triệu chứng / bệnh lý', record.symptoms],
        ['Tiêm phòng', record.vaccinationStatus],
        ['Kiểm tra thể chất', record.physicalCheck]
    ];
    fields.forEach(([label, value]) => {
        const line = document.createElement('div');
        line.textContent = `${label}: ${value || 'Chưa ghi nhận'}`;
        summary.appendChild(line);
    });
    summary.classList.add('visible');
}

function loadMedicalRecordSummary(petId) {
    hideMedicalRecordSummary();
    fetch('/SpaServices/GetPetMedicalSummary?petId=' + encodeURIComponent(petId))
        .then(response => response.ok ? response.json() : Promise.reject())
        .then(result => renderMedicalRecordSummary(result.record))
        .catch(() => setReceptionModeHint('Không đọc được sổ y tế của thú cưng. Vui lòng đổi sang luồng chưa có sổ y tế.', 'error'));
}

function fillExistingPet(select) {
    const opt = select.options[select.selectedIndex];
    const hidden = document.getElementById('ci-existingPetHidden');
    if (!opt.value) {
        hidden.value = '';
        enableNewPetForm();
        hideMedicalRecordSummary();
        return;
    }

    const hasMedicalRecord = opt.dataset.hasMedicalRecord === 'true';
    if ((isMedicalRecordMode() && !hasMedicalRecord) || (!isMedicalRecordMode() && hasMedicalRecord)) {
        select.value = '';
        hidden.value = '';
        enableNewPetForm();
        hideMedicalRecordSummary();
        setReceptionModeHint('Lựa chọn thú cưng không khớp với hình thức tiếp nhận.', 'error');
        return;
    }

    hidden.value = opt.value;
    document.getElementById('ci-petName').value = opt.dataset.name || '';
    document.getElementById('ci-species').value = opt.dataset.species || 'Chó';
    document.getElementById('ci-breed').value = opt.dataset.breed || '';
    document.getElementById('ci-age').value = opt.dataset.age || '';
    document.getElementById('ci-weight').value = opt.dataset.weight || '';
    document.getElementById('ci-pathology').value = opt.dataset.pathology || '';
    const form = document.getElementById('petNewForm');
    form.style.opacity = '0.7';
    form.style.pointerEvents = 'none';

    if (isMedicalRecordMode()) {
        loadMedicalRecordSummary(opt.value);
    } else {
        hideMedicalRecordSummary();
    }
}

// ===== HEALTH CHECK VALIDATION =====
function updateHealthStatus() {
    const status = document.getElementById('ci-healthStatus').value;
    const pathology = document.getElementById('ci-pathology');
    const message = document.getElementById('healthStatusMessage');

    pathology.setCustomValidity('');
    if (status === 'Monitor' && !pathology.value.trim()) {
        pathology.setCustomValidity('Vui lòng ghi rõ tình trạng cần theo dõi.');
    }

    if (status === 'Rejected') {
        message.style.display = 'flex';
        message.innerHTML = '<i class="fa-solid fa-ban"></i> Kết luận này sẽ bị hệ thống chặn, không thể nhận thú cưng vào chuồng.';
    } else {
        message.style.display = 'none';
        message.innerHTML = '';
    }
}

document.getElementById('ci-pathology').addEventListener('input', updateHealthStatus);

function formatDateTimeLocal(date) {
    const localDate = new Date(date.getTime() - date.getTimezoneOffset() * 60000);
    return localDate.toISOString().slice(0, 16);
}

function validateStayDates() {
    const checkInInput = document.getElementById('ci-checkIn');
    const checkOutInput = document.getElementById('ci-checkOut');
    const checkIn = checkInInput.value;
    const checkOut = checkOutInput.value;
    const now = new Date();

    checkInInput.setCustomValidity('');
    checkOutInput.setCustomValidity('');
    checkInInput.max = formatDateTimeLocal(now);
    if (checkIn) {
        checkOutInput.min = checkIn;
    }

    if (checkIn) {
        const checkInDate = new Date(checkIn);
        if (checkInDate > now) {
            checkInInput.setCustomValidity('Ngày nhận chuồng không được sau thời điểm hiện tại.');
        }
    }

    if (checkIn && checkOut) {
        const checkInDate = new Date(checkIn);
        const checkOutDate = new Date(checkOut);
        const stayDays = (checkOutDate - checkInDate) / (1000 * 60 * 60 * 24);

        if (checkOutDate < checkInDate) {
            checkOutInput.setCustomValidity('Ngày trả dự kiến không được trước ngày nhận.');
        } else if (stayDays > 365) {
            checkOutInput.setCustomValidity('Thời gian lưu trú dự kiến không được vượt quá 365 ngày.');
        }
    }

    return checkInInput.validity.valid && checkOutInput.validity.valid;
}

document.getElementById('checkInForm').addEventListener('submit', event => {
    updateHealthStatus();
    validateStayDates();

    const receptionMode = getReceptionMode();
    const healthStatus = document.getElementById('ci-healthStatus').value;

    if (receptionMode === 'MedicalRecord' && !document.getElementById('ci-existingPetHidden').value) {
        event.preventDefault();
        setReceptionModeHint('Tiếp nhận bằng sổ y tế yêu cầu chọn thú cưng đã có sổ y tế.', 'error');
        document.getElementById('ci-existingPet').focus();
        return;
    }

    if (healthStatus === 'Rejected') {
        event.preventDefault();
        alert('Thú cưng không đủ điều kiện lưu trú nên không thể nhận vào chuồng.');
        return;
    }

    if (!event.currentTarget.checkValidity()) {
        event.preventDefault();
        event.currentTarget.reportValidity();
    }
});

// ===== LOAD AVAILABLE CAGES =====
function loadAvailableCages(roomTypeId, selectedCageId = '') {
    const sel = document.getElementById('ci-cage');
    sel.innerHTML = '<option value="">Đang tải...</option>';
    if (!roomTypeId) {
        sel.innerHTML = '<option value="">— Chọn loại chuồng trước —</option>';
        return Promise.resolve();
    }
    return fetch('/SpaServices/GetAvailableCages?roomTypeId=' + roomTypeId)
        .then(r => r.json())
        .then(cages => {
            if (!cages.length) {
                sel.innerHTML = '<option value="">Không có chuồng trống</option>';
                return;
            }
            sel.innerHTML = '<option value="">— Chọn chuồng —</option>';
            cages.forEach(c => {
                sel.innerHTML += `<option value="${c.cageId}">${c.cageId}</option>`;
            });
            if (selectedCageId) {
                const targetOption = Array.from(sel.options).find(option => option.value === selectedCageId);
                if (targetOption) {
                    sel.value = selectedCageId;
                } else {
                    setReceptionModeHint('Chuồng đã giữ trong lịch online hiện không còn trống. Vui lòng kiểm tra lại sơ đồ chuồng.', 'error');
                }
            }
            calcStay();
        });
}

// ===== CALC STAY & PREVIEW PRICE =====
function calcStay() {
    const checkIn = document.getElementById('ci-checkIn').value;
    const checkOut = document.getElementById('ci-checkOut').value;
    const roomSel = document.getElementById('ci-roomType');
    const pricePreview = document.getElementById('pricePreview');
    const priceVal = document.getElementById('pricePreviewValue');
    const priceDet = document.getElementById('pricePreviewDetail');

    if (!checkIn || !checkOut || !roomSel.value) {
        pricePreview.style.display = 'none';
        return;
    }

    const opt = roomSel.options[roomSel.selectedIndex];
    const dailyPrice = parseFloat(opt?.dataset?.price || '0');
    const d1 = new Date(checkIn);
    const d2 = new Date(checkOut);
    if (!validateStayDates() || d2 < d1) {
        pricePreview.style.display = 'none';
        return;
    }

    const diffDays = Math.max(1, Math.ceil((d2 - d1) / (1000 * 60 * 60 * 24)));

    const total = dailyPrice * diffDays;
    priceVal.textContent = total.toLocaleString('vi-VN') + 'đ';
    priceDet.textContent = `${diffDays} ngày × ${dailyPrice.toLocaleString('vi-VN')}đ/ngày`;
    pricePreview.style.display = 'block';
}

// ===== SET DEFAULT CHECK-IN DATE =====
document.addEventListener('DOMContentLoaded', () => {
    const checkInInput = document.getElementById('ci-checkIn');
    const checkOutInput = document.getElementById('ci-checkOut');
    const nowValue = formatDateTimeLocal(new Date());
    checkInInput.max = nowValue;
    if (!checkInInput.value || new Date(checkInInput.value) > new Date()) {
        checkInInput.value = nowValue;
    }
    checkOutInput.min = checkInInput.value;
    checkInInput.addEventListener('input', calcStay);
    checkOutInput.addEventListener('input', calcStay);
    validateStayDates();
});

// ===== TOGGLE ROOM TYPE =====
function toggleRoomType(id, checkbox) {
    fetch('/SpaServices/ToggleRoomType', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': getAntiForgeryToken() },
        body: 'id=' + id
    })
    .then(r => r.json())
    .then(data => {
        if (!data.success) {
            checkbox.checked = !checkbox.checked;
            alert('Lỗi: ' + data.message);
        }
    });
}

// ===== OPEN EDIT ROOM TYPE =====
function openEditRoomType(id, type, size, capacity, hourly, daily, hasAc, hasCam, hasFood) {
    document.getElementById('edit-rt-id').value = id;
    document.getElementById('edit-rt-type').value = type;
    document.getElementById('edit-rt-capacity').value = capacity;
    document.getElementById('edit-rt-daily').value = daily;
    document.getElementById('edit-rt-hourly').value = hourly;
    document.getElementById('edit-rt-ac').checked = hasAc === true || hasAc === 'true';
    document.getElementById('edit-rt-cam').checked = hasCam === true || hasCam === 'true';
    document.getElementById('edit-rt-food').checked = hasFood === true || hasFood === 'true';
    // Set size dropdown
    const sizeSel = document.getElementById('edit-rt-size');
    for (let i = 0; i < sizeSel.options.length; i++) {
        if (sizeSel.options[i].value === size) { sizeSel.selectedIndex = i; break; }
    }
    new bootstrap.Modal(document.getElementById('editRoomTypeModal')).show();
}

function validateRoomTypePriceForm(form) {
    const dailyInput = form.querySelector('[name="dailyPrice"]');
    const hourlyInput = form.querySelector('[name="hourlyPrice"]');

    if (!dailyInput || !hourlyInput) return true;

    dailyInput.setCustomValidity('');
    hourlyInput.setCustomValidity('');

    const dailyPrice = Number(dailyInput.value);
    const hourlyPrice = Number(hourlyInput.value);

    if (dailyInput.value && dailyPrice < MIN_ROOM_TYPE_DAILY_PRICE) {
        dailyInput.setCustomValidity('Giá theo ngày không được thấp hơn 150.000đ.');
    }

    if (hourlyInput.value && hourlyPrice < MIN_ROOM_TYPE_HOURLY_PRICE) {
        hourlyInput.setCustomValidity('Giá theo giờ không được thấp hơn 40.000đ.');
    }

    return dailyInput.validity.valid && hourlyInput.validity.valid;
}

document.querySelectorAll('.room-type-form').forEach(form => {
    const priceInputs = form.querySelectorAll('[name="dailyPrice"], [name="hourlyPrice"]');
    priceInputs.forEach(input => {
        input.addEventListener('input', () => validateRoomTypePriceForm(form));
    });

    form.addEventListener('submit', event => {
        if (!validateRoomTypePriceForm(form) || !form.checkValidity()) {
            event.preventDefault();
            form.reportValidity();
        }
    });
});

// ===== DELETE ROOM TYPE =====
function deleteRoomType(id, name) {
    if (!confirm(`Xóa loại chuồng "${name}"?\nNếu có chuồng đang dùng, hệ thống sẽ tự động chuyển sang Ngưng hoạt động.`)) return;
    fetch('/SpaServices/DeleteRoomType', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': getAntiForgeryToken() },
        body: 'id=' + id
    })
    .then(r => r.json())
    .then(data => {
        if (data.success) { location.reload(); }
        else { alert('Lỗi: ' + data.message); }
    });
}

// ===== OPEN EDIT CAGE =====
function openEditCage(cageId, roomTypeId, feedSchedule, portion) {
    document.getElementById('edit-cage-id').value = cageId;
    document.getElementById('edit-cage-feed').value = feedSchedule;
    document.getElementById('edit-cage-portion').value = portion;
    const rtSel = document.getElementById('edit-cage-roomtype');
    for (let i = 0; i < rtSel.options.length; i++) {
        if (parseInt(rtSel.options[i].value) === roomTypeId) { rtSel.selectedIndex = i; break; }
    }
    new bootstrap.Modal(document.getElementById('editCageModal')).show();
}

// ===== DELETE CAGE =====
function deleteCage(cageId) {
    if (!confirm(`Xóa chuồng "${cageId}"?`)) return;
    fetch('/SpaServices/DeleteCage', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': getAntiForgeryToken() },
        body: 'cageId=' + encodeURIComponent(cageId)
    })
    .then(r => r.json())
    .then(data => {
        if (data.success) { location.reload(); }
        else { alert('❌ ' + data.message); }
    });
}

// ===== CONFIRM CHECK-OUT =====
let checkoutBookingId = null;
let checkoutCanFinalize = false;
function confirmCheckout(bookingId, petName, cageId) {
    checkoutBookingId = bookingId;
    document.getElementById('checkoutPetName').textContent = petName;
    document.getElementById('checkoutCageId').textContent = 'Chuồng ' + cageId;
    document.getElementById('checkoutLoading').hidden = false;
    document.getElementById('checkoutCostContent').hidden = true;
    const modal = new bootstrap.Modal(document.getElementById('checkOutModal'));
    modal.show();
    fetch('/SpaServices/HotelCheckoutPreview/' + bookingId)
        .then(r => r.json())
        .then(result => {
            if (!result.success) throw new Error(result.message);
            renderCheckoutPreview(result.data);
        })
        .catch(error => {
            document.getElementById('checkoutLoading').textContent = error.message || 'Không thể tính chi phí.';
        });
}

function renderCheckoutPreview(data) {
    const format = value => Number(value || 0).toLocaleString('vi-VN') + 'đ';
    document.getElementById('checkoutLoading').hidden = true;
    document.getElementById('checkoutCostContent').hidden = false;
    document.getElementById('checkoutCostItems').innerHTML = (data.items || []).map(item =>
        `<div style="display:flex;justify-content:space-between;gap:12px;font-size:0.82rem;"><span>${escapeMapHtml(item.description)}</span><strong>${format(item.amount)}</strong></div>`
    ).join('');
    document.getElementById('checkoutDiscount').textContent = '-' + format(data.discountAmount);
    document.getElementById('checkoutTotal').textContent = format(data.totalAmount);
    checkoutCanFinalize = data.canFinalize === true;
    const button = document.getElementById('confirmCheckoutBtn');
    const otherFields = document.getElementById('checkoutOtherFields');
    if (checkoutCanFinalize) {
        button.innerHTML = '<i class="fa-solid fa-check"></i> Hoàn tất trả pet';
        otherFields.hidden = true;
        document.getElementById('checkoutPaymentStatus').textContent = `Hóa đơn ${data.orderId} đã sẵn sàng hoàn tất.`;
    } else {
        button.innerHTML = '<i class="fa-solid fa-paper-plane"></i> Chốt và gửi thu ngân';
        otherFields.hidden = data.orderId != null;
        document.getElementById('checkoutPaymentStatus').textContent = data.orderId
            ? `Đã gắn hóa đơn ${data.orderId} · trạng thái ${data.orderStatus || 'chờ thanh toán'}.`
            : data.statementStatus === 'ReadyForPayment' ? 'Bảng kê đang chờ thu ngân.' : 'Kiểm tra chi phí trước khi gửi.';
    }
}

document.getElementById('confirmCheckoutBtn').addEventListener('click', () => {
    if (!checkoutBookingId) return;
    const endpoint = checkoutCanFinalize ? '/SpaServices/CheckOut' : '/SpaServices/PrepareHotelCheckout';
    const body = checkoutCanFinalize
        ? 'bookingId=' + checkoutBookingId
        : new URLSearchParams({
            HotelBookingId: checkoutBookingId,
            OtherDescription: document.getElementById('checkoutOtherDescription').value,
            OtherAmount: document.getElementById('checkoutOtherAmount').value || '0'
        }).toString();
    fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': getAntiForgeryToken() },
        body
    })
    .then(r => r.json())
    .then(data => {
        if (data.success) { location.reload(); }
        else { alert('Lỗi: ' + data.message); }
    });
});

// ===== ANTI-FORGERY TOKEN HELPER =====
function getAntiForgeryToken() {
    return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
}
