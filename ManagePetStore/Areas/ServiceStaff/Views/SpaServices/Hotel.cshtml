                                <input type="checkbox" name="hasCamera" value="true">
                                <span>📹 Camera theo dõi</span>
                            </label>
                            <label class="amenity-checkbox-item">
                                <input type="checkbox" name="hasPremiumFood" value="true">
                                <span>⭐ Thức ăn cao cấp</span>
                            </label>
                        </div>
                        <!-- Hidden fields for unchecked boxes -->
                        <input type="hidden" name="hasAc" value="false">
                        <input type="hidden" name="hasCamera" value="false">
                        <input type="hidden" name="hasPremiumFood" value="false">
                    </div>

                    <div class="modal-btn-row">
                        <button type="button" class="btn-modal-cancel" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn-modal-submit">
                            <i class="fa-solid fa-plus" style="margin-right:6px;"></i>Thêm loại chuồng
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

